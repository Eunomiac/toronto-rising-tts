{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: Module tooling (gate + generated Lua + UI XML templates)",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Build: TTS MCP (Node)",
      "type": "shell",
      "command": "npm run tts-mcp:build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Generate PCS data (pcs_data.ttslua from JSON)",
      "type": "shell",
      "command": "node",
      "args": [
        ".dev/scripts/generate_pcs_data_lua.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Fix TTS object stubs (.tts/objects XML + Lua)",
      "type": "shell",
      "command": "node",
      "args": [
        ".dev/scripts/fix_tts_object_stubs.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "none",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Generate CSheet defaults Lua (csheet_defaults_xml.ttslua)",
      "type": "shell",
      "command": "node",
      "args": [
        ".dev/scripts/generate_csheet_defaults_lua.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Generate UI XML from templates",
      "type": "shell",
      "command": "node",
      "args": [
        ".dev/scripts/xml_color_template_generator.js",
        "--templateDir",
        "ui/.templates"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Generate NPC panel XML from npcs_data",
      "type": "shell",
      "command": "node",
      "args": [
        ".dev/scripts/generate_npc_panel_xml.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Custom UI Assets: Full Pipeline (Build -> Pause -> Merge)",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/run-custom-ui-assets-pipeline.js",
        "--input",
        "${input:customUiAssetsImageFolder}",
        "--saveName",
        "${input:customUiAssetsSaveName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Custom UI Assets: Build Manifest from Image Files",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/build-manifest-from-task.js",
        "--mode",
        "${input:customUiManifestMode}",
        "--input",
        "${input:customUiAssetsImageFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Custom UI Assets: Merge Hosted URLs into Save CustomUIAssets",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/merge-custom-ui-assets-from-save-name.js",
        "--saveName",
        "${input:customUiAssetsSaveName}",
        "--manifest",
        ".dev/custom-ui-assets/manifest.json",
        "--assetsOut",
        ".dev/custom-ui-assets/generated-assets.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Custom UI Assets: List Custom UI Assets in Save",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/list-custom-ui-assets-from-save-name.js",
        "--saveName",
        "${input:customUiAssetsSaveName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Custom UI Assets: Prune Custom UI Assets in Save",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/prune-custom-ui-assets-from-save-name.js",
        "--saveName",
        "${input:customUiAssetsSaveName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "Custom UI Assets: TTS Image Cache Clear",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/custom-ui-assets/clear-tts-image-cache.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    },
    {
      "label": "TTS: Inject Bundled Global into Save JSON",
      "type": "shell",
      "command": "node",
      "args": [
        ".tools/tts-save/inject-bundled-global-from-save-name.js",
        "--saveName",
        "${input:ttsSaveName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    }
  ],
  "inputs": [
    {
      "id": "customUiManifestMode",
      "type": "pickString",
      "description": "Manifest source: folder (WEBP/PNG) or C.Sites in lib/constants.ttslua (see Terminal for steps)",
      "options": [
        "folder",
        "sites"
      ],
      "default": "folder"
    },
    {
      "id": "customUiAssetsImageFolder",
      "type": "promptString",
      "description": "Relative image folder (folder mode only; ignored for sites — you can keep the default)",
      "default": "assets\\images\\new_images"
    },
    {
      "id": "customUiAssetsSaveName",
      "type": "promptString",
      "description": "TTS save name or number (examples: 123, TS_Save_123, TS_Save_123.json)",
      "default": "TS_Save_"
    },
    {
      "id": "ttsSaveName",
      "type": "promptString",
      "description": "TTS save slot to patch (examples: 123, TS_Save_123). Requires .tts/bundled/Global.lua + Global.xml first.",
      "default": "TS_Save_"
    }
  ]
}
