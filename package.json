{
  "name": "toronto-rising-tts",
  "version": "1.0.0",
  "description": "Tabletop Simulator LUA modding project",
  "scripts": {
    "custom-ui-assets:manifest": "node .tools/custom-ui-assets/build-upload-manifest.js",
    "custom-ui-assets:merge": "node .tools/custom-ui-assets/merge-custom-ui-assets.js",
    "tts-bridge:build": "tsc -p .tools/tts-bridge/tsconfig.build.json",
    "tts-bridge:test": "vitest run --config .tools/tts-bridge/vitest.config.ts",
    "tts-bridge:run-sequence-test": "npm run tts-bridge:build && node .tools/tts-bridge/scripts/run-sequence-live-test.mjs",
    "tts-bridge:run-easing-mcp-test": "npm run tts-bridge:build && node .tools/tts-bridge/scripts/run-easing-mcp-test.mjs --only-easing",
    "tts-mcp:build": "npm run tts-bridge:build && tsc -p .tools/tts-mcp/tsconfig.json",
    "tts-mcp:start": "node .tools/tts-mcp/dist/index.js",
    "tts:smoke": "node .tools/tts-bridge/scripts/smoke-test.mjs",
    "code-review:build": "tsc -p .tools/code-review/tsconfig.build.json",
    "code-review:test": "vitest run --config .tools/code-review/vitest.config.ts",
    "code-review:validate": "npm run code-review:build && node .tools/code-review/dist/cli.js validate",
    "code-review:help": "npm run code-review:build && node .tools/code-review/dist/cli.js help",
    "tts-bridge:listen": "npm run tts-bridge:build && node .tools/tts-bridge/dist/listen.js"
  },
  "keywords": [
    "tabletop-simulator",
    "lua",
    "modding"
  ],
  "author": "",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "luaparse": "^0.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eunomiac/toronto-rising-tts.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Eunomiac/toronto-rising-tts/issues"
  },
  "homepage": "https://github.com/Eunomiac/toronto-rising-tts#readme"
}
