{
  "name": "toronto-rising-tts",
  "version": "1.0.0",
  "description": "Tabletop Simulator LUA modding project",
  "scripts": {
    "check:pcall-gate": "node .tools/pcall-gate/check-pcall-gate.mjs",
    "check:effective-stats-gate": "node .tools/effective-stats-gate/check-effective-stats-gate.mjs",
    "check:tts-object-stub-guids": "node .tools/tts-object-stubs-gate/check-tts-object-stub-guids.mjs",
    "csheet-defaults:generate": "node .dev/scripts/generate_csheet_defaults_lua.js",
    "npc-control-board-ui:generate": "node .dev/scripts/generate_npc_control_board_ui_lua.js",
    "npc-placements:migrate-byarea": "node .dev/scripts/migrate_npc_byarea_to_placements.mjs",
    "e2e-playbook:generate": "node .dev/scripts/generate_e2e_playbook_lua.js --campaign Dice",
    "e2e-playbook:generate:test": "node .dev/scripts/generate_e2e_playbook_lua.test.js",
    "ui-xml-templates:embed": "node .dev/scripts/embed_ui_xml_templates.js",
    "roll-dashboard:generate": "node .dev/scripts/generate_roll_dashboard_xml.js",
    "tts-objects:fix-stubs": "node .dev/scripts/fix_tts_object_stubs.js",
    "csheet-objects:fix-includes": "npm run tts-objects:fix-stubs",
    "custom-ui-assets:manifest": "node .tools/custom-ui-assets/build-upload-manifest.js",
    "custom-ui-assets:manifest-sites": "node .tools/custom-ui-assets/build-upload-manifest-from-sites-constants.js --constants lib/constants.ttslua --out .dev/custom-ui-assets/manifest.json --luaOut .dev/custom-ui-assets/manifest.lua --moduleOut lib/custom_ui_upload_manifest.ttslua",
    "custom-ui-assets:manifest-sites:batch": "node .tools/custom-ui-assets/build-upload-manifest-from-sites-constants.js --constants lib/constants.ttslua --batch --out .dev/custom-ui-assets/manifest.json --luaOut .dev/custom-ui-assets/manifest.lua --moduleOut lib/custom_ui_upload_manifest.ttslua",
    "custom-ui-assets:manifest-npc-tokens": "node .tools/custom-ui-assets/build-upload-manifest-from-npc-tokens.js --out .dev/custom-ui-assets/npc-token-manifest.json --moduleOut lib/npc_token_upload_manifest.ttslua",
    "custom-ui-assets:manifest-npc-tokens:batch": "node .tools/custom-ui-assets/build-upload-manifest-from-npc-tokens.js --batch --out .dev/custom-ui-assets/npc-token-manifest.json --moduleOut lib/npc_token_upload_manifest.ttslua",
    "custom-ui-assets:manifest-npc-groups": "node .tools/custom-ui-assets/build-upload-manifest-from-npc-groups.js --save .dev/TS_Save_230.json --out .dev/custom-ui-assets/npc-group-manifest.json --moduleOut lib/npc_group_upload_manifest.ttslua",
    "custom-ui-assets:manifest-npc-groups:batch": "node .tools/custom-ui-assets/build-upload-manifest-from-npc-groups.js --batch --save .dev/TS_Save_230.json --out .dev/custom-ui-assets/npc-group-manifest.json --moduleOut lib/npc_group_upload_manifest.ttslua",
    "custom-ui-assets:merge-npc-groups": "node .tools/custom-ui-assets/merge-custom-ui-assets.js --save .dev/TS_Save_230.json --manifest .dev/custom-ui-assets/npc-group-manifest.json --assetsOut .dev/custom-ui-assets/npc-group-generated-assets.json",
    "custom-ui-assets:report-npc-registry-gaps": "node .tools/custom-ui-assets/report-npc-upload-registry-gaps.js --save .dev/TS_Save_230.json --manifest .dev/custom-ui-assets/npc-group-manifest.json",
    "custom-ui-assets:pipeline-npc-groups": "node .tools/custom-ui-assets/run-custom-ui-assets-pipeline.js --mode npc-groups --saveName 230",
    "custom-ui-assets:extract-npc-token-urls": "node .tools/custom-ui-assets/extract-npc-token-hosted-urls.js",
    "custom-ui-assets:patch-npc-token-urls-in-save": "node .tools/custom-ui-assets/patch-npc-token-local-urls-in-save.js --save .dev/TS_Save_230.json",
    "custom-ui-assets:patch-npc-token-urls-in-save:dry-run": "node .tools/custom-ui-assets/patch-npc-token-local-urls-in-save.js --save .dev/TS_Save_230.json --dry-run",
    "custom-ui-assets:merge-npc-tokens": "node .tools/custom-ui-assets/merge-custom-ui-assets.js --save .dev/TS_Save_230.json --manifest .dev/custom-ui-assets/npc-token-manifest.json --assetsOut .dev/custom-ui-assets/npc-generated-assets.json",
    "custom-ui-assets:merge-npc-figurines": "node .tools/custom-ui-assets/merge-npc-figurine-images-into-save.js --save .dev/TS_Save_230.json",
    "custom-ui-assets:merge-npc-figurines:dry-run": "node .tools/custom-ui-assets/merge-npc-figurine-images-into-save.js --save .dev/TS_Save_230.json --dry-run",
    "custom-ui-assets:merge-npc-figurines:live": "node .tools/custom-ui-assets/merge-npc-figurine-images-into-save.js --saveName 230",
    "custom-ui-assets:pipeline": "node .tools/custom-ui-assets/run-custom-ui-assets-pipeline.js",
    "custom-ui-assets:merge": "node .tools/custom-ui-assets/merge-custom-ui-assets.js",
    "custom-ui-assets:extract-bp-decals": "node .tools/custom-ui-assets/extract-bp-decal-urls-from-save.js --save .dev/TS_Save_230.json --luaOut .dev/custom-ui-assets/bp-decal-urls.lua",
    "custom-ui-assets:merge-bp-decals-into-csheets": "node .tools/custom-ui-assets/merge-bp-decals-into-csheet-custom-ui-assets.js --save .dev/TS_Save_230.json",
    "custom-ui-assets:merge-object-assets": "node .tools/custom-ui-assets/merge-object-custom-ui-assets-from-json.js --save .dev/TS_Save_230.json --manifest lib/json/PC_Relationship_Images.json",
    "tts-save:extract-assets": "node .tools/tts-save/extract-categorize-save-assets.js --save .dev/TS_Save_230.json",
    "tts-save:extract-entities": "node .tools/tts-save/extract-save-entities.js --save .dev/TS_Save_230.json --outBasename save-entities-latest",
    "tts-save:list-loading-assets": "node .tools/tts-save/list-save-loading-assets.js --save .dev/TS_Save_230.json --outBasename save-loading-assets-latest",
    "tts-save:list-object-tags": "node .tools/tts-save/list-save-object-tags.js --save .dev/TS_Save_230.json --outBasename save-object-tags-latest",
    "tts-save:prune-component-tags": "node .tools/tts-save/prune-save-component-tags.js --save .dev/TS_Save_230.json --dryRun",
    "tts-save:prune-component-tags:apply": "node .tools/tts-save/prune-save-component-tags.js --save .dev/TS_Save_230.json",
    "tts-save:extract-save-inventory": "npm run tts-save:extract-assets -- --outBasename save-assets-latest && npm run tts-save:extract-entities",
    "tts-save:inject-global": "node .tools/tts-save/inject-bundled-global-from-save-name.js",
    "tts-save:measure-bundles": "node .tools/tts-save/measure-bundles.js",
    "tts-save:bundle-csheet-sample": "node .tools/tts-save/bundle-csheet-sample.js",
    "tts-save:migrate-seat-gmnotes:dry-run": "node .dev/scripts/migrate_seat_layout_gmnotes_save.js --dry-run --save .dev/TS_Save_230.json",
    "tts-save:migrate-seat-gmnotes": "node .dev/scripts/migrate_seat_layout_gmnotes_save.js --save .dev/TS_Save_230.json",
    "tts-save:migrate-seat-gmnotes:live": "node .dev/scripts/migrate_seat_layout_gmnotes_save.js --saveName 230",
    "tts-bridge:build": "tsc -p .tools/tts-bridge/tsconfig.build.json",
    "tts-bridge:test": "vitest run --config .tools/tts-bridge/vitest.config.ts",
    "tts-bridge:run-sequence-test": "npm run tts-bridge:build && node .tools/tts-bridge/scripts/run-sequence-live-test.mjs",
    "tts-mcp:compile": "tsc -p .tools/tts-mcp/tsconfig.json",
    "tts-mcp:build": "npm run tts-bridge:build && npm run tts-mcp:compile",
    "build:all-tooling": "npm run check:pcall-gate && npm run check:effective-stats-gate && node .dev/scripts/generate_pcs_data_lua.js && node .dev/scripts/generate_pc_relationships_lua.js && node .dev/scripts/generate_tr_weather_lua.js && npm run csheet-defaults:generate && npm run npc-control-board-ui:generate && npm run e2e-playbook:generate && npm run ui-xml-templates:embed && node .dev/scripts/xml_color_template_generator.js --templateDir ui/.templates && npm run roll-dashboard:generate && node .dev/scripts/generate_scenes_location_modals_xml.js && node .dev/scripts/fix_tts_object_stubs.js --quiet && npm run check:tts-object-stub-guids -- --quiet && npm run custom-ui-assets:merge-object-assets",
    "build": "npm run build:all-tooling",
    "tts-mcp:start": "node .tools/tts-mcp/scripts/start-manual.mjs",
    "tts:smoke": "node .tools/tts-bridge/scripts/smoke-test.mjs",
    "code-review:build": "tsc -p .tools/code-review/tsconfig.build.json",
    "code-review:test": "vitest run --config .tools/code-review/vitest.config.ts",
    "code-review:validate": "npm run code-review:build && node .tools/code-review/dist/cli.js validate",
    "code-review:help": "npm run code-review:build && node .tools/code-review/dist/cli.js help",
    "tts-bridge:listen": "npm run tts-bridge:build && node .tools/tts-bridge/dist/listen.js",
    "csv-to-markdown:start": "npm --prefix \".dev/CSV to Markdown Parser\" start",
    "csv-to-markdown:dev": "npm --prefix \".dev/CSV to Markdown Parser\" run dev"
  },
  "keywords": [
    "tabletop-simulator",
    "lua",
    "modding"
  ],
  "author": "",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "luaparse": "^0.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "luabundle": "^1.7.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eunomiac/toronto-rising-tts.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Eunomiac/toronto-rising-tts/issues"
  },
  "homepage": "https://github.com/Eunomiac/toronto-rising-tts#readme"
}
