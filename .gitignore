# Dependencies
node_modules/
yarn.lock

# IDE — track shared VS Code / Cursor tasks + TTS Lua workspace defaults; keep other settings local
.vscode/*
!.vscode/tasks.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# TTS specific
*.json.bak
*.lua.bak

# TTS extension generated files (bundled output)
.tts/bundled/

# Optional: if an extension still materializes .tts/output/, keep noise out of git
.tts/output/**/*.txt
.tts/output/**/*.log

# Bridge / extension debug writes (see .dev/DEBUG_FILE_LOGGING.md; default root .dev/.debug)
.dev/.debug/

# Compiled CSS (source SCSS is tracked)
UI/styles.css
UI/styles.css.map

# Compiled TypeScript (source TS is tracked)
UI/script.js
UI/script.js.map
UI/src/**/*.js
UI/src/**/*.js.map

# Build outputs
dist/
build/
.dev/TTS-Scripting-Guide-Modules/*_Save_*.json
# Extension sync targets (volatile; canonical Lua is under core/, lib/)
.tts/bundled/*
.tts/objects/*
