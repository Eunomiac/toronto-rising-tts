# Dependencies
node_modules/
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# TTS specific
*.json.bak
*.lua.bak

# TTS extension generated files (bundled output)
.tts/bundled/

# Debug logs (generated by debug module)
debug_logs/

# Compiled CSS (source SCSS is tracked)
UI/styles.css
UI/styles.css.map

# Compiled TypeScript (source TS is tracked)
UI/script.js
UI/script.js.map
UI/src/**/*.js
UI/src/**/*.js.map

# Build outputs
dist/
build/
dev/TTS-Scripting-Guide-Modules/*_Save_*.json
# Ignore contents of these dirs (not the dirs themselves, so negation can work)
.tts/bundled/*
.tts/objects/*
# Exception: keep Global.lua in objects tracked (source of truth)
!.tts/objects/Global.lua
