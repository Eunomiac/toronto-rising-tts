# Dependencies
node_modules/
yarn.lock

# Local secrets (Linear API, etc.)
.env

# Local symlinks to global agent/editor config; audit-only and may expose secrets/caches.
.external-agent-config/

# Storyteller dashboard secrets (copy from .env.example in each app folder)
.dev/storyteller-dashboard/.env

# IDE — track shared VS Code / Cursor tasks + TTS Lua workspace defaults; keep other settings local
# .vscode/*
!.vscode/tasks.json
!.vscode/settings.json
# .idea/
# *.swp
# *.swo
# *~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# TTS specific
# *.json.bak
# *.lua.bak
# ui/.templates/.build/

# TTS extension generated files (bundled output)
.tts/bundled/

# Optional: if an extension still materializes .tts/output/, keep noise out of git
# .tts/output/**/*.txt
# .tts/output/**/*.log

# Bridge / extension debug writes — runtime output only (see .dev/DEBUG_FILE_LOGGING.md).
.dev/.debug/

# Local dev artifacts — machine/session-specific; not versioned
.dev/TS_Save_230.json
.dev/build-logs/
.dev/testbed/TEST BED.ttslua
# lib/e2e_playbook_dice.ttslua

# Compiled CSS (source SCSS is tracked)
UI/styles.css
UI/styles.css.map

# Compiled TypeScript (source TS is tracked)
UI/script.js
UI/script.js.map
UI/src/**/*.js
UI/src/**/*.js.map

# Build outputs
dist/
build/
.dev/TTS-Scripting-Guide-Modules/*_Save_*.json
# Extension sync targets (volatile; canonical Lua is under core/, lib/)
.tts/bundled/*
.tts/objects/*

# Local Storyteller dashboard build output
.dev/storyteller-dashboard/dist/

assets/images/Clipboard Image.jpg
# Local Sheets Obsidian dashboard runtime artifacts
.dev/sheets-obsidian-dashboard/.env
.dev/sheets-obsidian-dashboard/.local/
.dev/sheets-obsidian-dashboard/dist/
.dev/sheets-obsidian-dashboard/output/
