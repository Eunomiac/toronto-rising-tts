---@diagnostic disable: lowercase-global
--[[
    CONTROL_BOARD_PALETTE object script (objects/npc_control_board_palette.ttslua).

    TTS Editor — Script:
    require("objects.npc_control_board_palette")

    Installs sparse snaps at token parking slots via Global (bundle-safe; palette logic in core.npc_gameboard).
]]

function onLoad()
    if Global ~= nil and type(Global.call) == "function" then
        Global.call("GlobalGameboardInstallPaletteSnaps", { force = true })
    end
end
