<!-- Main HUD - VTM5E Module -->
<!-- This file uses XML bundling with <Include> to combine modular UI components -->
<!-- The TTS Tools extension will bundle all includes when using "Save and Play" -->
<!-- Keep in sync with ui/hud.xml - edit the ui/*.xml files, this file is the bundle entry -->

<!-- 1. Tag-based defaults (include first) -->
<!-- include ui/defaults_tags -->
<!-- Tag-Based Defaults -->
<!-- Include first; applies to elements with no class. No layout applied in this file. -->

<Defaults>
  <!-- Baseline Layout Defaults -->
  <Image preserveAspect="true" raycastTarget="false" />
  <VerticalLayout raycastTarget="false" />
  <HorizontalLayout raycastTarget="false" />

  <!-- Button Base Styles -->
  <Button
    minWidth="150"
    minHeight="30"
    preferredWidth="150"
    preferredHeight="30"
    flexibleWidth="0"
    flexibleHeight="0"
    color="rgba(0.7,0.7,0.7,1)"
    fontSize="16"
    fontStyle="Bold" />
</Defaults>

<!-- include ui/defaults_tags -->

<!-- 2. General shared classes -->
<!-- include ui/defaults_classes -->
<!-- General Shared Classes -->
<!-- Include after defaults_tags; used across storyteller, player, shared. -->

<Defaults>
  <!-- Text Spacers -->
  <Text class="spacer_5" color="clear" fontSize="4" />
  <Text class="spacer_10" color="clear" fontSize="8" />
  <Text class="spacer_15" color="clear" fontSize="16" />
  <Text class="spacer_20" color="clear" fontSize="32" />

  <!-- Panel Styles -->
  <Panel class="panel-base" color="rgba(0, 0, 0, 0.7)" padding="10 10 10 10" />
  <Panel class="panel-dark" color="rgba(0, 0, 0, 0.85)" padding="10 10 10 10" />

  <!-- Button Sizes -->
  <Button class="smallButton"
    minWidth="100"
    preferredWidth="100" />

  <!-- Debug Panel Styles -->
  <Panel class="debugPanel"
    color="rgba(0,0,0,0.75)"
    height="400"
    width="350"
    padding="5 5 5 5"
    scale="0.75"
    rectAlignment="MiddleLeft"
    offsetXY="250 0" />

  <Text class="debugText"
    preferredWidth="200"
    alignment="UpperLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Reminder/Alert Panel Styles -->
  <Panel class="reminderPanel"
    color="Black"
    padding="15 5 5 5"
    scale="0.75"
    outline="#FF0000"
    outlineSize="2 2" />

  <Text class="reminderHeading reminderAction"
    color="#FFFFFF"
    alignment="MiddleLeft"
    outline="#000000"
    outlineSize="1 1"
    flexibleHeight="0" />
  <Text class="reminderAction"
    fontSize="24"
    fontStyle="Bold"
    outline="#550000"
    color="Red" />
  <Text class="reminderHeading"
    fontSize="18"
    fontStyle="Bold"
    outline="#555500"
    color="Yellow" />

  <!-- Image Button Layers (base + overlay for hover highlight pattern) -->
  <Image class="imageButtonBase"
    raycastTarget="true"
    color="rgba(0.5, 0.5, 0.5, 1)" />

  <Image class="imageButtonOverlay"
    color="clear"
    raycastTarget="false" />

  <Image class="imageBorder"
    rectAlignment="MiddleLeft" />

  <!-- Popup Image Styles (hidden fullscreen image popups) -->
  <Image class="popupImage"
    active="false" />

  <Image class="popupImageNarrow"
    width="60%" />

  <Panel class="popupImageContainer"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- Status Display Styles -->
  <Text class="statusText"
    fontSize="14"
    alignment="MiddleLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statusLabel"
    fontSize="14"
    alignment="MiddleLeft"
    color="#CCCCCC"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Stat Display (Hunger, Willpower, Health - player HUD) -->
  <HorizontalLayout class="statDisplay"
    spacing="10"
    padding="5 5 5 5"
    childAlignment="MiddleLeft"
    childForceExpandWidth="false" />

  <Text class="statLabel"
    fontSize="16"
    alignment="MiddleLeft"
    color="#CCCCCC"
    preferredWidth="100"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statValue"
    fontSize="18"
    alignment="MiddleCenter"
    color="#FFFFFF"
    preferredWidth="50"
    outline="#000000"
    outlineSize="1 1"
    fontStyle="Bold" />

  <!-- Player HUD Container -->
  <Panel class="playerHudPanel"
    width="250"
    height="150"
    color="rgba(0, 0, 0, 0.7)"
    padding="10 10 10 10"
    rectAlignment="UpperRight"
    offsetXY="-10 10" />

  <!-- Stat Display Layout -->
  <VerticalLayout class="playerStats"
    spacing="8"
    padding="5 5 5 5"
    childAlignment="UpperLeft"
    childForceExpandWidth="true" />
</Defaults>

<!-- include ui/defaults_classes -->

<!-- 3. Storyteller HUD (Host|Black): layout + 4 panels -->
<!-- include ui/storyteller/hud_storyteller_defaults -->
<!-- Storyteller HUD Defaults -->
<!-- Heritage admin panel + sidebar + camera classes. Include before hud_storyteller. -->

<Defaults>

  <!-- ================================================================ -->
  <!-- Admin Panel Classes (left-side button controls)                   -->
  <!-- ================================================================ -->

  <!-- Main button column: left-aligned, half-scale, vertically stacked -->
  <VerticalLayout class="storyteller_buttonControls"
    padding="10 10 5 5"
    spacing="5"
    rectAlignment="MiddleLeft"
    childAlignment="UpperLeft"
    width="160"
    offsetXY="0 -90"
    scale="0.5"
    flexibleWidth="0"
    flexibleHeight="0"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- Debug sub-panel: horizontal row of button columns offset right -->
  <HorizontalLayout class="storyteller_subButtonControls"
    spacing="5"
    offsetXY="75 50"
    width="200"
    height="500"
    rectAlignment="MiddleLeft"
    flexibleWidth="0"
    flexibleHeight="0"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- Debug traits overlay panel (positioning specific to storyteller layout) -->
  <Panel class="storyteller_debugTraits"
    height="900"
    width="800"
    rectAlignment="UpperRight"
    offsetXY="-400 -100" />

  <!-- Per-color debug trait text offsets -->
  <Text class="storyteller_debugTraitsRed" offsetXY="0 0" />
  <Text class="storyteller_debugTraitsYellow" offsetXY="200 0" />
  <Text class="storyteller_debugTraitsBlue" offsetXY="400 0" />
  <Text class="storyteller_debugStickers" offsetXY="600 0" />

  <!-- ================================================================ -->
  <!-- Sidebar Classes (right-side reference image toggles)             -->
  <!-- ================================================================ -->

  <!-- Faction icon container (bottom-right, above camera bar) -->
  <HorizontalLayout class="storyteller_factionIconContainer"
    rectAlignment="LowerRight"
    padding="0 400 0 20"
    spacing="0"
    height="150"
    width="800"
    scale="0.7"
    childAlignment="LowerLeft"
    childForceExpandHeight="true"
    childForceExpandWidth="false" />

  <!-- Camera control bar (bottom-right row) -->
  <HorizontalLayout class="storyteller_cameraControls"
    rectAlignment="LowerRight"
    padding="0 0 0 0"
    spacing="0"
    height="28"
    width="800"
    scale="0.7"
    childAlignment="LowerRight"
    childForceExpandHeight="true"
    childForceExpandWidth="false" />

  <!-- Camera button: clickable image with hover handlers -->
  <Image class="storyteller_cameraButton"
    raycastTarget="true"
    onMouseDown="HUD_cameraSet"
    onMouseEnter="HUD_highlight"
    onMouseExit="HUD_dim" />

  <!-- Right sidebar panel container -->
  <Panel class="storyteller_sidebar"
    rectAlignment="LowerRight"
    height="740"
    width="125"
    offsetXY="0 100" />

  <!-- Right sidebar inner vertical layout -->
  <VerticalLayout class="storyteller_sidebarLayout"
    height="100%"
    width="100%"
    childAlignment="LowerLeft"
    childForceExpandHeight="false"
    childForceExpandWidth="true" />

  <!-- Reference toggle button: show/hide on mouse events -->
  <Image class="storyteller_refButton"
    onMouseDown="HUD_show"
    onMouseUp="HUD_hide"
    onMouseEnter="HUD_highlight"
    onMouseExit="HUD_dim" />


</Defaults>

<!-- include ui/storyteller/hud_storyteller_defaults -->
<!-- include ui/storyteller/hud_storyteller -->
<!-- Storyteller HUD Layout -->
<!-- Visibility: Host|Black (Storyteller/GM) -->
<!-- Reproduces Heritage admin.xml: left-side game phase controls + debug panels -->
<!-- Also includes sidebar (reference toggles) and camera bar via sub-includes -->

<Panel id="adminControls" visibility="Host|Black" active="true">

  <!-- ================================================================ -->
  <!-- Main Button Column (left side, half-scale)                       -->
  <!-- Game phase progression: SETUP -> INIT -> START -> SCORING ->     -->
  <!--   MISSIONS -> AFTERMATH -> END                                   -->
  <!-- ================================================================ -->
  <VerticalLayout class="storyteller_buttonControls" visibility="Host|Black">
    <Button onClick="HUD_setupGame" color="#770000">0 - SETUP</Button>
    <Button onClick="HUD_initGame" color="#880000">1 - INIT</Button>
    <Button onClick="HUD_startGame" color="#990000">2 - START</Button>
    <Button class="smallButton" onClick="HUD_endCourtVote" color="#99FF99">End Vote</Button>
    <Button class="smallButton" onClick="HUD_overrideFirstPlayer" color="#99FFFF">First Player</Button>
    <Button class="smallButton" onClick="HUD_askRoundAndTurn" color="#FFFF00">Fix Turn</Button>
    <Button class="smallButton" onClick="HUD_toggleHavens" color="#FFFF00">Havens</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_scoreGame" color="#AA0000">3 - SCORING</Button>
    <Button class="smallButton" onClick="HUD_updateScore" color="#00FF00">Refresh</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_missionsGame" color="#BB0000">4 - MISSIONS</Button>
    <Button class="smallButton" onClick="HUD_updateTraits" color="#00BBBB">+Trait</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_afterGame" color="#CC0000">5 - AFTERMATH</Button>
    <Button class="smallButton" onClick="HUD_updateSticker" color="#00BBBB">+Sticker</Button>
    <Button class="smallButton" onClick="HUD_switchStickerTraits" color="#00FFFF">Switch</Button>
    <Button class="smallButton" onClick="HUD_processCardSpots" color="#FFFF00">Process</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_endGame" color="#DD0000">6 - END</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_printState">Print State</Button>
    <Button onClick="HUD_toggleHUD">HUD</Button>
  </VerticalLayout>

  <!-- ================================================================ -->
  <!-- Debug Sub-Panel (hidden by default, toggled by Debug button)     -->
  <!-- ================================================================ -->
  <HorizontalLayout id="debugControls" class="storyteller_subButtonControls" active="false" visibility="Host|Black">

    <!-- Debug Left Column -->
    <VerticalLayout class="storyteller_buttonControls storyteller_subButtonControls" visibility="Host|Black">
      <Button id="debugToggleZones" onClick="HUD_toggleZonesActive" color="#00FF00">Zones (Active)</Button>
      <Text class="spacer_20"></Text>
      <Text class="spacer_20"></Text>
      <Button onClick="HUD_toggleScores" color="#00FF00">SCORES</Button>
      <Text class="spacer_5"></Text>
      <Text class="spacer_5"></Text>
      <Button onClick="HUD_showTraits" color="#00BBBB">TRAITS</Button>
      <Button onClick="HUD_showStickers" color="#00BBBB">STICKERS</Button>
      <Text class="spacer_5"></Text>
      <Button onClick="HUD_setChapterData" color="#993399">Chapter Text</Button>
      <Text class="spacer_5"></Text>
      <Text class="spacer_5"></Text>
      <Text class="spacer_5"></Text>
      <Button onClick="HUD_processCharacterDeck" color="#FF8C00">Process CDeck</Button>
      <Button onClick="HUD_sortCharacterDeck" color="#FF8C00">Sort CDeck</Button>
      <Text class="spacer_15"></Text>
      <Button onClick="HUD_toggleTraitDebug">View Traits</Button>
      <Button onClick="HUD_toggleZoneVisibility">Zones</Button>
      <Text class="spacer_15"></Text>
      <Button onClick="HUD_debugEndGame" color="#444444">End Game</Button>
      <Text class="spacer_15"></Text>
      <Button onClick="HUD_refreshState">Refresh</Button>
    </VerticalLayout>

    <!-- Debug Right Column (offset right) -->
    <VerticalLayout class="storyteller_buttonControls storyteller_subButtonControls" visibility="Host|Black" ignoreLayout="true" offsetXY="75 0">
      <Button id="debugZoomCard" onClick="HUD_debugCardZoom">Zoom</Button>
      <Button id="debugClearZoom" onClick="HUD_debugClearZoom">End</Button>
      <Text class="spacer_15"></Text>
      <Button id="debugResetState" onClick="HUD_resetGameState" color="Red">Reset</Button>
      <Text class="spacer_15"></Text>
      <Button id="debugTestFunc1" onClick="HUD_testFunc1">TestFunc 1</Button>
      <Button id="debugTestFunc2" onClick="HUD_testFunc2">TestFunc 2</Button>
      <Button id="debugTestFunc3" onClick="HUD_testFunc3">TestFunc 3</Button>
    </VerticalLayout>

  </HorizontalLayout>

  <!-- ================================================================ -->
  <!-- Debug State Display Panel                                        -->
  <!-- ================================================================ -->
  <Panel id="debugStatePanel" active="false" class="debugPanel">
    <Text id="debugState" class="debugText"></Text>
  </Panel>

  <!-- ================================================================ -->
  <!-- Debug Traits Display Panel                                       -->
  <!-- ================================================================ -->
  <Panel id="debugTraitsPanel" active="false" class="debugPanel storyteller_debugTraits">
    <Text id="debugTraitsRed" class="debugText storyteller_debugTraitsRed"></Text>
    <Text id="debugTraitsYellow" class="debugText storyteller_debugTraitsYellow"></Text>
    <Text id="debugTraitsBlue" class="debugText storyteller_debugTraitsBlue"></Text>
    <Text id="debugStickers" class="debugText storyteller_debugTraitsBlue storyteller_debugStickers"></Text>
  </Panel>

