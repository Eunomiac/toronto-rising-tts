--- @param playerID string
--- @return table
function P.makeImpairedHumanityCondition(playerID)
  local pd = S.getPlayerData(playerID) or {}
  local col = pd.color or "Brown"
  return {
    statChanges = {
      strength = -2,
      dexterity = -2,
      stamina = -2,
      charisma = -2,
      manipulation = -2,
      composure = -2,
      intelligence = -2,
      wits = -2,
      resolve = -2
    },
    hudChanges = { ["overlay_humanity_impaired_" .. col] = true },
    lightingModeChanges = { ["playerLight2" .. col] = "DIM_PURPLE" },
    removalCriteria = "indefinite"
