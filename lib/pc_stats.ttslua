--- Resolve sheet/UI light keys (e.g. PLAYER_LIGHT_2_COLOR) to L.LIGHTMODES registry names.
--- @param rawKey string
--- @param seatColor string|nil
--- @return string|nil
function P.resolveLightRegistryKey(rawKey, seatColor)
  if type(rawKey) ~= "string" then
    return nil
  end
  if L.LIGHTMODES[rawKey] ~= nil then
    return rawKey
  end
  local prefix = "PLAYER_LIGHT_2_"
  if rawKey:sub(1, #prefix) == prefix then
    local suffix = rawKey:sub(#prefix + 1)
    if suffix == string.upper(suffix) and #suffix > 0 then
      local title = suffix:sub(1, 1) .. suffix:sub(2):lower()
      return "playerLight2" .. title
    end
  end
  if seatColor and L.LIGHTMODES["playerLight2" .. seatColor] ~= nil then
    return "playerLight2" .. seatColor
  end
  return rawKey
end

--- @param lightKey string registered L.LIGHTMODES key
--- @param mode string|table
--- @param playerColor string|nil
local function trySetLight(lightKey, mode, playerColor)
  local def = L.LIGHTMODES[lightKey]
  if def == nil then
    warnGm("Unknown light key: " .. tostring(lightKey))
    return
  end
  if type(mode) == "string" then
    local m = (def[mode] ~= nil) and mode or (string.upper(mode) == mode and mode or nil)
    if m == nil then
      m = mode
    end
    if def[m] == nil and mode ~= "OFF" and mode ~= "STANDARD" then
      warnGm("Light mode " .. tostring(mode) .. " not defined for " .. tostring(lightKey) .. " — skipping")
      return
    end
  end
  pcall(function()
    L.SetLightMode(lightKey, mode, playerColor, 0.5)
  end)
end

--- Apply lighting from all active conditions (last key wins per light).
--- @param playerID string
function P.applyActiveConditionPresentation(playerID)
  if playerID == C.StorytellerID then
    return
  end
  local pd = S.getPlayerData(playerID) or {}
  local col = pd.color
  local conditions = S.getStateVal("playerData", playerID, "conditions")
  if type(conditions) ~= "table" then
    return
  end
  local lastMode = {}
  for condKey, cond in pairs(conditions) do
    if type(cond) == "table" and type(cond.lightingModeChanges) == "table" then
      for lk, mode in pairs(cond.lightingModeChanges) do
        local reg = P.resolveLightRegistryKey(lk, col)
        if reg then
          lastMode[reg] = mode
        end
      end
    end
  end
  for reg, mode in pairs(lastMode) do
    trySetLight(reg, mode, col)
  end
end

--- Humanity stain delta; updates impairedHumanity from collision rules.
--- @param playerRef any
--- @param stainDelta number
function P.applyHumanityStainDelta(playerRef, stainDelta)
  local playerID = resolvePlayerId(playerRef)
  if not playerID or playerID == C.StorytellerID then
    return
  end
  local stats = S.getStateVal("playerData", playerID, "stats")
  local conditions = S.getStateVal("playerData", playerID, "conditions") or {}
  if type(stats) ~= "table" or type(stats.humanity) ~= "table" then
    return
  end
  local hu = stats.humanity
  local stains = math.max(0, (tonumber(hu.stains) or 0) + (tonumber(stainDelta) or 0))
  S.setStateVal(stains, "playerData", playerID, "stats", "humanity", "stains")

  local base = tonumber(hu.base) or 0
  local effT = P.effectiveTempForAggregate(stats, conditions, "humanity")
  local lineLen = base + effT
  local hasImpaired = P.humanityHasImpairedSlot(lineLen, stains)

  if hasImpaired then
    if conditions.impairedHumanity == nil then
      P.setConditionEntry(playerID, "impairedHumanity", P.makeImpairedHumanityCondition(playerID))
    end
  else
    if conditions.impairedHumanity ~= nil then
      P.setConditionEntry(playerID, "impairedHumanity", nil)
    end
  end
  P.applyActiveConditionPresentation(playerID)
  P.refreshHudOverlays()
end

--- Whether collision creates impaired box (last humanity slot touched by stains from right).
--- @param lineLen number
--- @param stains number
--- @return boolean
function P.humanityHasImpairedSlot(lineLen, stains)
  if lineLen < 1 or stains < 1 then
    return false
  end
  local firstStainSlot = 11 - stains
  return firstStainSlot <= lineLen
end

--- Clear all stains and re-sync impaired humanity.
--- @param playerRef any
function P.clearHumanityStains(playerRef)
  P.applyHumanityStainDelta(playerRef, -(9999))
  local playerID = resolvePlayerId(playerRef)
  if not playerID then
    return
  end
  S.setStateVal(0, "playerData", playerID, "stats", "humanity", "stains")
  local conditions = S.getStateVal("playerData", playerID, "conditions") or {}
  if conditions.impairedHumanity ~= nil then
    P.setConditionEntry(playerID, "impairedHumanity", nil)
  end
  P.applyActiveConditionPresentation(playerID)
  P.refreshHudOverlays()
end

--- @param playerRef any
--- @param delta number
function P.applyHumanityBaseDelta(playerRef, delta)
  local playerID = resolvePlayerId(playerRef)
  if not playerID or playerID == C.StorytellerID then
    return
  end
  local hu = S.getStateVal("playerData", playerID, "stats", "humanity")
  if type(hu) ~= "table" then
    return
  end
  local b = math.max(0, math.min(10, (tonumber(hu.base) or 0) + (tonumber(delta) or 0)))
  S.setStateVal(b, "playerData", playerID, "stats", "humanity", "base")
  local stats2 = S.getStateVal("playerData", playerID, "stats")
  local cond2 = S.getStateVal("playerData", playerID, "conditions") or {}
  local lineLen = b + P.effectiveTempForAggregate(stats2, cond2, "humanity")
  local stains = tonumber(S.getStateVal("playerData", playerID, "stats", "humanity", "stains")) or 0
  if P.humanityHasImpairedSlot(lineLen, stains) then
    if cond2.impairedHumanity == nil then
      P.setConditionEntry(playerID, "impairedHumanity", P.makeImpairedHumanityCondition(playerID))
    end
  else
    if cond2.impairedHumanity ~= nil then
      P.setConditionEntry(playerID, "impairedHumanity", nil)
    end
  end
  P.applyActiveConditionPresentation(playerID)
  P.refreshHudOverlays()
end

--- Storyteller string: configurable undamaged / superficial / aggravated (defaults O / / X)
--- @param playerRef any
--- @param which string health|willpower
--- @return string
function P.formatDamageTrackText(playerRef, which)
  local playerID = resolvePlayerId(playerRef)
  if not playerID then
    return ""
  end
  local stats = S.getStateVal("playerData", playerID, "stats")
  local conditions = S.getStateVal("playerData", playerID, "conditions")
  if type(stats) ~= "table" or type(stats[which]) ~= "table" then
    return ""
  end
  local gUnd, gSup, gAgg = damageTrackGlyphs()
  local tr = stats[which]
  local maxB = (tonumber(tr.base) or 0) + P.effectiveTempForAggregate(stats, conditions, which)
  if maxB < 1 then
    maxB = 1
  end
  local sup = tonumber(tr.superficial) or 0
  local agg = tonumber(tr.aggravated) or 0
  local chars = {}
  for i = 1, maxB do
    if i <= agg then
      chars[#chars + 1] = gAgg
    elseif i <= agg + sup then
      chars[#chars + 1] = gSup
    else
      chars[#chars + 1] = gUnd
    end
  end
  return table.concat(chars, "")
end

--- 10-wide humanity strip: unused / filled / stain / impaired glyphs (defaults _ O * I)
--- @param playerRef any
--- @return string
function P.formatHumanityTrackText(playerRef)
  local playerID = resolvePlayerId(playerRef)
  if not playerID then
    return ""
  end
  local stats = S.getStateVal("playerData", playerID, "stats")
  local conditions = S.getStateVal("playerData", playerID, "conditions")
  if type(stats) ~= "table" or type(stats.humanity) ~= "table" then
    return ""
  end
  local gUnused, gFill, gStain, gImp = humanityTrackGlyphs()
  local hu = stats.humanity
  local lineLen = (tonumber(hu.base) or 0) + P.effectiveTempForAggregate(stats, conditions, "humanity")
  local stains = tonumber(hu.stains) or 0
  local slotModes = {}
  for i = 1, 10 do
    slotModes[i] = gUnused
  end
  for i = 1, lineLen do
    slotModes[i] = gFill
  end
  local sIdx = 10
  for _ = 1, stains do
    if slotModes[sIdx] == gFill then
      slotModes[sIdx] = gImp
      break
    else
      slotModes[sIdx] = gStain
    end
    sIdx = sIdx - 1
    if sIdx < 1 then
      break
    end
  end
  return table.concat(slotModes, "")
end

--- Storyteller strip: `MAX_HUNGER` dots using Global `hungerTrack` glyphs (from CSHEET).
--- @param seatColor string
--- @return string
function P.formatHungerDotLine(seatColor)
  if type(seatColor) ~= "string" then
    return ""
  end
  local g = getMergedTrackerDisplay()
  local ht = g and g.hungerTrack
  local empty = type(ht) == "table" and tostring(ht.empty or "") or ""
  local glyphFull = type(ht) == "table" and tostring(ht.full or "") or ""
  if empty == "" then
    empty = "o"
  end
  if glyphFull == "" then
    glyphFull = "O"
  end
  local hg = tonumber(S.getPlayerVal(seatColor, "hunger")) or 0
  local maxDots = tonumber(C.MAX_HUNGER) or 5
  if maxDots < 1 then
    maxDots = 5
  end
  local chars = {}
  for i = 1, maxDots do
    chars[#chars + 1] = (i <= hg) and glyphFull or empty
  end
  return table.concat(chars, "")
end

--- Build XML attribute updates for character sheet objects.
--- @param stats table
--- @param conditions table|nil
--- @param pageNum number|nil sheet index from object name; see `P.SHEET_PAGE_UPDATE_PROFILE`
--- @return table[] list of { id = string, attributes = { active = "true"|"false" } }
function P.collectSheetImageUpdates(stats, conditions, pageNum)
  local updates = {}
  --- @param imageName string|nil when set, applied as `image` (custom-ui asset name)
  local function add(id, active, imageName)
    local attrs = { active = active and "true" or "false" }
    if type(imageName) == "string" and imageName ~= "" then
      attrs.image = imageName
    end
    updates[#updates + 1] = { id = id, attributes = attrs }
  end

  if type(stats) ~= "table" then
    return updates
  end

  local pageProfile = nil
  if pageNum ~= nil then
    pageProfile = P.SHEET_PAGE_UPDATE_PROFILE[pageNum] or "none"
    if pageProfile == "none" then
      return updates
    end
  end

  local dotKeys = {}
  if type(stats.attributes) == "table" then
    for k, _ in pairs(stats.attributes) do
      dotKeys[#dotKeys + 1] = { k, "attributes" }
    end
  end
  if type(stats.skills) == "table" then
    for k, _ in pairs(stats.skills) do
      dotKeys[#dotKeys + 1] = { k, "skills" }
    end
  end
  if type(stats.disciplines) == "table" then
    for k, _ in pairs(stats.disciplines) do
      dotKeys[#dotKeys + 1] = { k, "disciplines" }
    end
  end
  if type(stats.bloodPotency) == "table" then
    dotKeys[#dotKeys + 1] = { "bloodPotency", "bloodPotency" }
  end

  for _, pair in ipairs(dotKeys) do
    local key = pair[1]
    local eff = P.effectiveTempForDot(stats, conditions, key)
    local base = 0
    if pair[2] == "bloodPotency" then
      base = tonumber(stats.bloodPotency.base) or 0
    elseif pair[2] == "attributes" then
      base = tonumber(stats.attributes[key].base) or 0
    elseif pair[2] == "skills" then
      base = tonumber(stats.skills[key].base) or 0
    elseif pair[2] == "disciplines" then
      base = tonumber(stats.disciplines[key].base) or 0
    end
    local rating = base + eff
    for slot = 1, 5 do
      if slot > base then
        add("dot_on_" .. key .. "_" .. slot, false)
      end
      if slot <= base then
        add("dot_off_" .. key .. "_" .. slot, false)
      end
    end
    if eff > 0 then
      for slot = base + 1, math.min(5, rating) do
        add("dot_on_" .. key .. "_" .. slot, true)
      end
    elseif eff < 0 then
      for slot = rating + 1, base do
        add("dot_off_" .. key .. "_" .. slot, true)
      end
    end
  end

  local function boxFill(which, trackerKey)
    local tr = stats[which]
    if type(tr) ~= "table" then
      return
    end
    local td = getMergedTrackerDisplay()
    local layerImg = type(td) == "table" and type(td.sheetImages) == "table" and td.sheetImages[trackerKey] or nil
    local function boxImg(layer)
      if type(layerImg) == "table" then
        local v = layerImg[layer]
        if type(v) == "string" and v ~= "" then
          return v
        end
      end
      return nil
    end
    local maxB = (tonumber(tr.base) or 0) + P.effectiveTempForAggregate(stats, conditions, which)
    local sup = tonumber(tr.superficial) or 0
    local agg = tonumber(tr.aggravated) or 0
    for i = 1, 10 do
      add("box_agg_" .. trackerKey .. "_" .. i, false)
      add("box_sup_" .. trackerKey .. "_" .. i, false)
      add("box_on_" .. trackerKey .. "_" .. i, false)
    end
    local idx = 1
    for _ = 1, agg do
      if idx <= maxB then
        add("box_agg_" .. trackerKey .. "_" .. idx, true, boxImg("aggravated"))
        idx = idx + 1
      end
    end
    for _ = 1, sup do
      if idx <= maxB then
        add("box_sup_" .. trackerKey .. "_" .. idx, true, boxImg("superficial"))
        idx = idx + 1
      end
    end
    while idx <= maxB do
      add("box_on_" .. trackerKey .. "_" .. idx, true, boxImg("undamaged"))
      idx = idx + 1
    end
  end

  boxFill("health", "health")
  boxFill("willpower", "willpower")

  if type(stats.humanity) == "table" then
    local hu = stats.humanity
    local lineLen = (tonumber(hu.base) or 0) + P.effectiveTempForAggregate(stats, conditions, "humanity")
    local stains = tonumber(hu.stains) or 0
    for i = 1, 10 do
      add("box_on_humanity_" .. i, false)
      add("box_stain_humanity_" .. i, false)
      add("box_impaired_humanity_" .. i, false)
    end
    local slots = {}
    for i = 1, 10 do
      slots[i] = "empty"
    end
    for i = 1, lineLen do
      slots[i] = "on"
    end
    local sIdx = 10
    for _ = 1, stains do
      if sIdx < 1 then
        break
      end
      if slots[sIdx] == "on" then
        slots[sIdx] = "impaired"
        break
      end
      slots[sIdx] = "stain"
      sIdx = sIdx - 1
    end
    local tdH = getMergedTrackerDisplay()
    local hImg = type(tdH) == "table" and type(tdH.sheetImages) == "table" and tdH.sheetImages.humanity or nil
    local function humImg(layer)
      if type(hImg) == "table" then
        local v = hImg[layer]
        if type(v) == "string" and v ~= "" then
          return v
        end
      end
      return nil
    end
    for i = 1, 10 do
      if slots[i] == "on" then
        add("box_on_humanity_" .. i, true, humImg("filled"))
      elseif slots[i] == "stain" then
        add("box_stain_humanity_" .. i, true, humImg("stain"))
      elseif slots[i] == "impaired" then
        add("box_impaired_humanity_" .. i, true, humImg("impaired"))
      end
    end
  end

  if pageNum ~= nil and pageProfile ~= nil then
    local filtered = {}
    for _, u in ipairs(updates) do
      local id = u.id
      local dk = P.disciplineKeyFromDotElementId(id)
      local isDisc = dk ~= nil and P.DISCIPLINE_DOT_KEYS[dk] == true
      if pageProfile == "main" then
        if not isDisc then
          filtered[#filtered + 1] = u
        end
      elseif pageProfile == "disciplines" then
        if isDisc then
          filtered[#filtered + 1] = u
        end
      end
      -- New profiles (e.g. page 3+): add explicit `elseif pageProfile == "..."` branches here.
    end
    return filtered
  end

  return updates
end

--- Torpor cleared by ST; remove if healed below full agg track.
--- @param playerRef any
function P.storytellerClearTorpor(playerRef)
  local playerID = resolvePlayerId(playerRef)
  if not playerID then
    return
  end
  P.setConditionEntry(playerID, "torpor", nil)
  P.syncDamageDerivedConditions(playerID)
  P.applyActiveConditionPresentation(playerID)
  P.refreshHudOverlays()
end

return P
