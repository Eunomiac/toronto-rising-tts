--[[
    PC tracker math, VTM5e damage overflow, humanity stains, condition sync.
    Agent guidance: .dev/PC Data & Tracking/PC Tracking & State Behavior.md
]]

---@diagnostic disable: undefined-global
local P = {}
local S = require("core.state")
local C = require("lib.constants")
local U = require("lib.util")
local L = require("core.lighting")

--- Tracker glyphs / sheet images from Global (`GlobalRegisterTrackerDisplay`); nil until a sheet object loads.
--- @return table|nil
local function getMergedTrackerDisplay()
  local g = rawget(_G, "TRACKER_DISPLAY")
  if type(g) == "table" then
    return g
  end
  return nil
end

--- @return string, string, string
local function damageTrackGlyphs()
  local g = getMergedTrackerDisplay()
  local d = g and g.damageTrack
  if type(d) == "table" then
    return tostring(d.undamaged or "O"), tostring(d.superficial or "/"), tostring(d.aggravated or "X")
  end
  return "O", "/", "X"
end

--- @return string, string, string, string
local function humanityTrackGlyphs()
  local g = getMergedTrackerDisplay()
  local h = g and g.humanityTrack
  if type(h) == "table" then
    return tostring(h.unused or "_"), tostring(h.filled or "O"), tostring(h.stain or "*"), tostring(h.impaired or "I")
  end
  return "_", "O", "*", "I"
end

--- Push Global UI overlay visibility (UI.show/hide) after PC state changes.
function P.refreshHudOverlays()
  pcall(function()
    local HO = require("core.hud_overlays")
    HO.syncAll()
  end)
end

--- Like refreshHudOverlays, but clears overlay visibility cache for one seat first so hunger/condition
--- layers cannot get stuck when lastVisible matches desired state but TTS UI is out of sync.
--- @param seatColor string e.g. "Red"
function P.refreshHudOverlaysForSeat(seatColor)
  if type(seatColor) ~= "string" then
    return
  end
  pcall(function()
    local HO = require("core.hud_overlays")
    if type(HO.invalidateSeatCache) == "function" then
      HO.invalidateSeatCache(seatColor)
    end
    HO.syncAll()
  end)
end

--- Which automated UI id updates apply per sheet page (`CSHEET_PAGE_<n>_<COLOR>`).
--- Add rows when you add page 3..8 XML: `"main"` = attrs/skills/trackers/BP/humanity (no discipline dots);
--- `"disciplines"` = discipline dot-lines only; `"none"` = skip this pipeline (custom ids / later profile).
--- Pages not listed behave as `"none"` so new objects stay inert until you assign a profile.
P.SHEET_PAGE_UPDATE_PROFILE = {
  [1] = "main",
  [2] = "disciplines",
}

-- Dot-line disciplines live on character sheet page 2; other dots and trackers on page 1.
P.DISCIPLINE_DOT_KEYS = {
  animalism = true,
  auspex = true,
  bloodSorcery = true,
  celerity = true,
  dominate = true,
  fortitude = true,
  obfuscate = true,
  oblivion = true,
  potence = true,
  presence = true,
  protean = true
}

--- @param elementId string
--- @return string|nil discipline key from dot_on_<key>_<n> or dot_off_<key>_<n>
function P.disciplineKeyFromDotElementId(elementId)
  if type(elementId) ~= "string" then
    return nil
  end
  -- Captures: (1) on|off (2) attribute/skill/discipline key (3) slot number
  local _, _, _onOff, key = elementId:find("^dot_(on|off)_(.+)_(%d+)$")
  return key
end

--- @param msg string
local function warnGm(msg)
  if broadcastToAll ~= nil then
    pcall(function()
      broadcastToAll("[PC] " .. tostring(msg), Color(1, 0.55, 0.2))
    end)
  end
  print("[PC warnGm] " .. tostring(msg))
end

--- @param playerRef any
--- @return string|nil
local function resolvePlayerId(playerRef)
  if type(playerRef) == "string" and C.PlayerData[playerRef] then
    return playerRef
  end
  return S.getPlayerID(playerRef)
end

--- Sum condition stat deltas for aggregate trackers (health, willpower, humanity).
--- @param stats table
--- @param conditions table|nil
--- @param statKey string
--- @return number
function P.effectiveTempForAggregate(stats, conditions, statKey)
  local baseT = 0
  if type(stats) == "table" and type(stats[statKey]) == "table" then
    baseT = tonumber(stats[statKey].temp) or 0
  end
  local add = 0
  if type(conditions) == "table" then
    for _, cond in pairs(conditions) do
      if type(cond) == "table" and type(cond.statChanges) == "table" then
        local v = cond.statChanges[statKey]
        if v ~= nil then
          add = add + (tonumber(v) or 0)
        end
      end
    end
  end
  return baseT + add
end

--- @param stats table
--- @param conditions table|nil
--- @param dotKey string attribute/skill/discipline key
--- @return number
function P.effectiveTempForDot(stats, conditions, dotKey)
  local baseT = 0
  if type(stats) == "table" then
    if type(stats.attributes) == "table" and type(stats.attributes[dotKey]) == "table" then
      baseT = tonumber(stats.attributes[dotKey].temp) or 0
    elseif type(stats.skills) == "table" and type(stats.skills[dotKey]) == "table" then
      baseT = tonumber(stats.skills[dotKey].temp) or 0
    elseif type(stats.disciplines) == "table" and type(stats.disciplines[dotKey]) == "table" then
      baseT = tonumber(stats.disciplines[dotKey].temp) or 0
    elseif dotKey == "bloodPotency" and type(stats.bloodPotency) == "table" then
      baseT = tonumber(stats.bloodPotency.temp) or 0
    end
  end
  local add = 0
  if type(conditions) == "table" then
    for _, cond in pairs(conditions) do
      if type(cond) == "table" and type(cond.statChanges) == "table" then
        local v = cond.statChanges[dotKey]
        if v ~= nil then
          add = add + (tonumber(v) or 0)
        end
      end
    end
  end
  return baseT + add
end

--- @param track table superficial/aggravated
--- @param maxBoxes number
--- @param ds number superficial delta
--- @param da number aggravated delta
--- @return number, number new superficial, aggravated
local function applyTrackDeltasV5(track, maxBoxes, ds, da)
  local s = math.max(0, (tonumber(track.superficial) or 0) + (tonumber(ds) or 0))
  local a = math.max(0, (tonumber(track.aggravated) or 0) + (tonumber(da) or 0))
  local t = s + a
  if t <= maxBoxes then
    return s, a
  end
  local overflow = t - maxBoxes
  local s2 = s - math.min(s, overflow)
  local rem = overflow - (s - s2)
  local a2 = a - rem
  if a2 < 0 then
    a2 = 0
  end
  for _ = 1, overflow do
    if s2 > 0 then
      s2 = s2 - 1
      a2 = a2 + 1
    end
  end
  return s2, a2
end

--- @param playerRef any
--- @param which string "health"|"willpower"
--- @param superficialDelta number
--- @param aggravatedDelta number
function P.applyDamageOrHeal(playerRef, which, superficialDelta, aggravatedDelta)
  local playerID = resolvePlayerId(playerRef)
  if not playerID or playerID == C.StorytellerID then
    return
  end
  local stats = S.getStateVal("playerData", playerID, "stats")
  local conditions = S.getStateVal("playerData", playerID, "conditions")
  if type(stats) ~= "table" or type(stats[which]) ~= "table" then
    warnGm("applyDamageOrHeal: missing stats." .. which .. " for player")
    return
  end
  local tr = stats[which]
  local b = tonumber(tr.base) or 0
  local maxBoxes = b + P.effectiveTempForAggregate(stats, conditions, which)
  if maxBoxes < 1 then
    maxBoxes = 1
  end
  local ns, na = applyTrackDeltasV5(tr, maxBoxes, superficialDelta, aggravatedDelta)
  S.setStateVal(ns, "playerData", playerID, "stats", which, "superficial")
  S.setStateVal(na, "playerData", playerID, "stats", which, "aggravated")
  P.syncDamageDerivedConditions(playerID)
  P.applyActiveConditionPresentation(playerID)
  P.refreshHudOverlays()
end

--- @param playerID string
function P.syncDamageDerivedConditions(playerID)
  if playerID == C.StorytellerID then
    return
  end
  local stats = S.getStateVal("playerData", playerID, "stats")
  local conditions = S.getStateVal("playerData", playerID, "conditions") or {}
  if type(stats) ~= "table" then
    return
  end
  if type(conditions) ~= "table" then
    conditions = {}
    S.setStateVal(conditions, "playerData", playerID, "conditions")
  end

  local h = stats.health
  local w = stats.willpower
  if type(h) ~= "table" or type(w) ~= "table" then
    return
  end

  local hMax = (tonumber(h.base) or 0) + P.effectiveTempForAggregate(stats, conditions, "health")
  local wMax = (tonumber(w.base) or 0) + P.effectiveTempForAggregate(stats, conditions, "willpower")
  local hSup = tonumber(h.superficial) or 0
  local hAgg = tonumber(h.aggravated) or 0
  local wSup = tonumber(w.superficial) or 0
  local wAgg = tonumber(w.aggravated) or 0

  local hasTorpor = conditions.torpor ~= nil
  if hMax > 0 and hAgg >= hMax then
    if not hasTorpor then
      P.setConditionEntry(playerID, "torpor", P.makeTorporCondition(playerID))
    end
  end

  local impairedH = conditions.impairedHealth
  if hasTorpor then
    if impairedH ~= nil then
      conditions.impairedHealth = nil
      S.setStateVal(nil, "playerData", playerID, "conditions", "impairedHealth")
    end
  elseif hMax > 0 and (hSup + hAgg) >= hMax then
    if impairedH == nil then
      P.setConditionEntry(playerID, "impairedHealth", P.makeImpairedHealthCondition(playerID))
    end
  else
    if impairedH ~= nil then
      conditions.impairedHealth = nil
      S.setStateVal(nil, "playerData", playerID, "conditions", "impairedHealth")
    end
  end

  local impairedW = conditions.impairedWillpower
  if hasTorpor then
    if impairedW ~= nil then
      conditions.impairedWillpower = nil
      S.setStateVal(nil, "playerData", playerID, "conditions", "impairedWillpower")
    end
  elseif wMax > 0 and (wSup + wAgg) >= wMax then
    if impairedW == nil then
      P.setConditionEntry(playerID, "impairedWillpower", P.makeImpairedWillpowerCondition(playerID))
    end
  else
    if impairedW ~= nil then
      conditions.impairedWillpower = nil
      S.setStateVal(nil, "playerData", playerID, "conditions", "impairedWillpower")
    end
  end
end

--- @param playerID string
--- @param key string
--- @param entry table|nil
function P.setConditionEntry(playerID, key, entry)
  if entry == nil then
    S.setStateVal(nil, "playerData", playerID, "conditions", key)
  else
    S.setStateVal(entry, "playerData", playerID, "conditions", key)
  end
end

--- @param playerID string
--- @return table
function P.makeTorporCondition(playerID)
  local pd = S.getPlayerData(playerID) or {}
  local col = pd.color or "Brown"
  return {
    statChanges = {},
    hudChanges = { ["overlay_torpor_" .. col] = true },
    lightingModeChanges = { ["playerLight2" .. col] = "OFF" },
    removalCriteria = "indefinite"
  }
end

--- Storyteller-toggled HUD frenzy image (no stat or lighting effects).
--- @param playerID string
--- @return table
function P.makeHudFrenzyCondition(playerID)
  local pd = S.getPlayerData(playerID) or {}
  local col = pd.color or "Brown"
  return {
    statChanges = {},
    hudChanges = { ["overlay_frenzy_" .. col] = true },
    removalCriteria = "indefinite"
  }
end

--- Storyteller-toggled blindfold overlay (no stat or lighting effects).
--- @param playerID string
--- @return table
function P.makeHudBlindfoldCondition(playerID)
  local pd = S.getPlayerData(playerID) or {}
  local col = pd.color or "Brown"
  return {
    statChanges = {},
    hudChanges = { ["overlay_blindfold_" .. col] = true },
    removalCriteria = "indefinite"
