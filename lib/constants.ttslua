--- Derive rotational-seat camera mode lists from canonical camera definitions.
--- - bySeat: every key in C.RedCameraAngles.forSeat
--- - universal: base keys from C.RedCameraAngles.forUniversal (strip trailing reference color, e.g. facingRed -> facing)
--- `C.UniversalCameraAngles` remains the fixed universal map consumed at runtime by M.setCamera;
--- this derivation keeps rotational source mode lists aligned with the camera definitions.
--- @return table
local function deriveTableSourceCameraModes()
  local bySeat = {}
  local universal = {}
  local seenBySeat = {}
  local seenUniversal = {}

  for modeKey, modeVal in pairs((C.RedCameraAngles or {}).forSeat or {}) do
    if type(modeKey) == "string" and type(modeVal) == "table" and not seenBySeat[modeKey] then
      seenBySeat[modeKey] = true
      table.insert(bySeat, modeKey)
    end
  end

  local referenceColor = "Red"
  for universalKey, modeVal in pairs((C.RedCameraAngles or {}).forUniversal or {}) do
    if type(universalKey) == "string" and type(modeVal) == "table" then
      local base = string.match(universalKey, "^(.*)" .. referenceColor .. "$")
      if base ~= nil and base ~= "" and not seenUniversal[base] then
        seenUniversal[base] = true
        table.insert(universal, base)
      end
    end
  end

  table.sort(bySeat)
  table.sort(universal)
  return {
    bySeat = bySeat,
    universal = universal,
  }
end
-- Table Presets

--[[
  ## gameState Additions

  seatLayout = {
    currentTableKey: string, -- The key of the currently-active table. On load, after waiting until loading is complete and objects have settled, if this value is nil, then the currently-active table should be derived by checking all table objects for the "activeTable" tag, and this value should be set accordingly.
    occupiedNPCSlots = {
      NPC1 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC.
      NPC2 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
      NPC3 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
      NPC4 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
    }
  }

1. The current-active table should be stored in gameState.
2. A top-level fuction controls switching between tables. As a first step, it should check whether the table being activated is already active and, if so, do nothing. Otherwise, the function should perform the following sequence of actions simultaneously and instantly unless otherwise specified:
   a. Toggle the blindfold overlay on for all seated players.
   b. Wait 0.5s until the blindfold overlay has fully animated in.
   c. Assemble a (local) collection, `tableSeatObjects`, containing all of the following objects:
      - all `<Color>Object`-tagged objects
      - all `<NPC1|NPC2|NPC3|NPC4>Object`-tagged objects for which gameState.seatLayout.occupiedNPCSlots is truthy
   d. Assemble a (local) collection, `unlockedTableSeatObjects`, containing the subset of `tableSeatObjects` that are (a) `<Color>Object`-tagged and (b) presently unlocked (NPC-tagged objects will always be locked).
   e. Assemble a (local) collection, `invalidActiveNPCObjects`, containing the subset of `tableSeatObjects` with "NPC<#>Object" tags that (a) refer to truthy NPC slots in gameState.seatLayout.occupiedNPCSlots, (b) have an NPC slot in the current table's playerToPositionMap, and (c) do not have an NPC slot in the new table's playerToPositionMap (e.g. if switching from "Table A" to "Table B1", then this collection should include all objects tagged "NPC2Object", "NPC3Object", and "NPC4Object", assuming all three of those slots are occupied by NPCS (i.e. gameState.seatLayout.occupiedNPCSlots is truthy for all three of those NPCs)).
   f. Assemble a (local) collection, `validInactiveNPCObjects`, containing the subset of `tableSeatObjects` with "NPC<#>Object" tags that (a) refer to truthy NPC slots in gameState.seatLayout.occupiedNPCSlots, (b) have an NPC slot in the new table's playerToPositionMap, and (c) do not have an NPC slot in the current table's playerToPositionMap (e.g. if switching from "Table B2" to "Table B1", then this collection should include all objects tagged "NPC2Object", assuming gameState.seatLayout.occupiedNPCSlots.NPC2 is truthy).
   g. Assemble a (local) collection, `playerHandZones`, containing the five player hand zones (one for each player color).
   h. Toggle lock on for all objects in `unlockedTableSeatObjects`.
   i. Deactivate (as described below) all objects in `invalidActiveNPCObjects`.
   j. Toggle visibility on for all objects in `validInactiveNPCObjects`.
   k. Move the currently-active table object and all objects listed in its 'components' field to their inactivePosition, and set their visibility to invisible for all layer colors, including White, Black and Grey.
   l. Move the new table object to its activePosition, and set its visibility active to all player colors.
   m. If the data for the new table contains a components field, filter out those components whose 'usedBy' field is false in gameState.seatLayout.occupiedNPCSlots (i.e. they are used by NPCs who are not sitting at the table), then move the remaining components to their activePosition, and set their visibility active to all player colors.
   n. Update gameState.seatLayout.currentTableKey to the key of the new table. (Do not change gameState.seatLayout.occupiedNPCSlots; when returning to a table with more slots, NPCs that couldn't sit at the table before can now sit at the new, larger table. NPC active/inactive status is controlled elsewhere.)
   o. Call R.resolveSeatObjects(newTableRef) (using the defaults for sourceObjects and options) to spawn/move objects into the new table's seats, based on the new table's data.
   p. Set all players' camera modes to (the newly calculated) "default" mode.
   q. Toggle the blindfold overlay off for all seated players.

]]
