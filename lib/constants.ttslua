-- #region Sites

-- Sites
-- Optional `skyboxURL` (string): custom table background applied via `Scenes.reconcileSkyboxFromState` when this site is live (`sessionScene.siteKey`) and `sessionScene.skyboxOverride` is unset. When omitted, a random entry from `C.GenericSkyboxes` is used.

-- Optional `isSilent = true`: full ambient mute (background, location ambience, weather); featured music may still be played via Storyteller action. Merge with `Soundscape.applyContext(Soundscape.contextFromSite(site))`.
-- Optional `soundscape.backgroundMusic.playlist = "none"`: silence background music only (location ambience and weather still apply). Omit `backgroundMusic` to use catalog default mood (`main`).
-- Optional `isTopFogActive` (boolean): when set, `SceneLibrary.applySiteTopFogToSessionScene` writes `sessionScene.isTopFogActive` on location apply; when omitted, indoor sites default fog off and outdoor on.
-- `weatherDucking` (number 0..1): per-site weather volume multiplier via `Soundscape.applyContext` (`state.siteWeatherDucking`); when omitted, indoor/outdoor catalog defaults apply.
-- Optional `mappable` (boolean, default true): when false, active PCs' map pins hide at this scene site; absent PCs may keep a cached mappable offset.

-- Generic skyboxes: A random skybox from this list should be assigned whenever a scene is set at a site without a skyboxURL.
C.GenericSkyboxes = {
  "https://steamusercontent-a.akamaihd.net/ugc/9635803439806194822/777817ED5F8282C5C7DD18FFBBF1247513C26E6A/"
}

--- Resolves the TTS background (`Backgrounds.setCustomURL`) for a site key.
--- Uses `C.Sites[siteKey].skyboxURL` when present; otherwise picks randomly from `C.GenericSkyboxes`.
--- Scene-level override is handled separately via `sessionScene.skyboxOverride` in `Scenes.reconcileSkyboxFromState`.
--- @param siteKey string|nil
--- @return string|nil url
function C.resolveSkyboxURLForSite(siteKey)
  if type(siteKey) ~= "string" then
    return nil
  end
  siteKey = string.gsub(string.gsub(siteKey, "^%s+", ""), "%s+$", "")
  if siteKey == "" then
    return nil
  end

  local site = C.Sites[siteKey]
  if type(site) == "table" and type(site.skyboxURL) == "string" then
    local authored = string.gsub(string.gsub(site.skyboxURL, "^%s+", ""), "%s+$", "")
    if authored ~= "" then
      return authored
    end
  end

  local generics = C.GenericSkyboxes
  if type(generics) ~= "table" then
    return nil
  end
  local count = #generics
  if count < 1 then
    return nil
  end
  local pick = generics[math.random(count)]
  if type(pick) ~= "string" then
    return nil
  end
  pick = string.gsub(string.gsub(pick, "^%s+", ""), "%s+$", "")
  if pick == "" then
    return nil
  end
  return pick
end

--- Resolves `C.Districts` table key for a district object reference from `C.Sites[*].district`.
--- @param district table|nil
--- @return string|nil
function C.resolveDistrictKeyForDistrictTable(district)
  if type(district) ~= "table" then
    return nil
  end
  for key, dist in pairs(C.Districts or {}) do
    if dist == district then
      return key
    end
  end
  return nil
end

--- Whether a site supports map pin placement (`mappable` defaults true when omitted).
--- @param site table|nil
--- @return boolean
function C.isSiteMappable(site)
  if type(site) ~= "table" then
    return false
  end
  if site.mappable == false then
    return false
  end
  return true
end



