-- Default Table Source Objects
-- During a table transition, if a sourceObjects table is not provided, the default table source objects will be used.
-- See .dev/Rotational Coordinate Generator.md for more information on the sourceObjects table, and how its values are expanded and parsed into objects.
-- This is a nested table with the following fields:
--   - "player": a table of objects associated with player seats
--   - "all": a table of objects associated with all seats (player seats and NPC seats)
--   - "relative": a table of objects that are relative to the hand zone anchor of the matching table slot, and should be moved to rigidly follow the corresponding hand zone anchor when the seat layout is applied
--   - "cameraModes.bySeat": keys in C.RedCameraAngles; layout writes each player’s playerData.cameraAngles and universalCameraAngles[<mode><seatKey>] from the same derived angles (including NPC seats in the map).
C.TableSourceObjects = {
  player = {
    "CSHEET_BASE",
    "CSHEET_BASE_BACK",
    "CSHEET_DICE_DRAWER",
    "CSHEET_DICE_DRAWER_ANCHOR_ON",
    "CSHEET_DICE_DRAWER_ANCHOR_OFF",
    "CSHEET_PAGE_1",
    "CSHEET_PAGE_2",
    "CSHEET_PAGE_3",
    "CSHEET_PAGE_4",
    "CSHEET_PAGE_5",
    "CSHEET_PAGE_6",
    "CSHEET_PAGE_7",
    "CSHEET_PAGE_8",
    "DICEBAG_HUNGER",
    "DICEBAG_NORMAL",
    "SIGNAL_CANDLE",
    "SIGNAL_FIRE",
    "HUNGER_SMOKE",
    "SEAT_LIGHT_3"
  },
  all = {
    "SEAT_CHAIR",
    "SEAT_FIGURE",
    "SEAT_LIGHT_1",
    "SEAT_LIGHT_2"
  },
  relative = {
    G.GUIDS.PRINCE_SIGNET_BORDER_RED,
    G.GUIDS.PRINCE_SIGNET_RED,
    G.GUIDS.PRINCE_CURTAIN_RED,
    G.GUIDS.TAROT_DECK_PINK,
    G.GUIDS.TAROT_DRAWER_PINK,
    G.GUIDS.TAROT_BUTTON_PINK,
    G.GUIDS.TAROT_BUTTON_ANCHOR_ON_PINK,
    G.GUIDS.TAROT_BUTTON_ANCHOR_OFF_PINK,
    G.GUIDS.TAROT_DRAWER_ANCHOR_ON_PINK,
    G.GUIDS.TAROT_DRAWER_ANCHOR_OFF_PINK,
    G.GUIDS.TAROT_DECK_ANCHOR_PINK,
  },
  --- Per-GUID overrides after layout: position.y, anchor+rotationDelta, optional scale ({ x,y,z } partial ok).
  postCorrections = {
    [G.GUIDS.SEAT_CHAIR_BROWN] = {
      anchor = G.GUIDS.HAND_BROWN,
      rotationDelta = Vector({0, 180, 0}),
      position = {y = -44.86}
    },
    [G.GUIDS.SEAT_CHAIR_ORANGE] = {
      anchor = G.GUIDS.HAND_ORANGE,
      rotationDelta = Vector({0, 180, 0}),
      position = {y = -17.75}
    },
    [G.GUIDS.SEAT_CHAIR_PINK] = {
      anchor = G.GUIDS.HAND_PINK,
      rotationDelta = Vector({0, 180, 0}),
      position = {y = -20.29}
    },
    [G.GUIDS.SEAT_CHAIR_PURPLE] = {
      position = {y = -37.08}
    },
    [G.GUIDS.SEAT_CHAIR_NPC1] = {
      anchor = G.GUIDS.SEAT_FIGURE_NPC1,
