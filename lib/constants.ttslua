--- Derive `sourceObjects.cameraModes.bySeat` from `C.RedCameraAngles`.
--- Per-seat `playerData.cameraAngles` and `seatLayout.universalCameraAngles[<mode><seatKey>]` are both computed
--- from these keys in `lib.rotational-seat-layout` (no separate `forUniversal` list).
--- Relative entries in `C.UniversalCameraAngles` are merged in layout when `isRelativeToReferenceHandPosition` is true.
--- @return table
local function deriveTableSourceCameraModes()
  local bySeat = {}
  local seenBySeat = {}

  for modeKey, modeVal in pairs(C.RedCameraAngles or {}) do
    if type(modeKey) == "string" and type(modeVal) == "table" and not seenBySeat[modeKey] then
      seenBySeat[modeKey] = true
      table.insert(bySeat, modeKey)
    end
  end

  table.sort(bySeat)
  return {
    bySeat = bySeat,
  }
end

