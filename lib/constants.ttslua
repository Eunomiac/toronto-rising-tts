-- Static Player Data
-- Keyed by player ID (steam_id). Storyteller uses C.StorytellerID. Other players are added by the GM when they set up character details (after a player joins and selects a seat).
-- When a new player selects a seat, their steam_id is extracted and a minimal dynamic entry is created in gameState.playerData. The GM is notified to add full character data here.
C.PlayerData = {
    [C.StorytellerID] = {
      color = "Black",
      playerName = "Storyteller",
      charName = "Storyteller"
    },
    [C.PlayerIDs.Thaumaterge] = {
      color = "Brown",
      playerName = "Thaumaterge",
      charKey = "fomorach",
      charName = "Fomórach"
    },
    [C.PlayerIDs.Hastur] = {
      color = "Orange",
      playerName = "Hastur",
      charKey = "rashid",
      charName = "Rashid Abdulrahman"
    },
    [C.PlayerIDs.PixelPuzzler] = {
      color = "Red",
      playerName = "PixelPuzzler",
      charKey = "lucien",
      charName = "Lord Lucien"
    },
    [C.PlayerIDs.JRook] = {
      color = "Pink",
      playerName = "JRook",
      charKey = "aishe",
      charName = "Aishe Tache"
    },
    [C.PlayerIDs.Roarshack] = {
      color = "Purple",
      playerName = "Roarshack",
      charKey = "blackCaesar",
      charName = "Black Caesar"
    }
}

-- playerRef can be a color, a player name, or a character key
C.GetPlayerID = function(playerRef)
  if type(playerRef) == "string" then
    if C.PlayerIDs[playerRef] then
      return C.PlayerIDs[playerRef]
    end
    if C.PlayerData[playerRef] then
      return playerRef
    end
    -- Otherwise, search C.PlayerData for color, playerName, or charKey (case-insensitive).
    -- Guard optional fields: e.g. Storyteller row has no charKey; string.lower(nil) errors and broke lookups like PURPLE→Purple (iter order hit Storyteller first).
    local lr = string.lower(playerRef)
    for playerID, playerData in pairs(C.PlayerData) do
      if type(playerData) == "table" then
        local col, nm, ck = playerData.color, playerData.playerName, playerData.charKey
        if (type(col) == "string" and string.lower(col) == lr)
          or (type(nm) == "string" and string.lower(nm) == lr)
          or (type(ck) == "string" and string.lower(ck) == lr) then
          return playerID
        end
      end
    end
  end
  error("Invalid player reference: " .. tostring(playerRef))
end


