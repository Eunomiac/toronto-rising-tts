-- #region Camera Modes

-- Camera Modes
-- These are the camera modes that can be used to control the camera. This object contains the mode as the key, and either "bySeat" if the camera angle should be determined by the table seating functionality, or "universal" if the camera angle is the same for all players.
C.CameraModes = {
  default = "bySeat",
  sheet = "bySeat",
  roll = "bySeat",
  diceTray = "bySeat",
  districtCard = "universal",
  siteCard = "universal",
  npcCenter = "universal",
  npcNearLeft = "universal",
  npcNearRight = "universal",
  npcFarLeft = "universal",
  npcFarRight = "universal",
  wide = "universal",
  wideFacing = "universal"
}

-- Reference Color Red Camera Angles
-- These are the camera angle definitions that are defined for the Red seat, but that will need to be rotated and defined for each of the other player seats.
-- Each of these derived camera angles should be written into two locations in game state:
--    - "gameState.playerData[playerID].cameraAngles[cameraMode]": each camera angle should be written to each player's playerData leaving the mode name unchanged (e.g. "default", "facing", "sheet", etc.)
--    - "gameState.seatLayout.universalCameraAngles[cameraMode + seatKey]": each camera angle should also be made available to all players, by writing it to the seatLayout.universalCameraAngles object, with the seat key appended to the mode name (e.g. "facing" -> "facingBrown", "facingRed", "facingNPC1", etc.)  Note that, even though the NPC slots do not have player data (and thus won't have their own "facing", etc. entries), they will still need universal "facingNPC1", "sheetNPC2", etc. angles calculated for this step.

--[[ To be clear, after R.resolveSeatObjectsFromTable() is called, the "universal" camera modes will include one of every entry in C.UniversalCameraAngles, plus the following: "facingRed", "facingBrown", "facingOrange", "facingPink" and "facingPurple", as well as some number of "facingNPC1", "facingNPC2", "facingNPC3" and "facingNPC4" depending on which slots are open in the playerToPositionMap of the new table configuration -- and then the same for "sheetRed", "sheetBrown", ... and "diceTrayRed", "diceTrayBrown", ... etc. ]]

