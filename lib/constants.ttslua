--- Lighting preset when `sessionScene.siteKey` is absent (see `Scenes.syncSessionLightingPresetForLocation`).
C.DefaultNoLocationLightingPresetKey = "OutdoorDim"

--- @param key any
--- @return boolean
function C.isValidLightModeKey(key)
  if type(key) ~= "string" or key == "" then
    return false
  end
  return type(C.LightModes[key]) == "table"
end

--- Seat-dark override: `sessionScene.lightingPresetKey` or legacy admin scene name.
--- @param key any
--- @return boolean
function C.isDarkLightingPresetKey(key)
  if type(key) ~= "string" or key == "" then
    return false
  end
  if key == "dark" or key == "AdminDark" or key == "DARK" then
    return true
  end
  return string.sub(key, -4) == "Dark"
end

