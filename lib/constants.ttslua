-- Player Colors (PC seats). Storyteller may sit any TTS color; use C.GetPlayerColor for their live seat.
C.PlayerColors = {
    "Brown", "Orange", "Red", "Pink", "Purple"
}

--- Resolve playerRef to a storage / Steam ID string (Storyteller normalized to C.StorytellerID).
-- Accepts a TTS Player, steam id key, nickname key in C.PlayerIDs, seat color, playerName, charKey, or "Host"/"Storyteller".
-- @param playerRef Player|string
-- @return string
C.GetPlayerID = function(playerRef)
  if playerRef == nil then
    error("Invalid player reference: nil")
  end

  if type(playerRef) == "userdata" then
    ---@cast playerRef Player
    if playerRef.steam_id == nil then
      error("Invalid player reference: not a Player (missing steam_id)")
    end
    local sid = tostring(playerRef.steam_id)
    if sid == C.StorytellerID then
      return C.StorytellerID
    end
    return sid
  end

  if type(playerRef) ~= "string" then
    error("Invalid player reference: " .. tostring(playerRef))
  end

  if C.PlayerIDs[playerRef] then
    return C.PlayerIDs[playerRef]
  end
  if C.PlayerData[playerRef] then
    return playerRef
  end

  local lr = string.lower(playerRef)
  if lr == "host" or lr == "storyteller" then
    if Player ~= nil and type(Player.getAvailableColors) == "function" then
      for _, color in ipairs(Player.getAvailableColors()) do
        local p = Player[color]
        if p ~= nil and p.steam_id ~= nil and tostring(p.steam_id) == C.StorytellerID then
          return C.StorytellerID
        end
      end
    end
    return C.StorytellerID
  end

  for playerID, playerData in pairs(C.PlayerData) do
    if type(playerData) == "table" then
      local col, nm, ck = playerData.color, playerData.playerName, playerData.charKey
      if (type(col) == "string" and string.lower(col) == lr)
        or (type(nm) == "string" and string.lower(nm) == lr)
        or (type(ck) == "string" and string.lower(ck) == lr) then
        return playerID
      end
    end
  end
  error("Invalid player reference: " .. tostring(playerRef))
end

--- Same resolution rules as `C.GetPlayerID`, but returns nil instead of erroring (for soft lookups).
--- @param playerRef Player|string|nil
--- @return string|nil
C.GetPlayerIDOrNil = function(playerRef)
  if playerRef == nil then
    return nil
  end

  if type(playerRef) == "userdata" then
    ---@cast playerRef Player
    if playerRef.steam_id == nil then
      return nil
    end
    local sid = tostring(playerRef.steam_id)
    if sid == C.StorytellerID then
      return C.StorytellerID
    end
    return sid
  end

  if type(playerRef) ~= "string" then
    return nil
  end

  if C.PlayerIDs[playerRef] then
    return C.PlayerIDs[playerRef]
  end
  if C.PlayerData[playerRef] then
    return playerRef
  end

  local lr = string.lower(playerRef)
  if lr == "host" or lr == "storyteller" then
    if Player ~= nil and type(Player.getAvailableColors) == "function" then
      for _, color in ipairs(Player.getAvailableColors()) do
        local p = Player[color]
        if p ~= nil and p.steam_id ~= nil and tostring(p.steam_id) == C.StorytellerID then
          return C.StorytellerID
        end
      end
    end
    return C.StorytellerID
  end

  for playerID, playerData in pairs(C.PlayerData) do
    if type(playerData) == "table" then
      local col, nm, ck = playerData.color, playerData.playerName, playerData.charKey
      if (type(col) == "string" and string.lower(col) == lr)
        or (type(nm) == "string" and string.lower(nm) == lr)
        or (type(ck) == "string" and string.lower(ck) == lr) then
        return playerID
      end
    end
  end
  return nil
end

--- Current TTS seat color for this player (Host may not be seated at Black).
-- @param playerRef Player|string
-- @return string|nil
C.GetPlayerColor = function(playerRef)
  if playerRef == nil then
    return nil
  end

  local playerID = nil
  if type(playerRef) == "userdata" then
    ---@cast playerRef Player
    if playerRef.steam_id ~= nil and tostring(playerRef.steam_id) == C.StorytellerID then
      playerID = C.StorytellerID
    elseif playerRef.steam_id ~= nil then
      playerID = tostring(playerRef.steam_id)
    else
      return playerRef.color
    end
  else
    playerID = C.GetPlayerIDOrNil(playerRef)
    if type(playerID) ~= "string" then
      return nil
    end
  end

  if Player ~= nil and type(Player.getAvailableColors) == "function" then
    for _, color in ipairs(Player.getAvailableColors()) do
      local p = Player[color]
      if p ~= nil and p.steam_id ~= nil and tostring(p.steam_id) == playerID then
        return color
      end
    end
  end

  if type(playerRef) == "userdata" then
    ---@cast playerRef Player
    if playerRef.color ~= nil then
      return playerRef.color
    end
  end
  return nil
end

