-- #endregion

-- #region Weather
--[[
`./json/Weather.json` contains an entry for every month of the year. Each entry contains an `"avgTemp"` key, and a `"weather"` key.
The `"weather"` key contains one entry for each day of the month. Each of those entries is a 24-element array of five-character codes, representing the weather conditions for that hour.
To derive the weather for a given hour from its five-character code, the hour's code should be parsed as follows:

- Character 1 & Character 2: Base weather string. Lookup in `C.WEATHER.Base`. Each entry contains a descriptive text string to be added to the associated element in the HUD, the audio key for the rain emitter, and a boolean indicating whether there is thunder.
- Character 3: Temperature delta. Lookup in `C.WEATHER.TemperatureDelta`, then add to `"avgTemp"` for the month. This value is in Celsius, so convert to Fahrenheit by multiplying by 1.8 and adding 32 to provide both temperatures in the HUD.
- Character 4: Humidity. Lookup in `C.WEATHER.Humidity`. This is a descriptive text string to be added to the associated HUD element.
- Character 5: Wind. Lookup in `C.WEATHER.Wind`. Each entry contains a descriptive text string to be added to the associated HUD element, as well as two audio keys for the wind emitter: `"windAudioIfWarm"` and `"windAudioIfCold"`. The warm audio key is used if the temperature is above `C.WEATHER.WARM_TEMPERATURE_THRESHOLD`, the cold audio key is used if the temperature is at or below.
]]

C.WEATHER = {
  WARM_TEMPERATURE_THRESHOLD = 0,
  Base = {
    xx = {
      text = "Clear",
      rainAudio = "silent",
      isThunder = false
    },
    xf = {
      text = "Foggy",
      rainAudio = "silent",
      isThunder = false
    },
    bx = {
      text = "Blizzard",
      rainAudio = "silent",
      isThunder = false
    },
    bf = {
      text = "Whiteout",
      rainAudio = "silent",
      isThunder = false
    },
    cx = {
      text = "Overcast",
      rainAudio = "silent",
      isThunder = false
    },
    cf = {
      text = "Thick Fog",
      rainAudio = "silent",
      isThunder = false
    },
    px = {
      text = "Downpour",
      rainAudio = "rainHeavy",
      isThunder = false
    },
    pf = {
      text = "Foggy Downpour",
      rainAudio = "rainHeavy",
      isThunder = false
    },
    sx = {
      text = "Snowing",
      rainAudio = "silent",
      isThunder = false
    },
    sf = {
      text = "Whiteout",
      rainAudio = "silent",
      isThunder = false
    },
    tx = {
      text = "Thunderstorm",
      rainAudio = "rainHeavy",
      isThunder = true
    },
    tf = {
      text = "Thunderstorm",
      rainAudio = "rainHeavy",
      isThunder = true
    },
    wx = {
      text = "Raining",
      rainAudio = "rainLight",
      isThunder = false
    },
    wf = {
      text = "Drizzle",
      rainAudio = "rainLight",
      isThunder = false
    }
  },
  TemperatureDelta = {
    ["0"] = 0,
    A = 1,
    B = 2,
    C = 3,
    D = 4,
    E = 5,
    F = 6,
    G = 7,
    H = 8,
    I = 9,
    J = 10,
    K = 11,
    L = 12,
    M = 13,
    N = 14,
    O = 15,
    P = 16,
    Q = 17,
    R = 18,
    S = 19,
    T = 20,
    U = 21,
    V = 22,
    W = 23,
    X = 24,
    Y = 25,
    Z = 26,
    a = -1,
    b = -2,
    c = -3,
    d = -4,
    e = -5,
    f = -6,
    g = -7,
    h = -8,
    i = -9,
    j = -10,
    k = -11,
    l = -12,
    m = -13,
    n = -14,
    o = -15,
    p = -16,
    q = -17,
    r = -18,
    s = -19,
    t = -20,
    u = -21,
    v = -22,
    w = -23,
    x = -24,
    y = -25,
    z = -26
  },
  Humidity = {
    x = nil, -- The humidity text element should be set inactive if the humidity is nil.
    d = " ◆ Dry",
    h = " ◆ Humid",
    m = " ◆ Muggy",
    s = " ◆ Stifling"
  },
  Wind = {
    x = {
      textIfWarm = " ◆ Still",
      textIfCold = " ◆ Still",
      windAudioIfWarm = "silent",
      windAudioIfCold = "silent"
    },
    s = {
      textIfWarm = " ◆ Soft Breeze",
      textIfCold = " ◆ Chill Breeze",
      windAudioIfWarm = "silent",
      windAudioIfCold = "windWinterLow"
    },
    b = {
      textIfWarm = " ◆ Breeze",
      textIfCold = " ◆ Cutting Breeze",
      windAudioIfWarm = "windLow",
      windAudioIfCold = "windWinterLow"
    },
    w = {
      textIfWarm = " ◆ Blustery",
      textIfCold = " ◆ Freezing Winds",
      windAudioIfWarm = "windMed",
      windAudioIfCold = "windWinterMed"
    },
    g = {
      textIfWarm = " ◆ Gale",
      textIfCold = " ◆ Driving Winds",
      windAudioIfWarm = "windMed",
      windAudioIfCold = "windWinterMed"
    },
    h = {
      textIfWarm = " ◆ Howling Winds",
      textIfCold = " ◆ Howling Winds",
      windAudioIfWarm = "windMax",
      windAudioIfCold = "windWinterMax"
    },
    v = {
      textIfWarm = " ◆ Violent Winds",
      textIfCold = " ◆ Violent Winds",
      windAudioIfWarm = "windMax",
      windAudioIfCold = "windWinterMax"
    }
  }
}

-- If a scene overrides weather audio or sets thunderstorm to true, the HUD elements should be changed as follows:
C.WEATHER_AUDIO_OVERRIDES = {
  windAudio = {
    silent = { Wind = " ◆ Still" },
    windLow = { Wind = " ◆ Soft Breeze" },
    windMed = { Wind = " ◆ Blustery" },
    windMax = { Wind = " ◆ Violent Winds" },
    windWinterLow = { Wind = " ◆ Chill Breeze" },
    windWinterMed = { Wind = " ◆ Freezing Winds" },
    windWinterMax = { Wind = " ◆ Howling Winds" },
  },
  rainAudio = {
    silent = { Base = "Clear" },
    rainLight = { Base = "Raining" },
    rainHeavy = { Base = "Downpour" },
  },
  thunderstorm = {
    forcedOn = { Base = "Thunderstorm", Wind = " ◆ Violent Winds" },
    forcedOff = { Base = "BY_RAIN_AUDIO", Wind = "BY_WIND_AUDIO" }
  }
}
-- #endregion
return C
