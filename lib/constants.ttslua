--- Derive `sourceObjects.cameraModes.bySeat` from `C.ReferenceCameraAngles`.
--- Per-seat `playerData.cameraAngles` and `seatLayout.universalCameraAngles[<mode><seatKey>]` are both computed
--- from these keys in `lib.rotational-seat-layout` (no separate `forUniversal` list).
--- Relative entries in `C.UniversalCameraAngles` are merged in layout when `isRelativeToReferenceHandPosition` is true.
--- @return table
local function deriveTableSourceCameraModes()
  local bySeat = {}
  local seenBySeat = {}

  for modeKey, modeVal in pairs(C.ReferenceCameraAngles or {}) do
    if type(modeKey) == "string" and type(modeVal) == "table" and not seenBySeat[modeKey] then
      seenBySeat[modeKey] = true
      table.insert(bySeat, modeKey)
    end
  end

  table.sort(bySeat)
  return {
    bySeat = bySeat,
  }
end

-- #endregion

-- #region Table Seats
-- Table Presets

--[[
  ## gameState Additions

  seatLayout = {
    currentTableKey: string, -- The key of the currently-active table. On load, after waiting until loading is complete and objects have settled, if this value is nil, then the currently-active table should be derived by checking all table objects for the "activeTable" tag, and this value should be set accordingly.
    occupiedNPCSlots = {
      NPC1 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC.
      NPC2 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
      NPC3 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
      NPC4 = false|string, -- false if the slot is empty, or a key in D.characters of `npcs_data.ttslua` if the slot is occupied by an NPC
    }
  }

1. The current-active table should be stored in gameState.
2. A top-level fuction controls switching between tables. As a first step, it should check whether the table being activated is already active and, if so, do nothing. Otherwise, the function should perform the following sequence of actions simultaneously and instantly unless otherwise specified:
   a. Scene apply and manual table toggles call `core.hud_blindfold.runTransition`: pick one random blindfold variant (1..C.BlindfoldVariantCount) shared by all seated players, run table geometry + reconcilers, then lift blindfolds after a 10s settle delay.
   b. `RSL.SetTableTo(..., { skipTransitionBlindfold = true })` performs seat geometry only when an outer transition blindfold is already active.
   c. Assemble a (local) collection, `tableSeatObjects`, containing all of the following objects:
      - all `<Color>Object`-tagged objects
      - all `<NPC1|NPC2|NPC3|NPC4>Object`-tagged objects for which gameState.seatLayout.occupiedNPCSlots is truthy
   d. Assemble a (local) collection, `unlockedTableSeatObjects`, containing the subset of `tableSeatObjects` that are (a) `<Color>Object`-tagged and (b) presently unlocked (NPC-tagged objects will always be locked).
   e. Assemble a (local) collection, `invalidActiveNPCObjects`, containing the subset of `tableSeatObjects` with "NPC<#>Object" tags that (a) refer to truthy NPC slots in gameState.seatLayout.occupiedNPCSlots, (b) have an NPC slot in the current table's seatToPositionMap, and (c) do not have an NPC slot in the new table's seatToPositionMap (e.g. if switching from "Table A" to "Table B1", then this collection should include all objects tagged "NPC2Object", "NPC3Object", and "NPC4Object", assuming all three of those slots are occupied by NPCS (i.e. gameState.seatLayout.occupiedNPCSlots is truthy for all three of those NPCs)).
   f. Assemble a (local) collection, `validInactiveNPCObjects`, containing the subset of `tableSeatObjects` with "NPC<#>Object" tags that (a) refer to truthy NPC slots in gameState.seatLayout.occupiedNPCSlots, (b) have an NPC slot in the new table's seatToPositionMap, and (c) do not have an NPC slot in the current table's seatToPositionMap (e.g. if switching from "Table B2" to "Table B1", then this collection should include all objects tagged "NPC2Object", assuming gameState.seatLayout.occupiedNPCSlots.NPC2 is truthy).
   g. Assemble a (local) collection, `playerHandZones`, containing the five player hand zones (one for each player color).
   h. Toggle lock on for all objects in `unlockedTableSeatObjects`.
   i. Deactivate (as described below) all objects in `invalidActiveNPCObjects`.
   j. Toggle visibility on for all objects in `validInactiveNPCObjects`.
   k. Move the currently-active table object and all objects listed in its 'components' field to their inactivePosition, and set their visibility to invisible for all layer colors, including White, Black and Grey.
   l. Move the new table object to its activePosition, and set its visibility active to all player colors.
   m. If the data for the new table contains a components field, filter out those components whose 'usedBy' field is false in gameState.seatLayout.occupiedNPCSlots (i.e. they are used by NPCs who are not sitting at the table), then move the remaining components to their activePosition, and set their visibility active to all player colors.
   n. Update gameState.seatLayout.currentTableKey to the key of the new table. (Do not change gameState.seatLayout.occupiedNPCSlots; when returning to a table with more slots, NPCs that couldn't sit at the table before can now sit at the new, larger table. NPC active/inactive status is controlled elsewhere.)
   o. Call R.resolveSeatObjectsFromTable(newTableRef) (using the defaults for sourceObjects and options) to spawn/move objects into the new table's seats, based on the new table's data.
   p. When the outer `hud_blindfold` settle delay before blindfold lift begins, set all seated players' cameras to (the newly calculated) "default" mode via `M.setCamera`.
   q. Outer `hud_blindfold` transition clears the chosen blindfold variant after the settle delay.

]]
C.TableShapes = {
  CIRCULAR = "circular", -- Seats should be arranged via the rotational seat layout coordinate generator. Configurations of CIRCULAR tables must include `numSegments` and `angleSegmentOne` fields, with a `seatToPositionMap` field that defines each seat's position on the table as an index value (1..numSegments).
  RECTANGULAR = "rectangular", -- Does not include `numSegments` and `angleSegmentOne` fields. Instead, seat positons must be defined under `seatToPositionMap` in the table configuration (instead of an index integer). Each seat position's definition includes a "side" field, defined as an angle in multiples of 90 degrees pointing from the origin to the side of the table that the seat is on, following standard conventions (where 0° is the +Z axis, 90° is the +X axis, 180° is the -Z axis, and 270° is the -X axis), and an "index" value indicating the position of that seat along that side, moving clockwise from the origin (e.g. side = 0, index = 1 means the seat is the left-most position on the +Z side of the table).
  FACING = "facing" -- As with rectangular, except there are only two sides (0 and 180 degrees). Configurations of FACING tables must include a `seatToPositionMap` field that defines each seat's position on the table in the same way as RECTANGULAR tables.
}

