-- Camera Modes
-- These are the camera modes that can be used to control the camera. This object contains the mode as the key, and either "bySeat" if the camera angle should be determined by the table seating functionality, or "universal" if the camera angle is the same for all players.
C.CameraModes = {
  default = "bySeat",
  sheet = "bySeat",
  roll = "bySeat",
  diceTray = "bySeat",
  districtCard = "universal",
  siteCard = "universal",
  npcCenter = "universal",
  npcNearLeft = "universal",
  npcNearRight = "universal",
  npcFarLeft = "universal",
  npcFarRight = "universal",
  wide = "universal",
  wideFacing = "universal"
}

-- Reference Color Red Camera Angles
-- These are the camera angle definitions that are defined for the Red seat, but that will need to be rotated and defined for each of the other player seats.
-- The two fields determine how the camera angles are meant to be used:
--    - "forSeat": these camera angles should be written to the gameState.playerData[playerID].cameraAngles[cameraMode] after being rotated for the corresponding seat.
--    - "forUniversal": these camera angles are all named with the form "<cameraMode>Red", and are meant to be universal camera angles -- e.g. "facingRed" is a camera angle anyone can use to direct their view towards the Red player. For each of these, corresponding camera angles should be rotated and defined for each seat at the time R.resolveSeatObjectsFromTable() is called, including all NPC slots in the playerToPositionMap. However, they shouldn't be stored in playerData because they are meant to be universal: They should instead be stored at a higher-level state variable, and merged with the fixed C.UniversalCameraAngles object to create the final universal camera angles set that all players will use (and that M.setCamera() and related functions will draw from).

--[[ To be clear, after R.resolveSeatObjectsFromTable() is called, the "universal" camera modes will include one of every entry in C.UniversalCameraAngles, plus the following: "facingRed", "facingBrown", "facingOrange", "facingPink" and "facingPurple", as well as some number of "facingNPC1", "facingNPC2", "facingNPC3" and "facingNPC4" depending on which slots are open in the playerToPositionMap of the new table configuration -- and then the same for "sheetRed", "sheetBrown", ... and "diceTrayRed", "diceTrayBrown", ... etc. ]]

--[[

EXECUTE TO REFRESH CAMERA ANGLES:

local function cloneMode(mode)
    return {
        cameraMode = mode.cameraMode or "FirstPerson",
        position = Vector(mode.position or {0, 0, 0}),
        pitch = tonumber(mode.pitch) or 0,
        yaw = tonumber(mode.yaw) or 0,
        distance = tonumber(mode.distance) or 0,
    }
end

local storytellerID = C.StorytellerID

-- Ensure storyteller row exists
if S.getStateVal("playerData", storytellerID) == nil then
    S.setStateVal({
        color = "Black",
        hud = {},
        cameraAngles = {},
    }, "playerData", storytellerID)
end

-- Seed per-seat modes from Red reference
for modeKey, modeVal in pairs(C.RedCameraAngles.forSeat or {}) do
    if type(modeVal) == "table" then
        S.setStateVal(cloneMode(modeVal), "playerData", storytellerID, "cameraAngles", modeKey)
    end
end

-- Optional: also seed universal-facing variants onto storyteller's row for quick testing
-- (normally universal modes are read from C.UniversalCameraAngles + seatLayout.universalCameraAngles)
for modeKey, modeVal in pairs(C.RedCameraAngles.forUniversal or {}) do
    if type(modeVal) == "table" then
        S.setStateVal(cloneMode(modeVal), "playerData", storytellerID, "cameraAngles", modeKey)
    end
end

print("[CameraSeed] Storyteller camera angles seeded from C.RedCameraAngles.")
print(JSON.encode_pretty(S.getStateVal("playerData", storytellerID, "cameraAngles")))

local S = Global.getTable("S")
if not S then
  print("[cleanup] S module not available")
  return
end

local pid = "76561198002132577" -- StorytellerID
local pdata = S.getStateVal("playerData", pid)
if type(pdata) ~= "table" or type(pdata.cameraAngles) ~= "table" then
  print("[cleanup] No storyteller cameraAngles found")
  return
end

local moved = 0
local kept = 0
local universal = S.getStateVal("seatLayout", "universalCameraAngles")
if type(universal) ~= "table" then
  universal = {}
end

for k, v in pairs(pdata.cameraAngles) do
  if type(k) == "string" and string.match(k, "^[%a_]+Red$") then
    universal[k] = v
    pdata.cameraAngles[k] = nil
    moved = moved + 1
  else
    kept = kept + 1
  end
end

S.setStateVal(universal, "seatLayout", "universalCameraAngles")
S.setStateVal(pdata.cameraAngles, "playerData", pid, "cameraAngles")

print(string.format("[cleanup] moved=%d kept=%d", moved, kept))




]]

