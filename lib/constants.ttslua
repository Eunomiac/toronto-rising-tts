  "npcLight2NPC1",
  "npcLight2NPC2",
  "npcLight2NPC3",
  "npcLight2NPC4",
  "playerLight3Red",
  "playerLight3Orange",
  "playerLight3Pink",
  "playerLight3Brown",
  "playerLight3Purple",
  "famulusLight1Red",
  "famulusLight1Brown",
  "famulusLight2Red",
  "famulusLight2Brown",
  "storytellerDiceLight1",
  "storytellerDiceLight2",
  "storytellerDiceLight3"
}

--- @param modeStr string
--- @return table
local function spotlightMapUniform(modeStr)
  local t = {}
  for _, k in ipairs(LIGHTMODES_REGISTRY_KEYS_ORDERED) do
    t[k] = modeStr
  end
  return t
end

--- Chronicle scene spotlights: uniform seat/NPC/dice modes + optional main-table inline patch.
--- @param mainLightPatch table|string|nil inline patch or mode name for both main lights; nil → `"STANDARD"`
--- @param seatMode string|nil uniform registry mode for all other spotlight keys (default `"STANDARD"`)
--- @return table
local function chronicleSpotlights(mainLightPatch, seatMode)
  seatMode = seatMode or "STANDARD"
  local t = spotlightMapUniform(seatMode)
  local mainSpec = mainLightPatch or "STANDARD"
  t.mainLightLeft = mainSpec
  t.mainLightRight = mainSpec
  return t
end

--- Directional overhead tints for chronicle location presets (`Lighting.setLightColor`).
local CHRONICLE_OVERHEAD_INDOOR = Color(1.00, 0.85, 0.62, 1)
local CHRONICLE_OVERHEAD_OUTDOOR = Color(0.88, 0.93, 1.00, 1)
local CHRONICLE_OVERHEAD_UNDERGROUND = Color(0.78, 0.90, 0.80, 1)

--- Chronicle location preset: zero ambient; former ambient fill on directional overhead (`light_intensity`).
--- @param lightIntensity number
--- @param reflectionIntensity number
--- @param overheadTint userdata `Color` for `setLightColor`
--- @param mainLightPatch table|string|nil
--- @param seatMode string|nil
--- @return table
local function chronicleOverheadPreset(lightIntensity, reflectionIntensity, overheadTint, mainLightPatch, seatMode)
  return {
    ambient_intensity = 0,
    ambient_type = 1,
    light_intensity = lightIntensity,
    lut_contribution = 0,
    lut_index = 1,
    reflection_intensity = reflectionIntensity,
    setLightColor = overheadTint,
    spotlights = chronicleSpotlights(mainLightPatch, seatMode),
  }
end

