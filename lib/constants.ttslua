-- #region Light Presets

-- Registry keys matching `core/lighting.ttslua` `L.LIGHTMODES` (admin / uniform spotlight maps).
local LIGHTMODES_REGISTRY_KEYS_ORDERED = {
  "mainLightLeft",
  "mainLightRight",
  "playerLight1Brown",
  "playerLight1Orange",
  "playerLight1Red",
  "playerLight1Pink",
  "playerLight1Purple",
