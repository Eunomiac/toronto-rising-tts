-- #region Light Presets

-- Registry keys matching `core/lighting.ttslua` `L.LIGHTMODES` (admin / uniform spotlight maps).
local LIGHTMODES_REGISTRY_KEYS_ORDERED = {
  "gmLight",
  "mainLightLeft",
  "mainLightRight",
  "playerLight1Brown",
  "playerLight1Orange",
  "playerLight1Red",
  "playerLight1Pink",
  "playerLight1Purple",
  "playerLight2Brown",
  "playerLight2Orange",
  "playerLight2Red",
  "playerLight2Pink",
  "playerLight2Purple",
  "npcLight1NPC1",
  "npcLight1NPC2",
  "npcLight1NPC3",
  "npcLight1NPC4",
  "npcLight2NPC1",
  "npcLight2NPC2",
  "npcLight2NPC3",
  "npcLight2NPC4",
  "playerLight3Red",
  "playerLight3Orange",
  "playerLight3Pink",
  "playerLight3Brown",
  "playerLight3Purple",
}

--- @param modeStr string
--- @return table
local function spotlightMapUniform(modeStr)
  local t = {}
  for _, k in ipairs(LIGHTMODES_REGISTRY_KEYS_ORDERED) do
    t[k] = modeStr
  end
  return t
end

