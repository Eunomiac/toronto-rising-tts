    tracks = getTracks("location", nil, Catalog.PLAYMODES.SELECT)
  },
  featureMusic = {
    mainThemeFull = {
      playMode = Catalog.PLAYMODES.SEQUENCE,
      crossFadeSeconds = 0,
      tracks = getTracks("featureMusic", "mainThemeFull", Catalog.PLAYMODES.SEQUENCE)
    },
    mainThemeLoop = {
      playMode = Catalog.PLAYMODES.SEQUENCE,
      crossFadeSeconds = 0,
