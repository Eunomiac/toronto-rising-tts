    },
    scarlettAndTheBoys = {
      playMode = Catalog.PLAYMODES.SELECT,
      crossFadeSeconds = 0,
      tracks = getTracks("featureMusic", "scarlettAndTheBoys", Catalog.PLAYMODES.SELECT)
    }
  },
  weather = {
    rain = {
      playMode = Catalog.PLAYMODES.SELECT,
