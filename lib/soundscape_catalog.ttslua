local function getTracks(type, subType, playMode)
  local tracks = {}
  local usedSequenceOrders = {}
  for _, track in pairs(Catalog.TRACKS) do
    if track.type == type and (subType == nil or track.subType == subType) then
      if playMode == "SEQUENCE" then
        local order = tonumber(track.order) or 1
        if usedSequenceOrders[order] ~= nil then
          error(
            "Duplicate soundscape sequence order "
            .. tostring(order)
            .. " for playlist "
            .. tostring(type)
            .. "."
            .. tostring(subType or "")
            .. ": "
            .. tostring(usedSequenceOrders[order].key)
            .. " and "
            .. tostring(track.key)
          )
        end
        usedSequenceOrders[order] = track
      end
      table.insert(tracks, {
        key = track.key,
        effect = track.key,
        effectList = track.isLooping == true and Catalog.EFFECT_LIST.LOOPING or Catalog.EFFECT_LIST.TRIGGER,
        durationSeconds = track.duration,
        volume = track.volume,
        order = track.order,
      })
    end
  end
  if playMode == "SEQUENCE" then
    table.sort(tracks, function(left, right)
      local leftOrder = tonumber(left.order) or 1
      local rightOrder = tonumber(right.order) or 1
      if leftOrder == rightOrder then
        return tostring(left.key) < tostring(right.key)
      end
      return leftOrder < rightOrder
    end)
  end
  return tracks
end

Catalog.PLAYMODES = {
  RANDOMLOOP = "RANDOMLOOP", -- Play random tracks from the playlist in sequence indefinitely
  SELECT = "SELECT",         -- One track should be selected by key. The track's `isLooping` property determines if it should loop.
  RANDOM = "RANDOM",         -- Randomly select one track from the playlist and play it. The track's `isLooping` property determines if it should loop.
  SEQUENCE = "SEQUENCE",     -- Play tracks from the playlist in sequence. The track's `isLooping` property determines if it should loop.
}

Catalog.PLAYLISTS = { -- Note: Some of these values are nested by subcategory, others (without subcategories) are top-level keys
  silence = {
    playMode = Catalog.PLAYMODES.SEQUENCE,
    crossFadeSeconds = 0,
    tracks = getTracks("silence", nil, Catalog.PLAYMODES.SEQUENCE)
  },
  backgroundMusic = {
    main = {
      playMode = Catalog.PLAYMODES.RANDOMLOOP,
      crossFadeSeconds = 5,
      tracks = getTracks("backgroundMusic", "main", Catalog.PLAYMODES.RANDOMLOOP)
    },
    combat = {
      playMode = Catalog.PLAYMODES.RANDOMLOOP,
      crossFadeSeconds = 5,
      tracks = getTracks("backgroundMusic", "combat", Catalog.PLAYMODES.RANDOMLOOP)
