Catalog.DEFAULTS = {
  musicMood = "main",
  locationMusic = "none",
  featuredMusic = "none",
  location = "none",
  weather = "none",
  rain = "none",
  wind = "none",
  thunderEnabled = false,
  isIndoors = false,
  weatherDucking = {
    outdoorMultiplier = 1.0,
    indoorMultiplier = 0.25,
  },
  thunderScheduling = {
    minDelaySeconds = 18,
    maxDelaySeconds = 55,
  },
  fadeSeconds = {
    music = 8.0,
    featured = 2.0,
    weather = 3.0,
    location = 4.0,
  },
}

Catalog.WEATHER_CONDITIONS = {
  none = { label = "None", rain = "none", wind = "none", thunderEnabled = false, volume = 0 },
  rainLight = { label = "Light Rain", rain = "rainLight", wind = "none", thunderEnabled = false, volume = 0.5 },
  rainHeavy = { label = "Heavy Rain", rain = "rainHeavy", wind = "none", thunderEnabled = false, volume = 0.5 },
  wind = { label = "Wind", rain = "none", wind = "windMed", thunderEnabled = false, volume = 0.5 },
  thunderstorm = { label = "Thunderstorm", rain = "rainHeavy", wind = "windWinterMax", thunderEnabled = true, volume = 0.5 },
}

local function getByStringKey(group, key)
  if type(group) ~= "table" or type(key) ~= "string" then
    return nil
  end
  return group[key]
end

local function getTrackByKey(playlist, trackKey)
  if type(trackKey) ~= "string" or type(playlist) ~= "table" or type(playlist.tracks) ~= "table" then
    return nil
  end
  for _, track in ipairs(playlist.tracks) do
    if track.key == trackKey then
      return track
    end
  end
  return nil
end

local function getTrackFromNestedPlaylists(group, trackKey)
  if type(trackKey) ~= "string" or type(group) ~= "table" then
    return nil
  end
  for _, playlist in pairs(group) do
    local track = getTrackByKey(playlist, trackKey)
    if track ~= nil then
      return track
    end
  end
  return nil
end

--- Returns a background music playlist by exact generated playlist key.
-- @param playlistKey string
-- @return table|nil
function Catalog.getBackgroundPlaylist(playlistKey)
  return getByStringKey(Catalog.PLAYLISTS.backgroundMusic, playlistKey)
end

--- Returns a location ambience track by exact generated track key.
-- @param trackKey string
-- @return table|nil
function Catalog.getLocationTrack(trackKey)
  return getTrackByKey(Catalog.PLAYLISTS.location, trackKey)
end

--- Returns a featured music track by exact generated track key.
-- @param trackKey string
-- @return table|nil
function Catalog.getFeaturedTrack(trackKey)
  return getTrackFromNestedPlaylists(Catalog.PLAYLISTS.featureMusic, trackKey)
end

--- Returns a weather track by layer and exact generated track key.
-- @param layerKey string One of "rain", "wind", or "thunder".
-- @param trackKey string
-- @return table|nil
function Catalog.getWeatherTrack(layerKey, trackKey)
  local weather = Catalog.PLAYLISTS.weather
  local playlist = type(weather) == "table" and weather[layerKey] or nil
  return getTrackByKey(playlist, trackKey)
end

local function collectNestedPlaylistTracks(group)
  local tracks = {}
  if type(group) ~= "table" then
    return tracks
  end
  for playlistKey, playlist in pairs(group) do
    if type(playlist) == "table" and type(playlist.tracks) == "table" then
      for _, track in ipairs(playlist.tracks) do
        local copy = {
          key = track.key,
          label = track.key,
          playlistKey = playlistKey,
          effect = track.effect,
          effectList = track.effectList,
          durationSeconds = track.durationSeconds,
          volume = track.volume,
          crossFadeSeconds = playlist.crossFadeSeconds,
        }
        table.insert(tracks, copy)
      end
    end
  end
  table.sort(tracks, function(left, right)
    return tostring(left.key) < tostring(right.key)
  end)
  return tracks
end

local function collectPlaylistTracks(playlist)
  local tracks = {}
  if type(playlist) ~= "table" or type(playlist.tracks) ~= "table" then
    return tracks
  end
  for _, track in ipairs(playlist.tracks) do
    table.insert(tracks, {
      key = track.key,
      label = track.key,
      effect = track.effect,
      effectList = track.effectList,
      durationSeconds = track.durationSeconds,
      volume = track.volume,
      crossFadeSeconds = playlist.crossFadeSeconds,
    })
  end
  table.sort(tracks, function(left, right)
    return tostring(left.key) < tostring(right.key)
  end)
  return tracks
end

local function collectWeatherConditions()
  local rows = {}
  for key, condition in pairs(Catalog.WEATHER_CONDITIONS) do
    table.insert(rows, {
      key = key,
      label = condition.label or key,
      volume = condition.volume,
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.weather,
    })
  end
  table.sort(rows, function(left, right)
    return tostring(left.key) < tostring(right.key)
  end)
  return rows
end

--- Returns all debug-panel categories derived from TRACKS, PLAYLISTS, and defaults.
-- @return table
function Catalog.getDebugCategories()
  return {
    {
      key = "backgroundMusic",
      label = "Background Music",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.music,
      tracks = collectNestedPlaylistTracks(Catalog.PLAYLISTS.backgroundMusic),
    },
    {
      key = "featuredMusic",
      label = "Featured Music",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.featured,
      tracks = collectNestedPlaylistTracks(Catalog.PLAYLISTS.featureMusic),
    },
    {
      key = "location",
      label = "Location",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.location,
      tracks = collectPlaylistTracks(Catalog.PLAYLISTS.location),
    },
    {
      key = "weather",
      label = "Weather",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.weather,
      tracks = collectWeatherConditions(),
    },
    {
      key = "rain",
      label = "Rain",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.weather,
      tracks = collectPlaylistTracks(Catalog.PLAYLISTS.weather.rain),
    },
    {
      key = "wind",
      label = "Wind",
      crossFadeSeconds = Catalog.DEFAULTS.fadeSeconds.weather,
      tracks = collectPlaylistTracks(Catalog.PLAYLISTS.weather.wind),
    },
    {
      key = "thunder",
      label = "Thunder",
      crossFadeSeconds = 0,
      tracks = collectPlaylistTracks(Catalog.PLAYLISTS.weather.thunder),
    },
  }
end

return Catalog
