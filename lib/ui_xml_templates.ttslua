M._byKey["csheet/partials/project_block"] = [=[
<Panel class="project_container" >
  <HorizontalLayout class="project_header_container"  >
      <GridLayout class="project_header_dotline">
        <Image id="project_@@INDEX@@_scope_dot_1" class="project_scope_dot"  /> <!-- Dots are 'active=false' by default; activate a number of dots equal to the project's scope. -->
        <Image id="project_@@INDEX@@_scope_dot_2" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_3" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_4" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_5" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_6" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_7" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_8" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_9" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_10" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_11" class="project_scope_dot"  />
        <Image id="project_@@INDEX@@_scope_dot_12" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_13" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_14" class="project_scope_dot"   />
        <Image id="project_@@INDEX@@_scope_dot_15" class="project_scope_dot"   />
      </GridLayout>
    <Text id="project_@@INDEX@@_goal" class="project_goal_text" text=""  /> <!-- A text description of the goal of the project, e.g. "Wrest control of the Distillery District from the Jarvis Jacks" -->
  </HorizontalLayout>

  <Image id="project_@@INDEX@@_project_die" class="project_die" image=""  /> <!-- Image corresponding to the current value of the project die, e.g. "project_die_3". Determine this value by comparing the start date and the increment to the current clock time: A project with a weekly increment that started four weeks ago should have a project die value of (10 - 4 = 6). This value should be dynamically updated any time the clock time changes, but must be bounded between 1 and 10. -->

  <Panel class="project_result_container" >
    <Image id="project_@@INDEX@@_result_image" class="project_result_image" image="" /> <!-- Either "project_win" or "project_crit", depending on result of launch roll -->
    <Text id="project_@@INDEX@@_result_margin" class="project_result_margin" text="+4" /> <!-- The margin on the launch roll, e.g. "+4", but only on a Win; if a Critical Win, set to active=false -->
  </Panel>

  <Text id="project_@@INDEX@@_stakes_label" class="project_stakes_label" text="STAKE:" /> <!-- Set INACTIVE if launch roll result was a Critical Win -->

  <GridLayout id="project_@@INDEX@@_stakes" class="project_stake_container" > <!-- Set INACTIVE if launch roll result was a Critical Win -->

    <HorizontalLayout id="project_@@INDEX@@_stake_1" class="project_stake_container"  > <!-- Each of these six HorizontalLayouts areInactive by default; set active="true" for each staked Advantage -->
        <Text id="project_@@INDEX@@_stake_1_label" class="project_stake_label project_stake_label_@@PROJECT_STAKE_1_CLASS@@" text="" /> <!-- The name of the Advantage staked, e.g. "Influence (Nightlife)"-->
        <GridLayout class="project_stake_dotline">
          <Image id="project_@@INDEX@@_stake_1_dot_1" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_1_CLASS@@"  /> <!-- Dots are 'active=false' by default; activate however many dots of this advantage are staked. -->
          <Image id="project_@@INDEX@@_stake_1_dot_2" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_1_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_1_dot_3" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_1_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_1_dot_4" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_1_CLASS@@" />
          <Image id="project_@@INDEX@@_stake_1_dot_5" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_1_CLASS@@"  />
        </GridLayout>
    </HorizontalLayout>
    <HorizontalLayout id="project_@@INDEX@@_stake_2" class="project_stake_container"     >
        <Text id="project_@@INDEX@@_stake_2_label" class="project_stake_label project_stake_label_@@PROJECT_STAKE_2_CLASS@@" text="" />
        <GridLayout class="project_stake_dotline">
          <Image id="project_@@INDEX@@_stake_2_dot_1" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_2_CLASS@@ "  />
          <Image id="project_@@INDEX@@_stake_2_dot_2" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_2_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_2_dot_3" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_2_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_2_dot_4" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_2_CLASS@@" />
          <Image id="project_@@INDEX@@_stake_2_dot_5" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_2_CLASS@@"  />
        </GridLayout>
    </HorizontalLayout>
    <HorizontalLayout id="project_@@INDEX@@_stake_3" class="project_stake_container"     >
        <Text id="project_@@INDEX@@_stake_3_label" class="project_stake_label project_stake_label_@@PROJECT_STAKE_3_CLASS@@" text="" />
        <GridLayout class="project_stake_dotline">
          <Image id="project_@@INDEX@@_stake_3_dot_1" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_3_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_3_dot_2" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_3_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_3_dot_3" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_3_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_3_dot_4" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_3_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_3_dot_5" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_3_CLASS@@"   />
        </GridLayout>
    </HorizontalLayout>
    <HorizontalLayout id="project_@@INDEX@@_stake_4" class="project_stake_container"     >
        <Text id="project_@@INDEX@@_stake_4_label" class="project_stake_label project_stake_label_@@PROJECT_STAKE_4_CLASS@@" text="" />
        <GridLayout class="project_stake_dotline">
          <Image id="project_@@INDEX@@_stake_4_dot_1" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_4_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_4_dot_2" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_4_CLASS@@"  />
          <Image id="project_@@INDEX@@_stake_4_dot_3" class="project_stake_dot project_stake_dot_@@PROJECT_STAKE_4_CLASS@@"  />
