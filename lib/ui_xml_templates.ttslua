    <Image id="dot_statusCamarilla_4" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusCamarilla_5" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />

    <Image id="dot_statusClan_1" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_2" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_3" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_4" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_5" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
</Panel>
