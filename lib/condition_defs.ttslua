  },
  hudTransitionBlindfold = {
    id = "hudTransitionBlindfold",
    type = "ui",
    displayName = "Transition Blindfold",
    kind = "event",
    priority = 70,
    instanceSchema = { variant = "number" },
    statChanges = {},
    hud = { blindfoldVariant = true },
  },
  bumpBloodPotency = {
    id = "bumpBloodPotency",
    type = "stat",
