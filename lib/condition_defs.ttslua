  sceneBonusWpReroll = {
    id = "sceneBonusWpReroll",
    type = "roll",
    displayName = "Bonus WP Reroll",
    kind = "scene",
    priority = 15,
    statChanges = {},
    roll = { wpRerollCountBonus = 1 },
