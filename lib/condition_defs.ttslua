      charisma = -2,
      manipulation = -2,
      composure = -2,
      intelligence = -2,
      wits = -2,
      resolve = -2,
    },
    hud = { overlay = "overlay_humanity_impaired" },
    lighting = { seatLight2 = "DIM_PURPLE" },
  },
  stained = {
    id = "stained",
    type = "stat",
    displayName = "Stained",
    canApplyManually = false,
