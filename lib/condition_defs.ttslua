--[[
  Static registry of condition definitions (not persisted).
  Each derived condition owns a `derive(stats, activeConditions, statChanges?)` function.
  Required on every entry: id, type ("roll"|"stat"|"ui"), displayName, kind.
  Agent guidance: .dev/PC Data & Tracking/Conditions System Guide.md
]]

local CD = {}

local PSC = require("lib.pc_sheet_collect")

--- Keys forbidden in persisted condition values (legacy inline factory payloads).
CD.LEGACY_PERSISTED_KEYS = {
  statChanges = true,
  hudChanges = true,
  lightingModeChanges = true,
  removalCriteria = true,
  blindfoldVariant = true,
}

CD.VALID_TYPES = { roll = true, stat = true, ui = true }

--- Structural roll-option key → negating standard roll condition id.
CD.STRUCTURAL_NEGATING = {
  takeHalf = "noTakeHalf",
  wpReroll = "noWPReroll",
  hungerDice = "noHungerDice",
  crits = "noCriticals",
}

--- Negating roll condition id → structural rollOptions key.
CD.STRUCTURAL_NEGATING_REVERSE = {}
for structuralKey, negatingId in pairs(CD.STRUCTURAL_NEGATING) do
  CD.STRUCTURAL_NEGATING_REVERSE[negatingId] = structuralKey
end

--- Tracker max from stats base + temp only (no condition stat deltas).
--- @param stats table|nil
--- @param trackerKey string
--- @return number
function CD.trackerMaxFromStats(stats, trackerKey)
  return PSC.trackerMaxFromStats(stats, nil, trackerKey)
end

--- Whether collision creates impaired humanity box (last humanity slot touched by stains from right).
--- @param lineLen number
--- @param stains number
--- @return boolean
function CD.humanityHasImpairedSlot(lineLen, stains)
  if lineLen < 1 or stains < 1 then
    return false
  end
  local firstStainSlot = 11 - stains
  return firstStainSlot <= lineLen
end

--- True when stats include a Blood Potency rating (vampire with a BP tracker).
--- @param stats table|nil
--- @return boolean
function CD.statsHasBloodPotencyRating(stats)
  if type(stats) ~= "table" or type(stats.bloodPotency) ~= "table" then
    return false
  end
  local bp = stats.bloodPotency
  if bp.base == nil and bp.temp == nil and bp.value == nil then
    return false
  end
  return true
end

--- @param def table
local function validateDefMetadata(def)
  if type(def.type) ~= "string" or not CD.VALID_TYPES[def.type] then
    error(
      "condition_defs: \""
        .. tostring(def.id)
        .. "\" missing or invalid type (expected roll|stat|ui)"
    )
  end
  if type(def.displayName) ~= "string" or def.displayName == "" then
    error("condition_defs: \"" .. tostring(def.id) .. "\" missing displayName")
  end
end

--- @type table<string, table>
CD.Defs = {
  torpor = {
    id = "torpor",
    type = "stat",
    displayName = "Torpor",
    kind = "derived",
    priority = 100,
    deriveSticky = true,
    derive = function(stats, _activeConditions, statChanges)
      local maxBoxes = PSC.trackerMaxFromStats(stats, statChanges, "health")
      if maxBoxes < 1 then
        return false
      end
      local tr = stats.health
      if type(tr) ~= "table" then
        return false
      end
      local agg = tonumber(tr.aggravated) or 0
      return agg >= maxBoxes
    end,
    statChanges = {},
    hud = { overlay = "overlay_torpor" },
    lighting = { seatLight2 = "OFF" },
  },
  impairedHealth = {
    id = "impairedHealth",
    type = "stat",
    displayName = "Impaired Health",
    kind = "derived",
    priority = 40,
    suppressedBy = { "torpor" },
    derive = function(stats, _activeConditions, statChanges)
      local maxBoxes = PSC.trackerMaxFromStats(stats, statChanges, "health")
      if maxBoxes < 1 then
        return false
      end
      local tr = stats.health
      if type(tr) ~= "table" then
        return false
      end
      local sup = tonumber(tr.superficial) or 0
      local agg = tonumber(tr.aggravated) or 0
      return (sup + agg) >= maxBoxes
    end,
    statChanges = {
      strength = -2,
      dexterity = -2,
      stamina = -2,
    },
    hud = { overlay = "overlay_health_impaired" },
    lighting = { seatLight2 = "DIM_RED" },
  },
  impairedWillpower = {
    id = "impairedWillpower",
    type = "stat",
    displayName = "Impaired Willpower",
    kind = "derived",
    priority = 40,
    suppressedBy = { "torpor" },
    derive = function(stats, _activeConditions, statChanges)
      local maxBoxes = PSC.trackerMaxFromStats(stats, statChanges, "willpower")
      if maxBoxes < 1 then
        return false
      end
      local tr = stats.willpower
      if type(tr) ~= "table" then
        return false
      end
      local sup = tonumber(tr.superficial) or 0
      local agg = tonumber(tr.aggravated) or 0
      return (sup + agg) >= maxBoxes
    end,
    statChanges = {
      charisma = -2,
      manipulation = -2,
      composure = -2,
      intelligence = -2,
      wits = -2,
      resolve = -2,
    },
    hud = { overlay = "overlay_willpower_impaired" },
    lighting = { seatLight2 = "DIM_RED" },
  },
  impairedHumanity = {
    id = "impairedHumanity",
    type = "stat",
    displayName = "Impaired Humanity",
    kind = "derived",
    priority = 50,
    derive = function(stats, _activeConditions, statChanges)
      if type(stats.humanity) ~= "table" then
        return false
      end
      local hu = stats.humanity
      local lineLen = PSC.trackerMaxFromStats(stats, statChanges, "humanity")
      local stains = tonumber(hu.stains) or 0
      return CD.humanityHasImpairedSlot(lineLen, stains)
    end,
    statChanges = {
      strength = -2,
      dexterity = -2,
      stamina = -2,
      charisma = -2,
      manipulation = -2,
      composure = -2,
      intelligence = -2,
      wits = -2,
      resolve = -2,
    },
    hud = { overlay = "overlay_humanity_impaired" },
    lighting = { seatLight2 = "DIM_PURPLE" },
  },
  hudFrenzy = {
    id = "hudFrenzy",
    type = "ui",
    displayName = "Frenzy",
    kind = "manual",
    priority = 30,
    statChanges = {},
    hud = { overlay = "overlay_frenzy" },
  },
  hudBlindfold = {
    id = "hudBlindfold",
    type = "ui",
