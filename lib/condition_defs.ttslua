}

for _id, def in pairs(CD.Defs) do
  if type(def) == "table" then
    validateDefMetadata(def)
  end
end

--- @param conditionId string
--- @return table
function CD.getDef(conditionId)
  if type(conditionId) ~= "string" or conditionId == "" then
    error("condition_defs.getDef: conditionId must be a non-empty string")
  end
  local def = CD.Defs[conditionId]
  if type(def) ~= "table" then
    error("condition_defs.getDef: unknown condition id \"" .. conditionId .. "\"")
  end
  return def
end

--- @param conditionId string
--- @return boolean
function CD.isKnownId(conditionId)
  return type(conditionId) == "string" and CD.Defs[conditionId] ~= nil
end

--- Standard roll conditions shown in the ST Roll Options modal (type roll + kind standard).
--- @return string[]
function CD.listRollConditionIds()
  local ids = {}
  for id, def in pairs(CD.Defs) do
    if type(def) == "table" and def.type == "roll" and def.kind == "standard" then
      ids[#ids + 1] = id
    end
  end
  table.sort(ids, function(a, b)
    local na = CD.Defs[a].displayName or a
    local nb = CD.Defs[b].displayName or b
    if na ~= nb then
      return na < nb
    end
    return a < b
  end)
  return ids
end

--- @param conditionId string
--- @param rollType string|nil
--- @return boolean
function CD.isRollConditionVisibleForRollType(conditionId, rollType)
  local def = CD.Defs[conditionId]
  if type(def) ~= "table" then
    return false
  end
  local vis = def.rollVisibleForRollType
  if type(vis) ~= "table" then
    return true
  end
  if type(rollType) ~= "string" or rollType == "" then
    return false
  end
  return vis[rollType] == true
end

--- @param activeConditions table|nil
--- @return string[]
function CD.sortedActiveIds(activeConditions)
  local ids = {}
  if type(activeConditions) == "table" then
    for id, _ in pairs(activeConditions) do
      if type(id) == "string" then
        ids[#ids + 1] = id
      end
    end
  end
  table.sort(ids, function(a, b)
    local pa = (CD.Defs[a] and CD.Defs[a].priority) or 0
    local pb = (CD.Defs[b] and CD.Defs[b].priority) or 0
    if pa ~= pb then
      return pa < pb
    end
    return a < b
  end)
  return ids
end

return CD
