for _id, def in pairs(CD.Defs) do
  if type(def) == "table" then
    validateDefMetadata(def)
  end
end

--- @param conditionId string
--- @return table
function CD.getDef(conditionId)
  if type(conditionId) ~= "string" or conditionId == "" then
    error("condition_defs.getDef: conditionId must be a non-empty string")
  end
  local def = CD.Defs[conditionId]
  if type(def) ~= "table" then
    error("condition_defs.getDef: unknown condition id \"" .. conditionId .. "\"")
  end
  return def
end

--- @param conditionId string
--- @return boolean
function CD.isKnownId(conditionId)
  return type(conditionId) == "string" and CD.Defs[conditionId] ~= nil
end

--- @param def table|nil
--- @return boolean
function CD.isAutoDerived(def)
  return type(def) == "table" and def.canApplyManually == false
end

--- Scene / district / site condition lists may only reference manually applicable ids.
--- @param def table|nil
--- @return boolean
function CD.canListInSceneOrLocation(def)
  return type(def) == "table" and def.canApplyManually == true
end

--- Conditions reconciled by session hosting (location + scene), not ST UI toggles.
--- @param def table|nil
--- @return boolean
function CD.isSessionHostedCondition(def)
  if type(def) ~= "table" or def.canApplyManually ~= true or def.type == "ui" then
    return false
  end
  return type(def.derive) == "function" or type(def.roll) == "table"
end

--- Roll conditions shown in the ST Roll Options modal (per-roll overlay toggles).
--- @param def table|nil
--- @return boolean
function CD.isPerRollOptsCondition(def)
  if type(def) ~= "table" or def.type ~= "roll" then
    return false
  end
  if CD.STRUCTURAL_NEGATING_REVERSE[def.id] ~= nil then
    return true
  end
  local roll = def.roll
  if type(roll) ~= "table" then
    return false
  end
  for overlayKey in pairs(CD.PER_ROLL_OPTS_OVERLAY) do
    if roll[overlayKey] == true then
      return true
    end
  end
  return false
end

--- Roll condition ids for the ST Roll Options modal.
--- @return string[]
function CD.listRollConditionIds()
  local ids = {}
  for id, def in pairs(CD.Defs) do
    if CD.isPerRollOptsCondition(def) then
      ids[#ids + 1] = id
    end
  end
  table.sort(ids, function(a, b)
    local na = CD.Defs[a].displayName or a
    local nb = CD.Defs[b].displayName or b
    if na ~= nb then
      return na < nb
    end
    return a < b
  end)
  return ids
end

--- @param activeConditions table|nil
--- @return string[]
function CD.sortedActiveIds(activeConditions)
  local ids = {}
  if type(activeConditions) == "table" then
    for id, _ in pairs(activeConditions) do
      if type(id) == "string" then
        ids[#ids + 1] = id
      end
    end
  end
  table.sort(ids, function(a, b)
    local pa = (CD.Defs[a] and CD.Defs[a].priority) or 0
    local pb = (CD.Defs[b] and CD.Defs[b].priority) or 0
    if pa ~= pb then
      return pa < pb
    end
    return a < b
  end)
  return ids
end

return CD
