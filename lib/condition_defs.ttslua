  sceneVitaeCharge = {
    id = "sceneVitaeCharge",
    type = "stat",
    displayName = "Vitae Charge",
    kind = "scene",
    priority = 12,
    derive = function(stats, _activeConditions)
      return CD.statsHasBloodPotencyRating(stats)
    end,
    statChanges = { bloodPotency = 1 },
  },
  noTakeHalf = {
    id = "noTakeHalf",
    type = "roll",
    displayName = "No Take Half",
    kind = "standard",
    priority = 20,
    statChanges = {},
