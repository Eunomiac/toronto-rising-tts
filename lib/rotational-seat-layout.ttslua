--[[
    Rotational seat layout (lib/rotational-seat-layout.ttslua)

    - generateRotationalCoordinates: validate template naming (ROLE_SUFFIX), segment vs map;
      playerToPositionMap keys are arbitrary strings (not limited to TTS player colors),
      compute rigid frames per player color around centerPoint, write paste-ready FrameReference Lua.
      `sourceObjects` must be nested: `{ player = {...}, other = {...}, all = {...} }`.
      Entries may be GameObjects (GUID string, { guid }, or Object) or Frame tables
      `{ position = Vector|table, rotation = Vector|table, Name = "ROLE_REF" | ... }` (no `guid` key)
      for virtual slots (cameras, lights). Anchor azimuth uses `options.anchorIndex` (default 1), not
      necessarily the hand zone or first slot.
    - resolveSeatObjects: tag templates (not hand zones — tags affect zone behavior);
      for each non-template seat, move existing tagged pieces (never clone missing roles) then write
      `ROLE_<SEAT>` to GM Notes and swap tags: remove reference `{Color}Object`, add target `{Color}Object`.
      Layout role identity lives in GM Notes (Name is free for player-facing tooltips).

    Requires sendExternalMessage and a listener on 39998 (repo tts-bridge) for file export on generate + spawn; paths are under .dev/.debug/ (see core.debug).

    Usage:
        local R = require("lib.rotational-seat-layout")
        local computed = R.generateRotationalCoordinates(sourceObjects, center, n, a1, map, "Red", { anchorIndex = 2, radius = 24 })
        R.resolveSeatObjects(computed, sourceObjects)
        R.clearGeneratedSeatObjects(sourceObjects, computed.playerToPositionMap, { NPC1 = true })

    Agent guidance: .dev/Rotational Coordinate Generator.md; .dev/DEBUG_FILE_LOGGING.md; .dev/User Guides/TTS-3D-Positioning-Coordinate-Utilities.md.
]]

local U = require("lib.util")
local C = require("lib.constants")
local S = require("core.state")
local OP = require("lib.object_positions")
local L_LIGHT = require("core.lighting")
local NPCS = require("core.npcs")
local SRI = require("lib.seat-role-identity")
local TarotObjects = require("lib.tarot_objects")
local G = require("lib.guids")

--- Lazy load: core.debug is large; only needed for workspace file export helpers.
--- @return table
local function getDebugModule()
    return require("core.debug")
end

local M = {}

--- Maximum allowed angular error (degrees) between template anchor azimuth and nearest nominal segment.
local MAX_SEGMENT_ANGLE_ERROR_DEG = 3

local DEFAULT_FRAME_REFS_PATH = "debug_logs/seat_layout_frame_refs.lua"
local DEFAULT_GUID_MAP_PATH = "debug_logs/seat_layout_guids.lua"
local DEFAULT_FRAME_REFS_VAR = "SEAT_LAYOUT_FRAME_REFS"
local DEFAULT_GUID_MAP_VAR = "SEAT_LAYOUT_OBJECT_GUIDS"
local DEFAULT_GUID_TRANSFORMS_VAR = "SEAT_LAYOUT_OBJECT_TRANSFORMS"
local DEFAULT_GUID_FOLLOWER_TRANSFORMS_VAR = "SEAT_LAYOUT_FOLLOWER_OBJECT_TRANSFORMS"

local WRITE_RESULTS_TO_FILE = false

--- @param s string
--- @return string
local function trim(s)
  if U.Type(s) ~= "string" then
    return ""
  end
  return (string.gsub(s, "^%s*(.-)%s*$", "%1"))
end

local function assertSendExternalMessage()
  if sendExternalMessage == nil then
    error("rotational-seat-layout: sendExternalMessage is nil; TTS Tools extension is required to write workspace files")
  end
end

--- Shortest signed delta from fromDeg to toDeg in (-180, 180].
--- @param fromDeg number
--- @param toDeg number
--- @return number
local function shortestSignedDelta(fromDeg, toDeg)
  local d = toDeg - fromDeg
  while d > 180 do
    d = d - 360
  end
  while d < -180 do
    d = d + 360
  end
  return d
end

--- @param centerPoint Vector|table
--- @return string|nil
local function inferTableKeyFromCenterPoint(centerPoint)
  local cp = Vector(centerPoint)
  local bestKey = nil
  local bestDist = 1e9
  for tableKey, cfg in pairs(C.Tables or {}) do
    if U.Type(tableKey) == "string" and U.Type(cfg) == "table" and cfg.centerPoint ~= nil then
      local tcp = Vector(cfg.centerPoint)
      local dx = cp.x - tcp.x
      local dy = cp.y - tcp.y
      local dz = cp.z - tcp.z
      local d = math.sqrt(dx * dx + dy * dy + dz * dz)
      if d < bestDist then
        bestDist = d
        bestKey = tableKey
      end
    end
  end
  if bestKey ~= nil and bestDist <= 0.01 then
    return bestKey
  end
  return nil
end

--- @param oldCenter Vector
--- @param newCenter Vector
--- @param frame table { position = Vector, rotation = Vector }
--- @param deltaYaw number
--- @return table
local function rigidTransformBetweenCenters(oldCenter, newCenter, frame, deltaYaw)
  local rotated = U.frameAfterRigidYawAboutCenter(oldCenter, frame, deltaYaw)
  local translatedPos = Vector(rotated.position) + (Vector(newCenter) - Vector(oldCenter))
  return {
    position = translatedPos,
    rotation = Vector(rotated.rotation),
  }
end

--- @param obj Object
--- @return boolean
local function isCardLikeObject(obj)
  if obj == nil or not U.isGameObject(obj) then
    return false
  end
  local tagVal = obj.tag
  if tagVal == "Card" or tagVal == "Deck" then
    return true
  end
  local typeVal = obj.type
  if typeVal == "Card" or typeVal == "Deck" then
    return true
  end
  return false
end

--- @param obj Object
--- @return boolean
local function tryGetObjectLockState(obj)
  if obj.getLock ~= nil then
    local lockVal = obj.getLock()
    if type(lockVal) == "boolean" then
      return lockVal
    end
  end
  local lockedVal = obj.locked
  if type(lockedVal) == "boolean" then
    return lockedVal
  end
  return false
end

--- Move a player hand zone and keep cards/decks in rigid relative formation.
--- @param hz Object
--- @param targetPos Vector
--- @param targetRot Vector
--- @return table hzBefore { position = Vector, rotation = Vector }
local function moveHandZoneAndContainedCards(hz, targetPos, targetRot)
  local hzBefore = {
    position = hz.getPosition(),
    rotation = hz.getRotation(),
  }
  local zoneObjects = {}
  if hz.getObjects ~= nil then
    zoneObjects = hz.getObjects()
  end
  if U.Type(zoneObjects) ~= "table" then
    error("rotational-seat-layout: hand zone getObjects() must return a table")
  end

  local captured = {}
  for _, obj in ipairs(zoneObjects) do
    if isCardLikeObject(obj) then
      local wasLocked = tryGetObjectLockState(obj)
      local entry = {
        obj = obj,
        wasLocked = wasLocked,
        before = {
          position = obj.getPosition(),
          rotation = obj.getRotation(),
        },
      }
      captured[#captured + 1] = entry
      obj.setLock(true)
    end
  end

  hz.setPosition({ x = targetPos.x, y = targetPos.y, z = targetPos.z })
  hz.setRotation({ x = targetRot.x, y = targetRot.y, z = targetRot.z })
  local deltaYaw = shortestSignedDelta(hzBefore.rotation.y, targetRot.y)
  local alignedCardRotation = Vector(targetRot):add(Vector({ 0, 180, 0 }))
  for i = 1, #captured do
    local entry = captured[i]
    local newFrame = rigidTransformBetweenCenters(hzBefore.position, targetPos, entry.before, deltaYaw)
    entry.obj.setPosition({ x = newFrame.position.x, y = newFrame.position.y, z = newFrame.position.z })
    entry.obj.setRotation({ x = newFrame.rotation.x, y = newFrame.rotation.y, z = newFrame.rotation.z })
  end
  for i = 1, #captured do
    local entry = captured[i]
    -- Final snap avoids residual skew drift: cards should face opposite the hand-zone forward.
    entry.obj.setRotation({ x = alignedCardRotation.x, y = alignedCardRotation.y, z = alignedCardRotation.z })
    entry.obj.setLock(entry.wasLocked)
  end
  return hzBefore
end

--- @param thetaRef number
--- @param numSegments number
--- @param angleSegmentOne number
--- @return number inferredSegment1Based
--- @return number minAbsErrorDeg
local function inferNearestSegment(thetaRef, numSegments, angleSegmentOne)
  local stepDeg = 360 / numSegments
  local bestK = 1
  local bestErr = 1e9
  for k = 1, numSegments do
    local thetaK = angleSegmentOne + (k - 1) * stepDeg
    local err = math.abs(shortestSignedDelta(thetaRef, thetaK))
    if err < bestErr then
      bestErr = err
      bestK = k
    end
  end
  return bestK, bestErr
end

--- @param angleSegmentOne number
--- @param numSegments number
--- @param segmentIndex1Based number
--- @return number
local function segmentNominalAzimuthDeg(angleSegmentOne, numSegments, segmentIndex1Based)
  local stepDeg = 360 / numSegments
  return angleSegmentOne + (segmentIndex1Based - 1) * stepDeg
end

--- @param obj Object
--- @param index number
--- @return string roleIdentity
local function resolveTemplateRoleIdentity(obj, index)
  return SRI.requireRoleColorIdentity(
    obj,
    "rotational-seat-layout: template object index " .. tostring(index)
  )
end

--- True if `ref` is a Frame-only entry: table with `position` and `rotation`, no object `guid`.
--- @param ref unknown
--- @return boolean
local function isFrameEntry(ref)
  if U.Type(ref) ~= "table" or U.isGameObject(ref) then
    return false
  end
  if ref.guid ~= nil then
    return false
  end
  if ref.position == nil or ref.rotation == nil then
    return false
  end
  return true
end

--- ROLE_COLOR identity for a Frame table (`GMNotes`, then legacy Name/Nickname fields in export JSON).
--- @param frame table
--- @param index number
--- @return string displayName
local function resolveFrameTemplateDisplayName(frame, index)
  local candidates = {
    frame.GMNotes,
    frame.gmNotes,
    frame.Name,
    frame.Nickname,
    frame.displayName,
    frame.name,
    frame.templateName,
  }
  for _, c in ipairs(candidates) do
    if U.Type(c) == "string" then
      local t = trim(c)
      if t ~= "" and SRI.matchesRoleColorPattern(t) then
        return t
      end
    end
  end
  error(
    "rotational-seat-layout: frame entry index "
    .. tostring(index)
    .. " needs GMNotes, Name, Nickname, displayName, name, or templateName matching ROLE_COLOR pattern"
  )
end

--- @param roleKey string
--- @return boolean
local function isHandZoneRoleKey(roleKey)
  if U.Type(roleKey) ~= "string" then
    return false
  end
  return string.find(roleKey, "HAND_ZONE", 1, true) ~= nil
end

--- TTS hand zones cannot be tagged like other objects; detect by engine type or HAND_ZONE_* role name.
--- @param obj Object|nil
--- @return boolean
local function isHandZoneObject(obj)
  if obj == nil or not U.isGameObject(obj) then
    return false
  end
  local t = obj.type
  if t == "HandTrigger" then
    return true
  end
  local disp = SRI.readRoleColorIdentity(obj)
  if disp ~= nil then
    local roleKey, _ = SRI.parseRoleAndSuffix(disp)
    if isHandZoneRoleKey(roleKey) then
      return true
    end
  end
  return false
end

--- @param t table
--- @return string[]
local function sortedStringKeys(t)
  local ks = {}
  for k, _ in pairs(t) do
    if U.Type(k) == "string" then
      table.insert(ks, k)
    end
  end
  table.sort(ks)
  return ks
end

--- @param s string
--- @return string
local function luaTableKeyToken(s)
  if string.match(s, "^[%a_][%w_]*$") then
    return s
  end
  local esc = string.gsub(s, "\\", "\\\\")
  esc = string.gsub(esc, "\"", "\\\"")
  return "[\"" .. esc .. "\"]"
end

--- Fixed three decimals for stable, human-readable paste; avoids `%.6g` scientific notation on near-zero reference frames.
--- @param v Vector|table
--- @return string
local function formatVectorExpr(v)
  v = Vector(v)
  return string.format("Vector(%.3f, %.3f, %.3f)", v.x, v.y, v.z)
end

--- Flat keys: `ROLEKEY_` .. `string.upper(seatKey)` (e.g. `HUNGER_SMOKE_BROWN`). Ambiguous seat/role
--- combinations can collide; duplicates error at export time.
--- @param varName string
--- @param nested table<string, table<string, { position: Vector, rotation: Vector }>>
--- @return string
local function serializeFrameRefsLua(varName, nested)
  local flatRows = {}
  local seenFlat = {}
  for _, seatKey in ipairs(sortedStringKeys(nested)) do
    local roleMap = nested[seatKey]
    for _, roleKey in ipairs(sortedStringKeys(roleMap)) do
      local fr = roleMap[roleKey]
      local flatKey = roleKey .. "_" .. string.upper(seatKey)
      if seenFlat[flatKey] ~= nil then
        error(
          "rotational-seat-layout: duplicate flat frame ref key '"
          .. flatKey
          .. "' (role/seat naming collision); rename a role or seat id"
        )
      end
      seenFlat[flatKey] = true
      table.insert(flatRows, { key = flatKey, fr = fr })
    end
  end
  table.sort(flatRows, function(a, b)
    return a.key < b.key
  end)

  local lines = {}
  table.insert(lines,
    "-- Generated by lib.rotational-seat-layout (FrameReference map). Paste where `Vector` is global (TTS).")
  table.insert(lines, "-- Keys: ROLEKEY_UPPERSEATKEY (e.g. HUNGER_SMOKE_BROWN).")
  table.insert(lines, varName .. " = {")
  for _, row in ipairs(flatRows) do
    local keyTok = luaTableKeyToken(row.key)
    table.insert(
      lines,
      "  "
      .. keyTok
      .. " = { position = "
      .. formatVectorExpr(row.fr.position)
      .. ", rotation = "
      .. formatVectorExpr(row.fr.rotation)
      .. " },"
    )
  end
  table.insert(lines, "}")
  return table.concat(lines, "\n")
end

--- @param varName string
--- @param nested table<string, table<string, string>>
--- @return string
local function serializeGuidMapLua(varName, nested)
  local flatRows = {}
  local seenFlat = {}
  for _, seatKey in ipairs(sortedStringKeys(nested)) do
    local roleMap = nested[seatKey]
    for _, roleKey in ipairs(sortedStringKeys(roleMap)) do
      local flatKey = roleKey .. "_" .. string.upper(seatKey)
      if seenFlat[flatKey] ~= nil then
        error(
          "rotational-seat-layout: duplicate flat GUID key '"
          .. flatKey
          .. "' (role/seat naming collision); rename a role or seat id"
        )
      end
      seenFlat[flatKey] = true
      table.insert(flatRows, { key = flatKey, guid = roleMap[roleKey] })
    end
  end
  table.sort(flatRows, function(a, b)
    return a.key < b.key
  end)

  local lines = {}
  table.insert(lines, "-- Generated by lib.rotational-seat-layout (object GUID map).")
  table.insert(lines, "-- Keys: ROLEKEY_UPPERSEATKEY (e.g. HUNGER_SMOKE_BROWN).")
  table.insert(lines, varName .. " = {")
  for _, row in ipairs(flatRows) do
    local keyTok = luaTableKeyToken(row.key)
    table.insert(lines, "  " .. keyTok .. " = \"" .. row.guid .. "\",")
  end
  table.insert(lines, "}")
  return table.concat(lines, "\n")
end

--- @param varName string
--- @param nested table<string, table<string, { position: Vector, rotation: Vector }>>
--- @return string
local function serializeObjectTransformsLua(varName, nested)
  local lines = {}
  table.insert(lines, "-- Generated by lib.rotational-seat-layout (live object transforms at write time).")
  table.insert(lines, varName .. " = {")
  for _, color in ipairs(sortedStringKeys(nested)) do
    table.insert(lines, "  [\"" .. color .. "\"] = {")
    local roleMap = nested[color]
    for _, role in ipairs(sortedStringKeys(roleMap)) do
      local fr = roleMap[role]
      local keyTok = luaTableKeyToken(role)
      table.insert(
        lines,
        "    "
        .. keyTok
        .. " = { position = "
        .. formatVectorExpr(fr.position)
        .. ", rotation = "
        .. formatVectorExpr(fr.rotation)
        .. " },"
      )
    end
    table.insert(lines, "  },")
  end
  table.insert(lines, "}")
  return table.concat(lines, "\n")
end

--- @param varName string
--- @param nested table<string, table<string, { position: Vector, rotation: Vector }>>
--- @return string
local function serializeFollowerTransformsLua(varName, nested)
  local lines = {}
  table.insert(lines, "-- Generated by lib.rotational-seat-layout (extra follower object transforms at write time).")
  table.insert(lines, "-- Keys: [seatKey][objectGuid] = { position = Vector(...), rotation = Vector(...) }.")
  table.insert(lines, varName .. " = {")
  for _, seatKey in ipairs(sortedStringKeys(nested)) do
    table.insert(lines, "  [\"" .. seatKey .. "\"] = {")
    local byGuid = nested[seatKey]
    for _, guid in ipairs(sortedStringKeys(byGuid)) do
      local fr = byGuid[guid]
      local keyTok = luaTableKeyToken(guid)
      table.insert(
        lines,
        "    "
        .. keyTok
        .. " = { position = "
        .. formatVectorExpr(fr.position)
        .. ", rotation = "
        .. formatVectorExpr(fr.rotation)
        .. " },"
      )
    end
    table.insert(lines, "  },")
  end
  table.insert(lines, "}")
  return table.concat(lines, "\n")
end

--- Apply seat ownership/color to hand zones for valid TTS player colors.
--- Uses Hand Zone API `setValue(playerColor)` for ownership; tint is applied as cosmetic best-effort.
--- Non-player seat keys (e.g. NPC_SEAT) are ignored.
--- @param obj Object|nil
--- @param roleKey string
--- @param seatKey string
local function maybeSetHandZoneSeatColor(obj, roleKey, seatKey)
  if obj == nil then
    return
  end
  if U.Type(roleKey) ~= "string" or U.Type(seatKey) ~= "string" then
    return
  end
  if string.find(roleKey, "HAND_ZONE", 1, true) == nil then
    return
  end
  -- For HandTrigger objects, setValue(stringColor) sets hand owner color per TTS docs.
  obj.setValue(seatKey)
  ---@diagnostic disable-next-line: undefined-global
  local colorOrErr = stringColorToRGB(seatKey)
  if U.Type(colorOrErr) ~= "table" then
    error(
      "rotational-seat-layout: stringColorToRGB returned non-table for seat '"
      .. tostring(seatKey)
      .. "'"
    )
  end
  obj.setColorTint(colorOrErr)
end

--- Place an object at an exact transform while avoiding collision-based displacement.
--- Uses immediate setters so transforms are applied deterministically in-order.
--- @param obj Object
--- @param pos Vector
--- @param rot Vector
local function placeObjectExact(obj, pos, rot)
  local posTbl = { x = pos.x, y = pos.y, z = pos.z }
  local rotTbl = { x = rot.x, y = rot.y, z = rot.z }
  obj.setPosition(posTbl)
  obj.setRotation(rotTbl)
end

--- @param playerColor string
--- @return string
local function objectTagForPlayerColor(playerColor)
  return playerColor .. "Object"
end

local PLAYER_COLOR_SET = {}
for i = 1, #C.PlayerColors do
  local color = C.PlayerColors[i]
  if U.Type(color) == "string" then
    PLAYER_COLOR_SET[string.upper(color)] = true
  end
end

--- @param seatKey string
--- @return boolean
local function isPlayerSeatKey(seatKey)
  return PLAYER_COLOR_SET[string.upper(seatKey)] == true
end

--- @param sourceObjects table
--- @return table
local function resolveSourceTemplateGroups(sourceObjects)
  if U.Type(sourceObjects) ~= "table" then
    error(
    "rotational-seat-layout: sourceObjects must be a table with keys 'player', 'all', optional 'relative', and optional 'cameraModes'")
  end
  local groups = {
    player = sourceObjects.player or {},
    other = sourceObjects.other or {},
    all = sourceObjects.all or {},
    relative = sourceObjects.relative or {},
    cameraModes = sourceObjects.cameraModes or {},
  }
  if U.Type(groups.player) ~= "table" or U.Type(groups.other) ~= "table" or U.Type(groups.all) ~= "table" then
    error("rotational-seat-layout: sourceObjects.player/sourceObjects.other/sourceObjects.all must be arrays")
  end
  if U.Type(groups.relative) ~= "table" then
    error("rotational-seat-layout: sourceObjects.relative must be an array when provided")
  end
  if U.Type(groups.cameraModes) ~= "table" then
    error("rotational-seat-layout: sourceObjects.cameraModes must be a table when provided")
  end
  if groups.cameraModes.bySeat ~= nil and U.Type(groups.cameraModes.bySeat) ~= "table" then
    error("rotational-seat-layout: sourceObjects.cameraModes.bySeat must be an array when provided")
  end
  if sourceObjects.player == nil and sourceObjects.other == nil and sourceObjects.all == nil then
    error("rotational-seat-layout: sourceObjects must define at least one of: player, other, all")
  end
  return groups
end

--- @param sourceGroups table
--- @return table[]
local function collectTemplateGroups(sourceGroups)
  return {
    sourceGroups.player or {},
    sourceGroups.other or {},
    sourceGroups.all or {},
  }
end

--- @param ref any
--- @param referencePlayerColor string
--- @param label string
--- @return Object|nil
local function resolveObjectRefWithRoleSupport(ref, referencePlayerColor, label)
  local obj = U.getObject(ref, true)
  if obj ~= nil then
    return obj
  end
  if U.Type(ref) == "string" then
    obj = TarotObjects.resolveByGuid(ref)
    if obj ~= nil then
      return obj
    end
  end
  if U.Type(ref) ~= "string" then
    return nil
  end
  local refTrim = trim(ref)
  local refUpperColor = string.upper(referencePlayerColor or "")
  if refTrim == "" then
    return nil
  end
  local attemptedRoleIdentity = nil
  if SRI.matchesRoleColorPattern(refTrim) then
    attemptedRoleIdentity = refTrim
    obj = SRI.findObjectByRoleIdentity(refTrim)
  elseif string.match(refTrim, "^[%u%d_]+$") ~= nil then
    local roleName = refTrim .. "_" .. refUpperColor
    attemptedRoleIdentity = roleName
    obj = SRI.findObjectByRoleIdentity(roleName)
  end
  if obj == nil and label ~= nil then
    error(
      "rotational-seat-layout: could not resolve "
      .. tostring(label)
      .. " to an Object"
      .. " | ref="
      .. tostring(ref)
      .. " | referencePlayerColor="
      .. tostring(referencePlayerColor)
      .. " | attemptedRoleIdentity="
      .. tostring(attemptedRoleIdentity)
    )
  end
  return obj
end

--- @param obj Object
--- @return string|nil
local function deriveSeatKeyFromObjectTag(obj)
  if obj == nil then
    return nil
  end
  local tags = obj.getTags and obj.getTags() or {}
  if U.Type(tags) ~= "table" then
    return nil
  end
  for _, tag in ipairs(tags) do
    if U.Type(tag) == "string" then
      local seatKey = string.match(tag, "^(.-)Object$")
      if seatKey ~= nil and seatKey ~= "" then
        return seatKey
      end
    end
  end
  return nil
end

--- @param sourceGroups table
--- @return string[] bySeatModeKeys
local function collectCameraModeKeys(sourceGroups)
  local bySeat = {}
  local seenBySeat = {}
  local cameraModes = sourceGroups.cameraModes or {}
  local bySeatSource = cameraModes.bySeat or {}

  for i = 1, #bySeatSource do
    local key = bySeatSource[i]
    if U.Type(key) ~= "string" or trim(key) == "" then
      error("rotational-seat-layout: sourceObjects.cameraModes.bySeat entries must be non-empty strings")
    end
    if not seenBySeat[key] then
      seenBySeat[key] = true
      table.insert(bySeat, key)
    end
  end

  return bySeat
end

--- @param sourceGroups table
--- @param seatKey string
--- @return table
local function sourceGroupEntriesForSeat(sourceGroups, seatKey)
  local list = {}
  local specific = isPlayerSeatKey(seatKey) and sourceGroups.player or sourceGroups.other
  for i = 1, #specific do
    table.insert(list, specific[i])
  end
  for i = 1, #sourceGroups.all do
    table.insert(list, sourceGroups.all[i])
  end
  return list
end

--- @param entries table
--- @param referencePlayerColor string
--- @return table
local function resolveSeatTemplateSlots(entries, referencePlayerColor)
  local refUpper = string.upper(referencePlayerColor)
  local slots = {}
  for i = 1, #entries do
    local ref = entries[i]
    local slot = {
      sourceRef = ref,
      isFrame = false,
      roleKey = nil,
      displayName = nil,
      sourceFrame = nil,
      sourceObject = nil,
    }
    if isFrameEntry(ref) then
      slot.isFrame = true
      local disp = resolveFrameTemplateDisplayName(ref, i)
      local roleKey, suffixUpper = SRI.parseRoleAndSuffix(disp)
      if suffixUpper ~= refUpper then
        error(
          "rotational-seat-layout: frame entry "
          .. tostring(i)
          .. " ('"
          .. disp
          .. "') has suffix '_"
          .. suffixUpper
          .. "' but referencePlayerColor '"
          .. referencePlayerColor
          .. "' requires suffix '_"
          .. refUpper
          .. "'"
        )
      end
      slot.roleKey = roleKey
      slot.displayName = disp
      slot.sourceFrame = {
        position = Vector(ref.position),
        rotation = Vector(ref.rotation),
      }
    else
      local obj = resolveObjectRefWithRoleSupport(
        ref,
        referencePlayerColor,
        "source template entry [" .. tostring(i) .. "]"
      )
      if obj == nil then
        error("rotational-seat-layout: could not resolve source template entry [" .. tostring(i) .. "] to an Object")
      end
      local disp = resolveTemplateRoleIdentity(obj, i)
      local roleKey, suffixUpper = SRI.parseRoleAndSuffix(disp)
      if suffixUpper ~= refUpper then
        error(
          "rotational-seat-layout: template object "
          .. tostring(i)
          .. " ('"
          .. disp
          .. "') has suffix '_"
          .. suffixUpper
          .. "' but referencePlayerColor '"
          .. referencePlayerColor
          .. "' requires suffix '_"
          .. refUpper
          .. "'"
        )
      end
      slot.roleKey = roleKey
      slot.displayName = disp
      slot.sourceFrame = {
        position = obj.getPosition(),
        rotation = obj.getRotation(),
      }
      slot.sourceObject = obj
    end
    table.insert(slots, slot)
  end
  return slots
end

--- Ensure a hand-zone anchor slot exists for the reference seat.
--- If no HAND_ZONE role is present in templates, inject a virtual frame from the real hand zone.
--- @param referenceSlots table
--- @param referencePlayerColor string
--- @return table referenceSlots
--- @return number handZoneAnchorIndex
local function ensureReferenceHandZoneAnchorSlot(referenceSlots, referencePlayerColor)
  local handZoneAnchorIndex = nil
  for i = 1, #referenceSlots do
    local slot = referenceSlots[i]
    if isHandZoneRoleKey(slot.roleKey) then
      handZoneAnchorIndex = i
      break
    end
  end
  if handZoneAnchorIndex ~= nil then
    return referenceSlots, handZoneAnchorIndex
  end

  local hz = U.getHandZone(referencePlayerColor)
  if hz == nil then
    error(
      "rotational-seat-layout: no hand zone found for referencePlayerColor '"
      .. tostring(referencePlayerColor)
      .. "'; required to derive seat hand-zone anchors"
    )
  end

  local injectedRoleKey = "HAND_ZONE_ANCHOR"
  local injectedDisplayName = injectedRoleKey .. "_" .. string.upper(referencePlayerColor)
  table.insert(referenceSlots, {
    sourceRef = hz,
    isFrame = true,
    roleKey = injectedRoleKey,
    displayName = injectedDisplayName,
    sourceFrame = {
      position = hz.getPosition(),
      rotation = hz.getRotation(),
    },
    sourceObject = hz,
  })
  return referenceSlots, #referenceSlots
end

--- `activeTable.referenceHandPosition - C.CameraAuthoringReferenceHandPosition`. Applied to camera **position**
--- only for presets with `isRelativeToReferenceHandPosition == true`.
--- @param tableCfg table|nil
--- @return Vector
local function cameraPositionWorldOffsetForActiveTable(tableCfg)
  if U.Type(tableCfg) ~= "table" then
    return Vector(0, 0, 0)
  end
  ---@cast tableCfg table
  local refHand = tableCfg.referenceHandPosition
  if refHand == nil then
    return Vector(0, 0, 0)
  end
  local base = C.CameraAuthoringReferenceHandPosition
  if base == nil then
    return Vector(0, 0, 0)
  end
  return Vector(refHand) - Vector(base)
end

--- Apply a seat's precomputed **rigid transform** (yaw `deltaDeg` about `centerPoint`, then `shift`) to
--- a camera frame, so per-seat camera presets land with the seat. The seat's `{ deltaDeg, shift }` comes
--- from `computed.seatRigidByKey` (populated identically by circular + facing generators), so camera and
--- seat-object placement always agree.
--- @param centerPoint Vector
--- @param deltaDeg number seat yaw delta about centerPoint
--- @param shift Vector|table seat translation after yaw
--- @param worldPos Vector|table camera authoring position (reference seat space)
--- @param pitch number|nil
--- @param yaw number|nil
--- @return Vector finalPos
--- @return Vector finalRot pitch,yaw from rotated frame
local function cameraFrameFromRigid(centerPoint, deltaDeg, shift, worldPos, pitch, yaw)
  local cp = Vector(centerPoint)
  local camFrame = {
    position = Vector(worldPos),
    rotation = Vector({ pitch or 0, yaw or 0, 0 }),
  }
  local fr = U.frameAfterRigidYawAboutCenter(cp, camFrame, deltaDeg)
  return Vector(fr.position) + Vector(shift), Vector(fr.rotation)
end

--- @param computed table
--- @param sourceGroups table
--- @param positionWorldOffset Vector|nil hand authoring delta (see `cameraPositionWorldOffsetForActiveTable`)
local function applyCameraModesForSeats(computed, sourceGroups, positionWorldOffset)
  local bySeatModeKeys = collectCameraModeKeys(sourceGroups)
  local worldOff = Vector(0, 0, 0)
  if positionWorldOffset ~= nil then
    worldOff = Vector(positionWorldOffset)
  end
  local referenceColor = computed.referencePlayerColor
  local seatRigidByKey = computed.seatRigidByKey
  if U.Type(seatRigidByKey) ~= "table" then
    error("rotational-seat-layout: applyCameraModesForSeats requires computed.seatRigidByKey (from a layout generator)")
  end
  local referenceRigid = seatRigidByKey[referenceColor]
  if U.Type(referenceRigid) ~= "table" or referenceRigid.shift == nil then
    error("rotational-seat-layout: applyCameraModesForSeats missing rigid transform for reference seat '" ..
      tostring(referenceColor) .. "'")
  end
  local centerPoint = Vector(computed.centerPoint)

  --- Wrap yaw into [0, 360), clamp pitch into [0, 90], and avoid exact zero for yaw/pitch/distance.
  --- TTS treats exact zeros for these camera fields as "no change", so bump to 0.1.
  --- @param pitch number
  --- @param yaw number
  --- @param distance number
  --- @return number, number, number
  local function normalizeCameraAngles(pitch, yaw, distance)
    local p = tonumber(pitch) or 0
    local y = tonumber(yaw) or 0
    local d = tonumber(distance) or 0

    y = y % 360
    if y < 0 then
      y = y + 360
    end

    if p < 0 then
      p = 0
    elseif p > 90 then
      p = 90
    end

    if p == 0 then
      p = 0.1
    end
    if y == 0 then
      y = 0.1
    end
    if d == 0 then
      d = 0.1
    end

    return p, y, d
  end

  local universalAngles = {}

  if U.Type(C.UniversalCameraAngles) == "table" then
    for modeKey, modeVal in pairs(C.UniversalCameraAngles) do
      if U.Type(modeKey) == "string" and U.Type(modeVal) == "table" and modeVal.isRelativeToReferenceHandPosition == true then
        ---@cast modeVal TtsCameraAnglePreset
        if modeVal.position == nil then
          error("rotational-seat-layout: C.UniversalCameraAngles['" .. modeKey .. "'] is missing position")
        end
        local pos = Vector(modeVal.position) + worldOff
        local shiftedPos, shiftedRot = cameraFrameFromRigid(
          centerPoint,
          referenceRigid.deltaDeg,
          referenceRigid.shift,
          pos,
          modeVal.pitch or 0,
          modeVal.yaw or 0
        )
        local pitch, yaw, distance = normalizeCameraAngles(
          shiftedRot.x,
          shiftedRot.y,
          modeVal.distance or 0
        )
        universalAngles[modeKey] = {
          cameraMode = modeVal.cameraMode or "FirstPerson",
          position = { x = shiftedPos.x, y = shiftedPos.y, z = shiftedPos.z },
          pitch = pitch,
          yaw = yaw,
          distance = distance,
        }
      end
    end
  end

  for i = 1, #bySeatModeKeys do
    local modeKey = bySeatModeKeys[i]
    local redMode = C.RedCameraAngles and C.RedCameraAngles[modeKey] or nil
    if U.Type(redMode) ~= "table" then
      error(
        "rotational-seat-layout: sourceObjects.cameraModes.bySeat includes '"
        .. modeKey
        .. "' but C.RedCameraAngles has no entry for it"
      )
    end
    ---@cast redMode TtsCameraAnglePreset
    if redMode.position == nil then
      error("rotational-seat-layout: C.RedCameraAngles['" .. modeKey .. "'] is missing position")
    end

    local basePos = Vector(redMode.position)
    if redMode.isRelativeToReferenceHandPosition == true then
      basePos = basePos + worldOff
    end

    for seatKey, rigid in pairs(seatRigidByKey) do
      if U.Type(seatKey) == "string" and U.Type(rigid) == "table" and rigid.shift ~= nil then
        local shiftedPos, shiftedRot = cameraFrameFromRigid(
          centerPoint,
          rigid.deltaDeg,
          rigid.shift,
          basePos,
          redMode.pitch or 0,
          redMode.yaw or 0
        )
        local shiftedPosTable = { x = shiftedPos.x, y = shiftedPos.y, z = shiftedPos.z }
        local pitch, yaw, distance = normalizeCameraAngles(
          shiftedRot.x,
          shiftedRot.y,
          redMode.distance or 0
        )
        local camMode = redMode.cameraMode or "FirstPerson"
        universalAngles[modeKey .. seatKey] = {
          cameraMode = camMode,
          position = shiftedPosTable,
          pitch = pitch,
          yaw = yaw,
          distance = distance,
        }

        if isPlayerSeatKey(seatKey) then
          local playerID = S.getPlayerID(seatKey)
          if playerID ~= nil then
            S.setStateVal(
              {
                cameraMode = camMode,
                position = { x = shiftedPos.x, y = shiftedPos.y, z = shiftedPos.z },
                pitch = pitch,
                yaw = yaw,
                distance = distance,
              },
              "playerData",
              playerID,
              "cameraAngles",
              modeKey
            )
          end
        end
      end
    end
  end

  S.setStateVal(universalAngles, "seatLayout", "universalCameraAngles")
end

--- @param keys string[]
--- @return string[]
local function dedupeSeatKeysPreserveOrder(keys)
  local seen = {}
  local out = {}
  for _, k in ipairs(keys) do
    if not seen[k] then
      seen[k] = true
      table.insert(out, k)
    end
  end
  return out
end

--- Array of seat ids, or map whose string keys are seat ids (e.g. playerToPositionMap).
--- @param seatKeys table
--- @return string[]
local function collectSeatKeys(seatKeys)
  if U.Type(seatKeys) ~= "table" then
    error("rotational-seat-layout: seatKeys must be a table")
  end
  local raw = {}
  if #seatKeys > 0 then
    for i = 1, #seatKeys do
      local k = seatKeys[i]
      if U.Type(k) ~= "string" or k == "" then
        error("rotational-seat-layout: seatKeys[" .. tostring(i) .. "] must be a non-empty string")
      end
      table.insert(raw, k)
    end
  else
    for k, _ in pairs(seatKeys) do
      if U.Type(k) ~= "string" or k == "" then
        error("rotational-seat-layout: seatKeys map keys must be non-empty strings")
      end
      table.insert(raw, k)
    end
  end
  return dedupeSeatKeysPreserveOrder(raw)
end

--- Blacklist: truthy `blacklist[seatKey]`, or `seatKey` appears as an array element.
--- @param blacklist table|nil
--- @param seatKey string
--- @return boolean
local function isSeatKeyBlacklisted(blacklist, seatKey)
  if blacklist == nil then
    return false
  end
  if U.Type(blacklist) ~= "table" then
    error("rotational-seat-layout: blacklist must be a table or nil")
  end
  if blacklist[seatKey] then
    return true
  end
  for _, entry in ipairs(blacklist) do
    if entry == seatKey then
      return true
    end
  end
  return false
end

--- @param obj Object
--- @param tag string
local function mergeObjectTag(obj, tag)
  local tags = obj.getTags and obj.getTags() or {}
  if U.Type(tags) ~= "table" then
    tags = {}
  end
  for _, t in ipairs(tags) do
    if t == tag then
      return
    end
  end
  table.insert(tags, tag)
  obj.setTags(tags)
end

--- Drops `removeTag` and ensures `addTag` is present exactly once among any other tags.
--- @param obj Object
--- @param removeTag string e.g. `RedObject`
--- @param addTag string e.g. `OrangeObject`
local function replaceSeatOwnershipTags(obj, removeTag, addTag)
  if obj == nil then
    return
  end
  local tags = obj.getTags and obj.getTags() or {}
  if U.Type(tags) ~= "table" then
    tags = {}
  end
  local out = {}
  for _, t in ipairs(tags) do
    if t == removeTag then
      -- omit reference-seat tag
    else
      table.insert(out, t)
    end
  end
  local hasAdd = false
  for _, t in ipairs(out) do
    if t == addTag then
      hasAdd = true
      break
    end
  end
  if not hasAdd then
    table.insert(out, addTag)
  end
  obj.setTags(out)
end

--- After move: strip reference `{Color}Object` tag, add target seat tag, and update GM Notes role suffix.
--- @param obj Object
--- @param roleKey string template role (e.g. `CSHEET_PAGE_1`)
--- @param seatColor string target seat key (e.g. `"Orange"`)
--- @param referenceTag string e.g. `RedObject`
--- @param seatTag string e.g. `OrangeObject`
local function applySeatObjectIdentity(obj, roleKey, seatColor, referenceTag, seatTag)
  replaceSeatOwnershipTags(obj, referenceTag, seatTag)
  if not isHandZoneObject(obj) and not isHandZoneRoleKey(roleKey) then
    SRI.setRoleColorIdentity(obj, roleKey, seatColor)
  end
end

--- Resolve the reference seat's template slots, the hand-zone anchor slot index, and the anchor's
--- source frame. Shared by circular + facing layout generators.
--- @param sourceGroups table
--- @param referencePlayerColor string
--- @return table referenceSlots
--- @return number anchorIndex
--- @return table referenceAnchorFrame `{ position = Vector, rotation = Vector }`
local function resolveReferenceSeatAnchor(sourceGroups, referencePlayerColor)
  local referenceEntries = sourceGroupEntriesForSeat(sourceGroups, referencePlayerColor)
  if #referenceEntries < 1 then
    error("rotational-seat-layout: active source template list for reference seat is empty")
  end
  local referenceSlots = resolveSeatTemplateSlots(referenceEntries, referencePlayerColor)
  local anchorIndex
  referenceSlots, anchorIndex = ensureReferenceHandZoneAnchorSlot(referenceSlots, referencePlayerColor)
  local slotCount = #referenceSlots
  if U.Type(anchorIndex) ~= "number" or anchorIndex < 1 or anchorIndex > slotCount or math.floor(anchorIndex) ~= anchorIndex then
    error("rotational-seat-layout: resolved hand-zone anchor index is out of range (got " .. tostring(anchorIndex) .. ")")
  end
  local refAnchorSrc = referenceSlots[anchorIndex].sourceFrame
  local referenceAnchorFrame = {
    position = Vector(refAnchorSrc.position),
    rotation = Vector(refAnchorSrc.rotation),
  }
  return referenceSlots, anchorIndex, referenceAnchorFrame
end

--- Resolve one seat's template slots (injecting the reference hand-zone anchor frame when the seat has
--- no hand-zone role of its own), then place each slot by the seat's **rigid transform**: yaw `deltaDeg`
--- about `centerPoint`, then translate by `shift`. Shape-agnostic — circular and facing layouts only
--- differ in how `deltaDeg` / `shift` are computed.
--- @return table slotsOut
--- @return table byRoleKey
local function buildPlacedSeatSlots(sourceGroups, seatKey, referencePlayerColor, referenceSlots, anchorIndex, centerPoint, deltaDeg, shift)
  local entries = sourceGroupEntriesForSeat(sourceGroups, seatKey)
  local seatSlots = resolveSeatTemplateSlots(entries, referencePlayerColor)
  local hasHandZoneRole = false
  for i = 1, #seatSlots do
    if isHandZoneRoleKey(seatSlots[i].roleKey) then
      hasHandZoneRole = true
      break
    end
  end
  if not hasHandZoneRole then
    local refAnchorSlot = referenceSlots[anchorIndex]
    table.insert(seatSlots, {
      sourceRef = nil,
      isFrame = true,
      roleKey = refAnchorSlot.roleKey,
      displayName = refAnchorSlot.displayName,
      sourceFrame = {
        position = Vector(refAnchorSlot.sourceFrame.position),
        rotation = Vector(refAnchorSlot.sourceFrame.rotation),
      },
      sourceObject = nil,
    })
  end
  local slotsOut = {}
  local byRole = {}
  for i = 1, #seatSlots do
    local slot = seatSlots[i]
    local fr = U.frameAfterRigidYawAboutCenter(centerPoint, slot.sourceFrame, deltaDeg)
    fr.position = fr.position + shift
    local rk = slot.roleKey
    if byRole[rk] ~= nil then
      error("rotational-seat-layout: duplicate role key '" .. rk .. "' for seat " .. seatKey .. " (check template names)")
    end
    byRole[rk] = fr
    slotsOut[i] = {
      roleKey = rk,
      displayName = slot.displayName,
      isFrame = slot.isFrame,
      sourceRef = slot.sourceRef,
      frame = fr,
    }
  end
  return slotsOut, byRole
end

--- Greatest 1-based seat index defined on a FACING/RECTANGULAR side (the number of equal segments to
--- divide that side into). Counts the **full** config map so positions stay stable when seats are
--- filtered out (e.g. `Table C` keeps 5 NPC-side segments even though NPC5 is never occupied).
--- @param fullMap table<string, table> `playerToPositionMap` with `{ side, index }` entries
--- @param sideAngleDeg number
--- @return number
local function facingMaxIndexForSide(fullMap, sideAngleDeg)
  local target = sideAngleDeg % 360
  local maxIndex = 0
  for _, entry in pairs(fullMap) do
    if U.Type(entry) == "table" and U.Type(entry.index) == "number"
        and (tonumber(entry.side) or 0) % 360 == target then
      if entry.index > maxIndex then
        maxIndex = entry.index
      end
    end
  end
  return maxIndex
end

--- Center-of-segment X for a seat on a FACING side. The side runs along world X; the side is divided
--- into `nSeats` equal segments across the table's bounding-box X span. Index increases **clockwise**
--- from above: on the +Z side (0°) index 1 is the -X (left) end → +X; on the -Z side (180°) index 1 is
--- the +X end → -X.
--- @param sideAngleDeg number 0 (+Z) or 180 (-Z)
--- @param index1Based number
--- @param nSeats number
--- @param xMin number
--- @param xMax number
--- @return number
local function facingSegmentCenterX(sideAngleDeg, index1Based, nSeats, xMin, xMax)
  if nSeats < 1 then
    nSeats = 1
  end
  local segWidth = (xMax - xMin) / nSeats
  if (sideAngleDeg % 360) == 0 then
    return xMin + (index1Based - 0.5) * segWidth
  end
  return xMax - (index1Based - 0.5) * segWidth
end

--- Validate inputs, compute frames, write frame-ref workspace file. On success returns a table consumed by resolveSeatObjects.
---
--- @param sourceObjects table `{ player = {...}, other = {...}, all = {...} }` where each array entry is an object reference/GUID or a Frame table
--- @param centerPoint Vector|table
--- @param numSegments number
--- @param angleSegmentOne number degrees, azimuth of segment 1 (0° = +Z; higher segment indices = larger angle, clockwise as seen from +Y)
--- @param playerToPositionMap table<string, number> keys are arbitrary seat labels (TTS player colors, NPC seat ids, etc.); values are 1-based segment indices
--- @param referencePlayerColor string Which seat owns the template objects; every template name suffix must be _`string.upper(referencePlayerColor)` (suffix is uppercase alphanumeric)
--- @param options table|nil { anchorIndex?, radius?, frameRefsRelativePath?, frameRefsVarName? } — `anchorIndex` (default 1) selects which slot’s azimuth anchors the segment map
--- @return table computed bundle for spawn
function M.generateRotationalCoordinates(
    sourceObjects,
    centerPoint,
    numSegments,
    angleSegmentOne,
    playerToPositionMap,
    referencePlayerColor,
    options
)
  options = options or {}
  if U.Type(referencePlayerColor) ~= "string" or referencePlayerColor == "" then
    error("rotational-seat-layout: referencePlayerColor must be a non-empty string")
  end
  local sourceGroups = resolveSourceTemplateGroups(sourceObjects)
  if U.Type(numSegments) ~= "number" or numSegments < 1 or math.floor(numSegments) ~= numSegments then
    error("rotational-seat-layout: numSegments must be a positive integer")
  end
  if U.Type(angleSegmentOne) ~= "number" then
    error("rotational-seat-layout: angleSegmentOne must be a number (degrees)")
  end
  if U.Type(playerToPositionMap) ~= "table" then
    error("rotational-seat-layout: playerToPositionMap must be a table")
  end

  local mapCopy = {}
  for c, seg in pairs(playerToPositionMap) do
    if U.Type(c) ~= "string" or c == "" then
      error("rotational-seat-layout: playerToPositionMap keys must be non-empty strings")
    end
    if U.Type(seg) ~= "number" or seg < 1 or seg > numSegments or math.floor(seg) ~= seg then
      error(
        "rotational-seat-layout: segment for '"
        .. c
        .. "' must be integer 1.."
        .. tostring(numSegments)
        .. " (got "
        .. tostring(seg)
        .. ")"
      )
    end
    mapCopy[c] = seg
  end

  local referenceSlots, anchorIndex, referenceAnchorFrame = resolveReferenceSeatAnchor(sourceGroups, referencePlayerColor)

  local anchorPos = referenceSlots[anchorIndex].sourceFrame.position
  local cyl = U.XYZToCylindrical(anchorPos, centerPoint)
  local thetaRef = cyl.angle
  local inferredSeg, angErr = inferNearestSegment(thetaRef, numSegments, angleSegmentOne)
  if angErr > MAX_SEGMENT_ANGLE_ERROR_DEG then
    error(
      "rotational-seat-layout: template anchor azimuth is "
      .. string.format("%.2f", angErr)
      .. "° off the nearest nominal seat (max "
      .. tostring(MAX_SEGMENT_ANGLE_ERROR_DEG)
      .. "°). Check centerPoint, numSegments, angleSegmentOne, and template placement."
    )
  end

  local mapSeg = mapCopy[referencePlayerColor]
  if mapSeg == nil then
    error("rotational-seat-layout: playerToPositionMap missing entry for referencePlayerColor '" ..
    referencePlayerColor .. "'")
  end
  if mapSeg ~= inferredSeg then
    error(
      "rotational-seat-layout: inferred reference seat segment is "
      .. tostring(inferredSeg)
      .. " but playerToPositionMap['"
      .. referencePlayerColor
      .. "'] = "
      .. tostring(mapSeg)
      .. " (azimuth error to nearest seat was "
      .. string.format("%.2f", angErr)
      .. "°)"
    )
  end

  local inferredRadius = U.HorizontalDistance(anchorPos, centerPoint)
  if inferredRadius < 1e-4 then
    error("rotational-seat-layout: template anchor is too close to centerPoint in XZ (radius ~0)")
  end
  local useRadius = inferredRadius
  if options.radius ~= nil then
    if U.Type(options.radius) ~= "number" or options.radius <= 0 then
      error("rotational-seat-layout: options.radius must be a positive number when provided")
    end
    useRadius = options.radius
  end

  local byColor = {}
  local nestedFrameExport = {}
  local seatTypeByKey = {}
  local seatRigidByKey = {}

  for seatKey, seg in pairs(mapCopy) do
    local thetaK = segmentNominalAzimuthDeg(angleSegmentOne, numSegments, seg)
    local deltaDeg = shortestSignedDelta(thetaRef, thetaK)
    local rotatedAnchor = U.frameAfterRigidYawAboutCenter(centerPoint, referenceSlots[anchorIndex].sourceFrame, deltaDeg)
    local desiredAnchorPos = Vector({
      x = centerPoint.x + math.sin(math.rad(thetaK)) * useRadius,
      y = rotatedAnchor.position.y,
      z = centerPoint.z + math.cos(math.rad(thetaK)) * useRadius,
    })
    local shift = desiredAnchorPos - rotatedAnchor.position
    local slotsOut, byRole = buildPlacedSeatSlots(
      sourceGroups, seatKey, referencePlayerColor, referenceSlots, anchorIndex, centerPoint, deltaDeg, shift)
    byColor[seatKey] = {
      slots = slotsOut,
      byRoleKey = byRole,
    }
    nestedFrameExport[seatKey] = byRole
    seatTypeByKey[seatKey] = isPlayerSeatKey(seatKey) and "player" or "other"
    seatRigidByKey[seatKey] = { deltaDeg = deltaDeg, shift = shift }
  end

  local framePath = options.frameRefsRelativePath or DEFAULT_FRAME_REFS_PATH
  local frameVar = options.frameRefsVarName or DEFAULT_FRAME_REFS_VAR
  local tableKey = options.currentTableKey
  if U.Type(tableKey) ~= "string" or tableKey == "" then
    tableKey = inferTableKeyFromCenterPoint(centerPoint)
  end
  if U.Type(tableKey) == "string" and tableKey ~= "" then
    S.setStateVal(tableKey, "seatLayout", "currentTableKey")
  end
  if WRITE_RESULTS_TO_FILE then
    assertSendExternalMessage()
    local frameLua = serializeFrameRefsLua(frameVar, nestedFrameExport)
    local okWrite = getDebugModule().writeWorkspaceFile(framePath, frameLua, "none", false)
    if not okWrite then
      error("rotational-seat-layout: DEBUG.writeWorkspaceFile failed for frame refs at '" .. framePath .. "'")
    end
  end

  return {
    shape = C.TableShapes and C.TableShapes.CIRCULAR or "circular",
    referencePlayerColor = referencePlayerColor,
    centerPoint = centerPoint,
    numSegments = numSegments,
    angleSegmentOne = angleSegmentOne,
    thetaRef = thetaRef,
    radius = useRadius,
    inferredRadius = inferredRadius,
    referenceAnchorFrame = referenceAnchorFrame,
    playerToPositionMap = mapCopy,
    sourceGroups = sourceGroups,
    seatTypeByKey = seatTypeByKey,
    anchorIndex = anchorIndex,
    byColor = byColor,
    seatRigidByKey = seatRigidByKey,
    frameRefsRelativePath = framePath,
    frameRefsVarName = frameVar,
  }
end

--- FACING-table layout generator (`C.TableShapes.FACING`). Produces the same `computed` bundle as
--- `generateRotationalCoordinates` (consumed by `resolveSeatObjects` + `applyCameraModesForSeats`), but
--- places seats along two opposing sides instead of a ring.
---
--- `playerToPositionMap[seat]` is `{ side, index }`: `side` is the side's outward azimuth in degrees
--- (0 = +Z, 180 = -Z); `index` (1-based) is the seat's slot along that side. Each side is divided into
--- N equal segments across the **active table's bounding-box X span** (read live — the table must be at
--- its active position/scale), seat centered in its segment, index increasing clockwise from origin.
---
--- Placement is a rigid transform of the reference seat template: yaw `(seatSide - referenceSide)` about
--- `centerPoint` (0° or 180° — depends only on `side`, never `index`), then a pure X shift to the seat's
--- segment center. Y/Z come from the rotated reference anchor (symmetric rows about center).
---
--- Orientation is **perpendicular to the edge**, NOT a look-at of the center point: because the yaw is a
--- flat 0°/180° and the index only translates along X, every seat inherits the reference template's
--- authored facing (e.g. straight +Z for the 180° side), mirrored for the opposite side. Do not replace
--- this with a per-seat `lookAtRotation` — that would aim seats at the center instead of straight inward.
---
--- @param sourceObjects table same nested shape as `generateRotationalCoordinates`
--- @param tableCfg table the `C.Tables` entry (FACING); provides `guid`, `centerPoint`, full `playerToPositionMap`, `referencePlayerColor`
--- @param filteredMap table<string, table> seats to actually place (`{ side, index }` values; e.g. occupancy-filtered)
--- @param options table|nil { currentTableKey?, frameRefsRelativePath?, frameRefsVarName? }
--- @return table computed bundle for resolveSeatObjects
function M.generateFacingCoordinates(sourceObjects, tableCfg, filteredMap, options)
  options = options or {}
  if U.Type(tableCfg) ~= "table" then
    error("rotational-seat-layout: generateFacingCoordinates requires a table config")
  end
  local referencePlayerColor = tableCfg.referencePlayerColor
  if U.Type(referencePlayerColor) ~= "string" or referencePlayerColor == "" then
    error("rotational-seat-layout: FACING table referencePlayerColor must be a non-empty string")
  end
  local centerPoint = Vector(tableCfg.centerPoint)
  local fullMap = tableCfg.playerToPositionMap
  if U.Type(fullMap) ~= "table" then
    error("rotational-seat-layout: FACING table playerToPositionMap must be a table")
  end
  local refEntry = fullMap[referencePlayerColor]
  if U.Type(refEntry) ~= "table" or U.Type(refEntry.side) ~= "number" then
    error("rotational-seat-layout: FACING playerToPositionMap['" .. referencePlayerColor ..
      "'] must be { side = <deg>, index = <n> }")
  end
  local referenceSide = refEntry.side

  -- Bounds must be read AFTER the table is the active table (positioned + scaled); callers run this
  -- right after applyAllTablesVisualState.
  if U.Type(tableCfg.guid) ~= "string" or tableCfg.guid == "" then
    error("rotational-seat-layout: FACING table is missing guid (needed to read active bounds)")
  end
  local tableObj = G.getObject(tableCfg.guid)
  if tableObj == nil or type(tableObj.getBounds) ~= "function" then
    error("rotational-seat-layout: FACING table object '" .. tostring(tableCfg.guid) ..
      "' is not present; cannot read bounds")
  end
  local bounds = tableObj.getBounds()
  if U.Type(bounds) ~= "table" or bounds.center == nil or bounds.size == nil then
    error("rotational-seat-layout: FACING table getBounds() returned no center/size")
  end
  local boundsCenter = Vector(bounds.center)
  local boundsSize = Vector(bounds.size)
  local xMin = boundsCenter.x - boundsSize.x / 2
  local xMax = boundsCenter.x + boundsSize.x / 2

  local sourceGroups = resolveSourceTemplateGroups(sourceObjects)
  local referenceSlots, anchorIndex, referenceAnchorFrame =
      resolveReferenceSeatAnchor(sourceGroups, referencePlayerColor)

  local mapCopy = {}
  local byColor = {}
  local nestedFrameExport = {}
  local seatTypeByKey = {}
  local seatRigidByKey = {}

  for seatKey, entry in pairs(filteredMap) do
    if U.Type(seatKey) == "string" and U.Type(entry) == "table"
        and U.Type(entry.side) == "number" and U.Type(entry.index) == "number" then
      mapCopy[seatKey] = { side = entry.side, index = entry.index }
      local deltaDeg = shortestSignedDelta(referenceSide, entry.side)
      local rotatedAnchor = U.frameAfterRigidYawAboutCenter(centerPoint, referenceAnchorFrame, deltaDeg)
      local nSeats = facingMaxIndexForSide(fullMap, entry.side)
      local targetX = facingSegmentCenterX(entry.side, entry.index, nSeats, xMin, xMax)
      local desiredAnchorPos = Vector({
        x = targetX,
        y = rotatedAnchor.position.y,
        z = rotatedAnchor.position.z,
      })
      local shift = desiredAnchorPos - rotatedAnchor.position
      local slotsOut, byRole = buildPlacedSeatSlots(
        sourceGroups, seatKey, referencePlayerColor, referenceSlots, anchorIndex, centerPoint, deltaDeg, shift)
      byColor[seatKey] = {
        slots = slotsOut,
        byRoleKey = byRole,
      }
      nestedFrameExport[seatKey] = byRole
      seatTypeByKey[seatKey] = isPlayerSeatKey(seatKey) and "player" or "other"
      seatRigidByKey[seatKey] = { deltaDeg = deltaDeg, shift = shift }
    end
  end

  local framePath = options.frameRefsRelativePath or DEFAULT_FRAME_REFS_PATH
  local frameVar = options.frameRefsVarName or DEFAULT_FRAME_REFS_VAR
  local tableKey = options.currentTableKey
  if U.Type(tableKey) ~= "string" or tableKey == "" then
    tableKey = inferTableKeyFromCenterPoint(centerPoint)
  end
  if U.Type(tableKey) == "string" and tableKey ~= "" then
    S.setStateVal(tableKey, "seatLayout", "currentTableKey")
  end
  if WRITE_RESULTS_TO_FILE then
    assertSendExternalMessage()
    local frameLua = serializeFrameRefsLua(frameVar, nestedFrameExport)
    local okWrite = getDebugModule().writeWorkspaceFile(framePath, frameLua, "none", false)
    if not okWrite then
      error("rotational-seat-layout: DEBUG.writeWorkspaceFile failed for frame refs at '" .. framePath .. "'")
    end
  end

  return {
    shape = C.TableShapes and C.TableShapes.FACING or "facing",
    referencePlayerColor = referencePlayerColor,
    centerPoint = centerPoint,
    referenceAnchorFrame = referenceAnchorFrame,
    playerToPositionMap = mapCopy,
    sourceGroups = sourceGroups,
    seatTypeByKey = seatTypeByKey,
    anchorIndex = anchorIndex,
    byColor = byColor,
    seatRigidByKey = seatRigidByKey,
    frameRefsRelativePath = framePath,
    frameRefsVarName = frameVar,
  }
end

--- World XZ (Vector) of a FACING-table seat's segment center, from the active table's **live** bounds.
--- Mirrors `generateFacingCoordinates` X-segmentation; the row Z is derived from `referenceHandPosition`.
--- Returns nil if bounds are unavailable (e.g. the table is not the active table). Intended for minimap /
--- control-board markers; seat-object placement uses the generator's per-template frames, not this.
--- @param tableCfg table
--- @param sideAngleDeg number
--- @param index1Based number
--- @return Vector|nil
function M.facingSeatWorldXZ(tableCfg, sideAngleDeg, index1Based)
  if U.Type(tableCfg) ~= "table" or U.Type(tableCfg.guid) ~= "string" or tableCfg.centerPoint == nil then
    return nil
  end
  if U.Type(sideAngleDeg) ~= "number" or U.Type(index1Based) ~= "number" then
    return nil
  end
  local obj = G.getObject(tableCfg.guid)
  if obj == nil or type(obj.getBounds) ~= "function" then
    return nil
  end
  local bounds = obj.getBounds()
  if U.Type(bounds) ~= "table" or bounds.center == nil or bounds.size == nil then
    return nil
  end
  local cp = Vector(tableCfg.centerPoint)
  local bc = Vector(bounds.center)
  local bs = Vector(bounds.size)
  local xMin = bc.x - bs.x / 2
  local xMax = bc.x + bs.x / 2
  local nSeats = facingMaxIndexForSide(tableCfg.playerToPositionMap or {}, sideAngleDeg)
  local x = facingSegmentCenterX(sideAngleDeg, index1Based, nSeats, xMin, xMax)
  local rowDist = 0
  if tableCfg.referenceHandPosition ~= nil then
    rowDist = U.HorizontalDistance(cp, Vector(tableCfg.referenceHandPosition))
  end
  local z = cp.z + math.cos(math.rad(sideAngleDeg)) * rowDist
  return Vector(x, cp.y, z)
end

--- Tag templates; for non-template seats, move existing tagged objects that match each template slot
--- by ROLE key (GM Notes `ROLE_SUFFIX`; suffix may differ per seat), skip missing slots, write GUID map.
---
--- @param computed table return value of generateRotationalCoordinates (includes referencePlayerColor)
--- @param sourceObjects table same nested shape passed to generateRotationalCoordinates: `{ player = {...}, other = {...}, all = {...} }`
--- @param options table|nil { guidMapRelativePath?, guidMapVarName?, guidTransformsVarName?, guidFollowerTransformsVarName? }
function M.resolveSeatObjects(computed, sourceObjects, options)
  options = options or {}
  if U.Type(computed) ~= "table" or computed.byColor == nil or computed.playerToPositionMap == nil then
    error("rotational-seat-layout: computed must be the return value of generateRotationalCoordinates")
  end
  if U.Type(computed.referencePlayerColor) ~= "string" or computed.referencePlayerColor == "" then
    error("rotational-seat-layout: computed.referencePlayerColor is missing")
  end

  local referencePlayerColor = computed.referencePlayerColor
  local sourceGroups = resolveSourceTemplateGroups(sourceObjects)
  local referenceEntries = sourceGroupEntriesForSeat(sourceGroups, referencePlayerColor)
  if #referenceEntries < 1 then
    error("rotational-seat-layout: active source template list for reference seat is empty")
  end

  assertSendExternalMessage()

  local templateGuidSet = {}
  for _, group in ipairs(collectTemplateGroups(sourceGroups)) do
    for i = 1, #group do
      local ref = group[i]
      if not isFrameEntry(ref) then
        local obj = resolveObjectRefWithRoleSupport(
          ref,
          referencePlayerColor,
          "source template object at index " .. tostring(i)
        )
        if obj == nil then
          error("rotational-seat-layout: could not resolve source template object at index " .. tostring(i))
        end
        local g = obj.getGUID and obj.getGUID() or ""
        if g == "" then
          error("rotational-seat-layout: source template object has no GUID")
        end
        templateGuidSet[g] = true
      end
    end
  end

  local templateTag = objectTagForPlayerColor(referencePlayerColor)
  local referencePack = computed.byColor[referencePlayerColor]
  if U.Type(referencePack) ~= "table" or U.Type(referencePack.slots) ~= "table" then
    error("rotational-seat-layout: computed.byColor is missing reference seat slots")
  end

  local referenceObjByRole = {}
  for i = 1, #referencePack.slots do
    local slot = referencePack.slots[i]
    if isHandZoneRoleKey(slot.roleKey) then
      -- Store sentinel so reference hand-zone anchor slots are processed below even when virtual-frame injected.
      referenceObjByRole[slot.roleKey] = false
    elseif not slot.isFrame then
      local o = resolveObjectRefWithRoleSupport(
        slot.sourceRef,
        referencePlayerColor,
        "reference source object for role '" .. tostring(slot.roleKey) .. "'"
      )
      if o == nil then
        error("rotational-seat-layout: could not resolve reference source object for role '" ..
        tostring(slot.roleKey) .. "'")
      end
      if not isHandZoneRoleKey(slot.roleKey) and not isHandZoneObject(o) then
        mergeObjectTag(o, templateTag)
      end
      referenceObjByRole[slot.roleKey] = o
    end
  end

  -- Move reference-seat objects to their computed transforms too (important for radius override consistency).
  local referenceHandZoneMove = nil
  local previousVirtualAnchors = S.getStateVal("seatLayout", "virtualHandZoneAnchors")
  if U.Type(previousVirtualAnchors) ~= "table" then
    previousVirtualAnchors = {}
  end
  local nextVirtualAnchors = {}
  for i = 1, #referencePack.slots do
    local slot = referencePack.slots[i]
    local isHandZoneSlot = isHandZoneRoleKey(slot.roleKey)
    local pos = Vector(slot.frame.position)
    local rot = Vector(slot.frame.rotation)
    if isHandZoneSlot or not slot.isFrame then
      local obj = referenceObjByRole[slot.roleKey]
      if obj ~= nil and obj ~= false then
        placeObjectExact(obj, pos, rot)
        maybeSetHandZoneSeatColor(obj, slot.roleKey, referencePlayerColor)
      end
      if isHandZoneSlot and isPlayerSeatKey(referencePlayerColor) then
        local hz = U.getHandZone(referencePlayerColor)
        if hz == nil then
          error("rotational-seat-layout: no hand zone for reference seat '" .. tostring(referencePlayerColor) .. "'")
        end
        local hzBefore = moveHandZoneAndContainedCards(hz, pos, rot)
        maybeSetHandZoneSeatColor(hz, slot.roleKey, referencePlayerColor)
        referenceHandZoneMove = {
          roleKey = slot.roleKey,
          before = hzBefore,
          after = {
            position = pos,
            rotation = rot,
          },
        }
        nextVirtualAnchors[referencePlayerColor] = {
          position = pos,
          rotation = rot,
        }
      end
    end
  end

  --- [color] = { [role] = guid } for non-template colors (moved; empty string when slot skipped)
  local cloneGuidByColorRole = {}
  --- [color] = { [role] = Object } for non-template colors (moved; nil when slot skipped)
  local seatObjByColorRole = {}
  local handZoneMoveBySeat = {}
  handZoneMoveBySeat[referencePlayerColor] = referenceHandZoneMove
  local followerTransformsBySeat = {}
  local relativeGuidSet = {}
  if #sourceGroups.relative > 0 then
    for i = 1, #sourceGroups.relative do
      local relRef = sourceGroups.relative[i]
      local relObj = resolveObjectRefWithRoleSupport(
        relRef,
        referencePlayerColor,
        "sourceObjects.relative[" .. tostring(i) .. "]"
      )
      if relObj ~= nil and relObj.getGUID ~= nil then
        local rg = relObj.getGUID()
        if U.Type(rg) == "string" and rg ~= "" then
          relativeGuidSet[rg] = true
        end
      end
    end
  end

  for color, pack in pairs(computed.byColor) do
    if color ~= referencePlayerColor then
      local slots = pack.slots
      if U.Type(slots) ~= "table" or #slots < 1 then
        error("rotational-seat-layout: internal error: slot set missing for seat '" .. color .. "'")
      end
      local seatTag = objectTagForPlayerColor(color)
      local tagged = getObjectsWithTag(seatTag)
      local byRole = {}
      if U.Type(tagged) == "table" then
        for _, o in ipairs(tagged) do
          if o ~= nil and o.getGUID then
            local og = o.getGUID()
            if not templateGuidSet[og] and not relativeGuidSet[og] then
              local disp = SRI.readRoleColorIdentity(o)
              if disp ~= nil then
                local role, _ = SRI.parseRoleAndSuffix(disp)
                if byRole[role] ~= nil and byRole[role] ~= o then
                  error(
                    "rotational-seat-layout: seat '"
                    .. color
                    .. "' has two tagged objects with role '"
                    .. role
                    .. "' (from GM Notes); cannot pick one to move"
                  )
                else
                  byRole[role] = o
                end
              else
                local objGuid = tostring(o.getGUID() or "unknown-guid")
                local objNotes = o.getGMNotes ~= nil and tostring(o.getGMNotes() or "") or ""
                error(
                  "rotational-seat-layout: seat '"
                  .. color
                  .. "' tagged object "
                  .. objGuid
                  .. " has no ROLE_COLOR GM Notes (got GMNotes='"
                  .. objNotes
                  .. "')"
                )
              end
            end
          end
        end
      end

      cloneGuidByColorRole[color] = {}
      seatObjByColorRole[color] = {}
      handZoneMoveBySeat[color] = nil
      for i = 1, #slots do
        local slot = slots[i]
        local fr = slot.frame
        local pos = Vector(fr.position)
        local rot = Vector(fr.rotation)
        local expectedRole = slot.roleKey

        if isHandZoneRoleKey(expectedRole) then
          local previousAnchor = previousVirtualAnchors[color]
          local beforeAnchor = {
            position = pos,
            rotation = rot,
          }
          if U.Type(previousAnchor) == "table" and previousAnchor.position ~= nil and previousAnchor.rotation ~= nil then
            beforeAnchor = {
              position = Vector(previousAnchor.position),
              rotation = Vector(previousAnchor.rotation),
            }
          end

          if isPlayerSeatKey(color) then
            local hz = U.getHandZone(color)
            if hz == nil then
              error(
                "rotational-seat-layout: no hand zone for seat '"
                .. color
                .. "' (required for role '"
                .. expectedRole
                .. "')"
              )
            end
            local hzBefore = {
              position = hz.getPosition(),
              rotation = hz.getRotation(),
            }
            hzBefore = moveHandZoneAndContainedCards(hz, pos, rot)
            maybeSetHandZoneSeatColor(hz, expectedRole, color)
            local eg = hz.getGUID and hz.getGUID() or ""
            if eg == "" then
              error(
                "rotational-seat-layout: hand zone has empty GUID for seat '"
                .. color
                .. "'"
              )
            end
            cloneGuidByColorRole[color][expectedRole] = eg
            seatObjByColorRole[color][expectedRole] = hz
            beforeAnchor = hzBefore
          else
            cloneGuidByColorRole[color][expectedRole] = ""
            seatObjByColorRole[color][expectedRole] = nil
          end
          handZoneMoveBySeat[color] = {
            roleKey = expectedRole,
            before = beforeAnchor,
            after = {
              position = pos,
              rotation = rot,
            },
          }
          nextVirtualAnchors[color] = {
            position = pos,
            rotation = rot,
          }
        elseif slot.isFrame then
          cloneGuidByColorRole[color][expectedRole] = ""
          seatObjByColorRole[color][expectedRole] = nil
        else
          local existing = byRole[expectedRole]
          if existing ~= nil then
            byRole[expectedRole] = nil
            placeObjectExact(existing, pos, rot)
            applySeatObjectIdentity(existing, expectedRole, color, templateTag, seatTag)
            maybeSetHandZoneSeatColor(existing, expectedRole, color)
            local eg = existing.getGUID and existing.getGUID() or ""
            if eg == "" then
              error(
                "rotational-seat-layout: moved object has empty GUID for color '"
                .. color
                .. "' slot '"
                .. expectedRole
                .. "'"
              )
            end
            cloneGuidByColorRole[color][expectedRole] = eg
            seatObjByColorRole[color][expectedRole] = existing
          else
            cloneGuidByColorRole[color][expectedRole] = ""
            seatObjByColorRole[color][expectedRole] = nil
          end
        end
      end

      local orphanCount = 0
      local orphanDetails = {}
      for _role, o in pairs(byRole) do
        if o ~= nil then
          orphanCount = orphanCount + 1
          local guid = "unknown-guid"
          local name = "unknown-name"
          if o.getGUID ~= nil then
              guid = tostring(o.getGUID() or guid)
          end
          if o.getGMNotes ~= nil then
              local notes = tostring(o.getGMNotes() or "")
              if notes ~= "" then
                  name = notes
              end
          end
          if name == "unknown-name" and o.getName ~= nil then
              name = tostring(o.getName() or name)
          end
          orphanDetails[#orphanDetails + 1] = string.format("%s (%s)", name, guid)
        end
      end
      if orphanCount > 0 then
        table.sort(orphanDetails)
        print(
          "[rotational-seat-layout] seat '"
          .. color
          .. "': "
          .. tostring(orphanCount)
          .. " tagged object(s) did not match any template slot (left in place)."
          .. " Unmatched: "
          .. table.concat(orphanDetails, ", ")
        )
      end
    end
  end

  -- Relative objects always follow the hand-zone anchor of the seat inferred from their <SeatKey>Object tag.
  local relativeObjectsBySeat = {}
  if #sourceGroups.relative > 0 then
    for i = 1, #sourceGroups.relative do
      local relRef = sourceGroups.relative[i]
      local relObj = resolveObjectRefWithRoleSupport(
        relRef,
        referencePlayerColor,
        "sourceObjects.relative[" .. tostring(i) .. "]"
      )
      if relObj == nil then
        error("rotational-seat-layout: could not resolve sourceObjects.relative[" .. tostring(i) .. "]")
      end
      local seatKey = deriveSeatKeyFromObjectTag(relObj)
      if seatKey == nil then
        error(
          "rotational-seat-layout: sourceObjects.relative[" ..
          tostring(i) .. "] has no <SeatKey>Object tag to infer target seat"
        )
      end
      relativeObjectsBySeat[seatKey] = relativeObjectsBySeat[seatKey] or {}
      table.insert(relativeObjectsBySeat[seatKey], relObj)
    end
  end
  for seatKey, refs in pairs(relativeObjectsBySeat) do
    local hzMove = handZoneMoveBySeat[seatKey]
    if hzMove ~= nil then
      local beforePos = Vector(hzMove.before.position)
      local afterPos = Vector(hzMove.after.position)
      local beforeRot = Vector(hzMove.before.rotation)
      local afterRot = Vector(hzMove.after.rotation)
      local deltaYaw = shortestSignedDelta(beforeRot.y, afterRot.y)
      for i = 1, #refs do
        local extraObj = refs[i]
        if extraObj == nil then
          error(
            "rotational-seat-layout: could not resolve sourceObjects.relative["
            .. tostring(i)
            .. "] for seat '"
            .. seatKey
            .. "'"
          )
        end
        local oldFrame = {
          position = extraObj.getPosition(),
          rotation = extraObj.getRotation(),
        }
        local newFrame = rigidTransformBetweenCenters(beforePos, afterPos, oldFrame, deltaYaw)
        placeObjectExact(extraObj, newFrame.position, newFrame.rotation)
        local guid = extraObj.getGUID and extraObj.getGUID() or ""
        if guid ~= "" then
          if followerTransformsBySeat[seatKey] == nil then
            followerTransformsBySeat[seatKey] = {}
          end
          followerTransformsBySeat[seatKey][guid] = {
            position = extraObj.getPosition(),
            rotation = extraObj.getRotation(),
          }
        end
      end
    end
  end
  S.setStateVal(nextVirtualAnchors, "seatLayout", "virtualHandZoneAnchors")

  local guidNested = {}
  local transformNested = {}
  for color, _ in pairs(computed.playerToPositionMap) do
    guidNested[color] = {}
    transformNested[color] = {}
    local framesPack = computed.byColor[color]
    if framesPack == nil or U.Type(framesPack.slots) ~= "table" then
      error("rotational-seat-layout: internal error: missing byColor entry for '" .. color .. "'")
    end
    for i = 1, #framesPack.slots do
      local slot = framesPack.slots[i]
      local rk = slot.roleKey
      if guidNested[color][rk] ~= nil then
        error("rotational-seat-layout: internal error: duplicate role key in guid export '" .. rk .. "'")
      end
      local guid = ""
      local slotFrame = slot.isFrame
      local frComputed = slot.frame
      if color == referencePlayerColor then
        if slotFrame then
          if isHandZoneRoleKey(rk) and isPlayerSeatKey(color) then
            local hzRef = U.getHandZone(color)
            if hzRef == nil then
              error(
                "rotational-seat-layout: missing hand zone for reference seat '"
                .. tostring(color)
                .. "' while exporting GUID map"
              )
            end
            guid = hzRef.getGUID and hzRef.getGUID() or ""
            if guid == "" then
              error(
                "rotational-seat-layout: reference hand zone has empty GUID for seat '"
                .. tostring(color)
                .. "'"
              )
            end
          else
            guid = ""
          end
          transformNested[color][rk] = {
            position = Vector(frComputed.position),
            rotation = Vector(frComputed.rotation),
          }
        else
          local obj = referenceObjByRole[rk]
          if obj == nil then
            error(
              "rotational-seat-layout: internal error: missing reference object for color '"
              .. color
              .. "' role "
              .. tostring(rk)
            )
          end
          guid = obj.getGUID and obj.getGUID() or ""
          transformNested[color][rk] = {
            position = obj.getPosition(),
            rotation = obj.getRotation(),
          }
        end
      else
        local byRoleMap = cloneGuidByColorRole[color]
        if U.Type(byRoleMap) ~= "table" then
          error("rotational-seat-layout: internal error: missing clone GUID table for '" .. color .. "'")
        end
        guid = byRoleMap[rk] or ""
        if slotFrame then
          transformNested[color][rk] = {
            position = Vector(frComputed.position),
            rotation = Vector(frComputed.rotation),
          }
        else
          local objByRole = seatObjByColorRole[color]
          local liveObj = U.Type(objByRole) == "table" and objByRole[rk] or nil
          if liveObj ~= nil then
            transformNested[color][rk] = {
              position = liveObj.getPosition(),
              rotation = liveObj.getRotation(),
            }
          else
            transformNested[color][rk] = {
              position = Vector(frComputed.position),
              rotation = Vector(frComputed.rotation),
            }
          end
        end
      end
      if (guid == nil or guid == "") and not slotFrame and color == referencePlayerColor then
        error(
          "rotational-seat-layout: could not resolve object GUID for reference seat '"
          .. color
          .. "' role '"
          .. rk
          .. "'"
        )
      end
      guidNested[color][rk] = guid
    end
  end

  if WRITE_RESULTS_TO_FILE then
    local guidPath = options.guidMapRelativePath or DEFAULT_GUID_MAP_PATH
    local guidVar = options.guidMapVarName or DEFAULT_GUID_MAP_VAR
    local tfVar = options.guidTransformsVarName or DEFAULT_GUID_TRANSFORMS_VAR
    local followerTfVar = options.guidFollowerTransformsVarName or DEFAULT_GUID_FOLLOWER_TRANSFORMS_VAR
    local guidLua = serializeGuidMapLua(guidVar, guidNested)
    local tfLua = serializeObjectTransformsLua(tfVar, transformNested)
    local followerTfLua = serializeFollowerTransformsLua(followerTfVar, followerTransformsBySeat)
    local outputLua = guidLua .. "\n\n" .. tfLua .. "\n\n" .. followerTfLua
    local okGWrite = getDebugModule().writeWorkspaceFile(guidPath, outputLua, "none", false)
    if not okGWrite then
      error("rotational-seat-layout: DEBUG.writeWorkspaceFile failed for GUID map at '" .. guidPath .. "'")
    end
  end
end

--- Count occupied NPC seats (truthy character key in `seatLayout.occupiedNPCSlots`).
--- Counts `C.NPCSeats` only (NPC1..NPC4); narrative presence / enabled state is irrelevant.
--- @param slots table|nil defaults to `gameState.seatLayout.occupiedNPCSlots`
--- @return number
local function countOccupiedNpcSlots(slots)
  if U.Type(slots) ~= "table" then
    slots = S.getStateVal("seatLayout", "occupiedNPCSlots")
  end
  if U.Type(slots) ~= "table" then
    return 0
  end
  local n = 0
  for _, seatKey in ipairs(C.NPCSeats or {}) do
    local occupant = slots[seatKey]
    if U.Type(occupant) == "string" and occupant ~= "" then
      n = n + 1
    end
  end
  return n
end

--- Number of NPC seats (`C.NPCSeats`) the table config defines in `playerToPositionMap`.
--- @param tableCfg table|nil
--- @return number
local function tableNpcSlotCapacity(tableCfg)
  if U.Type(tableCfg) ~= "table" then
    return 0
  end
  ---@cast tableCfg table
  local map = tableCfg.playerToPositionMap
  if U.Type(map) ~= "table" then
    return 0
  end
  local n = 0
  for _, seatKey in ipairs(C.NPCSeats or {}) do
    if map[seatKey] ~= nil then
      n = n + 1
    end
  end
  return n
end

--- Numbered `C.Tables` variants for a family key, e.g. `"Table B"` → `{ [0]="Table B0", … }`.
--- @param familyKey string
--- @return table<number, string>
local function listNumberedTableVariants(familyKey)
  local out = {}
  if U.Type(familyKey) ~= "string" or familyKey == "" then
    return out
  end
  local escaped = familyKey:gsub("(%W)", "%%%1")
  local pattern = "^" .. escaped .. "(%d+)$"
  for key in pairs(C.Tables or {}) do
    if U.Type(key) == "string" then
      local numStr = string.match(key, pattern)
      local num = numStr and tonumber(numStr) or nil
      if num ~= nil then
        out[num] = key
      end
    end
  end
  return out
end

--- True when `key` has no exact `C.Tables` entry but numbered variants exist (dynamic family key).
--- @param key string|nil
--- @return boolean
local function isDynamicTableFamilyKey(key)
  if U.Type(key) ~= "string" or key == "" then
    return false
  end
  if U.Type(C.Tables) == "table" and U.Type(C.Tables[key]) == "table" then
    return false
  end
  return next(listNumberedTableVariants(key)) ~= nil
end

--- Resolve a table key to a concrete `C.Tables` key.
--- Exact keys (incl. explicit `Table B4`) return unchanged. Family keys (no exact entry, but numbered
--- variants exist) resolve to `familyKey .. occupiedNpcSlotCount` (override via `opts.occupiedCount`).
--- @param tableKey string
--- @param opts table|nil `{ occupiedCount = number? }`
--- @return string concreteKey
--- @return string|nil familyKey nil for exact keys; the family key when dynamically resolved
local function resolveTableKey(tableKey, opts)
  opts = U.Type(opts) == "table" and opts or {}
  if U.Type(tableKey) ~= "string" or tableKey == "" then
    error("rotational-seat-layout: resolveTableKey requires a non-empty string key")
  end
  if U.Type(C.Tables) == "table" and U.Type(C.Tables[tableKey]) == "table" then
    return tableKey, nil
  end
  local variants = listNumberedTableVariants(tableKey)
  if next(variants) == nil then
    error("rotational-seat-layout: unknown table key '" .. tableKey
      .. "' (no exact C.Tables entry and no numbered variants)")
  end
  local count = opts.occupiedCount
  if U.Type(count) ~= "number" then
    count = countOccupiedNpcSlots()
  end
  local candidate = variants[count]
  if candidate == nil then
    error("rotational-seat-layout: no '" .. tableKey .. "' variant for " .. tostring(count)
      .. " occupied NPC seat(s) (expected '" .. tableKey .. tostring(count) .. "')")
  end
  return candidate, tableKey
end

--- @param tableRef string|table
--- @return string key
--- @return table cfg
local function resolveTableRef(tableRef)
  if U.Type(tableRef) == "string" then
    local concreteKey = resolveTableKey(tableRef)
    local cfg = C.Tables and C.Tables[concreteKey] or nil
    if U.Type(cfg) ~= "table" then
      error("rotational-seat-layout: unknown tableRef key '" .. tostring(tableRef) .. "'")
    end
    ---@cast concreteKey string
    ---@cast cfg table
    return concreteKey, cfg
  end
  if U.Type(tableRef) ~= "table" then
    error("rotational-seat-layout: tableRef must be a table key string or C.Tables table")
  end
  for tableKey, cfg in pairs(C.Tables or {}) do
    if cfg == tableRef then
      return tableKey, cfg
    end
  end
  if U.Type(tableRef.guid) == "string" then
    for tableKey, cfg in pairs(C.Tables or {}) do
      if U.Type(cfg) == "table" and cfg.guid == tableRef.guid then
        return tableKey, cfg
      end
    end
  end
  error("rotational-seat-layout: tableRef table does not match any C.Tables entry")
end

--- @return string[]
local function getAllLayerColors()
  local out = {}
  local seen = {}
  local function pushColor(color)
    if U.Type(color) == "string" and color ~= "" and not seen[color] then
      seen[color] = true
      table.insert(out, color)
    end
  end
  if U.Type(C.PlayerColors) == "table" then
    for i = 1, #C.PlayerColors do
      pushColor(C.PlayerColors[i])
    end
  end
  pushColor("White")
  pushColor("Black")
  pushColor("Grey")
  return out
end

--- @param tableCfg table|nil
--- @return table<string, boolean>
local function collectSeatPresenceMap(tableCfg)
  local present = {}
  local map = nil
  if U.Type(tableCfg) == "table" then
    ---@cast tableCfg table
    map = tableCfg.playerToPositionMap
  end
  if U.Type(map) == "table" then
    ---@cast map table
    for seatKey, _ in pairs(map) do
      if U.Type(seatKey) == "string" then
        present[seatKey] = true
      end
    end
  end
  return present
end

--- Fingerprint of last successful `resolveSeatObjectsFromTable` (stable inputs only).
local lastLayoutSyncFingerprint = nil

--- @return table<string, string|boolean>
local function getOccupiedNPCSlots(opts)
  opts = U.Type(opts) == "table" and opts or {}
  local raw = S.getStateVal("seatLayout", "occupiedNPCSlots")
  if U.Type(raw) ~= "table" then
    return {}
  end
  local active = U.clone(raw)
  if opts.forFingerprint ~= true then
    local layoutCtx = NPCS.getReconcileLayoutContext and NPCS.getReconcileLayoutContext()
    if layoutCtx ~= nil then
      return active
    end
  end
  local npcInstances = S.getStateVal("npcs", "instances")
  if U.Type(npcInstances) == "table" then
    local inArea = {}
    for npcName, rec in pairs(npcInstances) do
      if U.Type(npcName) == "string" and U.Type(rec) == "table" and U.Type(rec.areaKey) == "string" then
        inArea[npcName] = true
      end
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
      local occupant = active[seatKey]
      if U.Type(occupant) == "string" and inArea[occupant] == true then
        active[seatKey] = false
      end
    end
  end
  return active
end

--- @param tableCfg table
--- @param occupiedNPCSlots table<string, string|boolean>
--- @param opts table|nil `{ forFingerprint = boolean? }`
--- @return table
local function buildFilteredSeatMap(tableCfg, occupiedNPCSlots, opts)
  opts = U.Type(opts) == "table" and opts or {}
  local out = {}
  if tableCfg == nil then
    return out
  end
  ---@cast tableCfg table
  local map = tableCfg.playerToPositionMap or {}
  local layoutCtx = nil
  if opts.forFingerprint ~= true then
    layoutCtx = NPCS.getReconcileLayoutContext and NPCS.getReconcileLayoutContext()
  end
  for seatKey, segment in pairs(map) do
    if U.Type(seatKey) == "string" then
      local isNpcSeat = U.isIn(seatKey, C.NPCSeats or {})
      local isOccupied = occupiedNPCSlots[seatKey] ~= nil and occupiedNPCSlots[seatKey] ~= false
      local includeSeat = isOccupied
      if isNpcSeat and layoutCtx ~= nil and U.Type(layoutCtx.physicalSeatAllowedBySeat) == "table" then
        local psa = layoutCtx.physicalSeatAllowedBySeat[seatKey]
        if psa ~= nil then
          includeSeat = psa == true
        end
      end
      if (not isNpcSeat) or includeSeat then
        out[seatKey] = segment
      end
    end
  end
  return out
end

--- Stable layout-sync fingerprint: table key + filtered seat map (no orchestrator layout context).
--- @param tableKey string
--- @return string|nil
local function computeLayoutSyncFingerprint(tableKey)
  if U.Type(tableKey) ~= "string" or tableKey == "" then
    return nil
  end
  local key, tableCfg = resolveTableRef(tableKey)
  local occupied = getOccupiedNPCSlots({ forFingerprint = true })
  local filtered = buildFilteredSeatMap(tableCfg, occupied, { forFingerprint = true })
  local mapKeys = {}
  for seatKey in pairs(filtered) do
    mapKeys[#mapKeys + 1] = seatKey
  end
  table.sort(mapKeys)
  local lines = { "table:" .. key, "map:" }
  for i = 1, #mapKeys do
    local seatKey = mapKeys[i]
    local seg = filtered[seatKey]
    local segStr
    if U.Type(seg) == "table" then
      -- FACING/RECTANGULAR seats: serialize { side, index } stably (raw tostring is an address).
      segStr = "side=" .. tostring(seg.side) .. ",index=" .. tostring(seg.index)
    else
      segStr = tostring(seg)
    end
    lines[#lines + 1] = seatKey .. "=" .. segStr
  end
  return table.concat(lines, "\n")
end

--- Clear layout-sync fingerprint so the next `SyncTable` / `resolveSeatObjectsFromTable` runs fully.
function M.invalidateLayoutSyncCache()
  lastLayoutSyncFingerprint = nil
end

--- True when stable layout inputs match the last successful `resolveSeatObjectsFromTable`.
--- @param tableKey string|nil defaults to `gameState.seatLayout.currentTableKey`
--- @return boolean
function M.isLayoutSyncCurrent(tableKey)
  local key = tableKey
  if U.Type(key) ~= "string" or key == "" then
    key = S.getStateVal("seatLayout", "currentTableKey")
  end
  if U.Type(key) ~= "string" or key == "" or lastLayoutSyncFingerprint == nil then
    return false
  end
  local fp = computeLayoutSyncFingerprint(key)
  return fp ~= nil and fp == lastLayoutSyncFingerprint
end

--- @param obj Object|nil
--- @param tableCfg table|nil
--- @param isActive boolean
local function applyTableObjectState(obj, tableCfg, isActive)
  if obj == nil or U.Type(tableCfg) ~= "table" then
    return
  end
  ---@cast obj Object
  ---@cast tableCfg table
  local targetPos = isActive and tableCfg.activePosition or tableCfg.inactivePosition
  if targetPos ~= nil then
    local p = Vector(targetPos)
    obj.setPosition({ x = p.x, y = p.y, z = p.z })
  end
  if obj.setColorTint ~= nil then
    if isActive then
      obj.setColorTint({ r = 1, g = 1, b = 1, a = 1 })
    else
      obj.setColorTint({ r = 1, g = 1, b = 1, a = 0 })
    end
  end
  if isActive then
    if obj.addTag ~= nil then
      obj.addTag("activeTable")
    end
  else
    if obj.removeTag ~= nil and obj.hasTag ~= nil and obj.hasTag("activeTable") then
      obj.removeTag("activeTable")
    end
  end
end

--- @param tableCfg table|nil
--- @param occupiedNPCSlots table<string, string|boolean>
--- @param isActive boolean
local function componentUsedByOccupied(componentCfg, occupiedNPCSlots)
  local usedBy = componentCfg.usedBy
  if U.Type(usedBy) ~= "string" then
    return true
  end
  return occupiedNPCSlots[usedBy] ~= nil and occupiedNPCSlots[usedBy] ~= false
end

--- @param tableCfg table|nil
--- @param occupiedNPCSlots table<string, string|boolean>
--- @param isActive boolean
local function applyTableComponentsState(tableCfg, occupiedNPCSlots, isActive)
  if U.Type(tableCfg) ~= "table" then
    return
  end
  ---@cast tableCfg table
  local components = tableCfg.components
  if U.Type(components) ~= "table" then
    return
  end
  ---@cast components table
  local activateByName = {}
  for componentName, componentCfg in pairs(components) do
    if U.Type(componentCfg) == "table" and U.Type(componentCfg.guid) == "string" then
      activateByName[componentName] = isActive and componentUsedByOccupied(componentCfg, occupiedNPCSlots)
    end
  end
  for componentName, componentCfg in pairs(components) do
    if activateByName[componentName] == true and U.Type(componentCfg.alsoEnable) == "string" then
      activateByName[componentCfg.alsoEnable] = true
    end
  end
  for componentName, componentCfg in pairs(components) do
    if U.Type(componentCfg) == "table" and U.Type(componentCfg.guid) == "string" then
      local obj = G.getObject(componentCfg.guid)
      if obj ~= nil then
        applyTableObjectState(obj, componentCfg, activateByName[componentName] == true)
      end
    end
  end
end

--- Apply authoritative active/inactive visuals to every table object and component.
--- Active table gets opaque tint + activePosition; others get alpha 0 + inactivePosition.
--- @param activeTableKey string
--- @param occupiedNPCSlots table<string, string|boolean>
local function applyAllTablesVisualState(activeTableKey, occupiedNPCSlots)
  for tableKey, tableCfg in pairs(C.Tables or {}) do
    if U.Type(tableKey) == "string" and U.Type(tableCfg) == "table" then
      local isActiveTable = tableKey == activeTableKey
      if U.Type(tableCfg.guid) == "string" then
        local obj = G.getObject(tableCfg.guid)
        applyTableObjectState(obj, tableCfg, isActiveTable)
      end
      applyTableComponentsState(tableCfg, occupiedNPCSlots, isActiveTable)
    end
  end
end

--- @param sourceObjects table
--- @param occupiedNPCSlots table<string, string|boolean>
--- @param targetTableCfg table
--- @param currentTableCfg table|nil
local function enforceNPCSeatObjectVisibility(sourceObjects, occupiedNPCSlots, targetTableCfg, currentTableCfg)
  local sourceGroups = resolveSourceTemplateGroups(sourceObjects)
  local allSourceRefs = collectTemplateGroups(sourceGroups)
  local tableSeatPresence = collectSeatPresenceMap(targetTableCfg)
  local currentSeatPresence = collectSeatPresenceMap(currentTableCfg)
  local allLayerColors = getAllLayerColors()
  local hiddenSeatY = -200
  local referenceColor = (targetTableCfg and targetTableCfg.referencePlayerColor) or "Red"
  local templateGuidSet = {}
  for _, group in ipairs(allSourceRefs) do
    for i = 1, #group do
      if not isFrameEntry(group[i]) then
        local obj = resolveObjectRefWithRoleSupport(
          group[i],
          referenceColor,
          "source template entry [" .. tostring(i) .. "] for NPC visibility"
        )
        if obj ~= nil and obj.getGUID ~= nil then
          local g = obj.getGUID()
          if U.Type(g) == "string" and g ~= "" then
            templateGuidSet[g] = true
          end
        end
      end
    end
  end

  local function setSeatVisible(seatKey, visible)
    local tag = objectTagForPlayerColor(seatKey)
    local objs = getObjectsWithTag(tag)
    if U.Type(objs) == "table" then
      for _, obj in ipairs(objs) do
        if obj ~= nil and obj.setInvisibleTo ~= nil then
          local guid = obj.getGUID and obj.getGUID() or ""
          -- Never hide template source refs; they are needed for cloning.
          local isTemplateSource = templateGuidSet[guid] == true
          if NPCS.isPooledFigurineObject(obj) then
            if visible and obj.setInvisibleTo ~= nil then
              obj.setInvisibleTo({})
            elseif not visible and obj.setInvisibleTo ~= nil then
              obj.setInvisibleTo(allLayerColors)
            end
          elseif not isTemplateSource then
            if visible then
              obj.setInvisibleTo({})
            else
              obj.setInvisibleTo(allLayerColors)
              local p = obj.getPosition and obj.getPosition() or nil
              if p ~= nil and obj.setPosition ~= nil then
                obj.setPosition({ x = p.x, y = hiddenSeatY, z = p.z })
              end
            end
          end
        end
      end
    end
  end

  for i = 1, #(C.NPCSeats or {}) do
    local seatKey = C.NPCSeats[i]
    local occupied = occupiedNPCSlots[seatKey] ~= nil and occupiedNPCSlots[seatKey] ~= false
    local targetHasSeat = tableSeatPresence[seatKey] == true
    local currentHasSeat = currentSeatPresence[seatKey] == true
    if occupied and targetHasSeat then
      setSeatVisible(seatKey, true)
    elseif occupied and currentHasSeat and (not targetHasSeat) then
      setSeatVisible(seatKey, false)
    elseif not occupied then
      setSeatVisible(seatKey, false)
    end
  end
end

--- @param seatKey string
--- @param roleKey string
--- @return Object|nil
local function findObjectForSeatRoleCorrection(seatKey, roleKey)
  local tag = objectTagForPlayerColor(seatKey)
  local objs = getObjectsWithTag(tag)
  if U.Type(objs) ~= "table" then
    return nil
  end
  for _, o in ipairs(objs) do
    local disp = SRI.readRoleColorIdentity(o)
    if disp ~= nil then
      local rk, _ = SRI.parseRoleAndSuffix(disp)
      if rk == roleKey then
        return o
      end
    end
  end
  return nil
end

--- True when this seat was part of the layout pass that produced `computed` (filtered map).
--- @param seatKey string
--- @param computed table|nil
--- @return boolean
local function seatIncludedInLayoutPass(seatKey, computed)
  if U.Type(seatKey) ~= "string" or seatKey == "" or U.Type(computed) ~= "table" then
    return false
  end
  if U.Type(computed.byColor) == "table" and computed.byColor[seatKey] ~= nil then
    return true
  end
  if U.Type(computed.playerToPositionMap) == "table" and computed.playerToPositionMap[seatKey] ~= nil then
    return true
  end
  return false
end

--- @param seatKey string
--- @param computed table|nil
--- @return Vector|nil
local function extractHandZoneRotationForSeat(seatKey, computed)
  if U.Type(computed) ~= "table" or U.Type(computed.byColor) ~= "table" then
    return nil
  end
  local pack = computed.byColor[seatKey]
  if U.Type(pack) ~= "table" or U.Type(pack.slots) ~= "table" then
    return nil
  end
  for i = 1, #pack.slots do
    local slot = pack.slots[i]
    if isHandZoneRoleKey(slot.roleKey)
      and U.Type(slot.frame) == "table"
      and slot.frame.rotation ~= nil
    then
      return Vector(slot.frame.rotation)
    end
  end
  return nil
end

--- Rotation base for post-corrections: PC seats use the live TTS hand zone; NPC seats use the
--- virtual hand-zone anchor written during layout (`seatLayout.virtualHandZoneAnchors` or computed slot).
--- Caller must only invoke for seats included in the current layout pass.
--- @param correction table
--- @param targetObj Object|nil
--- @param computed table|nil
--- @return Vector|nil
local function resolvePostCorrectionAnchorRotation(correction, targetObj, computed)
  if U.Type(correction.anchor) == "string" and correction.anchor ~= "" then
    local anchorObj = G.getObject(correction.anchor)
    if anchorObj == nil or anchorObj.getRotation == nil then
      return nil
    end
    return Vector(anchorObj.getRotation())
  end

  local seatKey = correction.anchorSeatKey
  if U.Type(seatKey) ~= "string" or seatKey == "" then
    seatKey = deriveSeatKeyFromObjectTag(targetObj)
  end
  if U.Type(seatKey) ~= "string" or seatKey == "" then
    return nil
  end

  if isPlayerSeatKey(seatKey) then
    local hz = U.getHandZone(seatKey)
    if hz ~= nil and hz.getRotation ~= nil then
      return Vector(hz.getRotation())
    end
    return nil
  end

  local virtual = S.getStateVal("seatLayout", "virtualHandZoneAnchors", seatKey)
  if U.Type(virtual) == "table" and virtual.rotation ~= nil then
    return Vector(virtual.rotation)
  end

  return extractHandZoneRotationForSeat(seatKey, computed)
end

--- Apply optional post-move transform corrections keyed by object GUID.
--- Rows whose `targetGuid` is not present in the game are skipped (one print per GUID); optional workshop pieces may be absent.
--- sourceObjects.postCorrections = {
---   [targetGuid] = {
---     anchor = "<guid>",                -- PC hand zone GUID when rotationDelta is provided
---     anchorSeatKey = "Brown"|"NPC1",   -- alternative: live hand zone (PC) or virtual hand zone (NPC)
---     rotationDelta = Vector|table,     -- optional additive offset from anchor rotation
---     position = { y = <number> }       -- optional absolute Y override
---     scale = { x = <number>, y = ..., z = ... }  -- optional; omitted axes keep current scale
---   }
--- }
--- `postCorrectionsBySeatRole` applies the same shape per seat/role (PC workshop figurines and pooled NPC cutouts).
--- Corrections run only for seats in the filtered layout pass (`computed.byColor` / `playerToPositionMap`).
--- @param sourceObjects table
--- @param computed table|nil
local function applyPostCorrections(sourceObjects, computed)
  if U.Type(sourceObjects) ~= "table" then
    return
  end
  local postCorrections = sourceObjects.postCorrections
  if U.Type(postCorrections) ~= "table" then
    postCorrections = {}
  end
  for guid, correction in pairs(postCorrections) do
    if U.Type(guid) ~= "string" or guid == "" then
      error("rotational-seat-layout: postCorrection key must be a non-empty GUID string")
    end
    if U.Type(correction) ~= "table" then
      error("rotational-seat-layout: postCorrection value must be a table for guid '" .. tostring(guid) .. "'")
    end
    --- Zero rotationDelta is a no-op: do not require `anchor`.
    local hasRotationCorrection = correction.rotationDelta ~= nil
    if hasRotationCorrection then
      local d = Vector(correction.rotationDelta)
      if math.abs(d.x) < 1e-6 and math.abs(d.y) < 1e-6 and math.abs(d.z) < 1e-6 then
        hasRotationCorrection = false
      end
    end
    local hasPositionCorrection = U.Type(correction.position) == "table" and correction.position.y ~= nil
    local scaleTbl = U.Type(correction.scale) == "table" and correction.scale or nil
    local hasScaleCorrection = scaleTbl ~= nil
      and (
        tonumber(scaleTbl.x) ~= nil
        or tonumber(scaleTbl.y) ~= nil
        or tonumber(scaleTbl.z) ~= nil
      )
    if not hasRotationCorrection and not hasPositionCorrection and not hasScaleCorrection then
      error(
        "rotational-seat-layout: postCorrection for guid '"
        .. tostring(guid)
        .. "' must include rotationDelta, position.y, and/or scale (numeric x/y/z)"
      )
    end

    local obj = G.getObject(guid)
    if obj == nil then
      print(
        "[rotational-seat-layout] postCorrection skipped: target object missing for guid '"
          .. tostring(guid)
          .. "'"
      )
    end
    if obj ~= nil then
      local applySeatKey = correction.anchorSeatKey
      if U.Type(applySeatKey) ~= "string" or applySeatKey == "" then
        applySeatKey = deriveSeatKeyFromObjectTag(obj)
      end
      local applyCorrection = false
      if U.Type(applySeatKey) == "string" and applySeatKey ~= "" then
        applyCorrection = seatIncludedInLayoutPass(applySeatKey, computed)
      end
      if applyCorrection then

    local function formatVec(v)
      local vv = Vector(v)
      return string.format("(%.3f, %.3f, %.3f)", vv.x, vv.y, vv.z)
    end

    local targetBeforePos = obj.getPosition()
    local targetBeforeRot = obj.getRotation()
    local nextPos = Vector(targetBeforePos)
    local nextRot = Vector(targetBeforeRot)

    -- Prefer computed seat-frame x/z as the base so y-only corrections preserve
    -- the rotated seat placement even when the object failed to move earlier.
    if U.Type(computed) == "table" and computed ~= nil and U.Type(computed.byColor) == "table" then
      ---@cast computed table
      local byColor = computed.byColor
      local seatKey = deriveSeatKeyFromObjectTag(obj)
      local disp = SRI.readRoleColorIdentity(obj)
      if U.Type(seatKey) == "string" and U.Type(disp) == "string" then
        ---@cast disp string
        local roleKey, _ = SRI.parseRoleAndSuffix(disp)
        local pack = byColor[seatKey]
        if U.Type(pack) == "table" and U.Type(pack.slots) == "table" then
          for i = 1, #pack.slots do
            local slot = pack.slots[i]
            if slot.roleKey == roleKey and U.Type(slot.frame) == "table" and slot.frame.position ~= nil then
              local seatPos = Vector(slot.frame.position)
              nextPos = Vector({ x = seatPos.x, y = nextPos.y, z = seatPos.z })
              break
            end
          end
        end
      end
    end

    if hasRotationCorrection then
      local delta = Vector(correction.rotationDelta)
      local baseRot = resolvePostCorrectionAnchorRotation(correction, obj, computed)
      if baseRot == nil then
        error(
          "rotational-seat-layout: postCorrection for guid '"
          .. tostring(guid)
          .. "' could not resolve anchor rotation (set anchor GUID for PC hand zone or anchorSeatKey for virtual hand zone)"
        )
      end
      nextRot = Vector({
        baseRot.x + delta.x,
        baseRot.y + delta.y,
        baseRot.z + delta.z,
      })
      -- print(
      --   "[rotational-seat-layout] postCorrection ROTATION guid='"
      --   .. tostring(guid)
      --   .. "' targetBeforeRot="
      --   .. formatVec(targetBeforeRot)
      --   .. " anchorGuid='"
      --   .. tostring(correction.anchor)
      --   .. "' anchorRot="
      --   .. formatVec(baseRot)
      --   .. " delta="
      --   .. formatVec(delta)
      --   .. " nextRot="
      --   .. formatVec(nextRot)
      -- )
    end

    if hasPositionCorrection then
      local yVal = tonumber(correction.position.y)
      if yVal == nil then
        error(
          "rotational-seat-layout: postCorrection position.y must be numeric for guid '"
          .. tostring(guid)
          .. "'"
        )
      end
      nextPos = Vector({ x = nextPos.x, y = yVal, z = nextPos.z })
      -- print(
      --   "[rotational-seat-layout] postCorrection POSITION guid='"
      --   .. tostring(guid)
      --   .. "' targetBeforePos="
      --   .. formatVec(targetBeforePos)
      --   .. " nextPos="
      --   .. formatVec(nextPos)
      -- )
    end

    placeObjectExact(obj, nextPos, nextRot)

    if hasScaleCorrection then
      local curScale = obj.getScale and obj.getScale() or nil
      if curScale == nil then
        error(
          "rotational-seat-layout: postCorrection scale requires getScale() for guid '" .. tostring(guid) .. "'"
        )
      end
      local sx = tonumber(scaleTbl.x) ~= nil and tonumber(scaleTbl.x) or curScale.x
      local sy = tonumber(scaleTbl.y) ~= nil and tonumber(scaleTbl.y) or curScale.y
      local sz = tonumber(scaleTbl.z) ~= nil and tonumber(scaleTbl.z) or curScale.z
      obj.setScale({ x = sx, y = sy, z = sz })
    end

    local targetAfterPos = obj.getPosition()
    local targetAfterRot = obj.getRotation()
    -- print(
    --   "[rotational-seat-layout] postCorrection AFTER guid='"
    --   .. tostring(guid)
    --   .. "' targetPos="
    --   .. formatVec(targetAfterPos)
    --   .. " targetRot="
    --   .. formatVec(targetAfterRot)
    -- )
      end
    end
  end

  local bySeatRole = sourceObjects.postCorrectionsBySeatRole
  if U.Type(bySeatRole) == "table" and U.Type(computed) == "table" and U.Type(computed.byColor) == "table" then
    for seatKey, roleMap in pairs(bySeatRole) do
      if U.Type(seatKey) == "string" and U.Type(roleMap) == "table" and seatIncludedInLayoutPass(seatKey, computed) then
        for roleKey, correction in pairs(roleMap) do
          if U.Type(roleKey) == "string" and U.Type(correction) == "table" then
            local obj = findObjectForSeatRoleCorrection(seatKey, roleKey)
            if obj ~= nil then
              local nextPos = Vector(obj.getPosition())
              local nextRot = Vector(obj.getRotation())
              local pack = computed.byColor[seatKey]
              if U.Type(pack) == "table" and U.Type(pack.slots) == "table" then
                for i = 1, #pack.slots do
                  local slot = pack.slots[i]
                  if slot.roleKey == roleKey
                    and U.Type(slot.frame) == "table"
                    and slot.frame.position ~= nil
                  then
                    local seatPos = Vector(slot.frame.position)
                    nextPos = Vector({ x = seatPos.x, y = nextPos.y, z = seatPos.z })
                    break
                  end
                end
              end
              local hasRotationCorrection = correction.rotationDelta ~= nil
              if hasRotationCorrection then
                local d = Vector(correction.rotationDelta)
                if math.abs(d.x) < 1e-6 and math.abs(d.y) < 1e-6 and math.abs(d.z) < 1e-6 then
                  hasRotationCorrection = false
                end
              end
              if hasRotationCorrection then
                local roleCorrection = U.clone(correction, true)
                roleCorrection.anchorSeatKey = seatKey
                local baseRot = resolvePostCorrectionAnchorRotation(roleCorrection, obj, computed)
                if baseRot == nil then
                  error(
                    "rotational-seat-layout: postCorrectionsBySeatRole could not resolve anchor rotation for "
                    .. tostring(seatKey)
                    .. "/"
                    .. tostring(roleKey)
                  )
                end
                local delta = Vector(correction.rotationDelta)
                nextRot = Vector({
                  baseRot.x + delta.x,
                  baseRot.y + delta.y,
                  baseRot.z + delta.z,
                })
              end
              if U.Type(correction.position) == "table" and correction.position.y ~= nil then
                local yVal = tonumber(correction.position.y)
                if yVal == nil then
                  error(
                    "rotational-seat-layout: postCorrectionsBySeatRole position.y must be numeric for "
                    .. seatKey
                    .. "/"
                    .. roleKey
                  )
                end
                nextPos = Vector({ x = nextPos.x, y = yVal, z = nextPos.z })
              end
              placeObjectExact(obj, nextPos, nextRot)
              local scaleTbl = U.Type(correction.scale) == "table" and correction.scale or nil
              if scaleTbl ~= nil then
                local curScale = obj.getScale and obj.getScale() or nil
                if curScale == nil then
                  error(
                    "rotational-seat-layout: postCorrectionsBySeatRole scale requires getScale() for "
                    .. seatKey
                    .. "/"
                    .. roleKey
                  )
                end
                local sx = tonumber(scaleTbl.x) ~= nil and tonumber(scaleTbl.x) or curScale.x
                local sy = tonumber(scaleTbl.y) ~= nil and tonumber(scaleTbl.y) or curScale.y
                local sz = tonumber(scaleTbl.z) ~= nil and tonumber(scaleTbl.z) or curScale.z
                obj.setScale({ x = sx, y = sy, z = sz })
              end
            end
          end
        end
      end
    end
  end
end

--- @return string|nil
local function inferActiveTableKeyFromTags()
  local guidToTableKey = {}
  for tableKey, tableCfg in pairs(C.Tables or {}) do
    if U.Type(tableKey) == "string" and U.Type(tableCfg) == "table" and U.Type(tableCfg.guid) == "string" then
      guidToTableKey[tableCfg.guid] = tableKey
    end
  end
  local tagged = getObjectsWithAllTags({ "table", "activeTable" })
  if U.Type(tagged) ~= "table" or #tagged ~= 1 then
    return nil
  end
  local guid = tagged[1].getGUID and tagged[1].getGUID() or nil
  if U.Type(guid) ~= "string" or guid == "" then
    return nil
  end
  return guidToTableKey[guid]
end

--- Before seat-layout generation, shift all reference-seat source objects (`RedObject`) by
--- the delta between the live reference hand-zone position and destination table reference hand position.
--- @param fromTableKey string|nil
--- @param toTableKey string
local function applyReferenceHandPositionDelta(fromTableKey, toTableKey)
  local toCfg = C.Tables and C.Tables[toTableKey]
  if U.Type(toCfg) ~= "table" then
    return
  end
  if toCfg.referenceHandPosition == nil then
    return
  end

  local refColor = toCfg.referencePlayerColor or "Red"
  local handZone = U.getHandZone(refColor)
  if handZone == nil or handZone.getPosition == nil then
    return
  end

  local liveRef = Vector(handZone.getPosition())
  local toRef = Vector(toCfg.referenceHandPosition)
  local delta = toRef - liveRef
  local tolerance = 0.01
  if delta:sqrMagnitude() <= (tolerance * tolerance) then
    return
  end

  -- Move reference hand zone using the same path as other seat hand-zone moves:
  -- lock contained cards/decks, move rigidly with zone, restore lock states.
  local handZoneRotation = handZone.getRotation and Vector(handZone.getRotation()) or Vector({ 0, 0, 0 })
  moveHandZoneAndContainedCards(handZone, toRef, handZoneRotation)

  -- Prevent double-shifting cards/decks already moved with the hand zone.
  local movedWithHandZone = {}
  if handZone.getObjects ~= nil then
    local inZone = handZone.getObjects() or {}
    for _, obj in ipairs(inZone) do
      if obj ~= nil and isCardLikeObject(obj) and obj.getGUID ~= nil then
        local g = obj.getGUID()
        if U.Type(g) == "string" and g ~= "" then
          movedWithHandZone[g] = true
        end
      end
    end
  end

  local refs = getObjectsWithTag("RedObject")
  if U.Type(refs) ~= "table" or #refs == 0 then
    return
  end

  local moved = 0
  for _, obj in ipairs(refs) do
    if obj ~= nil and obj.getPosition ~= nil and obj.setPosition ~= nil then
      local guid = obj.getGUID and obj.getGUID() or ""
      if not movedWithHandZone[guid] then
        local pos = obj.getPosition()
        obj.setPosition(pos + delta)
        moved = moved + 1
      end
    end
  end

  print(
    "[rotational-seat-layout] referenceHandPosition delta applied from '"
    .. tostring(toTableKey)
    .. "' refColor="
    .. tostring(refColor)
    .. " liveRef="
    .. tostring(liveRef)
    .. " targetRef="
    .. tostring(toRef)
    .. " delta="
    .. tostring(delta)
    .. " movedRedObjects="
    .. tostring(moved)
  )
end

--- Apply `C.Tables[*].objectPositions`: per-table partial position/rotation overrides by object GUID.
--- Only axes present in each partial table are written; others keep the object's current values.
--- @param tableCfg table|nil
local function applyTableConfigObjectPositions(tableCfg)
  if type(tableCfg) ~= "table" then
    return
  end
  local entries = tableCfg.objectPositions
  if type(entries) ~= "table" then
    return
  end
  for i = 1, #entries do
    local e = entries[i]
    if type(e) == "table" and type(e.guid) == "string" and e.guid ~= "" then
      local obj = G.getObject(e.guid)
      if obj ~= nil then
        if type(e.position) == "table" then
          local merged = OP.mergePosition(obj, e.position)
          obj.setPosition({ x = merged.x, y = merged.y, z = merged.z })
        end
        if type(e.rotation) == "table" then
          local mergedR = OP.mergeRotation(obj, e.rotation)
          obj.setRotation({ x = mergedR.x, y = mergedR.y, z = mergedR.z })
        end
      end
    end
  end
end

--- Convenience wrapper around generateRotationalCoordinates + resolveSeatObjects.
--- @param tableRef string|table key in C.Tables or table entry itself
--- @param sourceObjects table|nil defaults to C.TableSourceObjects
--- @param options table|nil forwarded options; `currentTableKey` defaults from tableRef; `force` bypasses fingerprint short-circuit
--- @return table|nil computed; nil when fingerprint short-circuit skips work
function M.resolveSeatObjectsFromTable(tableRef, sourceObjects, options)
  local tableKey, tableCfg = resolveTableRef(tableRef)
  local src = sourceObjects or C.TableSourceObjects
  if U.Type(src) ~= "table" then
    error("rotational-seat-layout: sourceObjects must be a table or nil (to use C.TableSourceObjects)")
  end
  local opts = U.clone(options or {}, true)
  local force = opts.force == true
  if force then
    lastLayoutSyncFingerprint = nil
  end
  local layoutFingerprint = computeLayoutSyncFingerprint(tableKey)
  if not force and layoutFingerprint ~= nil and layoutFingerprint == lastLayoutSyncFingerprint then
    return nil
  end
  if opts.currentTableKey == nil then
    opts.currentTableKey = tableKey
  end
  local previousTableKey = S.getStateVal("seatLayout", "currentTableKey")
  local previousTableCfg = nil
  if U.Type(previousTableKey) == "string" and U.Type(C.Tables and C.Tables[previousTableKey]) == "table" then
    previousTableCfg = C.Tables[previousTableKey]
  end
  -- Persist target table before any step that reads `gameState.seatLayout.currentTableKey`
  -- (lighting seat-presence, HUD consumers, etc.) so mid-resolve code sees the destination layout.
  S.setStateVal(tableKey, "seatLayout", "currentTableKey")
  local occupiedNPCSlots = getOccupiedNPCSlots()
  local filteredMap = buildFilteredSeatMap(tableCfg, occupiedNPCSlots)
  -- Activate the target table (instant setPosition) BEFORE generating so FACING bounds reads are valid.
  applyAllTablesVisualState(tableKey, occupiedNPCSlots)

  local computed
  if tableCfg.shape == (C.TableShapes and C.TableShapes.FACING) then
    computed = M.generateFacingCoordinates(src, tableCfg, filteredMap, opts)
  else
    computed = M.generateRotationalCoordinates(
      src,
      tableCfg.centerPoint,
      tableCfg.numSegments,
      tableCfg.angleSegmentOne,
      filteredMap,
      tableCfg.referencePlayerColor,
      opts
    )
  end
  M.resolveSeatObjects(computed, src, opts)
  applyPostCorrections(src, computed)
  applyTableConfigObjectPositions(tableCfg)
  enforceNPCSeatObjectVisibility(src, occupiedNPCSlots, tableCfg, previousTableCfg)
  local npcInstances = S.getStateVal("npcs", "instances")
  if U.Type(npcInstances) == "table" then
    for npcName, rec in pairs(npcInstances) do
      if U.Type(npcName) == "string" and U.Type(rec) == "table" then
        local seated = U.Type(rec.seatedSeatKey) == "string" and U.isIn(rec.seatedSeatKey, C.NPCSeats or {})
        if not seated then
          NPCS.applyCurrentLightMode(npcName, 0)
        end
      end
    end
  end
  local sourceGroups = resolveSourceTemplateGroups(src)
  local camWorldOffset = cameraPositionWorldOffsetForActiveTable(tableCfg)
  applyCameraModesForSeats(computed, sourceGroups, camWorldOffset)
  -- Seat-layout reconciliation boundary:
  -- this function owns geometric re-positioning of seat-bound objects (including
  -- hunger smoke / seat lights), then immediately hands final mode/visibility
  -- back to state-driven reconcilers so layout changes cannot override game state.
  do
    local L = require("core.lighting")
    if L ~= nil and type(L.reconcileAllPlayers) == "function" then
      local playerOpts = { skipStageBoundNpcSeats = true }
      if type(NPCS.isReconcileOrchestratorInProgress) == "function"
          and NPCS.isReconcileOrchestratorInProgress() then
        playerOpts.skipNpcSeats = true
      end
      L.reconcileAllPlayers(playerOpts)
    end
    local orchestratorActive = type(NPCS.isReconcileOrchestratorInProgress) == "function"
        and NPCS.isReconcileOrchestratorInProgress()
    if not orchestratorActive
        and type(NPCS.reconcileHomelandSeatSpotlightsForStageBound) == "function" then
      NPCS.reconcileHomelandSeatSpotlightsForStageBound()
    end
    local HO = require("core.hud_overlays")
    if HO ~= nil and type(HO.syncAll) == "function" then
      HO.syncAll()
    end
  end
  lastLayoutSyncFingerprint = computeLayoutSyncFingerprint(tableKey)
  return computed
end

--- Re-apply table state based on current `gameState.seatLayout.currentTableKey`.
--- Useful after load or when recovering from drift between state and live objects.
--- @param tableKey string|nil optional explicit table key to sync
--- @param opts table|nil `{ force = boolean? }` — `force` bypasses layout fingerprint short-circuit
--- @return table|nil computed
function M.SyncTable(tableKey, opts)
  opts = U.Type(opts) == "table" and opts or {}
  local key = tableKey
  if U.Type(key) ~= "string" or key == "" then
    key = S.getStateVal("seatLayout", "currentTableKey")
  end
  local inferredFromTags = false
  if U.Type(key) ~= "string" or key == "" then
    key = inferActiveTableKeyFromTags()
    inferredFromTags = U.Type(key) == "string" and key ~= ""
  end
  if U.Type(key) ~= "string" or key == "" then
    return nil
  end
  if inferredFromTags then
    S.setStateVal(key, "seatLayout", "currentTableKey")
  end
  return M.resolveSeatObjectsFromTable(tostring(key), nil, opts)
end

--- True when any module die is loose on the table (`getObjectsWithTag` excludes container contents).
--- @return boolean
function M.hasLooseDiceOnTable()
  local tagged = getObjectsWithTag("d10")
  return U.Type(tagged) == "table" and #tagged > 0
end

--- Alerts the GM and returns true when table/scene layout changes must wait for rolls to finish.
--- @param operationLabel string|nil e.g. `"switch table layout"` or `"apply a library scene"`
--- @return boolean true when the caller should abort
function M.alertAndBlockIfDiceOnTable(operationLabel)
  if not M.hasLooseDiceOnTable() then
    return false
  end
  local label = U.Type(operationLabel) == "string" and operationLabel ~= "" and operationLabel
      or "change table layout"
  U.AlertGM(
    "Cannot "
      .. label
      .. " while dice are on the table. Finish or cancel active rolls first (Confirm / Cancel on the roll dashboard)."
  )
  return true
end

--- Production entrypoint for table switching.
--- If `tableKey` is already active, a full sync is run in case the scene drifted.
--- Otherwise resolves seat geometry synchronously; transition blindfold is owned by `core.hud_blindfold`
--- (scene apply and manual table toggles call `HUDBF.runTransition` with `skipTransitionBlindfold`).
--- @param tableKey string
--- @param opts table|nil { skipTransitionBlindfold = boolean }
--- @return table|nil computed when immediate sync/switch path is used
function M.SetTableTo(tableKey, opts)
  opts = opts or {}
  if M.alertAndBlockIfDiceOnTable("switch table layout") then
    return nil
  end
  local resolvedKey, _ = resolveTableRef(tableKey)
  local currentTableKey = S.getStateVal("seatLayout", "currentTableKey")
  if currentTableKey == resolvedKey then
    return M.SyncTable(resolvedKey, { force = true })
  end

  local function doSwitch()
    applyReferenceHandPositionDelta(currentTableKey, resolvedKey)
    M.resolveSeatObjectsFromTable(resolvedKey, nil, { force = true })
  end

  if opts.skipTransitionBlindfold == true then
    doSwitch()
    return nil
  end

  local HUDBF = require("core.hud_blindfold")
  HUDBF.runTransition(function()
    doSwitch()
    return true
  end)
  return nil
end

--- Public: resolve a table key (family or concrete) to a concrete `C.Tables` key.
--- @param tableKey string
--- @param opts table|nil `{ occupiedCount = number? }`
--- @return string concreteKey
--- @return string|nil familyKey
function M.resolveTableKey(tableKey, opts)
  return resolveTableKey(tableKey, opts)
end

--- Public: true when `key` is a dynamic family key (no exact entry, numbered variants exist).
--- @param key string|nil
--- @return boolean
function M.isDynamicTableFamilyKey(key)
  return isDynamicTableFamilyKey(key)
end

--- Public: count occupied NPC seats in `seatLayout.occupiedNPCSlots` (`C.NPCSeats` only).
--- @param slots table|nil
--- @return number
function M.countOccupiedNpcSlots(slots)
  return countOccupiedNpcSlots(slots)
end

--- Public: NPC seat capacity (`C.NPCSeats` in `playerToPositionMap`) for a table config.
--- @param tableCfg table|nil
--- @return number
function M.tableNpcSlotCapacity(tableCfg)
  return tableNpcSlotCapacity(tableCfg)
end

--- Destruct every object with tag `{seatKey}Object` for each listed seat key, except objects in
--- `sourceObjects` (templates are never removed). Seat keys listed in `blacklist` are skipped
--- entirely (no objects with that tag are destroyed by this call).
---
--- `seatKeys` may be an array of strings or a map whose keys are seat ids (e.g. `computed.playerToPositionMap`).
--- `blacklist` may be a set (`{ NPC_SEAT = true, Brown = true }`) and/or an array (`{ "NPC_SEAT", "Brown" }`).
---
--- Does not write workspace files and does not require `sendExternalMessage`.
---
--- @param sourceObjects table same nested template table as generate/spawn; template object GUIDs are never destroyed
--- @param seatKeys table array of seat id strings, or map (keys = seat ids)
--- @param blacklist table|nil seat ids to preserve
--- @return number count of successfully destructed objects
function M.clearGeneratedSeatObjects(sourceObjects, seatKeys, blacklist)
  local sourceGroups = resolveSourceTemplateGroups(sourceObjects)
  local refColor = C.PlayerColors and C.PlayerColors[1] or "Red"
  local tableKey = S.getStateVal("seatLayout", "currentTableKey")
  if U.Type(tableKey) == "string" and U.Type(C.Tables and C.Tables[tableKey]) == "table" then
    refColor = C.Tables[tableKey].referencePlayerColor or refColor
  end

  local templateGuidSet = {}
  for _, group in ipairs(collectTemplateGroups(sourceGroups)) do
    for i = 1, #group do
      if not isFrameEntry(group[i]) then
        local obj = resolveObjectRefWithRoleSupport(
          group[i],
          refColor,
          "source template entry [" .. tostring(i) .. "] for clear"
        )
        if obj == nil then
          error("rotational-seat-layout: could not resolve source template entry [" .. tostring(i) .. "] for clear")
        end
        local g = obj.getGUID and obj.getGUID() or ""
        if g == "" then
          error("rotational-seat-layout: source template object has no GUID")
        end
        templateGuidSet[g] = true
      end
    end
  end

  local keys = collectSeatKeys(seatKeys)
  local destroyed = 0

  for _, seatKey in ipairs(keys) do
    if not isSeatKeyBlacklisted(blacklist, seatKey) then
      local tag = objectTagForPlayerColor(seatKey)
      local tagged = getObjectsWithTag(tag)
      if U.Type(tagged) == "table" then
        for _, o in ipairs(tagged) do
          if o ~= nil and o.getGUID then
            local og = o.getGUID()
            if not templateGuidSet[og] then
              o.destruct()
              destroyed = destroyed + 1
            end
          end
        end
      end
    end
  end

  return destroyed
end

--- Collect seat-layout objects that may still carry legacy Name/Nickname role identity.
--- @param sourceObjects table|nil defaults to `C.TableSourceObjects`
--- @return table[] rows `{ obj, reason }`
local function collectSeatLayoutMigrationCandidates(sourceObjects)
  local src = sourceObjects or C.TableSourceObjects
  local sourceGroups = resolveSourceTemplateGroups(src)
  local seenGuid = {}
  local rows = {}

  local function addCandidate(obj, reason)
    if obj == nil or obj.getGUID == nil then
      return
    end
    if isHandZoneObject(obj) then
      return
    end
    local guid = obj.getGUID()
    if U.Type(guid) ~= "string" or guid == "" or seenGuid[guid] then
      return
    end
    seenGuid[guid] = true
    rows[#rows + 1] = { obj = obj, reason = reason }
  end

  for i = 1, #C.PlayerColors do
    local seatKey = C.PlayerColors[i]
    local tagged = getObjectsWithTag(objectTagForPlayerColor(seatKey)) or {}
    for j = 1, #tagged do
      addCandidate(tagged[j], "tag:" .. seatKey)
    end
  end
  for i = 1, #(C.NPCSeats or {}) do
    local seatKey = C.NPCSeats[i]
    local tagged = getObjectsWithTag(objectTagForPlayerColor(seatKey)) or {}
    for j = 1, #tagged do
      addCandidate(tagged[j], "tag:" .. seatKey)
    end
  end
  for i = 1, #sourceGroups.relative do
    local relRef = sourceGroups.relative[i]
    local relObj = U.getObject(relRef, true)
    if relObj == nil and U.Type(relRef) == "string" then
      relObj = TarotObjects.resolveByGuid(relRef)
    end
    addCandidate(relObj, "relative")
  end

  return rows
end

--- One-time migration: copy legacy Name/Nickname `ROLE_COLOR` identity into GM Notes and clear Name/Nickname.
--- Run from the TTS console: `lua DEBUG.migrateSeatLayoutRolesToGmNotes()` (dry-run: `{ dryRun = true }`).
---
--- @param sourceObjects table|nil defaults to `C.TableSourceObjects`
--- @param options table|nil `{ dryRun?: boolean, clearLegacy?: boolean }` — `clearLegacy` defaults true
--- @return table summary
function M.migrateRoleIdentityToGmNotes(sourceObjects, options)
  options = type(options) == "table" and options or {}
  local dryRun = options.dryRun == true
  local clearLegacy = options.clearLegacy ~= false
  local candidates = collectSeatLayoutMigrationCandidates(sourceObjects)
  local summary = {
    dryRun = dryRun,
    scanned = #candidates,
    migrated = 0,
    alreadyMigrated = 0,
    skippedNoLegacy = 0,
    clearFailed = {},
    failed = {},
    details = {},
  }

  for i = 1, #candidates do
    local row = candidates[i]
    local obj = row.obj
    local guid = obj.getGUID and obj.getGUID() or "unknown-guid"
    local legacy = SRI.readLegacyRoleColorIdentity(obj)
    local current = SRI.readRoleColorIdentity(obj)

    if legacy == nil and current ~= nil then
      summary.alreadyMigrated = summary.alreadyMigrated + 1
    elseif legacy == nil then
      summary.skippedNoLegacy = summary.skippedNoLegacy + 1
    else
      local detail = {
        guid = guid,
        reason = row.reason,
        legacy = legacy,
        previousGmNotes = obj.getGMNotes and obj.getGMNotes() or "",
      }
      if dryRun then
        summary.migrated = summary.migrated + 1
        summary.details[#summary.details + 1] = detail
      else
        local okNotes = false
        if obj.setGMNotes then
          okNotes = obj.setGMNotes(legacy) ~= false
        end
        local okClear = true
        local clearErr = nil
        if clearLegacy and not isHandZoneObject(obj) then
          okClear, clearErr = SRI.clearLegacyRoleNameFields(obj)
        end
        if okNotes then
          summary.migrated = summary.migrated + 1
          summary.details[#summary.details + 1] = detail
        else
          summary.failed[#summary.failed + 1] = {
            guid = guid,
            legacy = legacy,
            error = "setGMNotes failed or unavailable",
          }
        end
        if not okClear and clearLegacy and not isHandZoneObject(obj) then
          summary.clearFailed[#summary.clearFailed + 1] = {
            guid = guid,
            legacy = legacy,
            error = clearErr or "unknown",
          }
          local hint = ""
          if clearErr == "nickname_requires_json_reload" or clearErr == "json_api_unavailable" then
            hint = " — use offline save migration (npm run tts-save:migrate-seat-gmnotes)"
          end
          print(
            "[rotational-seat-layout] migrate: GM Notes set for "
              .. guid
              .. " but legacy clear failed ("
              .. tostring(clearErr)
              .. ")"
              .. hint
          )
        end
      end
    end
  end

  print(
    string.format(
      "[rotational-seat-layout] migrateRoleIdentityToGmNotes%s: scanned=%d migrated=%d already=%d skippedNoLegacy=%d clearFailed=%d failed=%d",
      dryRun and " (dry-run)" or "",
      summary.scanned,
      summary.migrated,
      summary.alreadyMigrated,
      summary.skippedNoLegacy,
      #summary.clearFailed,
      #summary.failed
    )
  )
  return summary
end

return M
