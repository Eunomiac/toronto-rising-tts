--- Gets the GUID for a player's Normal dice bag.
-- Each player's seat has one Normal d10 bag from which dice are spawned when rolled.
-- @param color string Player seat color (Brown/Orange/Red/Pink/Purple)
-- @return string|nil GUID if found, nil otherwise
-- @usage local guid = G.GetDiceNormalGUID("Red")
function G.GetDiceNormalGUID(color)
    if color == nil then return nil end
    local guidKey = "DICEBAG_NORMAL_" .. string.upper(color)
    return G.GUIDS[guidKey]
end

--- Gets the GUID for a player's Hunger dice bag.
-- Each player's seat has one Hunger d10 bag (typically red dice) for their Hunger pool.
-- @param color string Player seat color (Brown/Orange/Red/Pink/Purple)
-- @return string|nil GUID if found, nil otherwise
-- @usage local guid = G.GetDiceHungerGUID("Red")
function G.GetDiceHungerGUID(color)
    if color == nil then return nil end
    local guidKey = "DICEBAG_HUNGER_" .. string.upper(color)
    return G.GUIDS[guidKey]
end

--- Identifies the player color and die type ("normal"|"hunger") for a given object GUID.
-- Used by the onObjectRandomize hook to attribute a randomized die to its owner.
-- Returns nil, nil if the GUID does not correspond to any known dice bag.
-- @param guid string Object GUID to look up
-- @return string|nil color, string|nil dieType  ("normal" or "hunger")
-- @usage local color, dieType = G.GetDiceOwner(obj.guid)
function G.GetDiceOwner(guid)
    if guid == nil then return nil, nil end
    local playerColors = {"Brown", "Orange", "Red", "Pink", "Purple"}
    for _, color in ipairs(playerColors) do
        local upperColor = string.upper(color)
        if G.GUIDS["DICEBAG_NORMAL_" .. upperColor] == guid then
            return color, "normal"
        end
        if G.GUIDS["DICEBAG_HUNGER_" .. upperColor] == guid then
            return color, "hunger"
        end
    end
    return nil, nil
end

return G
