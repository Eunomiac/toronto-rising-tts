--[[
    Static NPC layout and character definitions for core/npcs.ttslua.
    Replace image URLs with your uploaded workshop / cloud assets before play.

    Agent guidance: .dev/NPC Object Spawning & Spotlighting/NPC Object Overview.md; .dev/Chronicle Data/NPCS_*.md;
    .dev/Game State Data.jsonc (instance examples).
]]

local D = {}

D.lights = {
  OFF = {
    enabled = false,
    color = Color(1, 1, 1),
    range = 100,
    intensity = 0
  },
  STANDARD = {
    enabled = true,
    color = Color(0.75, 0.75, 0.75),
    range = 132,
    intensity = 5,
    angle = 88,
    positioning = {
      deltaUp = 5,
      deltaInward = 3,
      lookAtYShift = 0.1
    }
  },
  SPOTLIGHT = {
    enabled = true,
    color = Color(1, 1, 1),
    range = 100,
    intensity = 3,
    angle = 70,
    -- Same placement family as STANDARD (TOR-416): small geometric delta so cone barely relocates;
    -- visual punch is intensity / angle / color.
    positioning = {
      deltaUp = 6,
      deltaInward = 4,
      lookAtYShift = 0.1
    }
  }
}

--- Beam overrides for NPCs on STAGE_BOARD (`__stage_board__` placements). Deep-merged on top of `D.lights` + per-character `lighting` when resolving modes; position/aim fields stay from the base mode unless listed here.
D.stageLights = {}

