--[[
    Global script (canonical source). Tabletop Simulator loads .tts/objects/Global.lua, which
    only require()s this file. Edit here — not .tts/objects/Global.lua (that file may be overwritten on reload).

    Agent guidance (.dev/ documentation for this project):
    MANDATORY FIRST — docs/solutions/lua-local-function-order.md (top recurring bug: local function BEFORE every caller in THIS file; else nil at runtime),
    .cursor/rules/toronto-rising-lua-local-function-order.mdc,
    .cursor/rules/toronto-rising-multiplayer-authority.mdc + .dev/Multiplayer Functionality/Preparing For Multiplayer.md §1 (P1–P10 until TOR-144 E2E),
    DEVELOPMENT_WORKFLOW.md, TESTING.md, TTS_BUNDLING_SETUP.md, DEBUG_FILE_LOGGING.md, TTS_MCP.md,
    HUD_FUNCTIONS.md, HUDs & Overlays/Player HUD Overview.md,
    NPC Object Spawning & Spotlighting/NPC Object Overview.md,
    AVAILABLE_FUNCTIONS.md,
    User Guides/TTS-3D-Positioning-Coordinate-Utilities.md,
    Rotational Coordinate Generator.md, Utility Function - RotateToFrom.md,
    utility-functions/More Robust Lerping with Eases.md, Game State Data.jsonc,
    Chronicle Data/ (NPC reference for data keys), custom-ui-assets/ (image manifest outputs),
    tts-api/ (in-repo TTS Scripting + UI API reference; start at tts-api/Getting Started/).
]]

-- ---------------------------------------------------------------------------
-- Soundscape: hard-mute emitters by GUID (NO require). Unity audio can resume
-- before `require("core.soundscape")`; chunk-time GUID lookups are usually 0/9
-- until `onLoad`, so `function onLoad` repeats this + schedules Wait retries.
-- GUIDs MUST match `lib/guids.ttslua` `SOUNDSCAPE_*` (see SYNC comment there).
-- ---------------------------------------------------------------------------
U = require("lib.util")

local TR_EARLY_SOUNDSCAPE_EMITTER_GUIDS = {
  "2870fb",
  "ed206e",
  "ef76cf",
  "7a1f69",
  "8ecefd",
  "4f352f",
  "c0b9d4",
  "290128",
  "c7a6c5",
}

local function trEarlyCollectAudioSources(obj)
    if obj == nil then
        return {}
    end
    if obj.getComponentsInChildren ~= nil then
        local components = obj.getComponentsInChildren("AudioSource")
        if type(components) == "table" then
            return components
        end
    end
    if obj.getComponentInChildren ~= nil then
        local component = obj.getComponentInChildren("AudioSource")
        if component ~= nil then
            return { component }
        end
    end
    if obj.getComponent ~= nil then
        local component = obj.getComponent("AudioSource")
        if component ~= nil then
            return { component }
        end
    end
    return {}
end

local function trEarlyHardSilenceSources(obj)
    for _, source in ipairs(trEarlyCollectAudioSources(obj)) do
        if source ~= nil and source.set ~= nil then
            source.set("volume", 0)
            source.set("mute", true)
            source.set("spatialBlend", 0)
        end
    end
end

--- @param phaseLabel string identifies this pass in the TTS console load timeline
local function trEarlySilenceSoundscapeEmitters(phaseLabel)
    U.ensureLoadClockT0()
    local label = type(phaseLabel) == "string" and phaseLabel or "sync-immediate"
    local getObj = rawget(_G, "getObjectFromGUID")
    if type(getObj) ~= "function" then
        return
    end
    for _, guid in ipairs(TR_EARLY_SOUNDSCAPE_EMITTER_GUIDS) do
        local obj = getObj(guid)
        if obj ~= nil then
            trEarlyHardSilenceSources(obj)
            local ab = obj.AssetBundle
            if ab ~= nil and ab.getLoopingEffects ~= nil and ab.playLoopingEffect ~= nil then
                local effects = ab.getLoopingEffects()
                if type(effects) == "table" then
                    for _, eff in ipairs(effects) do
                        if type(eff) == "table" and eff.name == "silent" and type(eff.index) == "number" then
                            ab.playLoopingEffect(eff.index)
                            break
                        end
                    end
                end
            end
            trEarlyHardSilenceSources(obj)
        end
    end
end

--- Wall-clock delays after which we re-run silence (emitters often do not exist during the Global chunk).
local TR_EARLY_SILENCE_DEFERRAL_SECONDS = { 0, 0.05, 0.25, 0.5 }

--- @param schedulerLabel string origin for console logs (`chunk-load` vs `onLoad`)
--- @return boolean true if `Wait.time` was available
local function trScheduleEarlySoundscapeSilenceDeferred(schedulerLabel)
    local tag = type(schedulerLabel) == "string" and schedulerLabel or "unknown"
    local W = rawget(_G, "Wait")
    if type(W) ~= "table" or type(W.time) ~= "function" then
        return false
    end
    for _, sec in ipairs(TR_EARLY_SILENCE_DEFERRAL_SECONDS) do
        local delay = sec
        U.delay(function()
            trEarlySilenceSoundscapeEmitters(tag .. "-wait-" .. tostring(delay))
        end, delay)
    end
    return true
end

-- Chunk phase: objects often 0/9 until onLoad.
trEarlySilenceSoundscapeEmitters("chunk-sync-immediate")

