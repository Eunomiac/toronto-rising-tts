function HUD_debugLightActivate(player, button, id)
    if LightDebugFocus and LightDebugFocus.activate then
        LightDebugFocus.activate(player)
    else
        broadcastToColor("Debug Light: module not loaded.", player.color, {1, 0.35, 0})
    end
end

