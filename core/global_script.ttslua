--- Force a full synchronization pass from current state.
-- @param player Player The player who clicked (Host/Black)
-- @param button string Button value
-- @param id string The UI element ID
function HUD_syncAll(player, button, id)
    if not Sync or type(Sync.full) ~= "function" then
        broadcastToColor("Sync All: Sync.full missing.", player.color, {1, 0.5, 0})
        return
    end
    Sync.full({ force = true, reason = "HUD_syncAll" })
    broadcastToColor(
        "Full sync (force): scenes, soundscape, seat lights, NPC layout, overlays, and UI refreshed.",
        player.color,
        {0, 1, 1}
    )
end

--- Incremental sync from current state (fingerprints + narrow UI); use when desync is unlikely or for routine refresh.
--- @param player Player
--- @param button string
--- @param id string
function HUD_syncIncremental(player, button, id)
    if not Sync or type(Sync.full) ~= "function" then
        broadcastToColor("Sync incremental: Sync.full missing.", player.color, {1, 0.5, 0})
        return
    end
    Sync.full({ force = false, reason = "HUD_syncIncremental" })
    broadcastToColor("Incremental sync triggered (use Sync All if overlay/scene/audio drift persists).", player.color, {0, 1, 1})
end

