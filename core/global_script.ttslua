    local color, action = nil, nil
    if RUI.onPostRollCellMouseUp then
        color, action = RUI.onPostRollCellMouseUp(player, id)
    end
    if type(color) == "string" and type(action) == "string" then
        Global.call("GlobalPostRollModifyPool", { color = color, action = action })
    end
end

-- ============================================================================
-- DICE SYSTEM DEBUG HUD HANDLERS (Host only; wired to admin panel buttons)
-- ============================================================================

--- Debug admin row: left-click seat swap; right-click `default<Color>` camera for clicker.
-- id format: `debugSeat_<Color>` (e.g. `debugSeat_Brown`)
-- @param button string TTS mouse button (`"-1"` left, `"-2"` right)
function HUD_debugSeatColor(player, button, id)
    if player == nil then
        return
    end
    local targetColor = seatColorFromDebugSeatButtonId(id)
    if targetColor == nil then
        print(string.format("[HUD_debugSeatColor] Could not parse color from id: %s", tostring(id)))
        return
    end

    if button == "-2" then
        if M ~= nil and type(M.setCamera) == "function" then
            M.setCamera(player, "default" .. targetColor)
        end
        return
    end

    if type(player.changeColor) ~= "function" then
        return
    end
    if player.color ~= targetColor then
        local ok = player.changeColor(targetColor)
        if ok ~= true and player.color ~= targetColor then
            broadcastToColor(
                "Could not change to " .. targetColor .. " (seat may be occupied).",
                player.color,
                { 1, 0.35, 0 }
            )
        end
    end
    hideStartupLoadingOverlays()
    syncDebugSeatColorButtons()
end

--- Debug panel: manual seat-assignment UI refresh (Host hotseat swaps skip auto-refresh).
function HUD_refreshUi(player, value, id)
    local seatColor = hostCurrentSeatColor()
    if type(seatColor) ~= "string" or seatColor == "" or seatColor == "Grey" then
        if player ~= nil and type(player.color) == "string" and player.color ~= "Grey" then
            seatColor = player.color
        end
    end
    if type(seatColor) ~= "string" or seatColor == "" or seatColor == "Grey" then
        if player ~= nil and type(player.color) == "string" then
            broadcastToColor("Refresh UI: no seated color.", player.color, { 1, 0.5, 0 })
        else
            print("[HUD_refreshUi] Refresh UI: no seated color.")
        end
        return
    end
    refreshGlobalUiAfterSeatAssignment(seatColor)
end

--- Admin panel: arm a quick test roll for a player color (difficulty 2, Standard).
-- Calls DEBUG.rollTest so it can be re-pressed between runs without cleanup.
-- id format: "debugRoll_<Color>"  (e.g. "debugRoll_Brown")
function HUD_debugRollTest(player, value, id)
    if not requireStorytellerForMutation(player, "HUD_debugRollTest") then
        return
    end
    local color = colorFromRollElementId(id)
    if color == nil then
        print(string.format("[HUD_debugRollTest] Could not parse color from id: %s", tostring(id)))
        return
    end
    if DEBUG == nil then return end
    DEBUG.rollTest(color)
end

--- Admin panel: cancel all active rolls across every player color.
function HUD_debugRollCancelAll(player, value, id)
    if not requireStorytellerForMutation(player, "HUD_debugRollCancelAll") then
        return
    end
    if DEBUG == nil then return end
    DEBUG.rollCancelAll()
end

--- Opens ST roll options modal for the row's player.
-- id format: "rollDash_opts_<Color>"
function HUD_rollOptsOpen(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end
    local pid    = S.getPlayerID(color)
    local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    RUI.openRollOptionsModal(color)
end

--- Stashes roll options modal numeric InputFields (`onValueChanged` / `onEndEdit`).
-- @param player Player
-- @param value string|nil
-- @param id string|nil
function HUD_rollOptsInputChanged(player, value, id)
    if RUI and RUI.onRollOptsInputChanged then
        RUI.onRollOptsInputChanged(player, value, id)
    end
end

function HUD_rollOptsApply(player, value, id)
    RUI.applyRollOptionsModal(RC)
end

function HUD_rollOptsCancel(player, value, id)
    RUI.closeRollOptionsModal()
end

--- Toggles a roll-options modal button (permanent, structural, or roll condition).
function HUD_rollOptsToggle(player, value, id)
    if RUI and RUI.toggleRollOptsButton then
        RUI.toggleRollOptsButton(id)
    end
end

function HUD_rollStNameInputChanged(player, value, id)
    if RUI.onStRollNameInputChanged then
        RUI.onStRollNameInputChanged(player, value, id)
    end
end

function HUD_rollStNameApply(player, value, id)
    if RUI.applyStRollNameModal then
        RUI.applyStRollNameModal()
        RUI.refreshSTDashboard()
    end
end

function HUD_rollStNameCancel(player, value, id)
    if RUI.closeStRollNameModal then
        RUI.closeStRollNameModal()
    end
end

--- ST action button on the dashboard (context-sensitive: Open / Override / Confirm).
-- id format: "rollDash_btn_<Color>"
function HUD_rollSTAction(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end

    local pid    = S.getPlayerID(color)
    local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end

    if color == "Black" and active.phase == C.RollPhase.PRE_ROLL then
        HUD_rollRollButton(player, value, id)
        return
    end

    if active.phase == C.RollPhase.SETUP then
        RC.openRoll(color)
    elseif active.phase == C.RollPhase.POST_ROLL then
        if active.pendingResolution ~= nil then
            print("[HUD_rollSTAction] Player must choose Hunger/Stain or Brutal outcome on the roll panel.")
            return
        end
        RC.confirmRoll(color)
    end
    -- For PRE_ROLL / ROLLING: ST can only set difficulty or cancel; no action button action
end

--- @param seated Player|nil
--- @return boolean
local function isHostPlayer(seated)
    if not U.isPlayer(seated) then
        return false
    end
    local host = U.getHost()
    if not U.isPlayer(host) then
        return false
    end
    local seatedSteam = seated.steam_id
    local hostSteam = host.steam_id
    if type(seatedSteam) == "string" and seatedSteam ~= ""
        and type(hostSteam) == "string" and hostSteam ~= ""
        and seatedSteam == hostSteam
    then
        return true
    end
    return seated == host
end

--- TTS: player joined or changed seat color.
function onPlayerChangeColor(color)
    if type(color) ~= "string" or color == "" or color == "Grey" then
        return
    end

    local seated = Player[color]
    if U.isPlayer(seated) then
        local playerID = S.getStorageID(seated)
        if playerID == C.StorytellerID and CameraDebugFocus ~= nil
            and type(CameraDebugFocus.syncStorytellerCameraForSeatColor) == "function"
        then
            CameraDebugFocus.syncStorytellerCameraForSeatColor(color)
        end
    end
    if M ~= nil and type(M.onPlayerChangeColor) == "function" then
        M.onPlayerChangeColor(color)
    end
    local playerKey = seatAssignmentPlayerKey(seated)
    local pendingConnectRefresh = playerKey ~= nil and pendingConnectSeatRefreshByPlayer[playerKey] == true
    if pendingConnectRefresh then
        pendingConnectSeatRefreshByPlayer[playerKey] = nil
        refreshGlobalUiAfterSeatAssignment(color)
    elseif not isHostPlayer(seated) then
        refreshGlobalUiAfterSeatAssignment(color)
    end
    syncDebugSeatColorButtons()
end

--- TTS: player connected (assign chronicle seat when mapped in C.PlayerData).
function onPlayerConnect(player_color)
    if type(player_color) == "string" then
        local connected = Player[player_color]
        if U.isPlayer(connected) then
            clearSeatXmlRefreshForPlayer(connected)
            local playerKey = seatAssignmentPlayerKey(connected)
            if playerKey ~= nil then
                pendingConnectSeatRefreshByPlayer[playerKey] = true
            end
        end
    end
    if M ~= nil and type(M.tryAutoAssignSeatFromChronicle) == "function" then
        M.tryAutoAssignSeatFromChronicle(player_color)
    end
end
