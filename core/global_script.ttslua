--[[
    onLoad - Called when the game loads or is reset
    @param saved_data - JSON string containing saved game state
]]
--- Resolve steam id for a character sheet seat color. Uses Global bundle `C` + `C.PlayerColors` so
--- object UI scripts do not depend on their embedded copy of `lib.constants` matching the game.
--- @param rawSeatColor string e.g. "PURPLE" or "Purple" from `CSHEET_PAGE_<n>_<COLOR>` object name
--- @return string|nil
function GlobalResolveSheetPlayerID(rawSeatColor)
    if type(rawSeatColor) ~= "string" or rawSeatColor == "" then
        return nil
    end
    local lr = string.lower(rawSeatColor)
    local canon = nil
    for _, col in ipairs(C.PlayerColors) do
        if string.lower(col) == lr then
            canon = col
            break
        end
    end
    if canon == nil then
        return nil
    end
    local pid = C.GetPlayerID(canon)
    if type(pid) == "string" then
        return pid
    end
    return nil
end

--- @param playerID string Steam id (or key in C.PlayerData)
--- @return table|nil Merged row from `S.getPlayerData` — for object UI scripts; they have no `gameState`.
function GlobalGetMergedPlayerData(playerID)
    if type(playerID) ~= "string" then
        return nil
    end
    return S.getPlayerData(playerID)
end

--- Resolved condition statChanges for one PC (sheet dots, BP decals). Object scripts have no `core.conditions`.
--- @param playerID string
--- @return table statChanges map (may be empty)
function GlobalGetResolvedStatChangesForPlayer(playerID)
    if type(playerID) ~= "string" or playerID == "" then
        return {}
    end
    if playerID == C.StorytellerID then
        return {}
    end
    local ES = require("lib.effective_stats")
    return ES.forPlayer(playerID).statChanges
end

--- @return boolean
local function startupSeatLightsReadyForReveal()
    if L == nil or type(L.GetLight) ~= "function" then
        return false
    end
    local savedLights = S.getStateVal("lights")
    if type(savedLights) ~= "table" then
        return true
    end
    for lightRef, _ in pairs(savedLights) do
        if type(lightRef) == "string" then
            local isSeatLight = U.lightRefIsSeatSpotlight(lightRef)
            if isSeatLight and L.GetLight(lightRef, true) == nil then
                return false
            end
        end
    end
    return true
end

local function hideStartupLoadingOverlays()
    for _, color in ipairs(C.PlayerColors or {}) do
        UI.hide("overlay_loadingScreen_" .. tostring(color))
    end
end

--- Returns seat layout center point from global state for object scripts.
--- @return table|nil { x, y, z }
function GlobalGetSeatLayoutCenterPoint()
    local tableKey = S.getStateVal("seatLayout", "currentTableKey")
    if type(tableKey) == "string" and C.Tables and C.Tables[tableKey] and C.Tables[tableKey].centerPoint ~= nil then
        local cp = Vector(C.Tables[tableKey].centerPoint)
        return { x = cp.x, y = cp.y, z = cp.z }
    end
    return nil
end

--- Toggles a player's signal fire from object scripts (signal candle click target).
--- @param params table { color: string, duration: number|nil }
--- @return string|nil "on" or "off", or nil on failure
function GlobalToggleSignalFireState(params)
    if type(params) ~= "table" then
        return nil
    end
    local color = params.color
    if type(color) ~= "string" or color == "" then
        return nil
    end
    local duration = tonumber(params.duration)
    if duration == nil then
        duration = 0.2
    end
    return O.ToggleSignalFireState(color, duration)
end

--- NPC gameboard: Apply tokens on CONTROL_BOARD → `sessionScene.npcWorld.placements` → `Sync.npcs`.
--- @param params table|nil
--- @return boolean
function GlobalGameboardApply(params)
    local Gameboard = require("core.npc_gameboard")
    local ok = Gameboard.applyFromControlBoard()
    if type(ok) == "boolean" then
        return ok
    end
    return ok == true
end

--- NPC gameboard: Clear with double-click confirm (object `click_clear` → Global.call).
--- @param params table|nil `{ player_color?: string }`
--- @return boolean
function GlobalGameboardClearClick(params)
    local color = type(params) == "table" and params.player_color or "Black"
    local Gameboard = require("core.npc_gameboard")
    if not Gameboard.tryConfirmClear(color) then
        return false
    end
    return GlobalGameboardClear(params)
end

--- NPC gameboard: Clear placements (expects confirmed Clear from object UI).
--- @param params table|nil
--- @return boolean
function GlobalGameboardClear(params)
    local Gameboard = require("core.npc_gameboard")
    local ok = Gameboard.clearControlBoard()
    if type(ok) == "boolean" then
        return ok
    end
    return ok == true
end

--- Returns the phase string of a player's active roll, or nil if no roll is active.
-- Called by dice bag objects (via Global.call) so they know whether to spawn a die
-- or initiate a new roll when clicked.
-- @param params table  { color: string }
-- @return string|nil  e.g. "PRE_ROLL", "ROLLING", or nil
function GlobalGetRollPhase(params)
    if type(params) ~= "table" then return nil end
    local color = params.color
    if type(color) ~= "string" then return nil end
    local pid = S.getPlayerID(color)
    if pid == nil then return nil end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return nil end
    return active.phase
end

--- Called by a dice bag each time it spawns one die (via Global.call).
-- Updates RC.setPool with the latest count for that die type while preserving
-- the count reported by the other bag type.
-- @param params table  { color: string, dieType: "normal"|"hunger", count: number }
function GlobalReportBagDiceCount(params)
    if type(params) ~= "table" then return end
    local color   = params.color
    local dieType = params.dieType
    local count   = params.count
    if type(color) ~= "string" or type(dieType) ~= "string" or type(count) ~= "number" then
        return
    end
    if RC == nil then return end

    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    local pool = DK.normalizePool(active.pool)
    local prevTotal = DK.poolTotal(pool)

    -- Rouse bag serves manual + Blood Surge rouse; pool counts come from GlobalOnBagDieSpawned.
    if dieType == DK.KIND_ROUSE then
        return
    end

    local kind = dieType
    if kind == "normal" or kind == "hunger"
        or kind == "oblivRouse" or kind == "werewolf" or kind == "rage"
    then
        pool[kind] = count
    end

    if RC.setPoolKindCount(color, kind, count) then
        if prevTotal == 0 and DK.poolTotal(pool) > 0 then
            GlobalRollSeatCamera({ color = color, mode = "roll" })
        end
    end
end

--- Resolves which logical die type a bag click should spawn (Auto-Hunger redirect, Hunger Dice off).
-- Hunger redirect applies only to normal/hunger requests on vampire pools. Rouse, Obliv-Rouse,
-- Werewolf, and Rage kinds are never rewritten to normal.
-- @param params table  { color: string, requested: string }  DK.KIND_* value
-- @return string|nil
function GlobalRollSpawnDieRequest(params)
    if type(params) ~= "table" then return DK.KIND_NORMAL end
    local color     = params.color
    local requested = params.requested
    if type(color) ~= "string" or type(requested) ~= "string" then return requested end

    local pid = S.getPlayerID(color)
    if pid == nil then return requested end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return requested end
    if active.phase ~= C.RollPhase.PRE_ROLL and active.phase ~= C.RollPhase.SETUP then
        return requested
    end

    local pool = DK.normalizePool(active.pool)
    if active.rollType == C.RollType.WEREWOLF then
        if requested ~= DK.KIND_WEREWOLF and requested ~= DK.KIND_RAGE then
            print("[Roll] Werewolf rolls only accept Werewolf and Rage dice.")
            return nil
        end
    elseif DK.poolHasWerewolfKind(pool) then
        print("[Roll] Cannot mix Werewolf/Rage dice with other types on this roll.")
        return nil
    elseif (requested == DK.KIND_WEREWOLF or requested == DK.KIND_RAGE)
        and DK.poolHasVampireKind(pool) then
        print("[Roll] Cannot add Werewolf/Rage dice to a non-Werewolf roll.")
        return nil
    end

    -- Rouse and Oblivion-Rouse are mutually exclusive in one roll (silent bag fail).
    if requested == DK.KIND_ROUSE or requested == DK.KIND_OBLIV_ROUSE then
        if DK.rouseKindBlockedByPool(pool, requested) then
            return nil
        end
        return requested
    end

    -- Dedicated / non-vampire kinds: no Auto-Hunger or Hunger-Dice-off rewrite.
    if requested ~= DK.KIND_NORMAL and requested ~= DK.KIND_HUNGER then
        return requested
    end

    local RO = require("lib.roll_options")

    if not RO.getForActive(active, RO.ROLL_HUNGER_DICE) then
        if requested == DK.KIND_HUNGER then
            return nil
        end
        return DK.KIND_NORMAL
    end

    if RO.getPermanent(RO.PERM_AUTO_HUNGER) and requested == DK.KIND_NORMAL then
        local ch    = S.getPlayerVal(color, "hunger") or 0
        local poolH = pool.hunger or 0
        if poolH < ch then
            return DK.KIND_HUNGER
        end
    end

    return requested
end

--- Arc center for the live Storyteller roll tray (nil when unavailable).
-- @return table|nil  { x, y, z }
local function storytellerArcCenterForActive()
    local pid = S.getPlayerID("Black")
    if pid == nil then return nil end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if type(active) ~= "table" or type(active.stDrawerSlot) ~= "number" then
        return nil
    end
    local STD = require("lib.st_dice_drawer")
    local center = STD.arcCenterForSlot(active.stDrawerSlot)
    if center == nil then return nil end
    return { x = center.x, y = center.y, z = center.z }
end

--- Removes the last staged die from the bag for a logical die kind.
-- @param color string
-- @param dieKind string  DK.KIND_*
-- @return boolean
local function removeDieFromBag(color, dieKind)
    if type(color) ~= "string" or type(dieKind) ~= "string" then
        return false
    end
    local guid = nil
    if color == "Black" then
        guid = G.GetDiceStorytellerBagGUID(dieKind)
    elseif dieKind == DK.KIND_NORMAL then
        guid = G.GetDiceNormalGUID(color)
    elseif dieKind == DK.KIND_HUNGER then
        guid = G.GetDiceHungerGUID(color)
    elseif dieKind == DK.KIND_ROUSE then
        guid = G.GetDiceRouseGUID(color)
    elseif dieKind == DK.KIND_OBLIV_ROUSE then
        guid = G.GetDiceOblivRouseGUID(color)
    end
    if type(guid) ~= "string" then
        return false
    end
    local bag = getObjectFromGUID(guid)
    if bag == nil then
        return false
    end
    local arcCenter = (color == "Black") and storytellerArcCenterForActive() or nil
    return bag.call("removeLastSpawnedDie", { arcCenter = arcCenter }) == true
end

--- Cancels the active roll when the assembled pool is empty (after removing a die).
-- @param color string
local function maybeCancelRollIfPoolEmpty(color)
    if RC == nil or type(color) ~= "string" then return end
    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    local pool = DK.normalizePool(active.pool)
    if DK.poolTotal(pool) > 0 then
        return
    end
    RC.cancelRoll(color)
end

--- Removes one main-pool die (Normal before Hunger) from the matching bag.
-- @param color string
-- @return boolean
local function removeMainPoolDie(color)
    if type(color) ~= "string" then
        return false
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        return false
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then
        return false
    end
    local pool = DK.normalizePool(active.pool)
    local dieKind = nil
    if (pool.normal or 0) > 0 then
        dieKind = DK.KIND_NORMAL
    elseif (pool.hunger or 0) > 0 then
        dieKind = DK.KIND_HUNGER
    end
    if dieKind == nil then
        return false
    end
    return removeDieFromBag(color, dieKind)
end

--- Spawns one die when GlobalRollSpawnDieRequest approves the kind.
-- @param color string
-- @param dieKind string  DK.KIND_*
local function spawnRequestedDie(color, dieKind)
    if type(color) ~= "string" or type(dieKind) ~= "string" then
        return
    end
    local logical = GlobalRollSpawnDieRequest({ color = color, requested = dieKind })
    if logical ~= nil then
        GlobalSpawnDieFromBag(color, logical)
    end
end

--- Whether a player dice bag accepts clicks (visibility reconcile).
-- @param params table  { color, dieKind }
-- @return boolean
function GlobalIsPlayerDiceBagEnabled(params)
    if type(params) ~= "table" then return false end
    local color = params.color
    local dieKind = params.dieKind
    if type(color) ~= "string" or type(dieKind) ~= "string" then return false end
    return DBV.isBagEnabled(color, dieKind)
end

--- Player dice bag right-click: opposite of left-click (usually remove one die).
-- @param params table  { color, dieKind, phase }
function GlobalDiceBagRightClick(params)
    if type(params) ~= "table" or RC == nil then return end
    local RO = require("lib.roll_options")
    local color = params.color
    local dieKind = params.dieKind
    local phase = params.phase
    if type(color) ~= "string" or type(dieKind) ~= "string" then return end

    if GlobalIsPlayerDiceBagEnabled({ color = color, dieKind = dieKind }) ~= true then
        return
    end

    if phase == nil
        or (phase ~= C.RollPhase.PRE_ROLL and phase ~= C.RollPhase.SETUP) then
        return
    end

    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end

    local meta = type(active.meta) == "table" and active.meta or {}
    local surgeActive = meta.bloodSurgeActive == true
    local pool = DK.normalizePool(active.pool)

    if active.rollType == C.RollType.STANDARD then
        if dieKind == DK.KIND_NORMAL then
            if removeMainPoolDie(color) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        if dieKind == DK.KIND_HUNGER then
            if surgeActive then
                RC.removeOneBloodSurgeRouse(color)
            end
            return
        end
        if dieKind == DK.KIND_ROUSE then
            if (pool.rouse or 0) > 0 and removeDieFromBag(color, dieKind) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        if dieKind == DK.KIND_OBLIV_ROUSE then
            if (pool.oblivRouse or 0) > 0 and removeDieFromBag(color, dieKind) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        return
    end

    if RO.isRouseFamilyRoll(active.rollType) then
        if dieKind == DK.KIND_NORMAL then
            if (pool.normal or 0) + (pool.hunger or 0) > 0 and removeMainPoolDie(color) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        if dieKind == DK.KIND_HUNGER then
            return
        end
        if dieKind == DK.KIND_ROUSE and active.rollType == C.RollType.ROUSE then
            if (pool.rouse or 0) > 0 and removeDieFromBag(color, dieKind) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        if dieKind == DK.KIND_OBLIV_ROUSE and active.rollType == C.RollType.ROUSE_OBLIVION then
            if (pool.oblivRouse or 0) > 0 and removeDieFromBag(color, dieKind) then
                maybeCancelRollIfPoolEmpty(color)
            end
            return
        end
        return
    end

    if removeDieFromBag(color, dieKind) then
        maybeCancelRollIfPoolEmpty(color)
    end
end

--- Player dice bag click routing (objects/dice_bag.ttslua).
-- @param params table  { color, dieKind, phase, alt_click?: boolean }
function GlobalDiceBagClick(params)
    if type(params) ~= "table" or RC == nil then return end
    if params.alt_click == true then
        GlobalDiceBagRightClick(params)
        return
    end

    local RO = require("lib.roll_options")
    local color = params.color
    local dieKind = params.dieKind
    local phase = params.phase
    if type(color) ~= "string" or type(dieKind) ~= "string" then return end

    if GlobalIsPlayerDiceBagEnabled({ color = color, dieKind = dieKind }) ~= true then
        return
    end

    if phase == nil then
        if dieKind == DK.KIND_HUNGER then
            return
        elseif dieKind == DK.KIND_ROUSE then
            if RC.initiateRoll(color, {
                rollType = C.RollType.ROUSE,
                label = "",
                initiator = "player",
                skipSetup = true,
            }) then
                GlobalSpawnDefaultPoolDiceForActive({ color = color })
            end
        elseif dieKind == DK.KIND_OBLIV_ROUSE then
            if RC.initiateRoll(color, {
                rollType = C.RollType.ROUSE_OBLIVION,
                label = "",
                initiator = "player",
                skipSetup = true,
            }) then
                GlobalSpawnDefaultPoolDiceForActive({ color = color })
            end
        else
            RC.initiateRoll(color, {
                rollType = C.RollType.STANDARD,
                label = "",
                initiator = "player",
            })
        end
        GlobalRollSeatCamera({ color = color, mode = "roll" })
        return
    end

    if phase ~= C.RollPhase.PRE_ROLL and phase ~= C.RollPhase.SETUP then
        return
    end

    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end

    if RO.isRouseFamilyRoll(active.rollType) then
        if dieKind == DK.KIND_HUNGER then
            return
        end
        if dieKind == DK.KIND_NORMAL then
            RC.promoteDedicatedRouseToStandard(color)
            spawnRequestedDie(color, dieKind)
            return
        end
        if active.rollType == C.RollType.ROUSE and dieKind == DK.KIND_ROUSE then
            spawnRequestedDie(color, dieKind)
            return
        end
        if active.rollType == C.RollType.ROUSE_OBLIVION and dieKind == DK.KIND_OBLIV_ROUSE then
            spawnRequestedDie(color, dieKind)
        end
        return
    end

    if active.rollType == C.RollType.STANDARD then
        if dieKind == DK.KIND_HUNGER then
            if phase == C.RollPhase.SETUP then
                spawnRequestedDie(color, dieKind)
                return
            end
            -- PRE_ROLL: Hunger bag toggles Blood Surge. Pool hunger dice in SETUP come from
            -- Hunger-bag spawn; auto-hunger redirect applies to Normal-bag clicks only.
            local meta = type(active.meta) == "table" and active.meta or {}
            if meta.bloodSurgeActive == true then
                RC.addBloodSurgeRouse(color)
            else
                RC.activateBloodSurge(color)
            end
            return
        end
        if dieKind == DK.KIND_ROUSE or dieKind == DK.KIND_OBLIV_ROUSE then
            spawnRequestedDie(color, dieKind)
            return
        end
    end

    spawnRequestedDie(color, dieKind)
end

--- Spawns one die from a Storyteller dice bag (Werewolf / Rage / ST vampire bags).
-- @param params table  { dieKind: string }
function GlobalSpawnDieFromStorytellerBag(params)
    if type(params) ~= "table" then return end
    local dieKind = params.dieKind
    if type(dieKind) ~= "string" then return end
    local guid = G.GetDiceStorytellerBagGUID(dieKind)
    if type(guid) ~= "string" then return end
    local bag = getObjectFromGUID(guid)
    if bag == nil then return end

    local arcCenter = nil
    local pid = S.getPlayerID("Black")
    if pid ~= nil then
        local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
        if type(active) == "table" and type(active.stDrawerSlot) == "number" then
            local STD = require("lib.st_dice_drawer")
            arcCenter = STD.arcCenterForSlot(active.stDrawerSlot)
        end
    end

    bag.call("spawnDieRedirect", {
        bagColor = "Black",
        dieType = dieKind,
        arcCenter = arcCenter,
    })
end

--- Writes active roll id to a spawned die's GM Notes (leave-container backup for programmatic takeObject).
-- @param params table  { color: string, dieGuid: string, bloodSurgeRouse?: boolean }
function GlobalTagDieForActiveRoll(params)
    if type(params) ~= "table" then
        return
    end
    local color = params.color
    local dieGuid = params.dieGuid
    if type(color) ~= "string" or type(dieGuid) ~= "string" then
        return
    end
    local die = getObjectFromGUID(dieGuid)
    if die == nil then
        return
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        return
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil or active.phase == C.RollPhase.RESOLVED then
        return
    end
    if type(active.id) ~= "string" then
        return
    end
    if DK.gmNotesMatchRoll(die.getGMNotes(), active.id) then
        return
    end
    local isSurgeRouse = params.bloodSurgeRouse == true
        or die.script_state == DK.SCRIPT_STATE_BLOOD_SURGE_ROUSE
    die.setGMNotes(DK.encodeGmNotes(active.id, isSurgeRouse))
end

--- Opens the seat dice tray when the first die of any kind enters the PRE_ROLL/ROLLING pool.
-- Authoritative for Auto-Hunger redirects (hunger bag spawn may not run leave-container drawer path).
-- @param color string
-- @param active table  active roll after pool mutation
local function openDiceTrayOnFirstPoolDie(color, active)
    if type(color) ~= "string" or type(active) ~= "table" then
        return
    end
    if active.phase ~= C.RollPhase.SETUP
        and active.phase ~= C.RollPhase.PRE_ROLL
        and active.phase ~= C.RollPhase.ROLLING then
        return
    end
    if DK.poolTotal(DK.normalizePool(active.pool)) < 1 then
        return
    end
    if color == "Black" and type(active.stDrawerSlot) == "number" then
        local STR = require("core.storyteller_rolls")
        STR.onFirstDieSpawned()
    elseif color ~= "Black" then
        DiceDrawer.openForRoll(color)
    end
end

--- Bag spawn hook: delta pool counts (rouse vs bloodSurgeRouse) or staged count for other kinds.
-- @param params table
function GlobalOnBagDieSpawned(params)
    if type(params) ~= "table" or RC == nil then return end
    local color = params.color
    local dieType = params.dieType
    local stagedCount = tonumber(params.stagedCount)
    if type(color) ~= "string" or type(dieType) ~= "string" then return end

    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    local pool = DK.normalizePool(active.pool)
    local prevTotal = DK.poolTotal(pool)

    local ok = false
    if params.bloodSurgeRouse == true then
        ok = RC.adjustPoolKindCount(color, DK.KIND_BLOOD_SURGE_ROUSE, 1)
    elseif dieType == DK.KIND_ROUSE then
        -- Rouse bag may hold manual rouse + Blood Surge rouse; pool.rouse is manual only.
        -- Never fall back to stagedCount (total on bag) — it mixes both die kinds.
        local manualCount = tonumber(params.manualRouseCount)
        if manualCount ~= nil then
            ok = RC.setPoolKindCount(color, DK.KIND_ROUSE, manualCount)
        else
            ok = RC.adjustPoolKindCount(color, DK.KIND_ROUSE, 1)
        end
    elseif type(stagedCount) == "number" then
        -- Bag spawns pass stagedCount; sync pool to staged dice (avoids double-count
        -- when initiateRoll already preset pool.oblivRouse).
        ok = RC.setPoolKindCount(color, dieType, stagedCount)
    elseif dieType == DK.KIND_OBLIV_ROUSE then
        ok = RC.adjustPoolKindCount(color, DK.KIND_OBLIV_ROUSE, 1)
    end

    if ok and prevTotal == 0 then
        active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
        if active ~= nil then
            local poolAfter = DK.normalizePool(active.pool)
            if DK.poolTotal(poolAfter) > 0 then
                openDiceTrayOnFirstPoolDie(color, active)
                GlobalRollSeatCamera({ color = color, mode = "roll" })
            end
        end
    end
end

--- Bag remove hook: sync pool counts after a staged die is destroyed.
-- @param params table  { color, poolKind, stagedCount?, manualRouseCount? }
function GlobalOnBagDieRemoved(params)
    if type(params) ~= "table" or RC == nil then return end
    local color = params.color
    local poolKind = params.poolKind
    if type(color) ~= "string" or type(poolKind) ~= "string" then return end
    local stagedCount = tonumber(params.stagedCount)
    local manualRouseCount = tonumber(params.manualRouseCount)
    if poolKind == DK.KIND_BLOOD_SURGE_ROUSE then
        RC.adjustPoolKindCount(color, DK.KIND_BLOOD_SURGE_ROUSE, -1)
    elseif poolKind == DK.KIND_ROUSE then
        if manualRouseCount ~= nil then
            RC.setPoolKindCount(color, DK.KIND_ROUSE, manualRouseCount)
        else
            RC.adjustPoolKindCount(color, DK.KIND_ROUSE, -1)
        end
    elseif type(stagedCount) == "number" then
        RC.setPoolKindCount(color, poolKind, stagedCount)
    else
        RC.adjustPoolKindCount(color, poolKind, -1)
    end
end

--- Spawns one die from the bag object registered for this logical kind (GUID lookup).
-- Always uses that bag's contents; never redirects Rouse/Obliv spawns to Normal/Hunger bags.
-- @param colorOrParams string|table  seat color, or { color, dieKind, bloodSurgePool?, bloodSurgeRouse? }
-- @param dieKind string|nil  DK.KIND_* value when first arg is color
-- @param opts table|nil
function GlobalSpawnDieFromBag(colorOrParams, dieKind, opts)
    local color = colorOrParams
    if type(colorOrParams) == "table" then
        color = colorOrParams.color
        dieKind = colorOrParams.dieKind
        opts = colorOrParams
    end
    if type(color) ~= "string" or type(dieKind) ~= "string" then
        return
    end
    local bloodSurgePool = type(opts) == "table" and opts.bloodSurgePool == true
    local bloodSurgeRouse = type(opts) == "table" and opts.bloodSurgeRouse == true
    local guid = nil
    if dieKind == DK.KIND_NORMAL then guid = G.GetDiceNormalGUID(color)
    elseif dieKind == DK.KIND_HUNGER then guid = G.GetDiceHungerGUID(color)
    elseif dieKind == DK.KIND_ROUSE or dieKind == DK.KIND_BLOOD_SURGE_ROUSE then
        guid = G.GetDiceRouseGUID(color)
    elseif dieKind == DK.KIND_OBLIV_ROUSE then guid = G.GetDiceOblivRouseGUID(color)
    end
    if type(guid) ~= "string" then
        return
    end
    local bag = getObjectFromGUID(guid)
    if bag == nil then
        return
    end
    bag.call("spawnDieRedirect", {
        bagColor = color,
        dieType = (dieKind == DK.KIND_BLOOD_SURGE_ROUSE) and DK.KIND_ROUSE or dieKind,
        bloodSurgePool = bloodSurgePool,
        bloodSurgeRouse = bloodSurgeRouse,
    })
    bag.call("repositionStagedDice")
    if bloodSurgePool and (dieKind == DK.KIND_NORMAL or dieKind == DK.KIND_HUNGER) then
        RC.recordBloodSurgePoolAdd(color, dieKind, 1)
    end
end

--- Spawns staged dice for the active PRE_ROLL pool (delegates to GlobalSpawnActivePoolDiceForActive).
-- @param color string
local function spawnDefaultPoolDiceForActive(color)
    if type(color) ~= "string" then
        return
    end
    Global.call("GlobalSpawnActivePoolDiceForActive", { color = color })
end

--- Global.call entry: spawn default staged dice for active PRE_ROLL check pools.
-- @param params table  { color: string }
function GlobalSpawnDefaultPoolDiceForActive(params)
    if type(params) ~= "table" then return end
    local color = params.color
    if type(color) ~= "string" then return end
    spawnDefaultPoolDiceForActive(color)
end

--- Destroys hovering dice on every player bag for a seat.
-- @param params table  { color }
function GlobalDestroyAllPlayerBagDice(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then return end
    local bags = G.GetAllPlayerDiceBagGUIDs(params.color)
    for _, guid in pairs(bags) do
        local bag = getObjectFromGUID(guid)
        if bag ~= nil then bag.call("destroyDice") end
    end
end

--- Spawns blood surge rouse die + surge pool dice.
-- @param params table  { color, rollId, surgeCount }
function GlobalSpawnBloodSurgeDice(params)
    if type(params) ~= "table" then return end
    local color = params.color
    local rollId = params.rollId
    local surgeCount = tonumber(params.surgeCount) or 0
    if type(color) ~= "string" or type(rollId) ~= "string" then return end

    local rouseGuid = G.GetDiceRouseGUID(color)
    if type(rouseGuid) == "string" then
        local bag = getObjectFromGUID(rouseGuid)
        if bag ~= nil then
            bag.call("spawnDieRedirect", {
                bagColor = color,
                dieType = DK.KIND_ROUSE,
                bloodSurgeRouse = true,
            })
        end
    end

    for _ = 1, surgeCount do
        local logical = GlobalRollSpawnDieRequest({ color = color, requested = DK.KIND_NORMAL })
        if logical ~= nil then
            GlobalSpawnDieFromBag(color, logical, { bloodSurgePool = true })
        end
    end
end

--- Removes one staged die and cancels the roll if the pool becomes empty.
-- @param params table  { color: string, dieKind: string }
function GlobalRemoveDieFromBag(params)
    if type(params) ~= "table" then return end
    local color = params.color
    local dieKind = params.dieKind
    if type(color) ~= "string" or type(dieKind) ~= "string" then return end
    if removeDieFromBag(color, dieKind) then
        maybeCancelRollIfPoolEmpty(color)
    end
end

--- Storyteller dice bag click (delegates to core/storyteller_rolls.ttslua).
-- @param params table  { dieKind, clickedBy?, alt_click?: boolean }
function GlobalStorytellerDiceBagClick(params)
    local STR = require("core.storyteller_rolls")
    if type(params) == "table" and params.alt_click == true then
        STR.onDiceBagRightClick(params)
    else
        STR.onDiceBagClick(params)
    end
end

--- Removes Blood Surge dice for a roll: tagged rouse + surge-spawned normal/hunger only.
-- @param params table  { color, rollId }
function GlobalDestroyBloodSurgeDice(params)
    if type(params) ~= "table" then return end
    local color = params.color
    local rollId = params.rollId
    if type(color) ~= "string" or type(rollId) ~= "string" then return end
    local ownerTag = color .. "Object"
    local kinds = {
        { tag = DK.TAG_ROUSE, surgeRouseOnly = true },
        { tag = DK.TAG_NORMAL, surgePoolOnly = true },
        { tag = DK.TAG_HUNGER, surgePoolOnly = true },
    }
    for _, spec in ipairs(kinds) do
        local candidates = getObjectsWithAllTags({ spec.tag, "d10", ownerTag })
        for _, obj in ipairs(candidates) do
            if DK.gmNotesMatchRoll(obj.getGMNotes(), rollId) then
                local destroyIt = false
                if spec.surgeRouseOnly == true then
                    local _, isSurge = DK.decodeGmNotes(obj.getGMNotes())
                    destroyIt = isSurge == true
                        or obj.script_state == DK.SCRIPT_STATE_BLOOD_SURGE_ROUSE
                elseif spec.surgePoolOnly == true then
                    destroyIt = obj.script_state == DK.SCRIPT_STATE_BLOOD_SURGE_POOL
                end
                if destroyIt then
                    destroyObject(obj)
                end
            end
        end
    end
    local bagSpecs = {
        { guid = G.GetDiceRouseGUID(color), scriptState = DK.SCRIPT_STATE_BLOOD_SURGE_ROUSE },
        { guid = G.GetDiceNormalGUID(color), scriptState = DK.SCRIPT_STATE_BLOOD_SURGE_POOL },
        { guid = G.GetDiceHungerGUID(color), scriptState = DK.SCRIPT_STATE_BLOOD_SURGE_POOL },
    }
    for _, spec in ipairs(bagSpecs) do
        if type(spec.guid) == "string" then
            local bag = getObjectFromGUID(spec.guid)
            if bag ~= nil then
                bag.call("destroyStagedByScriptState", { scriptState = spec.scriptState })
            end
        end
    end
end

--- Destroys one Blood Surge rouse die on the table (released dice).
-- @param params table  { color, rollId }
-- @return boolean
function GlobalDestroyOneTableBloodSurgeRouse(params)
    if type(params) ~= "table" then return false end
    local color = params.color
    local rollId = params.rollId
    if type(color) ~= "string" or type(rollId) ~= "string" then return false end
    local ownerTag = color .. "Object"
    local candidates = getObjectsWithAllTags({ DK.TAG_ROUSE, "d10", ownerTag })
    for _, obj in ipairs(candidates) do
        local rid, isSurge = DK.decodeGmNotes(obj.getGMNotes())
        if rid == rollId and (isSurge == true or obj.script_state == DK.SCRIPT_STATE_BLOOD_SURGE_ROUSE) then
            destroyObject(obj)
            return true
        end
    end
    return false
end

--- Called by character sheet objects (via Global.call) to initiate a roll for their player.
-- Accepts either a direct rollType string, or a semantic trigger key that is resolved
-- to a roll type based on current game state (e.g. phase-dependent Remorse vs Humanity).
--
-- Trigger keys (params.trigger):
--   "humanity"  → C.RollType.HUMANITY_ROLL normally; C.RollType.REMORSE at end-of-session phase
--   "willpower" → C.RollType.WILLPOWER_ROLL
--   "rouse"     → C.RollType.ROUSE
--   "frenzy"    → C.RollType.FRENZY
-- (Extend this table as more sheet-interactive rolls are defined.)
--
-- @param params table  { color: string, rollType?: string, trigger?: string, label?: string }
-- @return boolean  true if the roll was initiated; false if blocked or invalid
function GlobalInitiateRoll(params)
    if type(params) ~= "table" then return false end
    if RC == nil then return false end

    local color = params.color
    if type(color) ~= "string" then return false end

    -- Resolve roll type: direct value takes precedence, then trigger mapping
    local rollType = params.rollType

    if rollType == nil and type(params.trigger) == "string" then
        local currentPhase = S.getStateVal("currentPhase")

        local triggerMap = {
            standard    = function() return C.RollType.STANDARD     end,
            simplecheck = function() return C.RollType.SIMPLE_CHECK end,
            humanity    = function()
                -- Remorse at end-of-session; Humanity Roll otherwise
                return (currentPhase == C.Phases.SESSION_END)
                    and C.RollType.REMORSE
                    or  C.RollType.HUMANITY_ROLL
            end,
            willpower = function() return C.RollType.WILLPOWER_ROLL end,
            rouse     = function() return C.RollType.ROUSE           end,
            rouseoblivion = function() return C.RollType.ROUSE_OBLIVION end,
            frenzy    = function() return C.RollType.FRENZY          end,
        }

        local resolver = triggerMap[params.trigger]
        if resolver ~= nil then
            rollType = resolver()
        else
            print(string.format(
                "[GlobalInitiateRoll] Unknown trigger key: '%s'", tostring(params.trigger)))
            return false
        end
    end

    if type(rollType) ~= "string" then
        print("[GlobalInitiateRoll] No rollType or trigger provided.")
        return false
    end

    -- Dice bags and character sheets call GlobalInitiateRoll — treat as player-initiated
    -- so the player panel is shown immediately with "Awaiting Storyteller..." feedback.
    local ok = RC.initiateRoll(color, {
        rollType  = rollType,
        label     = params.label or "",
        initiator = params.initiator or "player",
        skipSetup = params.skipSetup,
    })
    if ok then
        GlobalRollSeatCamera({ color = color, mode = "roll" })
        GlobalSpawnDefaultPoolDiceForActive({ color = color })
    end
    return ok
end

--- Shallow snapshot of character sheet tracker presentation (glyphs + optional sheet `image` ids).
--- Set from each `ui_csheet` object on load; drives Storyteller strip text via `lib.pc_stats` and sheet box art.
--- @param cfg table|nil with optional keys: `damageTrack`, `humanityTrack`, `sheetImages`
function GlobalRegisterTrackerDisplay(cfg)
    if type(cfg) ~= "table" then
        return
    end
    TRACKER_DISPLAY = {
        damageTrack = cfg.damageTrack,
        humanityTrack = cfg.humanityTrack,
        hungerTrack = cfg.hungerTrack,
        sheetImages = cfg.sheetImages,
    }
end

--- Build character sheet dot/box UI attribute updates (object scripts call via Global.call).
--- TTS `call()` forwards only one parameter — pass a single params table.
--- @param params table { playerID: string, pageNum: number|nil }
--- @return table[]
function GlobalCollectSheetImageUpdates(params)
    if type(params) ~= "table" then
        error("GlobalCollectSheetImageUpdates: params must be a table")
    end
    if type(params.playerID) ~= "string" or params.playerID == "" then
        error("GlobalCollectSheetImageUpdates: params.playerID must be a non-empty string")
    end
    local stats = S.getStateVal("playerData", params.playerID, "stats")
    if type(stats) ~= "table" then
        error("GlobalCollectSheetImageUpdates: missing stats for player " .. params.playerID)
    end
    local ES = require("lib.effective_stats")
    local ctx = ES.forPlayer(params.playerID)
    local PSC = require("lib.pc_sheet_collect")
    return PSC.collectSheetImageUpdates(ctx.stats, ctx.statChanges, params.pageNum)
end

--- Switch clicking player to a seat's sheet camera preset (sheetRed, sheetBrown, …).
--- @param params table { clickerColor: string, sheetSeatColor: string }
function GlobalSetSheetCamera(params)
    if type(params) ~= "table" then
        error("GlobalSetSheetCamera: params must be a table")
    end
    local clickerColor = params.clickerColor
    local sheetSeatColor = params.sheetSeatColor
    if type(clickerColor) ~= "string" or clickerColor == "" then
        error("GlobalSetSheetCamera: clickerColor is required")
    end
    if type(sheetSeatColor) ~= "string" or sheetSeatColor == "" then
        error("GlobalSetSheetCamera: sheetSeatColor is required")
    end
    local canonSeat = nil
    local lr = string.lower(sheetSeatColor)
    for _, col in ipairs(C.PlayerColors or {}) do
        if string.lower(col) == lr then
            canonSeat = col
            break
        end
    end
    if canonSeat == nil then
        error(string.format("GlobalSetSheetCamera: invalid sheet seat color %q", sheetSeatColor))
    end
    if M == nil or type(M.setCamera) ~= "function" then
        error("GlobalSetSheetCamera: M.setCamera is unavailable")
    end
    M.setCamera(clickerColor, "sheet" .. canonSeat)
end

function onLoad(saved_data)
    -- Emitters and `Wait.time` are typically available here; chunk-level pass often sees 0/9 GUIDs.
    trEarlySilenceSoundscapeEmitters("onLoad-sync-immediate")
    trScheduleEarlySoundscapeSilenceDeferred("onLoad")

    print(trLoadElapsedPrefix() .. "--- VTM5E Module Loaded ---")
    local startupLastAction = "onLoad:start"

    --- @param action string
    local function setStartupAction(action)
        if type(action) == "string" and action ~= "" then
            if startupLastAction ~= action then
                startupLastAction = action
                print(trLoadElapsedPrefix() .. "Startup step: " .. tostring(startupLastAction))
            end
        end
    end

    -- Print host Steam ID for hardcoding into C.StorytellerID (lib/constants.ttslua)
    setStartupAction("resolve-host-steam-id")
    local host = U.getHost and U.getHost()
    if host and host.steam_id then
        print(trLoadElapsedPrefix() .. "Host Steam ID (use for C.StorytellerID in lib/constants.ttslua): " .. tostring(host.steam_id))
    end

    -- Clear all debug logs to start fresh for this session
    setStartupAction("clear-debug-logs")
    DEBUG.clearAllLogs()

    -- Initialize game state from saved data or defaults
    setStartupAction("initialize-game-state")
    S.InitializeGameState(saved_data)
    if Scenes ~= nil and type(Scenes.syncSessionLightingPresetForLocation) == "function" then
        Scenes.syncSessionLightingPresetForLocation()
    end

    setStartupAction("conditions-validate-and-reconcile")
    local Conditions = require("core.conditions")
    Conditions.validateAllPersisted()
    Conditions.reconcileDerivedAllPlayers()
    Conditions.reconcileLocationHostedForScene({ skipPresentation = true })

    -- AssetBundles often resume Unity looping AudioSources from the save before reconcile runs; mute stray loops immediately.
    setStartupAction("soundscape-bootstrap-silence")
    if SS ~= nil and type(SS.bootstrapSilenceStrayEmitterLoops) == "function" then
        SS.bootstrapSilenceStrayEmitterLoops()
    end

    -- Initialize zones module
    setStartupAction("zones-onload")
    Z.onLoad()

    -- Initialize main module
    setStartupAction("main-onload")
    M.onLoad()

    -- Non-interactable + per-player invisibility from `C.LockedObjects` / `C.HiddenObjects` (replaces per-object onLoad scripts)
    setStartupAction("apply-locked-and-hidden-objects")
    if O ~= nil and type(O.ApplyLockedAndHiddenFromConstants) == "function" then
        O.ApplyLockedAndHiddenFromConstants()
    end

    -- Ensure table objects/components and seat layout objects are synchronized to current saved table
    -- state during load. Defer slightly so object GUID lookups (including relative objects) are ready.
    local startupTableSyncDone = false
    setStartupAction("schedule-table-sync")
    if R and type(R.SyncTable) == "function" then
        U.delay(function()
            setStartupAction("run-table-sync")
            R.SyncTable()
            startupTableSyncDone = true
            setStartupAction("table-sync-complete")
        end, 0.5)
    else
        startupTableSyncDone = true
        setStartupAction("table-sync-not-required")
    end

    -- Synchronization orchestration (step 2): consolidate the onLoad fan-out into Sync.full().
    setStartupAction("initial-sync-full")
    Sync.full({ reason = "onLoad_initial" })
    if GameStateOverlay and type(GameStateOverlay.ensureTicker) == "function" then
        GameStateOverlay.ensureTicker()
    end
    local startupInitialSyncDone = true
    setStartupAction("initial-sync-full-complete")

    setStartupAction("dice-bag-visibility-defaults")
    U.delay(function()
        DBV.disableHungerBagsForAllPlayers()
    end, 1.0)

    -- Keep loading overlay visible until startup settles:
    -- - table sync callback has run
    -- - first sync pass has been issued
    -- - seat lights are resolvable
    -- Then run one final sync pass, wait wall-clock, and hide loading overlay.
    -- Use U.RunSequence (U.waitUntil) instead of U.waitForCondition with nested U.delay:
    -- TTS does not reliably honor U.delay scheduled from inside a condition callback.
    local startupOverlayHideDelaySeconds = 20
    U.RunSequence({
        function()
            return function()
                if not startupTableSyncDone then
                    setStartupAction("waiting-for-table-sync")
                    return false
                end
                if not startupInitialSyncDone then
                    setStartupAction("waiting-for-initial-sync")
                    return false
                end
                if not startupSeatLightsReadyForReveal() then
                    setStartupAction("waiting-for-seat-lights")
                    return false
                end
                setStartupAction("startup-ready-conditions-met")
                return true
            end
        end,
        function()
            setStartupAction("startup-ready-final-sync-full")
            Sync.full({ reason = "onLoad_startup_gate" })
            setStartupAction("startup-ready-delay-before-overlay-hide")
            print(
                trLoadElapsedPrefix()
                    .. "Startup readiness gate complete: waiting "
                    .. tostring(startupOverlayHideDelaySeconds)
                    .. "s before hiding loading overlay."
            )
            return startupOverlayHideDelaySeconds
        end,
        function()
            setStartupAction("startup-ready-hide-loading-overlays")
            hideStartupLoadingOverlays()
            setStartupAction("startup-ready-complete")
            print(trLoadElapsedPrefix() .. "Startup readiness gate complete: loading overlay hidden.")
            return 0
        end,
    }, 180)

    -- Debug module help (optional - shows available test commands)
    -- DEBUG.help()

    print(trLoadElapsedPrefix() .. "Module initialization complete.")
end

--[[
    onSave - Called when the game is saved
    @return JSON string containing game state to save
]]
function onSave()
    if L ~= nil then
        if L.sanitizeLightsStateForSave ~= nil then
            L.sanitizeLightsStateForSave()
        elseif L.cleanupLightsState ~= nil then
            L.cleanupLightsState()
        end
    end
    -- Get save-safe state (whitelist approach - only includes explicitly listed fields)
    local state = S.getGameState(true)

    if state == nil then
        return ""  -- Return empty string if state is nil
    end

    if type(state) ~= "table" then
        print("WARNING: onSave() - state is not a table, type: " .. type(state))
        return ""
    end

        -- Dump complete gameState to file before save
        -- DEBUG.logStateToFile("BEFORE_SAVE")

        -- Debug: Inspect players structure before encoding
        if state.players then
            print("DEBUG onSave: Inspecting players structure...")
            print("DEBUG onSave: players type: " .. type(state.players))
            print("DEBUG onSave: players keys count: " .. (state.players and #U.getKeys(state.players) or 0))

            -- First, check what's actually in the raw gameState.players (before buildSaveState)
            print("DEBUG onSave: Checking RAW gameState.players structure...")
            local rawPlayers = S.getGameState(false).players
            if rawPlayers then
                print("DEBUG onSave: Raw players type: " .. type(rawPlayers))
                print("DEBUG onSave: Raw players has " .. #U.getKeys(rawPlayers) .. " keys")

                -- Check the "Red" entry specifically
                if rawPlayers["Red"] then
                    print("DEBUG onSave: Raw players['Red'] exists, type: " .. type(rawPlayers["Red"]))
                    if type(rawPlayers["Red"]) == "table" then
                        print("DEBUG onSave: Raw players['Red'] is a table with keys: " .. table.concat(U.getKeys(rawPlayers["Red"]), ", "))
                        -- Check for metatable
                        local mt = getmetatable(rawPlayers["Red"])
                        if mt then
                            print("DEBUG onSave: WARNING - players['Red'] has a metatable!")
                            for k, v in pairs(mt) do
                                print("DEBUG onSave:   metatable[" .. tostring(k) .. "] = " .. tostring(v) .. " (type: " .. type(v) .. ")")
                            end
                        end
                        -- Try to access each field individually
                        for key, val in pairs(rawPlayers["Red"]) do
                            local keyType = type(key)
                            local valType = type(val)
                            print("DEBUG onSave:   Raw Red[" .. tostring(key) .. "] (key type: " .. keyType .. ") = " .. tostring(val) .. " (type: " .. valType .. ")")
                        end
                    else
                        print("DEBUG onSave: Raw players['Red'] is NOT a table, it's: " .. type(rawPlayers["Red"]))
                    end
                end
            end

            -- Now check the sanitized version
            print("DEBUG onSave: Checking SANITIZED state.players structure...")
            for color, playerData in pairs(state.players) do
                print("DEBUG onSave: Player " .. tostring(color) .. " type: " .. type(playerData))
                if type(playerData) == "table" then
                    print("DEBUG onSave: Player " .. tostring(color) .. " keys: " .. table.concat(U.getKeys(playerData), ", "))
                    for key, val in pairs(playerData) do
                        local valType = type(val)
                        print("DEBUG onSave:   " .. tostring(key) .. " = " .. tostring(val) .. " (type: " .. valType .. ")")
                    end
                end
            end

            -- Try encoding just the "Red" entry to isolate the problem
        if state.players["Red"] then
            print("DEBUG onSave: Testing encoding of just 'Red' entry...")
            JSON.encode({ Red = state.players["Red"] })
            print("DEBUG onSave: Successfully encoded 'Red' entry")
        end
    end

    -- Encode the save-safe state
    local encoded = JSON.encode(state)
    if encoded == nil then
        print("WARNING: onSave() - JSON.encode returned nil")
        return ""
    end
    return encoded
end

--[[
    Zone Activation/Deactivation Functions
    These functions are called by the zones module to enable/disable zone event handlers.
]]
function ActivateZones()
    onObjectEnterZone = Z.onObjectEnterZone
    onObjectLeaveZone = Z.onObjectLeaveZone
end

function DeactivateZones()
    ---@diagnostic disable-next-line: assign-type-mismatch
    onObjectEnterZone = nil  -- TTS allows nil to disable zone handlers
    ---@diagnostic disable-next-line: assign-type-mismatch
    onObjectLeaveZone = nil  -- TTS allows nil to disable zone handlers
end

--- Palette → CONTROL_BOARD drops: remember pick-up origin for per-ring defaultLightMode (TOR-172).
function onObjectPickUp(player_color, object)
    if object ~= nil and object.hasTag ~= nil and object.hasTag("npc_control_token") == true then
        local Gameboard = require("core.npc_gameboard")
        if type(Gameboard.onNpcControlTokenPickUp) == "function" then
            Gameboard.onNpcControlTokenPickUp(object)
        end
    end
end

--- When a figurine is dropped after dragging, refresh its paired NPC spotlight.
function onObjectDrop(playerColor, object)
    if object == nil or object.hasTag == nil then
        return
    end
    -- TOR-197: O(1) tag gate — do not call NPCS for tokens, dice, cards, etc.
    if object.hasTag("npc_figurine") == true and NPCS and NPCS.onObjectDropped then
        NPCS.onObjectDropped(object)
    end
    if object.hasTag("npc_control_token") == true then
        local Gameboard = require("core.npc_gameboard")
        if Gameboard.onNpcControlTokenDropped then
            Gameboard.onNpcControlTokenDropped(object, playerColor)
        end
    end
end

--[[
    UI Event Handlers
    These functions are called by UI buttons via onClick attributes in the XML.
]]

--- Select storyteller panel (mutually exclusive: one panel open at a time)
-- Used by toggle buttons (`toggle_scenes`, `toggle_soundscape`, etc.) in bottom-right bar
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "toggle_scenes")
function HUD_selectStorytellerPanel(player, button, id)
    local panelKey = string.gsub(id, "^toggle_", "")
    StorytellerPanelUI.selectStorytellerPanel(panelKey)
    -- TTS applies U.setAttribute asynchronously; deferred refresh merges rows after the panel is active in XML.
    if panelKey == "npcs" and NPCS and NPCS.refreshStorytellerUIDeferred then
        NPCS.refreshStorytellerUIDeferred()
    end
    if panelKey == "pcs" and PCST and PCST.refreshAllRows then
        Wait.frames(function()
            PCST.refreshAllRows()
        end, 1)
    end
    if panelKey == "soundscape" then
        Wait.frames(function()
            UpdateUIDisplays({ soundscape = true })
        end, 1)
    end
    if panelKey == "scenes" then
        Wait.frames(function()
            UpdateUIDisplays({ scenesPanel = true, adminLighting = true })
        end, 1)
    end
end

--- Storyteller PCs panel control buttons (id pattern pcs_<Color>_<action>).
function HUD_pcPanel(player, button, id)
    if PCST and PCST.onHudClick then
        PCST.onHudClick(player, button, id)
    end
end

--- Toggle panel visibility (collapse/expand)
-- Used by toggle buttons (toggleElem_*) in the UI
-- @param player Player The player who clicked the button
-- @param button string Button value (typically "-1" for single click, "-2" for double click)
-- @param id string The UI element ID (e.g., "toggleElem_storytellerControls")
function HUD_togglePanel(player, button, id)
    -- Extract the element ID by removing "toggleElem_" prefix
    local elemID = string.gsub(id, "^toggleElem_", "")
    U.toggleXmlElement(elemID, button)
end

--- Change scene preset
-- Called when a scene button is clicked (e.g., "scene_elysium")
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "scene_elysium")
function HUD_changeScene(player, button, id)
    -- Extract scene name from ID (remove "scene_" prefix)
    local sceneName = string.gsub(id, "^scene_", "")

    -- Validate scene name
    local scene = Scenes.getScene(sceneName)
    if scene == nil then
        U.AlertGM("HUD_changeScene: Invalid scene name: " .. tostring(sceneName))
        return
    end

    -- State-first scene selection, then reconcile through the sync pipeline.
    S.setStateVal(sceneName, "currentScene")
    S.setStateVal(nil, "sceneTransition")
    if Sync and type(Sync.full) == "function" then
        Sync.full({ reason = "HUD_changeScene" })
    else
        UpdateUIDisplays()
    end

    print("HUD: Scene changed to " .. sceneName .. " by " .. player.color)
end

local ADMIN_LIGHT_SCENE_BUTTONS = {
    dark = "adminScene_dark",
    standard = "adminScene_standard",
    bright = "adminScene_bright",
}

local ADMIN_LIGHT_SCENE_BUTTON_COLORS_INACTIVE = "#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
local ADMIN_LIGHT_SCENE_BUTTON_COLORS_ACTIVE = "#228B22|#32CD32|#006400|#228B22"
local STORYTELLER_SOUND_GREY = "#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
local STORYTELLER_SOUND_GREEN = "#228B22|#32CD32|#006400|#228B22"
local STORYTELLER_SOUND_DISABLED = "#333333|#444444|#555555|rgba(0.2,0.2,0.2,0.5)"

local SOUNDSCAPE_MOOD_BUTTONS = {
    main = "soundscapeMood_main",
    intrigue = "soundscapeMood_intrigue",
    combat = "soundscapeMood_combat",
}

local PHASE_BUTTON_EXPECTATIONS = {
    phase_SessionStart = C.Phases.SESSION_START,
    phase_Play = C.Phases.PLAY,
    phase_Downtime = C.Phases.DOWNTIME,
    phase_Memoriam = C.Phases.MEMORIAM,
    phase_SessionEnd = C.Phases.SESSION_END,
}

local SOUNDSCAPE_FEATURED_BUTTONS = {
    TR_Full = "soundscapeFeatured_TR_Full",
    TR_Intro = "soundscapeFeatured_TR_Intro",
    TR_Loop = "soundscapeFeatured_TR_Loop",
    STB_HouseOfTheRisingSun = "soundscapeFeatured_STB_HouseOfTheRisingSun",
}

--- @param siteKey string
--- @return boolean
local function siteHasBackgroundMusicPlaylist(siteKey)
    if type(siteKey) ~= "string" or siteKey == "" then
        return false
    end
    local site = C.Sites[siteKey]
    if type(site) ~= "table" then
        return false
    end
    local sc = site.soundscape
    if type(sc) ~= "table" then
        return false
    end
    local bg = sc.backgroundMusic
    return type(bg) == "table" and type(bg.playlist) == "string" and bg.playlist ~= ""
end

--- @param soundscapeState table
--- @return string
local function resolveSiteKeyForSoundPanel(soundscapeState)
    local sk = S.getStateVal("sessionScene", "siteKey")
    if type(sk) == "string" and sk ~= "" then
        return sk
    end
    if type(soundscapeState) == "table" and type(soundscapeState.lastAppliedSiteKey) == "string" then
        return soundscapeState.lastAppliedSiteKey
    end
    return ""
end

--- Sync radio-button visuals for storyteller admin lighting scene controls.
local function syncAdminLightSceneButtons()
    local currentScene = Scenes and Scenes.getCurrentScene and Scenes.getCurrentScene() or nil
    for sceneKey, buttonId in pairs(ADMIN_LIGHT_SCENE_BUTTONS) do
        local isActive = currentScene == sceneKey
        U.setAttributes(buttonId, {
            colors = isActive and ADMIN_LIGHT_SCENE_BUTTON_COLORS_ACTIVE or ADMIN_LIGHT_SCENE_BUTTON_COLORS_INACTIVE,
            textColor = "#FFFFFF",
            fontStyle = "Bold",
        })
    end
end

--- Highlights active storyteller phase button (`gameState.currentPhase` matches `C.Phases` values).
local function syncStorytellerPhaseButtons()
    local phase = S.getStateVal("currentPhase")
    for buttonId, expected in pairs(PHASE_BUTTON_EXPECTATIONS) do
        local match = phase == expected
        U.setAttributes(buttonId, {
            colors = match and STORYTELLER_SOUND_GREEN or STORYTELLER_SOUND_GREY,
            textColor = "#FFFFFF",
            fontStyle = "Bold",
        })
    end
end

--- Storyteller Sound panel: bind lane labels + sliders from `Soundscape.getPlayingLanesForUi`.
local function syncSoundscapeLaneUi()
    if SS == nil or SS.getPlayingLanesForUi == nil or UI == nil or UI.setAttribute == nil then
        return
    end
    local rows = SS.getPlayingLanesForUi()
    local duckHint = ""
    for _, row in ipairs(rows) do
        if row.isDucked == true and (row.id == "rain" or row.id == "wind") and duckHint == "" then
            duckHint = "Weather is ducked while Indoors is true (slider sets natural volume)."
        end
        local suffix = ""
        if row.active ~= true then
            suffix = " (inactive)"
        end
        local pct = math.floor(((tonumber(row.naturalVolume) or 0) * 100) + 0.5)
        local line = string.format("%s%s — %d%%", row.label, suffix, pct)
        if UI.setValue ~= nil then
            UI.setValue("soundscapeLaneLbl_" .. row.id, line)
        end
        if row.isDucked == true and (row.id == "rain" or row.id == "wind") then
            UI.setAttribute("soundscapeLaneLbl_" .. row.id, "color", "#CCCC66")
        else
            UI.setAttribute("soundscapeLaneLbl_" .. row.id, "color", "#DDDDDD")
        end
        UI.setAttribute("soundscapeSlider_" .. row.id, "value", tostring(tonumber(row.naturalVolume) or 0))
    end
    if UI.setValue ~= nil then
        UI.setValue("soundscapeDuckHint", duckHint)
    end
end

--- Storyteller admin: select one of the lighting scenes (dark/standard/bright).
function HUD_selectAdminLightingScene(player, button, id)
    local sceneName = string.gsub(id or "", "^adminScene_", "")
    if sceneName ~= "dark" and sceneName ~= "standard" and sceneName ~= "bright" then
        U.AlertGM("HUD_selectAdminLightingScene: Invalid scene id: " .. tostring(id))
        return
    end

    local presetMap = {
        dark = "AdminDark",
        standard = "AdminStandard",
        bright = "AdminBright",
    }
    local presetKey = presetMap[sceneName]
    -- State-first scene selection, then reconcile through the sync pipeline.
    S.setStateVal(sceneName, "currentScene")
    S.setStateVal(presetKey, "sessionScene", "lightingPresetKey")
    S.setStateVal(nil, "sceneTransition")
    if Sync and type(Sync.full) == "function" then
        Sync.full({ reason = "HUD_selectAdminLightingScene" })
    else
        UpdateUIDisplays({
            scene = true,
            adminLighting = true,
        })
    end
end

--- Sync Storyteller soundscape controls with current soundscape state.
local function syncSoundscapeControls()
    if SS == nil or SS.getState == nil then
        return
    end
    local state = SS.getState()
    local summary = SS.getSummaryText()
    if UI ~= nil and UI.setValue ~= nil then
        UI.setValue("soundscapeSummary", summary)
    end

    local moodPlaying = state.backgroundMusicEnabled == true and state.backgroundMusicMode == "mood"
    for moodKey, buttonId in pairs(SOUNDSCAPE_MOOD_BUTTONS) do
        local isActive = moodPlaying and state.musicMood == moodKey
        U.setAttributes(buttonId, {
            colors = isActive and STORYTELLER_SOUND_GREEN or STORYTELLER_SOUND_GREY,
            textColor = "#FFFFFF",
            fontStyle = "Bold",
        })
    end

    local siteKey = resolveSiteKeyForSoundPanel(state)
    local locAllowed = siteHasBackgroundMusicPlaylist(siteKey)
    local locPlaying = state.backgroundMusicEnabled == true and state.backgroundMusicMode == "locationMusic"
    U.setAttributes("soundscapeMood_location", {
        colors = not locAllowed and STORYTELLER_SOUND_DISABLED
            or (locPlaying and STORYTELLER_SOUND_GREEN or STORYTELLER_SOUND_GREY),
        textColor = "#FFFFFF",
        fontStyle = "Bold",
    })

    local feat = state.featuredMusic
    for trackKey, buttonId in pairs(SOUNDSCAPE_FEATURED_BUTTONS) do
        local on = state.featuredActive == true and feat == trackKey
        U.setAttributes(buttonId, {
            colors = on and STORYTELLER_SOUND_GREEN or STORYTELLER_SOUND_GREY,
            textColor = "#FFFFFF",
            fontStyle = "Bold",
        })
    end

    syncSoundscapeLaneUi()
end

--- Storyteller soundscape panel: switch background music mood.
-- @param player Player
-- @param button string
-- @param id string Button id in the form `soundscapeMood_<moodKey>`
function HUD_soundscapeSetMusicMood(player, button, id)
    local moodKey = string.gsub(id or "", "^soundscapeMood_", "")
    local ok, message = SS.setMusicMood(moodKey)
    if SS.commitEagerSteadyState ~= nil then
        SS.commitEagerSteadyState(ok)
    end
    if ok then
        U.AlertGM("Soundscape music mood: " .. tostring(moodKey))
    else
        U.AlertGM("Soundscape warning: " .. tostring(message))
    end
    syncSoundscapeControls()
end

--- Storyteller soundscape panel: stop all layers through the silent loop.
function HUD_soundscapeStopAll(player, button, id)
    local ok, message = SS.stopAll()
    if SS.commitEagerSteadyState ~= nil then
        SS.commitEagerSteadyState(ok)
    end
    if ok then
        U.AlertGM("Soundscape stopped.")
    else
        U.AlertGM("Soundscape warning: " .. tostring(message))
    end
    syncSoundscapeControls()
end

--- End-of-session: physically silence emitters before save (does not mutate gameState.soundscape).
function HUD_soundscapePrepareSave(player, button, id)
    if SS == nil or type(SS.prepareEmittersForSave) ~= "function" then
        U.AlertGM("Soundscape: prepare for save is unavailable.")
        return
    end
    local ok, msg = SS.prepareEmittersForSave()
    if ok then
        U.AlertGM("Emitters prepared for save (silent). " .. tostring(msg or ""))
    else
        U.AlertGM("Soundscape prepare: " .. tostring(msg or "unknown issue"))
    end
    syncSoundscapeControls()
end

--- Storyteller soundscape panel: inspect hidden emitters and print a JSON summary.
function HUD_soundscapeInspect(player, button, id)
    local rows = SS.inspectEmitters()
    print(JSON.encode_pretty(rows))
    U.AlertGM("Soundscape emitter inspection printed to console.")
    syncSoundscapeControls()
end

--- Storyteller Sound: switch background music to the active site's catalog playlist (`C.Sites[*].soundscape.backgroundMusic`).
function HUD_soundscapeSetBackgroundLocation(player, button, id)
    local state = SS.getState()
    local siteKey = resolveSiteKeyForSoundPanel(state)
    if not siteHasBackgroundMusicPlaylist(siteKey) then
        U.AlertGM("Location music is unavailable for this site. Pick a site with soundscape.backgroundMusic in Scenes.")
        syncSoundscapeControls()
        return
    end
    local site = C.Sites[siteKey]
    local sc = site.soundscape
    local bg = type(sc) == "table" and sc.backgroundMusic or nil
    local playlist = type(bg) == "table" and bg.playlist or nil
    if type(playlist) ~= "string" or playlist == "" then
        U.AlertGM("Site has no background music playlist.")
        syncSoundscapeControls()
        return
    end
    local ok, message = SS.setLocationMusic(playlist)
    if SS.commitEagerSteadyState ~= nil then
        SS.commitEagerSteadyState(ok)
    end
    if ok then
        U.AlertGM("Location background music: " .. tostring(playlist))
    else
        U.AlertGM("Soundscape: " .. tostring(message))
    end
    syncSoundscapeControls()
end

--- Storyteller Sound: featured catalog track (`soundscapeFeatured_<key>` ids).
function HUD_soundscapePlayFeatured(player, button, id)
    local trackKey = string.gsub(id or "", "^soundscapeFeatured_", "")
    local ok, message = SS.playFeaturedMusic(trackKey)
    if ok then
        U.AlertGM("Featured: " .. tostring(trackKey))
    else
        U.AlertGM("Soundscape: " .. tostring(message))
    end
    syncSoundscapeControls()
end

function HUD_soundscapeStopFeatured(player, button, id)
    local ok, message = SS.stopFeaturedMusic()
    if ok then
        U.AlertGM("Featured stopped; background context preserved.")
    else
        U.AlertGM("Soundscape: " .. tostring(message))
    end
    syncSoundscapeControls()
end

--- Storyteller Sound: volume sliders (`soundscapeSlider_<lane>` lane = music|location|featured|rain|wind).
function HUD_soundscapeLaneSlider(player, value, id)
    local lane = string.gsub(id or "", "^soundscapeSlider_", "")
    local volume01 = tonumber(value)
    if volume01 == nil then
        return
    end
    local ok, message = SS.setStorytellerLaneVolume(lane, volume01)
    if not ok then
        U.AlertGM(tostring(message))
    end
    syncSoundscapeControls()
end

--- Storyteller Scenes panel clicks (`scenes_tbl_*`, `scenes_seat_*`).
function HUD_scenesPanel(player, button, id)
    StorytellerScenesPanel.onHudClick(player, button, id)
end

function HUD_scenesClockFieldChanged(player, value, id)
    StorytellerScenesPanel.onClockInputChanged(player, value, id)
end

--- Legacy no-op; clock fields use `HUD_scenesClockFieldChanged` (`onValueChanged` / `onEndEdit`).
function HUD_scenesPanelInput(player, value, id)
    StorytellerScenesPanel.onClockInputChanged(player, value, id)
end

function HUD_scenesApplyLocation(player, button, id)
    StorytellerScenesPanel.applyLocationFromInputs(player)
    syncSoundscapeControls()
end

function HUD_scenesApplyClock(player, button, id)
    StorytellerScenesPanel.applyClockFromInputs(player)
    syncSoundscapeControls()
end

--- Overwrites `gameState.presentDayClock` from stashed clock field values (month + day/year/time inputs).
function HUD_scenesSetPresentDayClock(player, button, id)
