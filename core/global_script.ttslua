--[[
    Global script (canonical source). Tabletop Simulator loads .tts/objects/Global.lua, which
    only require()s this file. Edit here — not .tts/objects/Global.lua (that file may be overwritten on reload).

    Agent guidance (.dev/ documentation for this project):
    DEVELOPMENT_WORKFLOW.md, TESTING.md, TTS_BUNDLING_SETUP.md, DEBUG_FILE_LOGGING.md, TTS_MCP.md,
    HUD_FUNCTIONS.md, HUDs & Overlays/Player HUD Overview.md,
    NPC Object Spawning & Spotlighting/NPC Object Overview.md,
    AVAILABLE_FUNCTIONS.md, EXTRACTABLE_FUNCTIONS_INDEX.md,
    User Guides/TTS-3D-Positioning-Coordinate-Utilities.md,
    Rotational Coordinate Generator.md, Utility Function - RotateToFrom.md,
    utility-functions/More Robust Lerping with Eases.md, Game State Data.jsonc,
    Chronicle Data/ (NPC reference for data keys), custom-ui-assets/ (image manifest outputs),
    tts-api/ (in-repo TTS Scripting + UI API reference; start at tts-api/Getting Started/).
]]

-- Load shared utilities and constants
U = require("lib.util")
C = require("lib.constants")

-- Load core modules

S = require("core.state")
M = require("core.main")
Z = require("core.zones")
Scenes = require("core.scenes")
O = require("core.objects")
local UIH = require("lib.ui_helpers")
local HUDP = require("core.hud_player")
local HO = require("core.hud_overlays")
NPCS = require("core.npcs")
PCST = require("core.pc_storyteller_panel")

-- Load debug module (only in development). Must be global so TTS console `lua DEBUG.foo()` works.
DEBUG = require("core.debug")

-- Load Console++ integration (optional - enables external command support)
-- This allows external tools to send commands to the game via onExternalMessage
require("lib.console")

-- Initialize game state table
gameState = {}

--[[
    Load UI XML
    The UI XML uses TTS Tools bundling:
    - .tts/objects/Global.xml is a stub: <Include src="ui/Global.xml" /> (volatile; restore if TTS overwrites)
    - ui/Global.xml is the canonical root bundle for global UI XML
    - On "Save and Play", the extension bundles all Includes and sends to TTS
    - No hardcoded XML in Lua; the bundled XML comes from the extension
    - refreshLightDebugPanel() injects dynamic spotlight rows at <!-- LIGHT_TABLE_ROWS -->
]]

--[[
    onLoad - Called when the game loads or is reset
    @param saved_data - JSON string containing saved game state
]]
--- Resolve steam id for a character sheet seat color. Uses Global bundle `C` + `C.PlayerColors` so
--- object UI scripts do not depend on their embedded copy of `lib.constants` matching the game.
--- @param rawSeatColor string e.g. "PURPLE" or "Purple" from `CSHEET_PAGE_<n>_<COLOR>` object name
--- @return string|nil
function GlobalResolveSheetPlayerID(rawSeatColor)
    if type(rawSeatColor) ~= "string" or rawSeatColor == "" then
        return nil
    end
    local lr = string.lower(rawSeatColor)
    local canon = nil
    for _, col in ipairs(C.PlayerColors) do
        if string.lower(col) == lr then
            canon = col
            break
        end
    end
    if canon == nil then
        return nil
    end
    local ok, pid = pcall(function()
        return C.GetPlayerID(canon)
    end)
    if ok and type(pid) == "string" then
        return pid
    end
    return nil
end

--- @param playerID string Steam id (or key in C.PlayerData)
--- @return table|nil Merged row from `S.getPlayerData` — for object UI scripts; they have no `gameState`.
function GlobalGetMergedPlayerData(playerID)
    if type(playerID) ~= "string" then
        return nil
    end
    return S.getPlayerData(playerID)
end

--- Returns the phase string of a player's active roll, or nil if no roll is active.
-- Called by dice bag objects (via Global.call) so they know whether to spawn a die
-- or initiate a new roll when clicked.
-- @param params table  { color: string }
-- @return string|nil  e.g. "PRE_ROLL", "ROLLING", or nil
function GlobalGetRollPhase(params)
    if type(params) ~= "table" then return nil end
    local color = params.color
    if type(color) ~= "string" then return nil end
    local pid = S.getPlayerID(color)
    if pid == nil then return nil end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return nil end
    return active.phase
end

--- Called by a dice bag each time it spawns one die (via Global.call).
-- Updates RC.setPool with the latest count for that die type while preserving
-- the count reported by the other bag type.
-- @param params table  { color: string, dieType: "normal"|"hunger", count: number }
function GlobalReportBagDiceCount(params)
    if type(params) ~= "table" then return end
    local color   = params.color
    local dieType = params.dieType
    local count   = params.count
    if type(color) ~= "string" or type(dieType) ~= "string" or type(count) ~= "number" then
        return
    end
    if RC == nil then return end

    -- Read current pool so we only change the reported die type.
    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    local pool   = active.pool or { normal = 0, hunger = 0 }
    local normal = tonumber(pool.normal) or 0
    local hunger = tonumber(pool.hunger) or 0

    if dieType == "normal" then
        normal = count
    elseif dieType == "hunger" then
        hunger = count
    end

    RC.setPool(color, normal, hunger)
end

--- Resolves which logical die type a bag click should spawn (Auto-Hunger redirect, Hunger Dice off).
-- @param params table  { color: string, requested: "normal"|"hunger" }
-- @return string  "normal" or "hunger"
function GlobalRollSpawnDieRequest(params)
    if type(params) ~= "table" then return "normal" end
    local color     = params.color
    local requested = params.requested
    if type(color) ~= "string" or type(requested) ~= "string" then return requested end

    local pid = S.getPlayerID(color)
    if pid == nil then return requested end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil or active.phase ~= C.RollPhase.PRE_ROLL then return requested end

    local RO = require("lib.roll_options")

    if not RO.getForActive(active, RO.ROLL_HUNGER_DICE) then
        return "normal"
    end

    if RO.getPermanent(RO.PERM_AUTO_HUNGER) and requested == "normal" then
        local ch    = S.getPlayerVal(color, "hunger") or 0
        local poolH = (active.pool and active.pool.hunger) or 0
        if poolH < ch then
            return "hunger"
        end
    end

    return requested
end

--- Called by character sheet objects (via Global.call) to initiate a roll for their player.
-- Accepts either a direct rollType string, or a semantic trigger key that is resolved
-- to a roll type based on current game state (e.g. phase-dependent Remorse vs Humanity).
--
-- Trigger keys (params.trigger):
--   "humanity"  → C.RollType.HUMANITY_ROLL normally; C.RollType.REMORSE at end-of-session phase
--   "willpower" → C.RollType.WILLPOWER_ROLL
--   "rouse"     → C.RollType.ROUSE
--   "frenzy"    → C.RollType.FRENZY
-- (Extend this table as more sheet-interactive rolls are defined.)
--
-- @param params table  { color: string, rollType?: string, trigger?: string, label?: string }
-- @return boolean  true if the roll was initiated; false if blocked or invalid
function GlobalInitiateRoll(params)
    if type(params) ~= "table" then return false end
    if RC == nil then return false end

    local color = params.color
    if type(color) ~= "string" then return false end

    -- Resolve roll type: direct value takes precedence, then trigger mapping
    local rollType = params.rollType

    if rollType == nil and type(params.trigger) == "string" then
        local currentPhase = S.getStateVal("currentPhase")

        local triggerMap = {
            standard    = function() return C.RollType.STANDARD     end,
            simplecheck = function() return C.RollType.SIMPLE_CHECK end,
            humanity    = function()
                -- Remorse at end-of-session; Humanity Roll otherwise
                return (currentPhase == C.Phases.END)
                    and C.RollType.REMORSE
                    or  C.RollType.HUMANITY_ROLL
            end,
            willpower = function() return C.RollType.WILLPOWER_ROLL end,
            rouse     = function() return C.RollType.ROUSE           end,
            frenzy    = function() return C.RollType.FRENZY          end,
        }

        local resolver = triggerMap[params.trigger]
        if resolver ~= nil then
            rollType = resolver()
        else
            print(string.format(
                "[GlobalInitiateRoll] Unknown trigger key: '%s'", tostring(params.trigger)))
            return false
        end
    end

    if type(rollType) ~= "string" then
        print("[GlobalInitiateRoll] No rollType or trigger provided.")
        return false
    end

    -- Dice bags and character sheets call GlobalInitiateRoll — treat as player-initiated
    -- so the player panel is shown immediately with "Awaiting Storyteller..." feedback.
    return RC.initiateRoll(color, {
        rollType  = rollType,
        label     = params.label or "",
        initiator = params.initiator or "player",
    })
end

--- Shallow snapshot of character sheet tracker presentation (glyphs + optional sheet `image` ids).
--- Set from each `ui_csheet` object on load; drives Storyteller strip text via `lib.pc_stats` and sheet box art.
--- @param cfg table|nil with optional keys: `damageTrack`, `humanityTrack`, `sheetImages`
function GlobalRegisterTrackerDisplay(cfg)
    if type(cfg) ~= "table" then
        return
    end
    TRACKER_DISPLAY = {
        damageTrack = cfg.damageTrack,
        humanityTrack = cfg.humanityTrack,
        hungerTrack = cfg.hungerTrack,
        sheetImages = cfg.sheetImages,
    }
end

function onLoad(saved_data)
    print("--- VTM5E Module Loaded ---")

    -- Print host Steam ID for hardcoding into C.StorytellerID (lib/constants.ttslua)
    local host = U.getHost and U.getHost()
    if host and host.steam_id then
        print("Host Steam ID (use for C.StorytellerID in lib/constants.ttslua): " .. tostring(host.steam_id))
    end

    -- Clear all debug logs to start fresh for this session
    DEBUG.clearAllLogs()

    -- Initialize game state from saved data or defaults
    S.InitializeGameState(saved_data)

    -- Initialize zones module
    Z.onLoad()

    -- Initialize main module
    M.onLoad()

    -- Initialize scenes module (loads default or saved scene)
    Scenes.onLoad()

    -- NPC instances + `L.LIGHTMODES` registration for spawned spotlights, then single lighting pipeline
    NPCS.restoreAfterStateLoad()
    L.InitLights()
    Wait.time(function()
        L.InitLightsDeferred()
    end, 0.35)

    -- UI XML is set by TTS Tools extension from bundled .tts/objects/Global.xml
    -- Inject dynamic spotlight rows into the LIGHT_TABLE_ROWS placeholder
    LightDebug.refreshLightDebugPanel()

    -- Update UI displays with current state
    UpdateUIDisplays()

    -- Refresh all roll panels to match any persisted roll state (e.g. after save/reload mid-roll)
    if RUI then
        pcall(function() RUI.refreshAll() end)
    end

    -- NPC panel rows are not refreshed from `UpdateUIDisplays` (perf). After state restore, merge once if that panel is visible.
    Wait.time(function()
        if NPCS and NPCS.refreshStorytellerUIIfVisible then
            NPCS.refreshStorytellerUIIfVisible()
        end
    end, 0.15)

    -- Debug module help (optional - shows available test commands)
    -- DEBUG.help()

    print("Module initialization complete.")
end

--[[
    onSave - Called when the game is saved
    @return JSON string containing game state to save
]]
function onSave()
    -- Wrap in pcall to catch any errors during save
    -- This prevents the save system from crashing and repeating errors
    local success, result = pcall(function()
        if L ~= nil and L.cleanupLightsState ~= nil then
            L.cleanupLightsState()
        end
        -- Get save-safe state (whitelist approach - only includes explicitly listed fields)
        local state = S.getGameState(true)

        if state == nil then
            return ""  -- Return empty string if state is nil
        end

        if type(state) ~= "table" then
            print("WARNING: onSave() - state is not a table, type: " .. type(state))
            return ""
        end

        -- Dump complete gameState to file before save
        -- DEBUG.logStateToFile("BEFORE_SAVE")

        -- Debug: Inspect players structure before encoding
        if state.players then
            print("DEBUG onSave: Inspecting players structure...")
            print("DEBUG onSave: players type: " .. type(state.players))
            print("DEBUG onSave: players keys count: " .. (state.players and #U.getKeys(state.players) or 0))

            -- First, check what's actually in the raw gameState.players (before buildSaveState)
            print("DEBUG onSave: Checking RAW gameState.players structure...")
            local rawPlayers = S.getGameState(false).players
            if rawPlayers then
                print("DEBUG onSave: Raw players type: " .. type(rawPlayers))
                print("DEBUG onSave: Raw players has " .. #U.getKeys(rawPlayers) .. " keys")

                -- Check the "Red" entry specifically
                if rawPlayers["Red"] then
                    print("DEBUG onSave: Raw players['Red'] exists, type: " .. type(rawPlayers["Red"]))
                    if type(rawPlayers["Red"]) == "table" then
                        print("DEBUG onSave: Raw players['Red'] is a table with keys: " .. table.concat(U.getKeys(rawPlayers["Red"]), ", "))
                        -- Check for metatable
                        local mt = getmetatable(rawPlayers["Red"])
                        if mt then
                            print("DEBUG onSave: WARNING - players['Red'] has a metatable!")
                            for k, v in pairs(mt) do
                                print("DEBUG onSave:   metatable[" .. tostring(k) .. "] = " .. tostring(v) .. " (type: " .. type(v) .. ")")
                            end
                        end
                        -- Try to access each field individually
                        for key, val in pairs(rawPlayers["Red"]) do
                            local keyType = type(key)
                            local valType = type(val)
                            print("DEBUG onSave:   Raw Red[" .. tostring(key) .. "] (key type: " .. keyType .. ") = " .. tostring(val) .. " (type: " .. valType .. ")")
                        end
                    else
                        print("DEBUG onSave: Raw players['Red'] is NOT a table, it's: " .. type(rawPlayers["Red"]))
                    end
                end
            end

            -- Now check the sanitized version
            print("DEBUG onSave: Checking SANITIZED state.players structure...")
            for color, playerData in pairs(state.players) do
                print("DEBUG onSave: Player " .. tostring(color) .. " type: " .. type(playerData))
                if type(playerData) == "table" then
                    print("DEBUG onSave: Player " .. tostring(color) .. " keys: " .. table.concat(U.getKeys(playerData), ", "))
                    for key, val in pairs(playerData) do
                        local valType = type(val)
                        print("DEBUG onSave:   " .. tostring(key) .. " = " .. tostring(val) .. " (type: " .. valType .. ")")
                    end
                end
            end

            -- Try encoding just the "Red" entry to isolate the problem
            if state.players["Red"] then
                print("DEBUG onSave: Testing encoding of just 'Red' entry...")
                local redSuccess, redResult = pcall(function()
                    return JSON.encode({Red = state.players["Red"]})
                end)
                if not redSuccess then
                    print("ERROR: onSave() - Failed to encode just 'Red' entry: " .. tostring(redResult))
                else
                    print("DEBUG onSave: Successfully encoded 'Red' entry")
                end
            end
        end

        -- Encode the save-safe state
        local encoded = JSON.encode(state)
        if encoded == nil then
            print("WARNING: onSave() - JSON.encode returned nil")
            return ""
        end

        return encoded
    end)

    if success then
        return result or ""  -- Ensure we always return a string
    else
        -- Log error but don't crash - return empty string to allow save to continue
        print("ERROR in onSave(): " .. tostring(result))
        log({onSaveError = result, traceback = debug.traceback()})
        DEBUG.logToFile("ERROR", "onSave() failed: " .. tostring(result), "debug_log")
        return ""  -- Return empty string on error (TTS will save empty state)
    end
end

--[[
    Zone Activation/Deactivation Functions
    These functions are called by the zones module to enable/disable zone event handlers.
]]
function ActivateZones()
    onObjectEnterZone = Z.onObjectEnterZone
    onObjectLeaveZone = Z.onObjectLeaveZone
end

function DeactivateZones()
    ---@diagnostic disable-next-line: assign-type-mismatch
    onObjectEnterZone = nil  -- TTS allows nil to disable zone handlers
    ---@diagnostic disable-next-line: assign-type-mismatch
    onObjectLeaveZone = nil  -- TTS allows nil to disable zone handlers
end

--- When a figurine is dropped after dragging, refresh its paired NPC spotlight.
function onObjectDrop(playerColor, object)
    if object ~= nil and NPCS and NPCS.onObjectDropped then
        NPCS.onObjectDropped(object)
    end
end

--[[
    UI Event Handlers
    These functions are called by UI buttons via onClick attributes in the XML.
]]

--- Select storyteller panel (mutually exclusive: one panel open at a time)
-- Used by toggle buttons (toggle_lighting, toggle_scenes, etc.) in bottom-right bar
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "toggle_lighting")
function HUD_selectStorytellerPanel(player, button, id)
    local panelKey = string.gsub(id, "^toggle_", "")
    UIH.selectStorytellerPanel(panelKey)
    -- TTS applies UI.setAttribute asynchronously; deferred refresh merges rows after the panel is active in XML.
    if panelKey == "npcs" and NPCS and NPCS.refreshStorytellerUIDeferred then
        NPCS.refreshStorytellerUIDeferred()
    end
    if panelKey == "pcs" and PCST and PCST.refreshAllRows then
        Wait.frames(function()
            PCST.refreshAllRows()
        end, 1)
    end
end

--- Storyteller PCs panel control buttons (id pattern pcs_<Color>_<action>).
function HUD_pcPanel(player, button, id)
    if PCST and PCST.onHudClick then
        PCST.onHudClick(player, button, id)
    end
end

--- Toggle panel visibility (collapse/expand)
-- Used by toggle buttons (toggleElem_*) in the UI
-- @param player Player The player who clicked the button
-- @param button string Button value (typically "-1" for single click, "-2" for double click)
-- @param id string The UI element ID (e.g., "toggleElem_storytellerControls")
function HUD_togglePanel(player, button, id)
    -- Extract the element ID by removing "toggleElem_" prefix
    local elemID = string.gsub(id, "^toggleElem_", "")
    UIH.toggleXmlElement(elemID, button)
end

--- Change scene preset
-- Called when a scene button is clicked (e.g., "scene_elysium")
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "scene_elysium")
function HUD_changeScene(player, button, id)
    -- Extract scene name from ID (remove "scene_" prefix)
    local sceneName = string.gsub(id, "^scene_", "")

    -- Validate scene name
    local scene = Scenes.getScene(sceneName)
    if scene == nil then
        U.AlertGM("HUD_changeScene: Invalid scene name: " .. tostring(sceneName))
        return
    end

    -- Load scene with smooth transition (2 seconds)
    Scenes.fadeToScene(sceneName, 2.0)

    -- Update UI display
    UpdateUIDisplays()

    print("HUD: Scene changed to " .. sceneName .. " by " .. player.color)
end

local ADMIN_LIGHT_SCENE_BUTTONS = {
    dark = "adminScene_dark",
    standard = "adminScene_standard",
    bright = "adminScene_bright",
}

local ADMIN_LIGHT_SCENE_BUTTON_COLORS_INACTIVE = "#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
local ADMIN_LIGHT_SCENE_BUTTON_COLORS_ACTIVE = "#B8860B|#FFD700|#FFA500|#B8860B"

--- Sync radio-button visuals for storyteller admin lighting scene controls.
local function syncAdminLightSceneButtons()
    local currentScene = Scenes and Scenes.getCurrentScene and Scenes.getCurrentScene() or nil
    for sceneKey, buttonId in pairs(ADMIN_LIGHT_SCENE_BUTTONS) do
        local isActive = currentScene == sceneKey
        local ok, _ = pcall(function()
            UI.setAttribute(buttonId, "colors", isActive and ADMIN_LIGHT_SCENE_BUTTON_COLORS_ACTIVE or ADMIN_LIGHT_SCENE_BUTTON_COLORS_INACTIVE)
        end)
        if not ok then
            -- Buttons may not exist in some XML bundles; fail silently.
        end
    end
end

--- Storyteller admin: select one of the lighting scenes (dark/standard/bright).
function HUD_selectAdminLightingScene(player, button, id)
    local sceneName = string.gsub(id or "", "^adminScene_", "")
    if sceneName ~= "dark" and sceneName ~= "standard" and sceneName ~= "bright" then
        U.AlertGM("HUD_selectAdminLightingScene: Invalid scene id: " .. tostring(id))
        return
    end

    local success = Scenes.fadeToScene(sceneName, 0.5)
    if success then
        UpdateUIDisplays()
    end
end

--- Advance game phase
-- Called when a phase button is clicked (e.g., "phase_play")
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "phase_play")
function HUD_advancePhase(player, button, id)
    -- Extract phase name from ID (remove "phase_" prefix)
    local phaseName = string.gsub(id, "^phase_", "")

    -- Map UI button IDs to actual phase constants
    local phaseMap = {
        play = C.Phases.PLAY,
        combat = C.Phases.COMBAT,
        -- Add more phase mappings as needed
    }

    local targetPhase = phaseMap[phaseName]
    if targetPhase == nil then
        U.AlertGM("HUD_advancePhase: Invalid phase: " .. tostring(phaseName))
        return
    end

    -- Advance phase
    M.advancePhase(targetPhase)

    -- Update UI display
    UpdateUIDisplays()

    print("HUD: Phase advanced to " .. targetPhase .. " by " .. player.color)
end

--- Reset game state
-- Called when the "Reset Game" button is clicked
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_resetGame(player, button, id)
    if NPCS and NPCS.destroyAllWorldAndState then
        NPCS.destroyAllWorldAndState()
    end
    S.resetGameState()

    -- Reset modules
    Scenes.resetScene(0)  -- Instant reset

    -- Update UI
    UpdateUIDisplays()

    print("HUD: Game reset by " .. player.color)
    broadcastToAll("Game has been reset.", {1, 0, 0})
end

--- Save game state explicitly
-- Called when the "Save State" button is clicked
-- Note: TTS also calls onSave() automatically, but this can be used for explicit saves
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_saveState(player, button, id)
    -- Trigger save (onSave will be called by TTS)
    -- This is mainly for UI feedback
    local state = S.getGameState()
    local stateStr = JSON.encode(state)

    print("HUD: Game state saved by " .. player.color)
    broadcastToColor("Game state saved successfully.", player.color, {0, 1, 0})
end

--- Toggle zones active/inactive
-- Called when the "Toggle Zones" debug button is clicked
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_toggleZones(player, button, id)
    -- Check current zone state
    local zonesActive = S.getStateVal("zones", "allZonesLocked")

    if zonesActive == true then
        Z.activateZones()
        broadcastToColor("Zones activated.", player.color, {0, 1, 0})
    else
        Z.deactivateZones()
        broadcastToColor("Zones deactivated.", player.color, {1, 0, 0})
    end

    print("HUD: Zones toggled by " .. player.color)
end

--- Update a spotlight's Color, Range, Angle, Intensity from the light debug panel
-- Called when the "Update" button is clicked for a specific light row
-- @param player Player The player who clicked the button
-- @param value string The GUID of the light object (passed from onClick)
-- @param id string The UI element ID (e.g., "lightUpdate_4148ba")
function HUD_lightUpdate(player, value, id)
    local guid = value
    if type(guid) ~= "string" or guid == "" then
        broadcastToColor("Light Debug: Invalid GUID.", player.color, {1, 0, 0})
        return
    end
    local colorVal = UI.getValue("lightColor_" .. guid) or ""
    local rangeVal = UI.getValue("lightRange_" .. guid) or ""
    local angleVal = UI.getValue("lightAngle_" .. guid) or ""
    local intensityVal = UI.getValue("lightIntensity_" .. guid) or ""
    local success = LightDebug.applyLightUpdate(guid, colorVal, rangeVal, angleVal, intensityVal)
    if success then
        broadcastToColor("Light updated.", player.color, {0, 1, 0})
    else
        broadcastToColor("Light Debug: Failed to update light.", player.color, {1, 0, 0})
    end
end

--- Refresh the light debug panel (repopulate the spotlight list)
-- Called when the "Refresh" button is clicked; rescans all objects for spotlights
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "lightDebugRefresh")
function HUD_lightRefresh(player, button, id)
    LightDebug.refreshLightDebugPanel()
    broadcastToColor("Light debug panel refreshed.", player.color, {0, 1, 0})
end

--- Log current game state to console (debug function)
-- Called when the "Log State" debug button is clicked
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_logState(player, button, id)
    local state = S.getGameState()
    print("=== GAME STATE ===")
    print(JSON.encode_pretty(state))
    print("==================")
    broadcastToColor("Game state logged to console.", player.color, {0, 1, 1})
end

--- Pretty-print full game state to workspace file (same path as DEBUG.logStateToFile).
-- Writes **.dev/.debug/debug_logs/game_state.txt** when the tts-bridge listens on 39998 (overwrites each click). See .dev/DEBUG_FILE_LOGGING.md.
-- Called when the Storyteller left-panel "Print State" button is clicked.
-- @param player Player The player who clicked (Host/Black)
-- @param button string Button value
-- @param id string The UI element ID
function HUD_printState(player, button, id)
    if not DEBUG or type(DEBUG.logStateToFile) ~= "function" then
        broadcastToColor("Print State: DEBUG.logStateToFile missing.", player.color, {1, 0.5, 0})
        return
    end
    -- Delegates to core/debug.ttslua: JSON.encode_pretty + writeToFile (sendExternalMessage, format "auto")
    DEBUG.logStateToFile("game_state")
    broadcastToColor(
        "Game state written to .dev/.debug/debug_logs/game_state.txt (enable External Editor + bridge on 39998 if missing).",
        player.color,
        {0, 1, 1}
    )
end

--- Focused spotlight debug: read GUID from `dl_guid`, validate, show slider panel.
-- @param player Player
