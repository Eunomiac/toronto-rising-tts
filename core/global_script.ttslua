--- Park a roll die into the preload pool, or destroy overflow / unknown dice (TOR-308).
-- Must stay above every Global / local destroy path that formerly used bare destroyObject on dice.
-- @param die Object|nil
-- @return boolean true when parked
local function releaseDieToPreloadOrDestroy(die)
    local DPP = require("core.dice_preload_pool")
    return DPP.releaseOrDestroy(die)
end

--- Y at or above this counts as on-table for startup cleanup (matches RSL.hasLooseDiceOnTable / TOR-243).
local LOOSE_DICE_ON_TABLE_Y_MIN = -50

--- Stow trays and clear loose on-table d10 before startup SyncTable (TOR-307). Skips d10Preload (y < threshold).
local function cleanupLooseDiceBeforeTableSync()
    local pcTraysLowered = DiceDrawer.reconcileAllToOff({ instant = true })
    local stTraysRestored = STD.reconcileAllToWorkshopHome({ instant = true })
    local stowed = 0
    for _, color in ipairs(C.PlayerColors) do
        destroyBagDice(color)
        stowed = stowed + 1
    end
    destroyBagDice("Black")

    local swept = 0
    local tagged = getObjectsWithTag("d10") or {}
    for _, die in ipairs(tagged) do
        if die ~= nil and die.getPosition ~= nil then
            local p = die.getPosition()
            if type(p) == "table" and type(p.y) == "number" and p.y >= LOOSE_DICE_ON_TABLE_Y_MIN then
                releaseDieToPreloadOrDestroy(die)
                swept = swept + 1
            end
        end
    end
    if pcTraysLowered > 0 or stTraysRestored > 0 or swept > 0 then
        print(string.format(
            U.loadElapsedPrefix() .. "[Startup] loose-dice cleanup: lowered %d PC tray(s), restored %d ST drawer(s), swept %d on-table d10",
            pcTraysLowered,
            stTraysRestored,
            swept
        ))
    end
end

--- Opens the player dice tray when a roll enters PRE_ROLL (TOR-305). Storyteller uses Roll-click spawn path.
-- @param color string
function GlobalOpenPlayerDiceTrayForRoll(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then
        return
    end
    local color = params.color
    if color == "Black" then
        return
    end
    DiceDrawer.openForRoll(color)
end

--- Coupled roll physical prep for a PC seat: bag visibility, drawer, auto-spawn (staggered one frame).
-- Timing: player initiator at SETUP; storyteller initiator at PRE_ROLL (openRoll); locked Remorse at initiate.
-- @param params table  { color: string }
function GlobalResolveRollPhysicalPrep(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then
        return
    end
    local color = params.color
    if color == "Black" then
        return
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        return
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then
        return
    end
    DBV.reconcileForPlayer(color, active)
    GlobalOpenPlayerDiceTrayForRoll({ color = color })
    local pool = DK.normalizePool(active.pool)
    if DK.poolTotal(pool) > 0 then
        Wait.frames(function()
            GlobalSpawnActivePoolDiceForActive({ color = color })
        end, 1)
    end
end

