--- Seat camera preset during dice rolls (`roll`, `diceTray`, `default`). Safe no-op if unseated.
-- @param params table  { color: string, mode?: string }
function GlobalRollSeatCamera(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then return end
    -- Storyteller NPC rolls: no seat camera presets (ST stays on table view).
    if params.color == "Black" then
        return
    end
    local mode = type(params.mode) == "string" and params.mode or "roll"
    if M == nil or type(M.setCamera) ~= "function" then return end
    M.setCamera(params.color, mode)
end

