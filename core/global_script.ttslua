--- Writes district into pending library row or live sessionScene; Apply location still required when live.
function HUD_scenesPickDistrict(player, button, id)
    if not requireStorytellerForMutation(player, "HUD_scenesPickDistrict") then
        return
    end
    local key = string.match(id or "", "^scenes_pick_district_(.+)$")
    if type(key) ~= "string" or key == "" then
        U.AlertGM("Scenes: could not parse district picker control.")
        return
    end
    U.setAttribute("scenes_modal_districts_root", "active", "false")
    StorytellerScenesPanel.setLocationKeyFromPicker("district", key)
    StorytellerScenesPanel.applySiteModalDistrictVisibility()
    U.setAttribute("scenes_modal_sites_root", "active", "true")
    U.AlertGM("District set: " .. key .. " — pick a site, then Apply location + soundscape when ready.")
end

