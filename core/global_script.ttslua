--[[
    Sidebar reference popup handlers
    Called by storyteller sidebar Image buttons: onMouseDown/Up/Enter/Exit.
    id is the button element id (e.g. hudRefBattlegroundsHost); popup id is "Ref..." (strip "hud").
]]

--- Show reference popup for sidebar button. Right-click (value "-2") keeps it open via ON state.
function HUD_show(player, value, id)
    local imageID = string.gsub(id, "hud", "")
    -- If already toggled ON (right-click pin), turn off and return
    if UI.getValue(id) == "ON" then
        UI.setValue(id, "")
        UI.hide(imageID)
        U.setAttribute(id .. "Overlay", "color", "clear")
        return
    end
    -- Right-click: mark as ON so HUD_hide does not close the popup
    if value == "-2" then
        UI.setValue(id, "ON")
    end
    UI.show(imageID)
end

--- Hide reference popup on mouse up unless it was right-click pinned (ON).
function HUD_hide(player, value, id)
    if UI.getValue(id) ~= "ON" then
        UI.hide(string.gsub(id, "hud", ""))
    end
end

--- Hover highlight: set overlay to white.
function HUD_highlight(player, value, id)
    local overlayID = id .. "Overlay"
    U.setAttribute(overlayID, "color", "#FFFFFF")
end

--- Hover end: dim overlay back to clear unless popup is pinned ON.
function HUD_dim(player, value, id)
    if UI.getValue(id) ~= "ON" then
        local overlayID = id .. "Overlay"
        U.setAttribute(overlayID, "color", "clear")
    end
end

--[[
    UI Display Update Functions
    These functions update UI elements to reflect current game state.
]]

local UI_DISPLAY_CACHE = {
    phase = nil,
    scene = nil,
    values = {},
}

--- @param elementId string
--- @param value string
local function setValueCached(elementId, value)
    local nextVal = tostring(value)
    if UI_DISPLAY_CACHE.values[elementId] == nextVal then
        return
    end
    UI.setValue(elementId, nextVal)
    UI_DISPLAY_CACHE.values[elementId] = nextVal
end

--- Updates all UI displays with current game state.
-- Called after state changes (phase, scene, etc.)
-- Exposed globally for testing/debugging.
-- Optional `delta` flags allow targeted refreshes:
--   phase, scene, adminLighting, soundscape, playerStats, playerHud, overlays, pcstRows, pcstSheets, gameStateOverlay
-- Optional `delta.colors` — array of seat color strings; when set, `playerStats` / `playerHud` loop only those seats.
-- When omitted, all sections refresh (legacy behavior).
-- @param delta table|nil
function UpdateUIDisplays(delta)
    local refreshAll = (type(delta) ~= "table")
    local function wants(key)
        return refreshAll or delta[key] == true
    end

    --- @param seatColor string
    --- @return boolean
    local function wantsSeatColor(seatColor)
        if refreshAll or type(delta) ~= "table" then
            return true
        end
        local colors = delta.colors
        if type(colors) ~= "table" or #colors == 0 then
            return true
        end
        for _, c in ipairs(colors) do
            if c == seatColor then
                return true
            end
        end
        return false
    end

    if wants("phase") then
        local currentPhase = S.getStateVal("currentPhase")
        if currentPhase ~= nil and UI_DISPLAY_CACHE.phase ~= currentPhase then
            setValueCached("currentPhaseDisplay", currentPhase)
            UI_DISPLAY_CACHE.phase = currentPhase
        end
        syncStorytellerPhaseButtons()
    end

    if wants("scene") then
        local currentScene = Scenes.getCurrentScene()
        if currentScene ~= nil and UI_DISPLAY_CACHE.scene ~= currentScene then
            setValueCached("currentSceneDisplay", currentScene)
            UI_DISPLAY_CACHE.scene = currentScene
        end
    end

    if wants("adminLighting") then
        syncAdminLightSceneButtons()
    end
    if wants("scenesPanel") then
        if StorytellerScenesPanel and StorytellerScenesPanel.refresh then
            StorytellerScenesPanel.refresh()
        end
        syncAdminLightSceneButtons()
    end
    if wants("soundscape") then
        syncSoundscapeControls()
    end

    if wants("playerStats") or wants("playerHud") then
        M.forPlayers(function(player, color)
            if not wantsSeatColor(color) then
                return
            end
            local pid = S.getPlayerID(player) or S.getPlayerID(color)
            local hunger = pid and S.getPlayerVal(color, "hunger") or 0
            local willpower = 5
            local health = 7
            if pid then
                local ES = require("lib.effective_stats")
                local ctx = ES.forPlayer(pid)
                willpower = ctx.trackerMax("willpower")
                health = ctx.trackerMax("health")
            end

            if wants("playerStats") then
                setValueCached("hungerVal_" .. color, tostring(hunger))
                setValueCached("willpowerVal_" .. color, tostring(willpower))
                setValueCached("healthVal_" .. color, tostring(health))
            end

            if wants("playerHud") then
                -- Player HUD (Right Sidebar + Core/Reference visibility)
                HUDP.updatePlayerUI(player, color)
            end
        end)
        if wants("playerHud") and type(HUDP.afterPlayerHudBatch) == "function" then
            HUDP.afterPlayerHudBatch()
        end
    end

    if wants("overlays") then
        HO.syncAll()
    end

    -- NPC storyteller panel: do not refresh here. `UpdateUIDisplays` runs on phase/scene/etc.;
    -- NPC panel updates are triggered by NPC changes and when the NPC tab is opened
    -- (`HUD_selectStorytellerPanel` → deferred refresh).

    if wants("pcstRows") and PCST and PCST.refreshAllRows then
        PCST.refreshAllRows()
    end

    if wants("pcstSheets") and PCST and PCST.refreshAllCharacterSheets then
        PCST.refreshAllCharacterSheets()
    end

    if refreshAll or wants("gameStateOverlay") or wants("phase") or wants("scenesPanel") then
        if GameStateOverlay and type(GameStateOverlay.reconcileFromState) == "function" then
            GameStateOverlay.reconcileFromState()
        end
    end
end

--- Resolve UI element id for NPC panel controls (onClick / mouse handlers).
--- TTS sometimes passes the element id in `value` instead of `id`.
--- @param value any
--- @param id any
--- @return string|nil
local function resolveNpcPanelRouteId(value, id)
    if type(id) == "string" and id ~= "" then
        return id
    end
    if type(value) == "string" and string.match(value, "^npc_") then
        return value
    end
    return nil
end

--- Routed NPC panel button clicks (stable ids generated in panel_npcs.xml).
--- TTS passes (player, value, id); value is mouse button string for Button (e.g. "-1").
function HUD_npcDispatch(player, value, id)
    local routeId = resolveNpcPanelRouteId(value, id)
    if NPCS and NPCS.dispatchNpcUiClick then
        NPCS.dispatchNpcUiClick(routeId)
    end
end

--- Hold-to-spotlight: mouse down on ◎ control.
function HUD_npcSpotDown(player, value, id)
    local routeId = resolveNpcPanelRouteId(value, id)
    if NPCS and NPCS.dispatchNpcSpotDown and routeId then
        NPCS.dispatchNpcSpotDown(routeId)
    end
end

--- Hold-to-spotlight: mouse up on ◎ control.
function HUD_npcSpotUp(player, value, id)
    local routeId = resolveNpcPanelRouteId(value, id)
    if NPCS and NPCS.dispatchNpcSpotUp and routeId then
        NPCS.dispatchNpcSpotUp(routeId)
    end
end

-- Load additional modules that need global exposure (after handlers; onLoad runs later so L exists)
L = require("core.lighting")
R = require("lib.rotational-seat-layout")
LightDebug = require("core.light_debug")
LightDebugFocus = require("core.light_debug_focus")
CameraDebugFocus = require("core.camera_debug_focus")

-- ============================================================================
-- DICE SYSTEM MODULES
-- Loaded last so they can reference G (guids) and S (state) safely.
-- RC and RUI are global so TTS UI onClick handlers can call them directly.
-- ============================================================================
RC  = require("core.roll_controller")
RUI = require("core.roll_ui")
local pendingRollCleanup = {}
local pendingRollCleanupTimerIds = {}

--- Stops a scheduled post-broadcast dice cleanup for a seat (if any).
-- @param color string
local function cancelPendingRollCleanup(color)
    if type(color) ~= "string" then
        return
    end
    local timerId = pendingRollCleanupTimerIds[color]
    if timerId ~= nil then
        U.stopDelay(timerId)
    end
    pendingRollCleanup[color] = nil
    pendingRollCleanupTimerIds[color] = nil
end

-- Wire RC callback hooks so roll state changes automatically refresh UI.
-- No pcall here: errors in the UI layer should surface as TTS chat errors
-- rather than being silently swallowed, making bugs easier to diagnose.
RC.onRollStateChanged = function(color)
    if type(color) == "string" and color ~= "Black" then
        local pid = S.getPlayerID(color)
        local active = pid ~= nil
            and S.getStateVal("playerData", pid, "hud", "rollData", "active")
            or nil
        DBV.reconcileForPlayer(color, active)
    end
    RUI.refreshPlayerRollPanel(color)
    RUI.refreshSTDashboard()
    if color == "Black" then
        local STR = require("core.storyteller_rolls")
        STR.onRollStateChanged()
    end
end

RC.onRollCamera = function(color, modeName)
    if type(color) == "string" and type(modeName) == "string" then
        GlobalRollSeatCamera({ color = color, mode = modeName })
    end
end

RC.onRollResolved = function(color, result, label)
    GlobalRollSeatCamera({ color = color, mode = "default" })
    RUI.showResultBroadcast(color, result, label)
    -- Storyteller rolls stay on the table until the ST cancels the slot manually.
    if color == "Black" then
        return
    end
    -- Drawer stays open until the broadcast hides and dice are destroyed (see below).
    local existingTimerId = pendingRollCleanupTimerIds[color]
    if existingTimerId ~= nil then
        U.stopDelay(existingTimerId)
    end

    pendingRollCleanup[color] = true
    pendingRollCleanupTimerIds[color] = U.delay(function()
        pendingRollCleanup[color] = nil
        pendingRollCleanupTimerIds[color] = nil
        destroyBagDice(color)
    end, C.ROLL_RESULT_BROADCAST_SECONDS)
end

--- Handles dice-bag clicks during post-resolution broadcast cleanup delay.
-- If a cleanup is pending, consume it and close the drawer immediately.
-- @param params table  { color: string }
-- @return boolean  true if pending cleanup was consumed
function GlobalConsumePendingRollCleanup(params)
    if type(params) ~= "table" then return false end
    local color = params.color
    if type(color) ~= "string" then return false end

    if pendingRollCleanup[color] ~= true then
        return false
    end

    local timerId = pendingRollCleanupTimerIds[color]
    if timerId ~= nil then
        U.stopDelay(timerId)
    end
    pendingRollCleanup[color] = nil
    pendingRollCleanupTimerIds[color] = nil
    destroyBagDice(color)
    return true
end

-- ============================================================================
-- PHYSICAL DICE INTEGRATION
-- Dice are pre-tagged in TTS at authoring time:
--   "NormalDie" or "HungerDie"   — die type
--   "<Color>Object"               — owner color (e.g. "BrownObject")
-- When a die spawns from a bag, onObjectLeaveContainer writes the active roll
-- ID to obj.setGMNotes() so RC._getDiceForRoll can identify which dice belong
-- to which roll (relevant for Extended rolls / queued Rouse checks).
-- onObjectRandomize resets the debounce timer in ROLLING and POST_ROLL phases;
-- the eventual U.delay fires RC.onDiceSettled → RC.recalculate (live read).
-- ============================================================================

--- Extracts the owner color from an object's tag list.
-- Returns nil if no "<Color>Object" tag is found.
-- @param tags table  Array of tag strings from obj.getTags()
-- @return string|nil  Player seat color (e.g. "Red")
local function colorFromTags(tags)
    local owner = DK.ownerFromTags(tags, C.PlayerColors)
    if owner == "storyteller" then
        return "Black"
    end
    return owner
end

--- True if this object is one of our d10 dice (any registered die kind).
local function isDieTag(tags)
    return DK.isDieObjectTags(tags)
end

--- Called by TTS when any object is randomized (die rolled, deck shuffled, etc.).
-- Only responds to dice in ROLLING or POST_ROLL phases (identified by tags).
-- Resets the debounce timer; does NOT accumulate die values.
-- @param obj        Object  The randomized TTS object
-- @param playerColor string  TTS seat color of the player who rolled (may be "")
function onObjectRandomize(obj, playerColor)
    if obj == nil then return end
    -- TOR-197: O(1) gate — all module dice carry tag `d10`; decks/shuffles exit here.
    if obj.hasTag == nil or obj.hasTag("d10") ~= true then
        return
    end
    if RC == nil then return end

    local tags = obj.getTags()
    if type(tags) ~= "table" then return end

    -- Only handle dice objects (see isDieTag); exclude bags/decks.
    if not isDieTag(tags) then return end
    if RC.isPhysicalDieRandomizeEvent(obj) ~= true then
        return
    end

    -- Resolve owner color from die's own tags (<Color>Object)
    local color = colorFromTags(tags)
    if color == nil then return end

    -- Clear this player's area selection when a roll-phase die is randomized (e.g. R key).
    -- Otherwise box-selected dice stay selected and the next "R" rolls the entire pool.
    local pid = S.getPlayerID(color)
    if pid ~= nil then
        local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
        if active ~= nil
            and (active.phase == C.RollPhase.ROLLING or active.phase == C.RollPhase.POST_ROLL)
        then
            local clearSeat = (type(playerColor) == "string" and playerColor ~= "") and playerColor or color
            local p = Player[clearSeat]
            if p ~= nil then
                p.clearSelectedObjects()
            end
        end
    end

    -- Willpower reroll wave: per-die tray locks (before table-wide debounce).
    if RC.onWpRerollDieRandomized ~= nil then
        RC.onWpRerollDieRandomized(color, obj)
    end

    -- Delegate debounce reset to roll controller
    RC.onDieSettledSignal(color)
end

--- Called by TTS when any object leaves a container (bag, deck, etc.).
-- When a die is spawned from a dice bag during an active roll, writes the
-- current roll ID to the die's GM Notes. This is the only dynamic tagging step;
-- type and color tags are already baked into the die by the bag setup.
-- @param container Object  The container the object left
-- @param obj       Object  The object that was taken out
function onObjectLeaveContainer(container, obj)
    if obj == nil then return end
    -- TOR-197: O(1) gate — only module dice leave bags with tag `d10`.
    if obj.hasTag == nil or obj.hasTag("d10") ~= true then
        return
    end
    if RC == nil then return end

    local tags = obj.getTags()
    if type(tags) ~= "table" then return end

    -- Only process dice objects
    if not isDieTag(tags) then return end

    -- Identify the owner color from the die's tags
    local color = colorFromTags(tags)
    if color == nil then return end

    -- Get the active roll for this player
    local pid    = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end

    -- Write the roll ID to GM Notes so RC._getDiceForRoll can identify this die.
    -- Dice are spawned during PRE_ROLL (pool assembly) and released in ROLLING,
    -- so the tag must be written at leave-container time regardless of phase.
    -- The roll ID is fixed from initiation, so writing it early is always correct.
    -- Skip only if the roll is already RESOLVED (die is unrelated to any active roll).
    if active.phase == C.RollPhase.RESOLVED then return end
    local isSurgeRouse = obj.script_state == DK.SCRIPT_STATE_BLOOD_SURGE_ROUSE
    obj.setGMNotes(DK.encodeGmNotes(active.id, isSurgeRouse))

    -- Open drawer on first bag spawn (PRE_ROLL) or auto-spawn after Roll (ROLLING).
    if active.phase == C.RollPhase.PRE_ROLL or active.phase == C.RollPhase.ROLLING then
        if color == "Black" and type(active.stDrawerSlot) == "number" then
            local STR = require("core.storyteller_rolls")
            STR.onFirstDieSpawned()
        else
            DiceDrawer.openForRoll(color)
        end
    end
end

-- ============================================================================
-- DICE BAG HELPERS
-- Call releaseDice() / destroyDice() on a player's dice bags by GUID.

--- World Y threshold for locked staged dice on the bag arc (`objects/dice_bag` STAGING_WORLD_Y = 8).
local STAGED_DICE_MIN_Y = 7

--- True when a die is still locked on the PRE_ROLL staging arc (not released to the tray).
-- @param obj Object
-- @return boolean
local function isStagedHoverDie(obj)
    if obj == nil or obj.isLocked == nil then
        return false
    end
    if obj.isLocked() ~= true then
        return false
    end
    local pos = obj.getPosition()
    return type(pos) == "table" and type(pos.y) == "number" and pos.y >= STAGED_DICE_MIN_Y
end

--- Destroy locked hover dice for one seat/kind when the bag script is missing or broken.
-- @param color string
-- @param dieKind string  DK.KIND_*
-- @return number destroyed
local function destroyStagedHoverDiceForKind(color, dieKind)
    if type(color) ~= "string" or type(dieKind) ~= "string" then
        return 0
    end
    local dieTag = DK.kindToTag(dieKind)
    if dieTag == nil then
        return 0
    end
    local ownerTag = color .. "Object"
    local destroyed = 0
    for _, obj in ipairs(getObjectsWithAllTags({ dieTag, "d10", ownerTag })) do
        if isStagedHoverDie(obj) then
            destroyObject(obj)
            destroyed = destroyed + 1
        end
    end
    return destroyed
end

--- True when the object's bundled Lua defines a global function (healthy dice_bag stub).
-- @param bag Object
-- @param funcName string
-- @return boolean
local function bagLuaScriptHasFunction(bag, funcName)
    if bag == nil or type(funcName) ~= "string" or bag.getLuaScript == nil then
        return false
    end
    local script = bag.getLuaScript()
    if type(script) ~= "string" then
        return false
    end
    return string.find(script, "function " .. funcName, 1, true) ~= nil
end

local PLAYER_BAG_KIND_TO_DK = {
    normal = DK.KIND_NORMAL,
    hunger = DK.KIND_HUNGER,
    rouse = DK.KIND_ROUSE,
    oblivRouse = DK.KIND_OBLIV_ROUSE,
}

--- Destroys staged dice on one bag; falls back to tag scan when save script drifted.
-- @param color string
-- @param bagKind string  key from GetAllPlayerDiceBagGUIDs
-- @param guid string
local function destroyBagStagedDiceAtGuid(color, bagKind, guid)
    local bag = getObjectFromGUID(guid)
    if bag == nil then
        return
    end
    if bagLuaScriptHasFunction(bag, "destroyDice") then
        bag.call("destroyDice")
        return
    end
    local dieKind = PLAYER_BAG_KIND_TO_DK[bagKind]
    if type(dieKind) ~= "string" then
        return
    end
    local n = destroyStagedHoverDiceForKind(color, dieKind)
    if n > 0 then
        print(string.format(
            "[Roll] destroyBagDice: bag %s (%s) missing destroyDice — removed %d staged die(s) via Global fallback",
            tostring(guid), tostring(bagKind), n))
    end
end

--- Calls a named function on all of a player's dice bags.
-- @param color    string  Player seat color
-- @param funcName string  "releaseDice", "destroyDice", etc.
function callBagFunction(color, funcName)
    if funcName == "destroyDice" then
        local bags = G.GetAllPlayerDiceBagGUIDs(color)
        for bagKind, guid in pairs(bags) do
            if type(guid) == "string" then
                destroyBagStagedDiceAtGuid(color, bagKind, guid)
            end
        end
        return
    end
    local bags = G.GetAllPlayerDiceBagGUIDs(color)
    for _, guid in pairs(bags) do
        if type(guid) == "string" then
            local bag = getObjectFromGUID(guid)
            if bag ~= nil then
                bag.call(funcName)
            end
        end
    end
end

--- Per-seat bag kinds not in every layout (no console warning when GUID is absent).
local OPTIONAL_PLAYER_BAG_KINDS = {
    oblivRouse = true,
}

--- Returns the number of dice currently hovering in one of a player's bags.
-- @param color string  Player seat color
-- @param dieTypeName string  "normal"|"hunger"|"rouse"|"oblivRouse"
-- @return number
local function getBagSpawnedCount(color, dieTypeName)
    local guid = nil
    if dieTypeName == "hunger" then guid = G.GetDiceHungerGUID(color)
    elseif dieTypeName == "normal" then guid = G.GetDiceNormalGUID(color)
    elseif dieTypeName == "rouse" then guid = G.GetDiceRouseGUID(color)
    elseif dieTypeName == "oblivRouse" then guid = G.GetDiceOblivRouseGUID(color)
    else guid = G.GetDiceNormalGUID(color)
    end
    if type(guid) ~= "string" then
        if OPTIONAL_PLAYER_BAG_KINDS[dieTypeName] ~= true then
            print(string.format(
                "[Roll] getBagSpawnedCount: no %s bag GUID for seat %s (layout or Save & Play stale?)",
                tostring(dieTypeName), tostring(color)))
        end
        return 0
    end
    local bag = getObjectFromGUID(guid)
    if bag == nil then
        print(string.format(
            "[Roll] getBagSpawnedCount: bag object missing for %s %s (GUID %s)",
            tostring(color), tostring(dieTypeName), tostring(guid)))
        return 0
    end
    local result = nil
    if dieTypeName == "rouse" then
        result = bag.call("getManualRouseSpawnedCount")
    end
    if type(result) ~= "number" then
        result = bag.call("getSpawnedCount")
    end
    if type(result) ~= "number" then
        error("getBagSpawnedCount: getSpawnedCount returned non-number for GUID '" .. tostring(guid) .. "'")
    end
    return result
end

--- Spawned count for a Storyteller bag by logical kind.
-- @param dieTypeName string
-- @return number
local function getBagSpawnedCountStoryteller(dieTypeName)
    local guid = G.GetDiceStorytellerBagGUID(dieTypeName)
    if type(guid) ~= "string" then
        return 0
    end
    local bag = getObjectFromGUID(guid)
    if bag == nil then
        return 0
    end
    local result = bag.call("getSpawnedCount")
    if type(result) ~= "number" then
        return 0
    end
    return result
end

--- Auto-spawns missing pool dice for Black (Storyteller bags).
-- @param pool table
-- @return boolean true if any autoSpawn ran
local function autoSpawnBlackPool(pool)
    local didAutoSpawn = false
    local spawnPlan = {
        { "normal", pool.normal },
        { "hunger", pool.hunger },
        { "rouse", pool.rouse },
        { "oblivRouse", pool.oblivRouse },
        { "werewolf", pool.werewolf },
        { "rage", pool.rage },
    }
    for _, entry in ipairs(spawnPlan) do
        local kind = entry[1]
        local target = entry[2] or 0
        local needed = target - getBagSpawnedCountStoryteller(kind)
        if needed > 0 then
            local guid = G.GetDiceStorytellerBagGUID(kind)
            if type(guid) == "string" then
                local bag = getObjectFromGUID(guid)
                if bag ~= nil then
                    bag.call("autoSpawn", { count = needed })
                    didAutoSpawn = true
                end
            end
        end
    end
    return didAutoSpawn
end

--- Bag GUID lookup for player pool auto-spawn by logical kind name.
-- @param color string
-- @param kindName string  "normal"|"hunger"|"rouse"|"oblivRouse"
-- @return string|nil
local function playerBagGuidForPoolKind(color, kindName)
    if kindName == "normal" then
        return G.GetDiceNormalGUID(color)
    end
    if kindName == "hunger" then
        return G.GetDiceHungerGUID(color)
    end
    if kindName == "rouse" then
        return G.GetDiceRouseGUID(color)
    end
    if kindName == "oblivRouse" then
        return G.GetDiceOblivRouseGUID(color)
    end
    return nil
end

--- Auto-spawns missing pool dice on player bags (standard / extended pools).
-- @param color string
-- @return boolean true if any bag autoSpawn ran
local function spawnMissingPoolDiceForColor(color)
    if type(color) ~= "string" or color == "Black" then
        return false
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        return false
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil or active.pool == nil then
        return false
    end
    if active.phase ~= C.RollPhase.PRE_ROLL and active.phase ~= C.RollPhase.SETUP then
        return false
    end
    local pool = DK.normalizePool(active.pool)
    local didAutoSpawn = false
    local spawnPlan = {
        { "normal", pool.normal },
        { "hunger", pool.hunger },
        { "rouse", pool.rouse },
        { "oblivRouse", pool.oblivRouse },
    }
    for _, entry in ipairs(spawnPlan) do
        local kindName = entry[1]
        local target = entry[2] or 0
        local needed = target - getBagSpawnedCount(color, kindName)
        if needed > 0 then
            local guid = playerBagGuidForPoolKind(color, kindName)
            if type(guid) == "string" then
                local bag = getObjectFromGUID(guid)
                if bag ~= nil then
                    bag.call("autoSpawn", { count = needed })
                    bag.call("repositionStagedDice")
                    bag.call("ensureRollTagsOnStagedDice")
                    didAutoSpawn = true
                end
            end
        end
    end
    return didAutoSpawn
end

--- Spawns staged dice to match active.pool in PRE_ROLL (all roll types).
-- Player seats: spawn only missing dice per bag (target − staged). Same path for dedicated
-- Rouse/Oblivion/Simple Check and compound Standard rolls — rollType must not fork spawn logic.
-- Storyteller (Black): autoSpawnBlackPool with the same target − staged rule per kind.
-- @param color string
-- @return boolean true if any dice were auto-spawned
local function spawnActivePoolDiceForActive(color)
    if type(color) ~= "string" then
        return false
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        return false
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then
        return false
    end
    if active.phase ~= C.RollPhase.PRE_ROLL and active.phase ~= C.RollPhase.SETUP then
        return false
    end
    if color == "Black" then
        return autoSpawnBlackPool(DK.normalizePool(active.pool))
    end
    DBV.reconcileForPlayer(color, active)
    return spawnMissingPoolDiceForColor(color)
end

--- Global.call entry: spawn active pool dice for SETUP / PRE_ROLL (player + ST bags).
-- @param params table  { color: string }
-- @return boolean|nil  true if any auto-spawn ran
function GlobalSpawnActivePoolDiceForActive(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then
        return false
    end
    return spawnActivePoolDiceForActive(params.color)
end

local DRAWER_RELEASE_MIN_Y = 2.5
--- FIFO jobs for `GlobalWaitDrawerThenReleaseBagDice` (one coroutine per enqueue; local `job` per run).
local drawerReleaseJobQueue = {}

--- Unlocks staged bag dice for one seat (drawer must already be opening or open).
-- @param color string
local function unlockStagedBagDice(color)
    if color == "Black" then
        local pid = S.getPlayerID(color)
        if pid ~= nil then
            local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
            if type(active) == "table" and type(active.stDrawerSlot) == "number" then
                local STR = require("core.storyteller_rolls")
                STR.onFirstDieSpawned()
            end
        end
        local bags = G.GetAllStorytellerDiceBagGUIDs()
        for _, guid in pairs(bags) do
            if type(guid) == "string" then
                local bag = getObjectFromGUID(guid)
                if bag ~= nil then bag.call("releaseDice") end
            end
        end
        return
    end
    callBagFunction(color, "ensureRollTagsOnStagedDice")
    callBagFunction(color, "releaseDice")
end

--- Coroutine: wait until dice drawer is raised, then unlock staged dice.
function GlobalWaitDrawerThenReleaseBagDice()
    local job = table.remove(drawerReleaseJobQueue, 1)
    if type(job) ~= "table" or type(job.color) ~= "string" then
        return 1
    end
    U.waitUntil(function()
        unlockStagedBagDice(job.color)
        if type(job.onComplete) == "function" then
            job.onComplete()
        end
    end, function()
        local y = DiceDrawer.getPositionY(job.color)
        return type(y) == "number" and y > DRAWER_RELEASE_MIN_Y
    end, false, 10)
    return 1
end

--- Opens drawer if needed, waits until y > 2.5, then unlocks staged dice.
-- @param color string
-- @param onComplete function|nil  optional callback after dice are released
local function releaseBagDice(color, onComplete)
    if color == "Black" then
        unlockStagedBagDice(color)
        if type(onComplete) == "function" then
            onComplete()
        end
        return
    end
    DiceDrawer.openForRoll(color)
    local y = DiceDrawer.getPositionY(color)
    if type(y) == "number" and y > DRAWER_RELEASE_MIN_Y then
        unlockStagedBagDice(color)
        if type(onComplete) == "function" then
            onComplete()
        end
        return
    end
    drawerReleaseJobQueue[#drawerReleaseJobQueue + 1] = { color = color, onComplete = onComplete }
    startLuaCoroutine(Global, "GlobalWaitDrawerThenReleaseBagDice")
end

--- Global.call entry: unlock staged bag dice (PRE_ROLL → ROLLING), same as panel Roll.
-- @param params table  { color: string }
function GlobalReleaseBagDice(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then
        return false
    end
    releaseBagDice(params.color)
    return true
end

--- Destroys normal/hunger staged bag dice and table dice for a roll (keeps Rouse kinds).
-- @param params table  { color: string, rollId: string }
function GlobalDestroyNonRouseDiceForRoll(params)
    if type(params) ~= "table" then return end
    local color = params.color
    local rollId = params.rollId
    if type(color) ~= "string" or type(rollId) ~= "string" then return end

    local bags = G.GetAllPlayerDiceBagGUIDs(color)
    for _, kind in ipairs({ "normal", "hunger" }) do
        local guid = bags[kind]
        if type(guid) == "string" then
            local bag = getObjectFromGUID(guid)
            if bag ~= nil then bag.call("destroyDice") end
        end
    end

    local ownerTag = color .. "Object"
    for _, kind in ipairs({ DK.KIND_NORMAL, DK.KIND_HUNGER }) do
        local dieTag = DK.kindToTag(kind)
        if dieTag ~= nil then
            local candidates = getObjectsWithAllTags({ dieTag, "d10", ownerTag })
            for _, obj in ipairs(candidates) do
                if DK.gmNotesMatchRoll(obj.getGMNotes(), rollId) then
                    destroyObject(obj)
                end
            end
        end
    end
end

--- Unlocks and releases Rouse/Oblivion-Rouse bag dice for the active roll (Take Half pending).
-- @param params table  { color: string }
function GlobalReleaseRouseDiceForActiveRoll(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then return end
    local color = params.color
    local pid = S.getPlayerID(color)
    if pid == nil then return end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil or type(active.id) ~= "string" then return end

    local bags = G.GetAllPlayerDiceBagGUIDs(color)
    for _, kind in ipairs({ "rouse", "oblivRouse" }) do
        local guid = bags[kind]
        if type(guid) == "string" then
            local bag = getObjectFromGUID(guid)
            if bag ~= nil then bag.call("releaseDice") end
        end
    end

    local rollId = active.id
    local ownerTag = color .. "Object"
    for _, kind in ipairs({ DK.KIND_ROUSE, DK.KIND_OBLIV_ROUSE }) do
        local dieTag = DK.kindToTag(kind)
        if dieTag ~= nil then
            local candidates = getObjectsWithAllTags({ dieTag, "d10", ownerTag })
            for _, obj in ipairs(candidates) do
                if DK.gmNotesMatchRoll(obj.getGMNotes(), rollId) then
                    obj.setLock(false)
                end
            end
        end
    end
    DiceDrawer.openForRoll(color)
end

--- Global.call entry: stop a pending post-result dice cleanup timer for a seat.
-- @param params table  { color: string }
function GlobalCancelPendingRollCleanup(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then return end
    cancelPendingRollCleanup(params.color)
end

--- Global.call entry: destroy all bag dice and close the drawer (Take Half without Rouse, cancel, etc.).
-- @param params table  { color: string }
function GlobalDestroyBagDice(params)
    if type(params) ~= "table" or type(params.color) ~= "string" then return end
    destroyBagDice(params.color)
end

--- Global.call entry: destroy table dice tagged with a roll id (player seats).
-- @param params table  { color: string, rollId: string }
function GlobalDestroyPlayerTableDiceForRoll(params)
    if type(params) ~= "table" then return end
    local color = params.color
    local rollId = params.rollId
    if type(color) ~= "string" or type(rollId) ~= "string" or color == "Black" then
        return
    end
    local ownerTag = color .. "Object"
    for _, kind in ipairs(DK.ALL_KINDS) do
        local dieTag = DK.kindToTag(kind)
        if dieTag ~= nil then
            local candidates = getObjectsWithAllTags({ dieTag, "d10", ownerTag })
            for _, obj in ipairs(candidates) do
                if DK.gmNotesMatchRoll(obj.getGMNotes(), rollId) then
                    destroyObject(obj)
                end
            end
        end
    end
end

--- Destroys all hovering dice for a player.
-- Called on: cancel, Take Half (no pending Rouse), and post-resolution cleanup.
function destroyBagDice(color)
    cancelPendingRollCleanup(color)
    if color == "Black" then
        local STR = require("core.storyteller_rolls")
        STR.destroyStagedBagDice()
        return
    end
    DiceDrawer.closeAfterRoll(color)
    callBagFunction(color, "destroyDice")
end

-- ============================================================================
-- DICE SYSTEM HUD HANDLERS
-- TTS XML onClick targets for roll panels and ST dashboard.
-- All functions extract the player color from the element id suffix.
-- ============================================================================

--- Colors that may appear as a roll UI id suffix (longest first avoids ambiguous tails).
local ROLL_UI_COLOR_SUFFIXES = { "Orange", "Purple", "Brown", "Black", "Pink", "Red" }

--- Extracts a player/ST seat color from a UI element id of the form "<prefix>_<Color>".
-- Matches suffix only (not substrings). ST slot CLEAR ids (`rollDash_stCancel_1`) have no
-- color suffix and must be handled before calling this (see HUD_rollCancel).
-- @param id string  Element id (e.g. "rollControl_btnRoll_Red" or "rollPanel_btnRoll_Black")
-- @return string|nil
local function colorFromRollElementId(id)
    if type(id) ~= "string" or id == "" then
        return nil
    end
    for _, color in ipairs(ROLL_UI_COLOR_SUFFIXES) do
        if #id > #color and string.sub(id, -#color) == color
            and string.sub(id, -#color - 1, -#color - 1) == "_"
        then
            return color
        end
    end
    return nil
end

--- Player clicks "ROLL" button — advances PRE_ROLL → ROLLING and releases locked dice.
-- id format: "rollControl_btnRoll_<Color>" (PC) or "rollPanel_btnRoll_Black" (ST)
function HUD_rollRollButton(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end

    GlobalRollSeatCamera({ color = color, mode = "diceTray" })

    local didAutoSpawn = spawnActivePoolDiceForActive(color)

    -- Release staged dice in PRE_ROLL while hunger/rouse bags are still at rest Y,
    -- then advance to ROLLING (hunger bag stays raised through ROLLING; hidden at POST_ROLL).
    local function afterDiceReleased()
        if RC.startRolling(color) ~= true then
            return
        end
        if color == "Black" then
            Wait.frames(function()
                local STR = require("core.storyteller_rolls")
                STR.physicalRollTrayDice()
            end, 3)
        end
    end

    local function releaseThenStartRolling()
        releaseBagDice(color, afterDiceReleased)
    end

    if didAutoSpawn then
        Wait.frames(releaseThenStartRolling, 10)
    else
        releaseThenStartRolling()
    end
end

--- Player clicks "TAKE HALF" — records take-half successes, skips rolling non-Rouse dice.
-- When Rouse dice remain, only normal/hunger are destroyed; Rouse dice are released to roll.
-- id format: "rollControl_btnHalf_<Color>" or "rollPanel_btnHalf_Black"
function HUD_rollTakeHalf(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end
    RC.takeHalf(color)
end

--- Player clicks "SPEND WILLPOWER" — spends 1 Superficial WP, re-enters ROLLING.
-- id format: "rollControl_btnWP_<Color>" or "rollPanel_btnWP_Black"
function HUD_rollSpendWP(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end

    GlobalRollSeatCamera({ color = color, mode = "diceTray" })
    RC.spendWillpower(color)
end

--- Player (or ST) clicks "CONFIRM" — finalises the roll result.
-- id format: "rollControl_btnConfirm_<Color>" or "rollPanel_btnConfirm_Black"
function HUD_rollConfirm(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end
    RC.confirmRoll(color)
end

--- Oblivion (D) choice: Hunger or Stain (rollControl_btnObliv*_* or rollPanel_btnObliv*_Black).
function HUD_rollConfirmOblivChoice(player, value, id)
    if type(id) ~= "string" then return end
    local color = colorFromRollElementId(id)
    if color == nil then return end
    local choice = nil
    if string.find(id, "OblivHunger", 1, true) or string.find(id, "btnOblivHunger", 1, true) then
        choice = "hunger"
    elseif string.find(id, "OblivStain", 1, true) or string.find(id, "btnOblivStain", 1, true) then
        choice = "stain"
    end
    if choice == nil then return end
    RC.confirmOblivionChoice(color, choice)
end

--- Brutal Outcome: Fail or Violence (rollControl_btnBrutal*_* or rollPanel_btnBrutal*_Black).
function HUD_rollConfirmBrutalChoice(player, value, id)
    if type(id) ~= "string" then return end
    local color = colorFromRollElementId(id)
    if color == nil then return end
    local choice = nil
    if string.find(id, "BrutalFail", 1, true) or string.find(id, "btnBrutalFail", 1, true) then
        choice = "fail"
    elseif string.find(id, "BrutalViolence", 1, true) or string.find(id, "btnBrutalViolence", 1, true) then
        choice = "violence"
    end
    if choice == nil then return end
    RC.confirmBrutalChoice(color, choice)
end

--- Player (or ST) clicks "CANCEL" — cancels the active roll and queue.
-- Any staged or released dice are destroyed immediately.
-- id format: "rollControl_btnCancel_<Color>" or "rollPanel_btnCancel_Black"
function HUD_rollCancel(player, value, id)
    -- ST drawer slot CLEAR buttons (rollDash_stCancel_1..3) have no color suffix.
    local stSlot = string.match(id or "", "^rollDash_stCancel_(%d)$")
    if stSlot ~= nil then
        local STR = require("core.storyteller_rolls")
        STR.cancelSlot(tonumber(stSlot))
        return
    end

    local color = colorFromRollElementId(id)
    if color == nil then return end

    if color == "Black" then
        local pid = S.getPlayerID(color)
        if pid ~= nil then
            local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
            if type(active) == "table" and type(active.stDrawerSlot) == "number" then
                local STR = require("core.storyteller_rolls")
                STR.cancelSlot(active.stDrawerSlot)
                return
            end
        end
    end

    RC.cancelRoll(color)
end

--- Player (or ST) clicks "RECALCULATE" — re-reads all physical dice on the table
-- and re-classifies the result. The primary path for Willpower rerolls and
-- manual corrections (player adjusts dice, then clicks this button).
-- Available in ROLLING and POST_ROLL phases.
-- id format: "rollPanel_btnRecalc_Black" (ST only; no Recalculate on PC rollControl panel)
function HUD_rollRecalculate(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end
    RC.recalculate(color)
end

--- Left Sidebar roll initiation buttons — one per roll type.
-- id format: "rollBtn_<rollType>_<Color>"  (e.g. "rollBtn_standard_Red")
function HUD_rollInitiate(player, value, id)
    if type(id) ~= "string" then return end
    -- Extract color from suffix and roll type from middle segment
    local color = colorFromRollElementId(id)
    if color == nil then return end

    -- id = "rollBtn_<rollType>_<Color>" → strip prefix and suffix
    local prefix    = "rollBtn_"
    local colorSuffix = "_" .. color
    if string.sub(id, 1, #prefix) ~= prefix then return end
    local middle = string.sub(id, #prefix + 1, #id - #colorSuffix)
    if middle == "" then return end

    -- Map id-safe rollType to C.RollType value (keys are lowercase in ids)
    local rollTypeMap = {
        standard      = C.RollType.STANDARD,
        simplecheck   = C.RollType.SIMPLE_CHECK,
        rouse         = C.RollType.ROUSE,
        rouseoblivion = C.RollType.ROUSE_OBLIVION,
        remorse       = C.RollType.REMORSE,
        willpowerroll = C.RollType.WILLPOWER_ROLL,
        humanityroll  = C.RollType.HUMANITY_ROLL,
        frenzy        = C.RollType.FRENZY,
        werewolf      = C.RollType.WEREWOLF,
        werewolfroll  = C.RollType.WEREWOLF,
        launch        = C.RollType.LAUNCH,
        goal          = C.RollType.GOAL,
    }
    local rollType = rollTypeMap[string.lower(middle)]
    if rollType == nil then
        print(string.format("[HUD_rollInitiate] Unknown roll type key: '%s'", middle))
        return
    end

    -- ST panel buttons always mark the roll as storyteller-initiated so the player
    -- panel stays hidden until the ST clicks OPEN (PRE_ROLL).
    -- Rouse / Obliv checks skip SETUP and need the default staged die + drawer (first spawn).
    local ok = RC.initiateRoll(color, { rollType = rollType, initiator = "storyteller" })
    if ok then
        GlobalSpawnDefaultPoolDiceForActive({ color = color })
    end
end

--- ST sets difficulty from the dashboard input field.
-- id format: "rollDash_difficulty_<Color>"
-- value = the InputField text
function HUD_rollSetDifficulty(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end

    local difficulty = tonumber(value)
    if difficulty == nil then
        print(string.format("[HUD_rollSetDifficulty] Invalid difficulty value: '%s'", tostring(value)))
        return
    end
    RC.setDifficulty(color, math.floor(difficulty))
end

-- ============================================================================
-- DICE SYSTEM DEBUG HUD HANDLERS (Host only; wired to admin panel buttons)
-- ============================================================================

--- Admin panel: arm a quick test roll for a player color (difficulty 2, Standard).
-- Calls DEBUG.rollTest so it can be re-pressed between runs without cleanup.
-- id format: "debugRoll_<Color>"  (e.g. "debugRoll_Brown")
function HUD_debugRollTest(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then
        print(string.format("[HUD_debugRollTest] Could not parse color from id: %s", tostring(id)))
        return
    end
    if DEBUG == nil then return end
    DEBUG.rollTest(color)
end

--- Admin panel: cancel all active rolls across every player color.
function HUD_debugRollCancelAll(player, value, id)
    if DEBUG == nil then return end
    DEBUG.rollCancelAll()
end

--- Opens ST roll options modal for the row's player.
-- id format: "rollDash_opts_<Color>"
function HUD_rollOptsOpen(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end
    local pid    = S.getPlayerID(color)
    local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end
    RUI.openRollOptionsModal(color)
end

--- Stashes roll options modal numeric InputFields (`onValueChanged` / `onEndEdit`).
-- @param player Player
-- @param value string|nil
-- @param id string|nil
function HUD_rollOptsInputChanged(player, value, id)
    if RUI and RUI.onRollOptsInputChanged then
        RUI.onRollOptsInputChanged(player, value, id)
    end
end

function HUD_rollOptsApply(player, value, id)
    RUI.applyRollOptionsModal(RC)
end

function HUD_rollOptsCancel(player, value, id)
    RUI.closeRollOptionsModal()
end

function HUD_rollStNameInputChanged(player, value, id)
    if RUI.onStRollNameInputChanged then
        RUI.onStRollNameInputChanged(player, value, id)
    end
end

function HUD_rollStNameApply(player, value, id)
    if RUI.applyStRollNameModal then
        RUI.applyStRollNameModal()
        RUI.refreshSTDashboard()
    end
end

function HUD_rollStNameCancel(player, value, id)
    if RUI.closeStRollNameModal then
        RUI.closeStRollNameModal()
    end
end

--- ST action button on the dashboard (context-sensitive: Open / Override / Confirm).
-- id format: "rollDash_btn_<Color>"
function HUD_rollSTAction(player, value, id)
    local color = colorFromRollElementId(id)
    if color == nil then return end

    local pid    = S.getPlayerID(color)
    local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then return end

    if color == "Black" and active.phase == C.RollPhase.PRE_ROLL then
        HUD_rollRollButton(player, value, id)
        return
    end

    if active.phase == C.RollPhase.SETUP then
        RC.openRoll(color)
    elseif active.phase == C.RollPhase.POST_ROLL then
        if active.pendingResolution ~= nil then
            print("[HUD_rollSTAction] Player must choose Hunger/Stain or Brutal outcome on the roll panel.")
            return
        end
        RC.confirmRoll(color)
    end
    -- For PRE_ROLL / ROLLING: ST can only set difficulty or cancel; no action button action
end
