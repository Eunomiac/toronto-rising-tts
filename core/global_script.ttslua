--- Writes picked district key into `gameState.sessionScene.districtKey`; Apply location still required.
function HUD_scenesPickDistrict(player, button, id)
    local key = string.match(id or "", "^scenes_pick_district_(.+)$")
    if type(key) ~= "string" or key == "" then
        U.AlertGM("Scenes: could not parse district picker control.")
        return
    end
    HUD_scenesCloseLocationModals(player, button, id)
    S.setStateVal(key, "sessionScene", "districtKey")
    StorytellerScenesPanel.applySiteModalDistrictVisibility()
    StorytellerScenesPanel.refresh()
    Sync.ui({ gameStateOverlay = true })
    U.AlertGM("District set: " .. key .. " — click Apply location + soundscape when ready.")
end

--- Writes picked site key into `gameState.sessionScene.siteKey`; Apply location still required.
function HUD_scenesPickSite(player, button, id)
    local key = string.match(id or "", "^scenes_pick_site_(.+)$")
    if type(key) ~= "string" or key == "" then
        U.AlertGM("Scenes: could not parse site picker control.")
        return
    end
    HUD_scenesCloseLocationModals(player, button, id)
    S.setStateVal(key, "sessionScene", "siteKey")
    StorytellerScenesPanel.refresh()
    Sync.ui({ gameStateOverlay = true })
    U.AlertGM("Site set: " .. key .. " — click Apply location + soundscape when ready.")
end

--- Month button on Scenes panel (`scenes_month_1` … `12`).
function HUD_scenesMonthPick(player, button, id)
    local m = tonumber(string.match(id or "", "^scenes_month_(%d+)$"))
    if m == nil then
        U.AlertGM("Scenes: could not parse month picker id.")
        return
    end
    StorytellerScenesPanel.setPendingMonth(m)
end

