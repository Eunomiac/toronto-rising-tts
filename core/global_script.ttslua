--- Toggles auto-export of NPC storyteller panel row XML to the IDE workspace (TTS Tools) on each panel refresh.
--- Admin button: grey (off), green (on).
function HUD_toggleNpcPanelXmlDump(player, button, id)
    if NPCS == nil or NPCS.setAutoDumpStorytellerNpcPanelXmlEnabled == nil then
        return
    end
    local nextOn = not NPCS.isAutoDumpStorytellerNpcPanelXmlEnabled()
    NPCS.setAutoDumpStorytellerNpcPanelXmlEnabled(nextOn)
    NPCS.syncAdminNpcPanelXmlDumpButton()
    if nextOn and NPCS.refreshStorytellerUIIfVisible then
        NPCS.refreshStorytellerUIIfVisible()
    end
end

