        RUI.onPostRollCellMouseEnter(player, id)
    end
end

function HUD_postRollCellMouseExit(player, value, id)
    if RUI.onPostRollCellMouseExit then
        RUI.onPostRollCellMouseExit(player, id)
    end
end

function HUD_postRollCellMouseDown(player, value, id)
