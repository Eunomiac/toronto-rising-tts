function HUD_scenesPickSite(player, button, id)
    if not requireStorytellerForMutation(player, "HUD_scenesPickSite") then
        return
    end
    local key = string.match(id or "", "^scenes_pick_site_(.+)$")
    if type(key) ~= "string" or key == "" then
        U.AlertGM("Scenes: could not parse site picker control.")
        return
    end
    HUD_scenesCloseLocationModals(player, button, id)
    StorytellerScenesPanel.setLocationKeyFromPicker("site", key)
    U.AlertGM("Site set: " .. key .. " — click Apply location + soundscape when ready.")
end

