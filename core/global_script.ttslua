--- Resolved condition statChanges for one PC (sheet dots, BP decals). Object scripts have no `core.conditions`.
--- @param playerID string
--- @return table statChanges map (may be empty)
function GlobalGetResolvedStatChangesForPlayer(playerID)
    if type(playerID) ~= "string" or playerID == "" then
        return {}
    end
    if playerID == C.StorytellerID then
        return {}
    end
    local ES = require("lib.effective_stats")
    return ES.forPlayer(playerID).statChanges
end

--- @return boolean
local function startupSeatLightsReadyForReveal()
    if L == nil or type(L.seatSpotlightsResolvable) ~= "function" then
        return false
    end
    return L.seatSpotlightsResolvable() == true
end

local STARTUP_LOADING_OVERLAY_ID = "overlay_loadingScreen_startup"

--- Per connected player: seat colors that already received `UI.setXml` this session (TOR-285 hotseat lag).
local seatXmlRefreshDoneByPlayer = {}

--- First `onPlayerChangeColor` after `onPlayerConnect` still auto-refreshes UI (including Host connect).
local pendingConnectSeatRefreshByPlayer = {}

--- Force-hide global startup loading screen for all clients.
--- `U.RunSequence`: hide (FadeOut) → wait 1s → clear `active` so a later full-XML seat
--- refresh (TOR-285) cannot resurrect the overlay with `active` still true.
local function hideStartupLoadingOverlays()
    U.RunSequence({
        function()
            UI.hide(STARTUP_LOADING_OVERLAY_ID)
            return 1
        end,
        function()
            if type(U.setAttribute) == "function" then
                U.setAttribute(STARTUP_LOADING_OVERLAY_ID, "active", "false")
            elseif type(UI.setAttribute) == "function" then
                UI.setAttribute(STARTUP_LOADING_OVERLAY_ID, "active", "false")
            end
        end,
    })
end

local function seatAssignmentPlayerKey(player)
    if player == nil or not U.isPlayer(player) then
        return nil
    end
    local steam = player.steam_id
    if type(steam) == "string" and steam ~= "" then
        return steam
    end
    if type(player.color) == "string" and player.color ~= "" then
        return "color:" .. player.color
    end
    return nil
end

local function clearSeatXmlRefreshForPlayer(player)
    local key = seatAssignmentPlayerKey(player)
    if key ~= nil then
        seatXmlRefreshDoneByPlayer[key] = {}
    end
end

local function hasSeatXmlRefreshDone(player, seatColor)
    local key = seatAssignmentPlayerKey(player)
    if key == nil then
        return false
    end
    local perPlayer = seatXmlRefreshDoneByPlayer[key]
    return type(perPlayer) == "table" and perPlayer[seatColor] == true
end

local function markSeatXmlRefreshDone(player, seatColor)
    local key = seatAssignmentPlayerKey(player)
    if key == nil then
        return
    end
    if type(seatXmlRefreshDoneByPlayer[key]) ~= "table" then
        seatXmlRefreshDoneByPlayer[key] = {}
    end
    seatXmlRefreshDoneByPlayer[key][seatColor] = true
end

--- Re-evaluate XmlUI visibility after seat assignment (TTS engine snapshotted-at-load quirk; TOR-285).
--- Full `UI.setXml` runs once per player per seat color after connect; later hotseat swaps skip it.
--- @param seatColor string
local function refreshGlobalUiAfterSeatAssignment(seatColor)
    if type(seatColor) ~= "string" or seatColor == "" or seatColor == "Grey" then
        return
    end

    local isPcSeat = U.isIn(seatColor, C.PlayerColors)
    local isStorytellerSeat = seatColor == "Black"
    if not isPcSeat and not isStorytellerSeat then
        return
    end

    local seated = Player[seatColor]
    local needsSetXml = true
    if U.isPlayer(seated) and hasSeatXmlRefreshDone(seated, seatColor) then
        needsSetXml = false
    end

    local shouldMarkSeatRefreshDone = false

    local function applyPostSeatUiRefresh()
        -- Drop orphaned transition blindfolds on empty PC seats (host left mid-settle).
        local HUDBF = require("core.hud_blindfold")
        if type(HUDBF.clearBlindfoldsForUnoccupiedPcSeats) == "function" then
            HUDBF.clearBlindfoldsForUnoccupiedPcSeats()
        end
        -- UI.setXml rebuilds XmlUI from source defaults (overlays active=false). Clear
        -- HO lastVisible / fingerprint caches so the next overlay sync re-issues show/hide
        -- instead of assuming pre-setXml visibility still matches the live UI.
        if type(HO.invalidateOverlayInputCache) == "function" then
            HO.invalidateOverlayInputCache()
        end
        if isPcSeat and type(HO.invalidateSeatCache) == "function" then
            HO.invalidateSeatCache(seatColor)
        elseif type(HO.invalidateSeatCache) == "function" then
            for _, pcColor in ipairs(C.PlayerColors or {}) do
                HO.invalidateSeatCache(pcColor)
            end
        end
        local delta = {
            overlays = true,
            gameStateOverlay = true,
            debugSeatColors = true,
        }
        if isPcSeat then
            delta.playerHud = true
            delta.colors = { seatColor }
        end
        if isStorytellerSeat then
            delta.scenesPanel = true
            delta.statsPanel = true
            delta.projectsPanel = true
            delta.adminLighting = true
            delta.soundscape = true
            delta.phase = true
        end
        if type(UpdateUIDisplays) == "function" then
            UpdateUIDisplays(delta)
        end
        if shouldMarkSeatRefreshDone and U.isPlayer(seated) then
            markSeatXmlRefreshDone(seated, seatColor)
            shouldMarkSeatRefreshDone = false
        end
        hideStartupLoadingOverlays()
    end

    local function schedulePostSeatUiRefresh()
        if UI.loading == true then
            U.waitUntil(applyPostSeatUiRefresh, function()
                return UI.loading ~= true
            end, false, 10, 0.05)
        else
            U.delay(applyPostSeatUiRefresh, 0)
        end
    end

    if not needsSetXml then
        schedulePostSeatUiRefresh()
        return
    end

    if type(UI.getXml) ~= "function" or type(UI.setXml) ~= "function" then
        return
    end

    local xml = UI.getXml()
    if type(xml) ~= "string" or xml == "" then
        return
    end

    if U.isPlayer(seated) then
        shouldMarkSeatRefreshDone = true
    end
    UI.setXml(xml)
    schedulePostSeatUiRefresh()
end

--- Bundle-safe seat-assignment UI refresh (`Global.call` from `core/main.ttslua` auto-assign early return).
--- @param params table|string `{ color: string }` or seat color string
function GlobalRefreshUiAfterSeatAssignment(params)
    local seatColor = params
    if type(params) == "table" then
        seatColor = params.color or params.seatColor or params.player_color
    end
    refreshGlobalUiAfterSeatAssignment(seatColor)
end

--- Returns seat layout center point from global state for object scripts.
--- @return table|nil { x, y, z }
function GlobalGetSeatLayoutCenterPoint()
    local tableKey = S.getStateVal("seatLayout", "currentTableKey")
    if type(tableKey) == "string" and C.Tables and C.Tables[tableKey] and C.Tables[tableKey].centerPoint ~= nil then
        local cp = Vector(C.Tables[tableKey].centerPoint)
        return { x = cp.x, y = cp.y, z = cp.z }
    end
    return nil
end

--- Bundle-safe steam gate for object scripts (`Global.call`).
--- @param params table `{ player?: Player, player_color?: string, color?: string }`
--- @return boolean
function GlobalIsStorytellerSteamPlayer(params)
    if type(params) ~= "table" then
        return false
    end
    if params.player ~= nil then
        return U.isStorytellerSteamPlayer(params.player) == true
    end
    local color = params.player_color or params.color
    return U.isStorytellerSteamPlayer(color) == true
end


--- Toggles a player's signal fire from object scripts (signal candle click target).
--- @param params table { color: string, duration: number|nil }
--- @return string|nil "on" or "off", or nil on failure
function GlobalToggleSignalFireState(params)
    if type(params) ~= "table" then
        return nil
    end
    local color = params.color
    if type(color) ~= "string" or color == "" then
        return nil
    end
    local duration = tonumber(params.duration)
    if duration == nil then
        duration = 0.2
    end
    return O.ToggleSignalFireState(color, duration)
end

--- Pink tarot drawer/deck/button pose toggle (host-only; object script routes via Global.call).
--- @param params table { targetOn: boolean, buttonGuid?: string }
--- @return boolean|nil applied on-state, or nil on failure / non-host
function GlobalApplyTarotState(params)
    if type(params) ~= "table" or type(params.targetOn) ~= "boolean" then
        return nil
    end
    local TarotToggle = require("lib.tarot_toggle")
    return TarotToggle.applyState(params.targetOn, params.buttonGuid)
end

--- Read-only tarot on/off inference for object onLoad (keeps ui_tarot_button bundle thin).
--- @param params table { buttonGuid?: string, fallback?: boolean }
--- @return boolean
function GlobalInferTarotState(params)
    if type(params) ~= "table" then
        return false
    end
    local TarotToggle = require("lib.tarot_toggle")
    return TarotToggle.inferCurrentState(params.buttonGuid, params.fallback == true)
end

--- NPC gameboard: Apply tokens on CONTROL_BOARD → `sessionScene.npcWorld.placements` → `Sync.npcs`.
--- @param params table|nil
--- @return boolean
function GlobalGameboardApply(params)
    local Gameboard = require("core.npc_gameboard")
    local ok = Gameboard.applyFromControlBoard()
    if type(ok) == "boolean" then
        return ok
    end
    return ok == true
end

--- TOR-173: single orchestrator coroutine for stage placement lerp batches on Apply.
function GlobalStageLerpOrchestrator()
    local NPCStageLerp = require("core.npc_stage_lerp")
    return NPCStageLerp.runOrchestratorCoroutine()
end

--- NPC gameboard: Clear with double-click confirm (object `click_clear` → Global.call).
--- @param params table|nil `{ player_color?: string }`
--- @return boolean
function GlobalGameboardClearClick(params)
    local color = type(params) == "table" and params.player_color or "Black"
    local Gameboard = require("core.npc_gameboard")
    if not Gameboard.tryConfirmClear(color) then
        return false
    end
    return GlobalGameboardClear(params)
end

