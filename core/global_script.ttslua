--- Advance game phase
-- Called when a phase button is clicked (e.g., "phase_play")
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID (e.g., "phase_play")
function HUD_advancePhase(player, button, id)
    if not requireStorytellerForMutation(player, "HUD_advancePhase") then
        return
    end
    local tail = string.gsub(id or "", "^phase_", "")
    local phaseMap = {
        SessionStart = C.Phases.SESSION_START,
        Play = C.Phases.PLAY,
        Downtime = C.Phases.DOWNTIME,
        Memoriam = C.Phases.MEMORIAM,
        SessionEnd = C.Phases.SESSION_END,
        -- Legacy lowercase ids (if any XML still emits them)
        sessionstart = C.Phases.SESSION_START,
        play = C.Phases.PLAY,
        downtime = C.Phases.DOWNTIME,
        memoriam = C.Phases.MEMORIAM,
        sessionend = C.Phases.SESSION_END,
    }

    local targetPhase = phaseMap[tail]
    if targetPhase == nil then
        targetPhase = phaseMap[string.lower(tail)]
    end
    if targetPhase == nil then
        U.AlertGM("HUD_advancePhase: Invalid phase: " .. tostring(tail))
        return
    end

    M.advancePhase(targetPhase)
    UpdateUIDisplays({ phase = true })
    syncStorytellerPhaseButtons()

    print("HUD: Phase set to " .. tostring(targetPhase) .. " by " .. tostring(player and player.color))
end

--- Reset game state
-- Called when the "Reset Game" button is clicked
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_resetGame(player, button, id)
    if not requireStorytellerForMutation(player, "HUD_resetGame") then
        return
    end
    if NPCS and NPCS.destroyAllWorldAndState then
        NPCS.destroyAllWorldAndState()
    end
    S.resetGameState()

    -- Reset modules
    Scenes.resetScene(0)  -- Instant reset

    -- Update UI
    UpdateUIDisplays()

    print("HUD: Game reset by " .. player.color)
    broadcastToAll("Game has been reset.", {1, 0, 0})
end

--- Save game state explicitly
-- Called when the "Save State" button is clicked
-- Note: TTS also calls onSave() automatically, but this can be used for explicit saves
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_saveState(player, button, id)
    -- Trigger save (onSave will be called by TTS)
    -- This is mainly for UI feedback
    local state = S.getGameState()
    local stateStr = JSON.encode(state)

    print("HUD: Game state saved by " .. player.color)
    broadcastToColor("Game state saved successfully.", player.color, {0, 1, 0})
end

--- Log current game state to console (debug function)
-- Called when the "Log State" debug button is clicked
-- @param player Player The player who clicked the button
-- @param button string Button value
-- @param id string The UI element ID
function HUD_logState(player, button, id)
    local state = S.getGameState()
    print("=== GAME STATE ===")
    print(JSON.encode_pretty(state))
    print("==================")
    broadcastToColor("Game state logged to console.", player.color, {0, 1, 1})
end

--- Pretty-print full game state to workspace file (same path as DEBUG.logStateToFile).
-- Writes **.dev/.debug/debug_logs/game_state.txt** when the tts-bridge listens on 39998 (overwrites each click). See .dev/DEBUG_FILE_LOGGING.md.
-- Called when the Storyteller left-panel "Print State" button is clicked.
-- @param player Player The player who clicked (Host/Black)
-- @param button string Button value
-- @param id string The UI element ID
function HUD_printState(player, button, id)
    if not DEBUG or type(DEBUG.logStateToFile) ~= "function" then
        broadcastToColor("Print State: DEBUG.logStateToFile missing.", player.color, {1, 0.5, 0})
        return
    end
    -- Delegates to core/debug.ttslua: JSON.encode_pretty + writeToFile (sendExternalMessage, format "auto")
    DEBUG.logStateToFile("game_state")
    broadcastToColor(
        "Game state written to .dev/.debug/debug_logs/game_state.txt (enable External Editor + bridge on 39998 if missing).",
        player.color,
        {0, 1, 1}
    )
end

--- Force a full synchronization pass from current state.
-- @param player Player The player who clicked (Host/Black)
-- @param button string Button value
-- @param id string The UI element ID
function HUD_syncAll(player, button, id)
    if not requireStorytellerForMutation(player, "HUD_syncAll") then
        return
    end
    if not Sync or type(Sync.full) ~= "function" then
        broadcastToColor("Sync All: Sync.full missing.", player.color, {1, 0.5, 0})
        return
    end
    Sync.full({ force = true, reason = "HUD_syncAll" })
    broadcastToColor(
        "Full sync (force): scenes, soundscape, seat lights, NPC layout, overlays, and UI refreshed.",
        player.color,
        {0, 1, 1}
    )
end

