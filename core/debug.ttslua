--[[
    State Inspection Functions
]]

--- Display current game state (readable format)
function DEBUG.showState()
    printTestHeader("Current Game State")
    local state = S.getGameState()
    print(JSON.encode_pretty(state))
end

--- Display live session scene + library linkage (current authoring model).
function DEBUG.showScene()
    printTestHeader("Session Scene + Library")
    print("currentScene (lighting preset key): " .. tostring(S.getStateVal("currentScene")))
    print("sessionScene.lightingPresetKey: " .. tostring(S.getStateVal("sessionScene", "lightingPresetKey")))
    print("sceneLibrary.activeKey: " .. tostring(S.getStateVal("sceneLibrary", "activeKey")))
    print("sceneLibrary.lastAppliedKey: " .. tostring(S.getStateVal("sceneLibrary", "lastAppliedKey")))
    print("sessionScene.siteKey: " .. tostring(S.getStateVal("sessionScene", "siteKey")))
    print("sessionScene.districtKey: " .. tostring(S.getStateVal("sessionScene", "districtKey")))
    local npcWorld = S.getStateVal("sessionScene", "npcWorld")
    if type(npcWorld) == "table" and type(npcWorld.byArea) == "table" then
        local Convert = require("lib.npc_placements_convert")
        if Convert.byAreaHasEntries(npcWorld.byArea) then
            print("sessionScene.npcWorld.byArea: legacy entries present — run S.validateState or npm run npc-placements:migrate-byarea")
        end
    end
    if type(npcWorld) == "table" and type(npcWorld.placements) == "table" then
        local n = 0
        for _ in pairs(npcWorld.placements) do
            n = n + 1
        end
        print("sessionScene.npcWorld.placements: " .. tostring(n))
    end
end

--- Scan `npc_light` for duplicate pooled spotlights per roster key (same as load audit).
--- @param opts table|nil forwarded to `NPCS.auditDuplicatePooledSpotlights` (e.g. `{ alert = true, destroyDuplicates = true }`)
--- @return table audit result
function DEBUG.auditDuplicatePooledSpotlights(opts)
    local NPCS = require("core.npcs")
    opts = type(opts) == "table" and opts or {}
    if opts.phase == nil then
        opts.phase = "debug-audit"
    end
    return NPCS.auditDuplicatePooledSpotlights(opts)
end

--- Dump `sessionScene.npcWorld.placements` and live instance stage poses.
function DEBUG.dumpNpcPlacements()
    printTestHeader("NPC gameboard placements")
    local placements = S.getStateVal("sessionScene", "npcWorld", "placements")
    if type(placements) ~= "table" then
        print("placements: (none)")
        return
    end
    local keys = {}
    for k, _ in pairs(placements) do
        keys[#keys + 1] = k
    end
    table.sort(keys)
    for _, ck in ipairs(keys) do
        local row = placements[ck]
        if type(row) == "table" then
            print(string.format(
                "  %s u=%.3f v=%.3f yaw=%.0f mode=%s",
                ck,
                tonumber(row.u) or 0,
                tonumber(row.v) or 0,
                tonumber(row.yaw) or 0,
                tostring(row.npcLightMode or "")
            ))
        end
    end
    if NPCS ~= nil and type(NPCS.collectSessionStagePlacements) == "function" then
        print("collectSessionStagePlacements rows: " .. tostring(#NPCS.collectSessionStagePlacements()))
    end
end

--[[ Gameboard & Stage E2E (TOR-141 / TOR-169) — see .dev/E2E Playbooks/Gameboard-E2E.md ]]
local E2E_GB = require("lib.e2e_gameboard")

--- Assert gameboard/state probes; prints `[gbConfirm] PASS` / `FAIL`.
--- @param labelOrExpected string|table test label, or `{ placements = … }` only
--- @param maybeExpected table|nil
--- @return boolean
function DEBUG.gbConfirm(labelOrExpected, maybeExpected)
    if type(labelOrExpected) == "table" and maybeExpected == nil then
        return E2E_GB.confirm("gbConfirm", labelOrExpected)
    end
    return E2E_GB.confirm(tostring(labelOrExpected), maybeExpected or {})
end

