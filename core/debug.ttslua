--- Print active condition ids and resolved effects for one seat (MCP / console diagnosis).
--- @param seatColor string e.g. "Brown"
function DEBUG.dumpConditions(seatColor)
  if type(seatColor) ~= "string" or seatColor == "" then
    error("DEBUG.dumpConditions: seatColor required")
  end
  local S = require("core.state")
  local Conditions = require("core.conditions")
  local playerID = S.getPlayerID(seatColor)
  if type(playerID) ~= "string" then
    print("[DEBUG.dumpConditions] no playerID for seat " .. seatColor)
    return
  end
  local conditions = S.getStateVal("playerData", playerID, "conditions") or {}
  local resolved = Conditions.resolveForPlayer(playerID)
  print("[DEBUG.dumpConditions] seat=" .. seatColor .. " playerID=" .. playerID)
  print("  activeIds: " .. JSON.encode(conditions))
  print("  resolved.statChanges: " .. JSON.encode(resolved.statChanges))
  print("  resolved.hudElementIds: " .. JSON.encode(resolved.hudElementIds))
  print("  resolved.lightingModes: " .. JSON.encode(resolved.lightingModes))
end

--- Print effective stat getters for one seat (MCP / console diagnosis).
--- @param seatColor string e.g. "Brown"
function DEBUG.dumpEffectiveStats(seatColor)
  if type(seatColor) ~= "string" or seatColor == "" then
    error("DEBUG.dumpEffectiveStats: seatColor required")
  end
  local S = require("core.state")
  local ES = require("lib.effective_stats")
  local playerID = S.getPlayerID(seatColor)
  if type(playerID) ~= "string" then
    print("[DEBUG.dumpEffectiveStats] no playerID for seat " .. seatColor)
    return
  end
  local ctx = ES.forPlayer(playerID)
  print("[DEBUG.dumpEffectiveStats] seat=" .. seatColor .. " playerID=" .. playerID)
  print("  trackerMax health=" .. tostring(ctx.trackerMax("health"))
    .. " willpower=" .. tostring(ctx.trackerMax("willpower"))
    .. " humanity=" .. tostring(ctx.trackerMax("humanity")))
  print("  bloodPotencyRating=" .. tostring(ctx.bloodPotencyRating())
    .. " bloodSurge=" .. tostring(ctx.bloodPotencyDerived().bloodSurge))
  print("  humanityHasImpairedSlot=" .. tostring(ctx.humanityHasImpairedSlot()))
  print("  statChanges: " .. JSON.encode(ctx.statChanges))
end

--- Print merged roll policy for the active roll on one seat (MCP / console diagnosis).
--- @param seatColor string e.g. "Brown"
function DEBUG.dumpRollPolicy(seatColor)
  if type(seatColor) ~= "string" or seatColor == "" then
    error("DEBUG.dumpRollPolicy: seatColor required")
  end
  local S = require("core.state")
  local Conditions = require("core.conditions")
  local playerID = S.getPlayerID(seatColor)
  if type(playerID) ~= "string" then
    print("[DEBUG.dumpRollPolicy] no playerID for seat " .. seatColor)
    return
  end
  local active = S.getStateVal("playerData", playerID, "hud", "rollData", "active")
  print("[DEBUG.dumpRollPolicy] seat=" .. seatColor .. " playerID=" .. playerID)
  if type(active) ~= "table" then
    print("  no active roll — resolved policy at initiate would be:")
    print("  " .. JSON.encode(Conditions.resolveRollPolicy(playerID)))
    return
  end
  if type(active.rollPolicy) == "table" then
    print("  active.rollPolicy: " .. JSON.encode(active.rollPolicy))
  else
    print("  active.rollPolicy: (missing — re-initiate roll after deploy)")
    print("  current merge: " .. JSON.encode(Conditions.resolveRollPolicy(playerID)))
  end
end

return DEBUG
