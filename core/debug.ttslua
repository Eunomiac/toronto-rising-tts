---@diagnostic disable: lowercase-global
--[[
    Debug module (core/debug.ttslua)

    Development helpers: inspection, dice roll shortcuts, soundscape setters, file logging,
    coordinate utilities, and light-feasibility probes. Exposed globally for TTS console
    and External Editor (`lua rollTest("Brown", 3)`, `lua debugHelp()`, etc.).

    Manual E2E verification: `.dev/E2E Playbooks/` (see `.dev/TESTING.md`).

    Agent guidance: .dev/DEBUG_FILE_LOGGING.md; .dev/TESTING.md; .dev/User Guides/TTS-3D-Positioning-Coordinate-Utilities.md
]]

DEBUG = {}
U = require("lib.util")
S = require("core.state")
M = require("core.main")
Z = require("core.zones")
Scenes = require("core.scenes")
Soundscape = require("core.soundscape")
C = require("lib.constants")
G = require("lib.guids")
L = require("core.lighting")
O = require("core.objects")
local Sync = require("core.sync")
LightTest = require("core.light_test")
-- Bundler tracing: `lib.workspace_ndjson_log` is otherwise only required from inside DEBUG.* at runtime
-- and can be omitted from Save & Play bundles → a late require there fails in-game. Keep one top-level require.
require("lib.workspace_ndjson_log")

--- Keep debug-side hunger writes aligned with runtime sync behavior.
--- @param color string
--- @param value number
local function setHungerAndSync(color, value)
    S.setPlayerVal(color, "hunger", value)
    Sync.player(color)
end

--[[
    File Logging Configuration
    External Editor bridge (repo tts-bridge on port 39998): `sendExternalMessage` with type "write"
    and `name` is written under **workspaceFolder/.dev/.debug/<name>** when MCP or `npm run tts-bridge:listen`
    is active. Same for logToFile and writeWorkspaceFile. See .dev/DEBUG_FILE_LOGGING.md.
]]
local LOG_DIR = "debug_logs"
local LOG_EXTENSION = "txt"

--- Prefix printed in DEBUG messages (relative to workspace folder); files appear here when the bridge handles writes.
local WORKSPACE_DEBUG_WRITE_ROOT = ".dev/.debug"

-- Cache for log file contents (to support append mode)
-- Key: filename (without extension), Value: accumulated content string
local logCache = {}

--- Printed at most once when `sendExternalMessage` is missing (NDJSON / workspace writes).
local warnedNdjsonSendExternalMissing = false
local lastCapturedCameraEntry = nil

--[[
    Helper Functions
]]

--- Gets current timestamp as a formatted string
-- @return string Timestamp in format "YYYY-MM-DD HH:MM:SS"
local function getTimestamp()
    local time = os.time()
    -- Lua 5.1 doesn't have os.date with format strings, so we use a workaround
    -- For TTS, we'll use a simpler format
    return tostring(time)
end

--- Writes content to a file in the workspace using TTS Tools extension
-- Supports append mode by maintaining an in-memory cache of file contents
-- @param filename string Name of the file (without extension)
-- @param content string Content to write
-- @param format string Optional format: "auto" (for JSON) or "none" (default: "none")
-- @param append boolean If true, appends to existing cached content (default: true for logs, false for dumps)
local function writeToFile(filename, content, format, append)
    format = format or "none"
    append = append ~= false  -- Default to true (append mode) unless explicitly set to false

    -- Use sendExternalMessage to write to file.
    -- Don't set `object`; with only `name`, the bridge writes to .dev/.debug/<name>.
    local fullName = LOG_DIR .. "/" .. filename .. "." .. LOG_EXTENSION

    -- For append mode, maintain cache and accumulate content
    if append then
        if not logCache[filename] then
            logCache[filename] = ""
        end
        logCache[filename] = logCache[filename] .. content
        content = logCache[filename]  -- Write accumulated content
    else
        -- Overwrite mode: clear cache and write new content
        logCache[filename] = content
    end

    -- Check if sendExternalMessage exists (TTS Tools extension)
    ---@diagnostic disable-next-line: undefined-global
    if sendExternalMessage then
        ---@diagnostic disable-next-line: undefined-global
        sendExternalMessage({
            type = "write",
            content = content,
            name = fullName,
            format = format
        })
        print("DEBUG: Log written to " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. fullName)
    else
        -- Fallback: just print if extension not available
        print("DEBUG (file logging not available): " .. filename)
        print(content)
    end
end

--- Writes content via sendExternalMessage type "write". File appears as **workspace/.dev/.debug/<relativePath>** when the bridge listens on 39998.
--- Does not use log append cache; each call overwrites that file path.
--- @param relativePath string Path suffix under .dev/.debug, e.g. "debug_logs/npcs_panel.txt"
--- @param content string
--- @param format string|nil "none" or "auto" (default "none")
--- @param silent boolean|nil If true, do not print confirmation (for high-frequency writes)
--- @return boolean
function DEBUG.writeWorkspaceFile(relativePath, content, format, silent)
    format = format or "none"
    if U.Type(relativePath) ~= "string" or relativePath == "" then
        print("DEBUG.writeWorkspaceFile: invalid relativePath")
        return false
    end
    if U.Type(content) ~= "string" then
        content = tostring(content)
    end
    ---@diagnostic disable-next-line: undefined-global
    if sendExternalMessage then
        ---@diagnostic disable-next-line: undefined-global
        sendExternalMessage({
            type = "write",
            content = content,
            name = relativePath,
            format = format
        })
        if not silent then
            print("DEBUG: Wrote " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. relativePath)
            print(
                "DEBUG: tts-bridge stores custom writes under .dev/.debug/ (first workspace folder if multi-root). "
                    .. "Enable custom messages (ttsEditor.enableMessages) if writes are ignored."
            )
        end
        return true
    end
    print("DEBUG.writeWorkspaceFile: sendExternalMessage not available (TTS Tools extension?)")
    return false
end

--- @param n number|nil
--- @return string
local function formatCameraNumber(n)
    if type(n) ~= "number" then
        return "0"
    end
    return string.format("%.4f", n)
end

--- Capture the player's current view and export a paste-ready Lua snippet.
--- The output can be pasted into C.UniversalCameraAngles or C.RedCameraAngles.
--- @param player Player
--- @return boolean ok
--- @return string resultMessage
function DEBUG.captureCameraViewPreset(player)
    if player == nil or not U.isPlayer(player) then
        return false, "DEBUG.captureCameraViewPreset: invalid player"
    end

    local function callPlayerMethod(name, ...)
        local fn = player[name]
        if type(fn) ~= "function" then
            return nil
        end
        return fn(player, ...)
    end

    local cameraMode = callPlayerMethod("getCameraMode") or "FirstPerson"
    local pointerPos = callPlayerMethod("getPointerPosition")
    local pointerRot = callPlayerMethod("getPointerRotation")
    local handTf = callPlayerMethod("getHandTransform", 1) or callPlayerMethod("getHandTransform")

    local pos = nil
    if pointerPos ~= nil then
        pos = Vector(pointerPos)
    elseif type(handTf) == "table" and handTf.position ~= nil then
        pos = Vector(handTf.position)
    else
        pos = Vector({0, 0, 0})
    end

    local pitch = 0
    local yaw = 0
    local distance = 0
    if pointerRot ~= nil then
        local rot = Vector(pointerRot)
        pitch = rot.x
        yaw = rot.y
    elseif type(handTf) == "table" and handTf.rotation ~= nil then
        local rot = Vector(handTf.rotation)
        pitch = rot.x
        yaw = rot.y
    end

    if type(handTf) == "table" and handTf.position ~= nil and pointerPos ~= nil then
        local origin = Vector(handTf.position)
        local target = Vector(pointerPos)
        local dx = target.x - origin.x
        local dy = target.y - origin.y
        local dz = target.z - origin.z
        local horizontal = math.sqrt(dx * dx + dz * dz)

        -- If API does not expose pointer rotation, derive orientation from origin -> pointer target.
        if pointerRot == nil then
            yaw = math.deg(math.atan2(dx, dz))
            if horizontal > 0.001 then
                pitch = -math.deg(math.atan2(dy, horizontal))
            end
        end
        distance = math.sqrt(dx * dx + dy * dy + dz * dz)
    end

    lastCapturedCameraEntry = {
        cameraMode = tostring(cameraMode),
        position = Vector(pos),
        pitch = pitch,
        yaw = yaw,
        distance = distance,
    }

    local ts = os.time()
    local colorKey = string.upper(player.color or "UNKNOWN")
    local relativePath = "debug_logs/camera_capture_" .. colorKey .. "_" .. tostring(ts) .. ".lua"
    local body = table.concat({
        "-- Camera capture snapshot (generated by HUD_debugCaptureCameraPreset)",
        "-- Paste one of the entries below into C.UniversalCameraAngles or C.RedCameraAngles.",
        "-- Suggested mode key: <replace_me>",
        "",
        "local CAPTURED_CAMERA_ENTRY = {",
        "  cameraMode = " .. string.format("%q", tostring(cameraMode)) .. ",",
        "  position = Vector({" .. formatCameraNumber(pos.x) .. ", " .. formatCameraNumber(pos.y) .. ", " .. formatCameraNumber(pos.z) .. "}),",
        "  pitch = " .. formatCameraNumber(pitch) .. ",",
        "  yaw = " .. formatCameraNumber(yaw) .. ",",
        "  distance = " .. formatCameraNumber(distance) .. ",",
        "}",
        "",
        "-- Example paste targets:",
        "C.UniversalCameraAngles[\"<replace_me>\"] = CAPTURED_CAMERA_ENTRY",
        "C.RedCameraAngles[\"<replace_me>\"] = CAPTURED_CAMERA_ENTRY",
        "",
    }, "\n")

    local okWrite = DEBUG.writeWorkspaceFile(relativePath, body, "none", false)
    if not okWrite then
        return false, "camera capture failed to write file"
    end
    return true, relativePath
end

--- Apply the most recently captured camera entry to a player.
--- @param player Player
--- @return boolean ok
--- @return string resultMessage
function DEBUG.applyLastCapturedCameraPreset(player)
    if player == nil or not U.isPlayer(player) then
        return false, "DEBUG.applyLastCapturedCameraPreset: invalid player"
    end
    if type(lastCapturedCameraEntry) ~= "table" then
        return false, "No captured camera snapshot is available yet."
    end

    local entry = {
        cameraMode = lastCapturedCameraEntry.cameraMode or "FirstPerson",
        position = Vector(lastCapturedCameraEntry.position or {0, 0, 0}),
        pitch = tonumber(lastCapturedCameraEntry.pitch) or 0,
        yaw = tonumber(lastCapturedCameraEntry.yaw) or 0,
        distance = tonumber(lastCapturedCameraEntry.distance) or 0,
    }

    player.setCameraMode(entry.cameraMode)
    player.lookAt({
        position = entry.position,
        pitch = entry.pitch,
        yaw = entry.yaw,
        distance = entry.distance,
    })
    U.delay(function()
        player.setCameraMode(entry.cameraMode)
    end, 0.5)

    return true, "Applied most recent captured camera preset."
end

--- Clear debug NDJSON buffer and truncate workspace log (same path as NPC lighting instrumentation).
--- TTS console: lua DEBUG.beginWorkspaceDebugSession()
function DEBUG.beginWorkspaceDebugSession()
    local W = require("lib.workspace_ndjson_log")
    if W == nil or U.Type(W.beginSession) ~= "function" then
        print("DEBUG.beginWorkspaceDebugSession: lib.workspace_ndjson_log invalid")
        return
    end
    W.beginSession("debug_workspace_ndjson.log")
    W.append("debug_workspace_ndjson.log", {
        hypothesisId = "bootstrap",
        location = "DEBUG.beginWorkspaceDebugSession",
        message = "NDJSON session opened",
        data = { relativePath = "debug_workspace_ndjson.log" },
    })
    print("DEBUG: began workspace debug session -> " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/debug_workspace_ndjson.log")
end

--- Truncate + clear in-memory buffer for a named NDJSON log under `.dev/.debug/<relativePath>`.
--- Same transport as `beginWorkspaceDebugSession` (`lib.workspace_ndjson_log` + `sendExternalMessage`).
--- @param relativePath string e.g. `debug_session.log`
function DEBUG.workspaceNdjsonBegin(relativePath)
    if U.Type(relativePath) ~= "string" or relativePath == "" then
        print("DEBUG.workspaceNdjsonBegin: invalid relativePath")
        return
    end
    ---@diagnostic disable-next-line: undefined-global
    if sendExternalMessage == nil then
        if not warnedNdjsonSendExternalMissing then
            warnedNdjsonSendExternalMissing = true
            print(
                "DEBUG.workspaceNdjsonBegin: sendExternalMessage is nil — workspace NDJSON will NOT be written."
            )
            print(
                "  Fix: use TTS Editor / extension connected to this workspace, enable custom messages (ttsEditor.enableMessages), then Save & Play."
            )
            print(
                "  Expected file when working: <workspaceFolder>/" .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. relativePath
            )
        end
        return
    end
    local W = require("lib.workspace_ndjson_log")
    if W == nil or U.Type(W.beginSession) ~= "function" then
        print("DEBUG.workspaceNdjsonBegin: lib.workspace_ndjson_log invalid")
        return
    end
    W.beginSession(relativePath)
    -- First disk write is always a non-empty append (beginSession does not touch the file).
    W.append(relativePath, {
        hypothesisId = "bootstrap",
        location = "DEBUG.workspaceNdjsonBegin",
        message = "NDJSON session opened",
        data = { relativePath = relativePath },
    })
    print("DEBUG: NDJSON session + bootstrap line -> " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. relativePath)
end

--- Append one NDJSON record (human header + JSON line). File appears under `.dev/.debug/<relativePath>`.
--- @param relativePath string
--- @param payload table fields e.g. sessionId, hypothesisId, location, message, data
function DEBUG.workspaceNdjsonAppend(relativePath, payload)
    if U.Type(relativePath) ~= "string" or relativePath == "" then
        return
    end
    if U.Type(payload) ~= "table" then
        payload = { message = tostring(payload) }
    end
    ---@diagnostic disable-next-line: undefined-global
    if sendExternalMessage == nil then
        if not warnedNdjsonSendExternalMissing then
            warnedNdjsonSendExternalMissing = true
            print(
                "DEBUG.workspaceNdjsonAppend: sendExternalMessage is nil — NDJSON append skipped. See DEBUG.workspaceNdjsonBegin message for fixes."
            )
        end
        return
    end
    local W = require("lib.workspace_ndjson_log")
    if W == nil or U.Type(W.append) ~= "function" then
        print("DEBUG.workspaceNdjsonAppend: lib.workspace_ndjson_log invalid")
        return
    end
    W.append(relativePath, payload)
end

--- Prints a formatted test header
-- @param testName string Name of the test
local function printTestHeader(testName)
    print("\n" .. string.rep("=", 60))
    print("TEST: " .. testName)
    print(string.rep("=", 60))
end

--- Prints a formatted test result and logs to file
-- @param testName string Name of the test
-- @param passed boolean Whether the test passed
-- @param details string Optional details about the test
local function printTestResult(testName, passed, details)
    local status = passed and "✓ PASS" or "✗ FAIL"
    local color = passed and {0, 1, 0} or {1, 0, 0}
    print(status .. ": " .. testName)
    if details then
        print("  Details: " .. details)
    end

    -- Also log to file
    DEBUG.logTestToFile(testName, passed, details, "test_results")
end



