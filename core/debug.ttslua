    print("  soundscapeStopAll()      - Stop all soundscape layers through the silent loop")
    print("  DEBUG.getLookAtOffset(obj)    - Read stored look-at calibration offset (Vector)")
    print("  DEBUG.calibrateLookAtOffset(obj, target, roundIntervalDeg?)")
    print("                          - Calibrate per-object look-at correction using current rotation")
    print("  DEBUG.setRotationLookAt(obj, target, useCalibration?)")
    print("                          - Apply look-at rotation (uses calibration by default)")
    print("  DEBUG.setCenterObject(centerObjOrGuid) - Store center object for coordinate conversions")
    print("  DEBUG.clearCenterObject()              - Clear stored center object")
    print("  DEBUG.setPositionCylindrical(obj, radius, angleDeg, height, target?)")
    print("                          - Position using cylindrical coords relative to stored center")
    print("  DEBUG.setPositionSpherical(obj, radius, angleDeg, angle2Deg, target?)")
    print("                          - Position using spherical coords relative to stored center")
    print("  DEBUG.spawnCustomUiUploadBatchFromManifest(manifest, options?)")
    print("                          - Spawn temporary upload tokens from manifest table")
    print("  DEBUG.spawnCustomUiUploadBatchFromJson(jsonString, options?)")
    print("                          - Spawn temporary upload tokens from JSON manifest string")
    print("  DEBUG.loadCustomUiUploadManifest(moduleName?)")
    print("                          - Require generated manifest module (default: lib.custom_ui_upload_manifest)")
    print("  DEBUG.spawnCustomUiUploadBatch(options?, moduleName?)")
    print("                          - Spawn from loaded/default manifest module")
    print("  DEBUG.spawnNpcTokenUploadBatch(options?)")
    print("                          - Spawn tokenFront_* / tokenBack_* from lib.npc_token_upload_manifest")
    print("  DEBUG.spawnNpcControlBoardTokens(options?)")
    print("                          - Spawn 61 paired gameboard tokens on CONTROL_BOARD (palette grid)")
    print("  DEBUG.clearNpcControlBoardTokens()")
    print("                          - Delete npc_control_token objects")
    print("  DEBUG.applyNpcControlTokenHostedImages()")
    print("                          - After upload+extract, refresh token images from hosted URLs")
    print("  DEBUG.clearCustomUiUploadTokens()")
    print("                          - Delete temporary upload tokens created by debug uploader")
    print("\nLIGHT FEASIBILITY (workshop investigation):")
    print("  testSpawnLightType(), testCloneLight(guid), testInspectLight(guid)")
    print("  testSpawnLight(...), testCompareStructures(guid), findPotentialLights()")
    print("\nHELP:")
    print("  debugHelp()              - Show this help message")
    print("\n" .. string.rep("=", 70))
end

