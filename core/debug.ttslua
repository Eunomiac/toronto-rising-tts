end

--- Snap table from DEBUG.installNpcControlBoardSnaps options (flat fields or `{ config = … }`).
--- @param options table|nil
--- @return table|nil
local function resolveDebugControlBoardSnapConfig(options)
    options = type(options) == "table" and options or {}
    if type(options.config) == "table" then
        return options.config
    end
    if type(options.origin) == "table" or type(options.snapGroups) == "table" or options.rings ~= nil then
        return options
    end
    return nil
end

--- Force CONTROL_BOARD snap grid (normally runs from reconcile / Sync.npcs).
--- @param options table|nil Full `CONTROL_BOARD_SNAP` table, or `{ config?: table }` — overrides `DATA.CONTROL_BOARD_SNAP` for IDE iteration
--- @return boolean
function DEBUG.installNpcControlBoardSnaps(options)
    local Gameboard = require("core.npc_gameboard")
    return Gameboard.installPolarSnaps(nil, {
        force = true,
        config = resolveDebugControlBoardSnapConfig(options),
    }) == true
end

--- Install a new CONTROL_BOARD snap grid, remap tokens by ring + spread offset, sync stage figurines.
--- A. Logs each token's ring (old config catalog match).
--- B. `installPolarSnaps` with `options` / `options.config` as the new snap table.
--- C. Moves tokens + `sessionScene.npcWorld.placements` to best-matching snaps on the same ring; missing rings → palette; `Sync.npcs` unless `skipSync`.
--- @param options table|nil New `CONTROL_BOARD_SNAP` (or `{ config = … }`); optional `oldConfig` for matching override; by default old config comes from currently installed board snaps; `skipSync` to skip figurine reconcile
--- @return table|nil stats from Gameboard.remapControlBoardSnapsToConfig
function DEBUG.installAndRemapNpcControlBoardSnaps(options)
    options = type(options) == "table" and options or {}
    local Gameboard = require("core.npc_gameboard")
    local newConfig = resolveDebugControlBoardSnapConfig(options)
    if type(newConfig) ~= "table" then
        print("[DEBUG] installAndRemapNpcControlBoardSnaps: pass a CONTROL_BOARD_SNAP table or { config = … }")
        return nil
    end
    local oldConfig = type(options.oldConfig) == "table" and options.oldConfig or nil
    local hasInstalled = Gameboard.getInstalledControlBoardSnapConfig() ~= nil
    local sourceLabel = hasInstalled and "installed snaps" or "DATA fallback"
    if oldConfig ~= nil then
        sourceLabel = "options.oldConfig"
    end
    print("[DEBUG] installAndRemapNpcControlBoardSnaps: begin (" .. sourceLabel .. " → new config)")
    return Gameboard.remapControlBoardSnapsToConfig(oldConfig, newConfig, {
        skipSync = options.skipSync == true,
    })
end

--- Print control-board table-component marker decisions (table leaves, etc.) and optionally force a debug reconcile pass.
--- @param options table|nil `{ includeTagless?: boolean, forceReconcile?: boolean }`
--- @return table|nil
function DEBUG.dumpControlBoardTableComponents(options)
    options = type(options) == "table" and options or {}
    local Gameboard = require("core.npc_gameboard")
    if options.forceReconcile == true then
        Gameboard.reconcileControlBoardFromState({
            force = true,
            debugComponentMarkers = true,
        })
    end
    local result = Gameboard.debugDescribeControlBoardTableComponents({
        includeTagless = options.includeTagless == true,
    })
    print("[DEBUG] dumpControlBoardTableComponents: scanned " .. tostring(result and result.count or 0) .. " marker(s)")
    return result
end

--- Print snap count from config without installing (fast tuning).
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
function DEBUG.previewControlBoardSnapCount(config)
    local Gameboard = require("core.npc_gameboard")
    local total, perRing = Gameboard.countControlBoardSnapPoints(config)
    print("[DEBUG] CONTROL_BOARD snap count: " .. tostring(total))
    for ringIndex, ringTotal in ipairs(perRing) do
        print("  ring " .. tostring(ringIndex) .. ": " .. tostring(ringTotal))
    end
end

--- Print Lua table or CSV of snap family roles → world X/Z (STAGE) for tuning or migration.
--- @param config table|nil Full CONTROL_BOARD_SNAP table or nil for DATA default
--- @param options table|nil `{ useInterpolatedRings?: boolean, format?: "lua"|"csv" }`
function DEBUG.exportControlBoardSnapFamilies(config, options)
    local Gameboard = require("core.npc_gameboard")
    options = type(options) == "table" and options or {}
    local byRole = Gameboard.exportSnapFamiliesByRole(config, options)
    local format = options.format == "csv" and "csv" or "lua"
    local text = format == "csv"
        and Gameboard.formatSnapFamiliesCsv(byRole)
        or Gameboard.formatSnapFamiliesLua(byRole)
    print("[DEBUG] CONTROL_BOARD snap families (world X/Z on STAGE, " .. format .. "):")
    print(text)
    return byRole
end

--- Display zone status
function DEBUG.showZones()
    printTestHeader("Zone Status")
    local zonesLocked = S.getStateVal("zones", "allZonesLocked")
    print("Zones Locked: " .. tostring(zonesLocked))
    print("Zone Events Active: " .. tostring(not zonesLocked))
end

--- Toggle all Anchor-tagged objects:
--- hidden(alpha=0) -> reveal(alpha=1) and y-190
--- visible(alpha=1) -> hide(alpha=0) and y+190
--- @return table
function DEBUG.toggleAllAnchorObjects()
    local anchors = getObjectsWithTag("Anchor") or {}
    local movedUp = 0
    local movedDown = 0
    local skipped = 0
    for _, obj in ipairs(anchors) do
        if obj ~= nil then
            local pos = obj.getPosition()
            local tint = obj.getColorTint() or { 1, 1, 1, 1 }
            local r = tint.r or tint[1] or 1
            local g = tint.g or tint[2] or 1
            local b = tint.b or tint[3] or 1
            local a = tint.a or tint[4] or 1
            local isHidden = a <= 0.001
            if isHidden then
                obj.setPosition({ x = pos.x, y = pos.y - 190, z = pos.z })
                obj.setColorTint({ r, g, b, 1 })
                movedDown = movedDown + 1
            else
                obj.setPosition({ x = pos.x, y = pos.y + 190, z = pos.z })
                obj.setColorTint({ r, g, b, 0 })
                movedUp = movedUp + 1
            end
        else
            skipped = skipped + 1
        end
    end
    local summary = {
        total = #anchors,
        movedUpHidden = movedUp,
        movedDownShown = movedDown,
        skipped = skipped,
    }
    print("[DEBUG.toggleAllAnchorObjects] " .. JSON.encode(summary))
    return summary
end

--- Toggle Spotlight-tagged object arrows using AssetBundle looping effects.
--- UI 1 <-> UI 2 maps to API index 0 <-> 1 (0-based).
--- @return table
function DEBUG.toggleAllSpotlightArrows()
    local spotlights = getObjectsWithTag("Spotlight") or {}
    local toggled = 0
    local skipped = 0
    for _, obj in ipairs(spotlights) do
        local ab = obj and obj.AssetBundle or nil
        if ab ~= nil and ab.getLoopingEffectIndex ~= nil and ab.playLoopingEffect ~= nil then
            local currentIdx0 = ab.getLoopingEffectIndex()
            if type(currentIdx0) == "number" then
                local currentUi = currentIdx0 + 1
                local targetUi = (currentUi == 2) and 1 or 2
                local targetIdx0 = targetUi - 1
                ab.playLoopingEffect(targetIdx0)
                toggled = toggled + 1
            else
                skipped = skipped + 1
            end
        else
            skipped = skipped + 1
        end
    end
    local summary = {
        tagged = #spotlights,
        toggled = toggled,
        skipped = skipped,
    }
    print("[DEBUG.toggleAllSpotlightArrows] " .. JSON.encode(summary))
    return summary
end

--- Inspect soundscape AssetBundle emitters, looping/trigger effect names, and AudioSource counts.
