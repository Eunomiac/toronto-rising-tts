--- Asserts gameState.storytellerRolls fields for E2E.
-- @param expected table  { liveSlotIndex?, initiateBlocked?, initiateLabel?, initiateRollType? }
-- @return boolean pass
-- @usage lua rollStConfirm({ liveSlotIndex = 1 })
function DEBUG.rollStConfirm(expected)
    if type(expected) ~= "table" then
        print("[rollStConfirm] FAIL: expected table required")
        return false
    end
    local failures = {}
    local root = S.getStateVal("storytellerRolls") or {}
    if expected.liveSlotIndexAbsent == true then
        if root.liveSlotIndex ~= nil then
            failures[#failures + 1] = "liveSlotIndex: expected nil, got "
                .. tostring(root.liveSlotIndex)
        end
    elseif type(expected.liveSlotIndex) == "number" then
        local actual = root.liveSlotIndex
        if actual ~= expected.liveSlotIndex then
            failures[#failures + 1] = "liveSlotIndex: got " .. tostring(actual)
                .. ", want " .. tostring(expected.liveSlotIndex)
        end
    end
    if expected.initiateBlocked == true then
        local STR = require("core.storyteller_rolls")
        local lbl = (type(expected.initiateLabel) == "string") and expected.initiateLabel or "E2E blocked"
        local rt = expected.initiateRollType or C.RollType.STANDARD
        local ok = STR.initiateNpcRoll(lbl, rt)
        if ok then
            failures[#failures + 1] = "initiateNpcRoll: expected blocked, got ok"
        end
    end
    if #failures == 0 then
        print("[rollStConfirm] PASS")
        return true
    end
    print("[rollStConfirm] FAIL")
    for i, line in ipairs(failures) do
        print(string.format("  %d) %s", i, line))
    end
    return false
end

--- E2E: spawn pool dice, startRolling, preset faces, settle (no randomize).
-- Replaces panel **Roll** + manual face tweak. Run after `rollTest` + pool spawn
-- (`rollE2eSetPoolAndSpawn` / `rollE2eSetPoolAutoHunger` / Suite F `RC.setPool` + `GlobalSpawnDefaultPoolDiceForActive`).
-- Do not click panel Roll before this helper.
-- @param color string
-- @param facesByKind table
-- @return boolean pass
-- @usage lua rollE2eSettlePresetCheck("Brown", { rouse = { 4 } })
function DEBUG.rollE2eSettlePresetCheck(color, facesByKind)
    if RC == nil then
        print("[rollE2eSettlePresetCheck] FAIL: RC not loaded")
        return false
    end
    if type(color) ~= "string" or type(facesByKind) ~= "table" then
        print("[rollE2eSettlePresetCheck] FAIL: usage rollE2eSettlePresetCheck(color, { rouse = { 4 } })")
        return false
    end

    local pid = S.getPlayerID(color)
    if pid == nil then
        print("[rollE2eSettlePresetCheck] FAIL: no playerID for " .. color)
        return false
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil then
        print("[rollE2eSettlePresetCheck] FAIL: no active roll for " .. color
            .. " (run rollTest first; do not click panel Roll before this helper)")
        return false
    end

    if active.phase == C.RollPhase.PRE_ROLL then
        if Global ~= nil and type(Global.call) == "function" then
            Global.call("GlobalSpawnActivePoolDiceForActive", { color = color })
        end
        if RC.startRolling(color) ~= true then
            print("[rollE2eSettlePresetCheck] FAIL: RC.startRolling failed (phase="
                .. tostring(active.phase) .. ")")
            return false
        end
    elseif active.phase ~= C.RollPhase.ROLLING and active.phase ~= C.RollPhase.POST_ROLL then
        print("[rollE2eSettlePresetCheck] FAIL: phase " .. tostring(active.phase)
            .. " (expected preRoll, rolling, or postRoll)")
        return false
    end

    local facesSet = DEBUG.rollSetFaces(color, facesByKind)
    if type(facesSet) ~= "number" or facesSet < 1 then
        print("[rollE2eSettlePresetCheck] FAIL: no check dice on table to preset (facesSet="
            .. tostring(facesSet) .. ")")
        return false
    end

    RC.onDiceSettled(color)
    print("[rollE2eSettlePresetCheck] PASS — preset faces applied and settle triggered for " .. color)
    return true
end

--- Prints the full active roll record and queue for a player.
-- @param color string  Player seat color
-- @usage lua rollState("Brown")
function DEBUG.rollState(color)
    if type(color) ~= "string" then
        print("Usage: rollState(color)")
        return
    end
    local pid    = S.getPlayerID(color)
    local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
    local queue  = (pid and S.getStateVal("playerData", pid, "hud", "rollData", "queue")) or {}
    print(string.format("[DEBUG.rollState] %s — active roll:", color))
    if active ~= nil then
        print(JSON.encode_pretty(active))
    else
        print("  (no active roll)")
    end
    if #queue > 0 then
        print(string.format("  queue (%d): %s", #queue, JSON.encode(queue)))
    end
end

--- Normalizes a custom-die rotation label (TTS may use string or number).
-- @param v string|number|nil
-- @return number|nil
local function e2eFaceValueNumber(v)
    if type(v) == "number" then
        return math.floor(v)
    end
    if type(v) == "string" then
        return tonumber(v)
    end
    return nil
end

--- True when a rotation-value entry matches the target face (1–10).
-- @param entryValue string|number
-- @param target number
-- @return boolean
local function e2eRotationEntryMatches(entryValue, target)
    local n = e2eFaceValueNumber(entryValue)
    return n ~= nil and n == target
end

--- Reads a custom die face as integer 1–10 (E2E preset verify only).
-- @param obj Object
-- @return number|nil
local function e2eReadDieFaceValue(obj)
    if obj == nil then
        return nil
    end
    local raw = nil
    if obj.getRotationValue ~= nil then
        raw = obj.getRotationValue()
    end
    if raw == nil and obj.getValue ~= nil then
        raw = obj.getValue()
    end
    return e2eFaceValueNumber(raw)
end

--- Applies one custom-die face via instant setRotation (not setRotationValue).
-- setValue/setRotationValue animate (lift/spin/drop); immediate getValue still reads the old face.
-- Bag-spawned dice are locked until panel Roll — unlock briefly for the snap.
-- @param obj Object
-- @param faceVal number 1–10
-- @return boolean true when read-back matches target
local function e2eSetDieFaceValue(obj, faceVal)
    if obj == nil or type(faceVal) ~= "number" then
        return false
    end
    local target = math.floor(faceVal)
    if target < 1 or target > 10 then
        return false
    end

    local snapRot = nil
    if obj.getRotationValues ~= nil then
        local rotValues = obj.getRotationValues()
        if type(rotValues) == "table" then
            for _, entry in ipairs(rotValues) do
                if type(entry) == "table" and e2eRotationEntryMatches(entry.value, target) then
                    snapRot = entry.rotation
                    break
                end
            end
        end
    end
    if snapRot == nil or type(snapRot.x) ~= "number" then
        print(string.format(
            "[DEBUG.rollSetFaces] WARN: no RotationValues entry for face %d (guid=%s)",
            target, tostring(obj.getGUID())))
        return false
    end

    local wasLocked = obj.getLock()
    if wasLocked then
        obj.setLock(false)
    end
    if obj.setRotation ~= nil then
        obj.setRotation({ x = snapRot.x, y = snapRot.y, z = snapRot.z })
    elseif obj.setRotationSmooth ~= nil then
        obj.setRotationSmooth({ x = snapRot.x, y = snapRot.y, z = snapRot.z }, false, true)
    else
        if wasLocked then
            obj.setLock(true)
        end
        return false
    end

    local actual = e2eReadDieFaceValue(obj)
    if wasLocked then
        obj.setLock(true)
    end
    if actual ~= target then
        print(string.format(
            "[DEBUG.rollSetFaces] WARN: snap face %d read back as %s (guid=%s)",
            target, tostring(actual), tostring(obj.getGUID())))
        return false
    end
    return true
end

--- Locks rouse-family dice so Take Half + rouse `recalculate` gate passes after E2E face preset.
-- @param color string
-- @param rollId string
local function e2eLockRouseDiceForTakeHalf(color, rollId)
    if RC == nil or type(rollId) ~= "string" then
        return
    end
    local _, objectsByKind = RC._getDicePoolsForRoll(color, rollId)
    for _, kind in ipairs({ DK.KIND_ROUSE, DK.KIND_BLOOD_SURGE_ROUSE, DK.KIND_OBLIV_ROUSE }) do
        local objs = objectsByKind[kind]
        if type(objs) == "table" then
            for _, obj in ipairs(objs) do
                if obj ~= nil then
                    obj.setLock(true)
                end
            end
        end
    end
end

--- Sets physical die faces for the active roll (ROLLING or POST_ROLL), then recalculates.
-- @param color string
-- @param facesByKind table e.g. { normal = {7, 7}, hunger = {10, 1}, rouse = {4} }
-- @return number facesSet
-- @usage lua rollSetFaces("Brown", { normal = {4, 4}, hunger = {10, 1} })
function DEBUG.rollSetFaces(color, facesByKind)
    if RC == nil then
        print("[DEBUG.rollSetFaces] RC not loaded")
        return 0
    end
    if type(color) ~= "string" or type(facesByKind) ~= "table" then
        print("Usage: rollSetFaces(color, { normal={7,7}, hunger={10,1}, ... })")
        return 0
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        print("[DEBUG.rollSetFaces] no playerID for " .. color)
        return 0
    end
    local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
    if active == nil or type(active.id) ~= "string" then
        print("[DEBUG.rollSetFaces] no active roll for " .. color)
        return 0
    end
    if active.phase ~= C.RollPhase.ROLLING and active.phase ~= C.RollPhase.POST_ROLL then
        print(string.format(
            "[DEBUG.rollSetFaces] %s: roll phase is %s (need rolling or postRoll)",
            color, tostring(active.phase)))
        return 0
    end
    local _, objectsByKind = RC._getDicePoolsForRoll(color, active.id)
    local setCount = 0
    for kind, values in pairs(facesByKind) do
        if type(values) == "table" and type(objectsByKind[kind]) == "table" then
            local objs = objectsByKind[kind]
            for i, faceVal in ipairs(values) do
                local obj = objs[i]
                if obj ~= nil and type(faceVal) == "number" then
                    if e2eSetDieFaceValue(obj, faceVal) then
                        setCount = setCount + 1
                    end
                end
            end
        end
    end
    if active.takeHalfAwaitingRouse == true then
        e2eLockRouseDiceForTakeHalf(color, active.id)
    end
    RC.recalculate(color)
    print(string.format("[DEBUG.rollSetFaces] %s: set %d face(s); recalculated.", color, setCount))
    return setCount
end

--- Apply temporary manual conditions for E2E (e.g. Suite F). Cleared with rollE2eClearConditions.
-- @param color string
-- @param conditionIds table Array of condition id strings from condition_defs
-- @usage lua rollE2eApplyConditions("Brown", { "e2eBestialNull" })
function DEBUG.rollE2eApplyConditions(color, conditionIds)
    if type(color) ~= "string" or type(conditionIds) ~= "table" then
        print("Usage: rollE2eApplyConditions(color, { 'conditionId', ... })")
        return
    end
    local playerID = S.getPlayerID(color)
    if playerID == nil then
        print("[DEBUG.rollE2eApplyConditions] no playerID for " .. color)
        return
    end
    local Conditions = require("core.conditions")
    for _, cid in ipairs(conditionIds) do
        if type(cid) == "string" and cid ~= "" then
            Conditions.setManual(playerID, cid, true)
            print("[DEBUG.rollE2eApplyConditions] set " .. cid .. " on " .. color)
        end
    end
end

--- Clear manual conditions applied for E2E on one seat.
-- @param color string
-- @param conditionIds table|nil  If nil, clears e2eBestialNull
function DEBUG.rollE2eClearConditions(color, conditionIds)
    if type(color) ~= "string" then
        print("Usage: rollE2eClearConditions(color, conditionIds?)")
        return
    end
    local playerID = S.getPlayerID(color)
    if playerID == nil then
        return
    end
    local ids = conditionIds
    if type(ids) ~= "table" then
        ids = { "e2eBestialNull" }
    end
    local Conditions = require("core.conditions")
    for _, cid in ipairs(ids) do
        if type(cid) == "string" and cid ~= "" then
            Conditions.clear(playerID, cid)
        end
    end
    print("[DEBUG.rollE2eClearConditions] cleared on " .. color)
end

--- Sets active.pool and spawns staged dice (PRE_ROLL). Use before rollE2eSettlePresetCheck.
-- @param color string
-- @param normal number
-- @param hunger number
-- @return boolean
-- @usage lua rollE2eSetPoolAndSpawn("Brown", 2, 0)
function DEBUG.rollE2eSetPoolAndSpawn(color, normal, hunger)
    if RC == nil then
        print("[rollE2eSetPoolAndSpawn] FAIL: RC not loaded")
        return false
    end
    if type(color) ~= "string" or type(normal) ~= "number" or type(hunger) ~= "number" then
        print("[rollE2eSetPoolAndSpawn] FAIL: usage rollE2eSetPoolAndSpawn(color, normal, hunger)")
        return false
    end
    if RC.setPool(color, normal, hunger) ~= true then
        print("[rollE2eSetPoolAndSpawn] FAIL: RC.setPool failed for " .. color)
        return false
    end
    if Global == nil or type(Global.call) ~= "function" then
        print("[rollE2eSetPoolAndSpawn] FAIL: Global.call unavailable")
        return false
    end
    Global.call("GlobalSpawnActivePoolDiceForActive", { color = color })
    print(string.format(
        "[rollE2eSetPoolAndSpawn] %s: pool normal=%d hunger=%d spawned",
        color, normal, hunger))
    return true
end

--- Builds pool from Auto-Hunger bag-click rules, then spawns (Suite G classify tests).
-- Each virtual Normal-bag click adds Hunger while pool.hunger < seat hunger, else Normal.
-- @param color string
-- @param normalBagClicks number  Total left-clicks on Normal bag (not Hunger bag)
-- @return boolean
-- @usage lua rollE2eSetPoolAutoHunger("Brown", 4)
function DEBUG.rollE2eSetPoolAutoHunger(color, normalBagClicks)
    if type(color) ~= "string" or type(normalBagClicks) ~= "number" then
        print("[rollE2eSetPoolAutoHunger] FAIL: usage rollE2eSetPoolAutoHunger(color, normalBagClicks)")
        return false
    end
    local clicks = math.max(0, math.floor(normalBagClicks))
    local pid = S.getPlayerID(color)
    local hungerLevel = 0
    if pid ~= nil then
        local stats = S.getStateVal("playerData", pid, "stats")
        if type(stats) == "table" then
            hungerLevel = tonumber(stats.hunger) or 0
        end
    end
    local hunger = 0
    local normal = 0
    for _ = 1, clicks do
        if hunger < hungerLevel then
            hunger = hunger + 1
        else
            normal = normal + 1
        end
    end
    return DEBUG.rollE2eSetPoolAndSpawn(color, normal, hunger)
end

--- E2E: add a pool kind count and spawn staged dice (PRE_ROLL only).
-- Use after `rollE2eSetPoolAndSpawn` when a test needs rouse (or other kinds) in the pool.
-- @param color string
-- @param kind string  e.g. `DK.KIND_ROUSE` (`"rouse"`)
-- @param count number
-- @return boolean
-- @usage lua rollE2eAddPoolKindSpawn("Brown", "rouse", 1)
function DEBUG.rollE2eAddPoolKindSpawn(color, kind, count)
    if RC == nil then
        print("[rollE2eAddPoolKindSpawn] FAIL: RC not loaded")
        return false
    end
    if type(color) ~= "string" or type(kind) ~= "string" or type(count) ~= "number" then
        print("[rollE2eAddPoolKindSpawn] FAIL: usage rollE2eAddPoolKindSpawn(color, kind, count)")
        return false
    end
    if RC.setPoolKindCount(color, kind, count) ~= true then
        print("[rollE2eAddPoolKindSpawn] FAIL: RC.setPoolKindCount failed for " .. color)
        return false
    end
    if Global == nil or type(Global.call) ~= "function" then
        print("[rollE2eAddPoolKindSpawn] FAIL: Global.call unavailable")
        return false
    end
    Global.call("GlobalSpawnActivePoolDiceForActive", { color = color })
    print(string.format("[rollE2eAddPoolKindSpawn] %s: %s=%d spawned", color, kind, count))
    return true
end

--- True when broadcast panel content was populated (active attribute may lag in same frame).
-- @return boolean
local function rollE2eBroadcastPanelHasContent()
    local classText = tostring(UI.getValue("rollResult_class") or "")
    local nameText = tostring(UI.getValue("rollResult_name") or "")
    return classText ~= "" or nameText ~= ""
end

--- True when the shared roll result broadcast panel is visible.
-- @return boolean
local function rollE2eBroadcastPanelVisible()
    local activeAttr = UI.getAttribute("rollResult_panel", "active")
    if string.lower(tostring(activeAttr or "")) == "true" then
        return true
    end
    return rollE2eBroadcastPanelHasContent()
end

--- Maps E2E `resultClass` shorthands (e.g. "Win") to panel labels (`C.ResultClassLabel`).
-- @param expected string
-- @return boolean matches classText
local function rollE2eBroadcastClassMatches(classText, expected)
    if type(expected) ~= "string" or expected == "" then
        return false
    end
    local hay = string.lower(classText)
    local needles = { string.lower(expected) }
    local norm = string.lower(expected):gsub("%s+", "")
    local shorthandToKey = {
        win = C.ResultClass.WIN,
        success = C.ResultClass.WIN,
        failure = C.ResultClass.FAILURE,
        fail = C.ResultClass.FAILURE,
        criticalwin = C.ResultClass.CRITICAL_WIN,
        messycritical = C.ResultClass.MESSY_CRITICAL,
        bestialfailure = C.ResultClass.BESTIAL_FAILURE,
        totalfailure = C.ResultClass.TOTAL_FAILURE,
        totalbestialfailure = C.ResultClass.TOTAL_BESTIAL_FAILURE,
    }
    local rcKey = shorthandToKey[norm]
    if rcKey ~= nil and type(C.ResultClassLabel[rcKey]) == "string" then
        needles[#needles + 1] = string.lower(C.ResultClassLabel[rcKey])
    end
    for _, needle in ipairs(needles) do
        if needle ~= "" and string.find(hay, needle, 1, true) ~= nil then
            return true
        end
    end
    return false
end

--- E2E: assert `rollResult_*` broadcast UI after `rollForceConfirm` / panel Confirm.
-- @param expected table|nil  `{ visible = true, resultClass = "Failure", successes = 2, margin = -1 }`
--   `visible` — when true, or when any field below is set, panel must be active
--   `resultClass` — substring match (case-insensitive) on `rollResult_class`; E2E shorthands
--     ("Win", "Failure", …) also match `C.ResultClassLabel` panel text (e.g. Win → SUCCESS)
--   `successes` — integer N matches `"N success"` / `"N successes"` on `rollResult_successes`
--   `margin` — integer matches `Margin: %+d` on `rollResult_margin`
--   `marginAbsent` — when true, `rollResult_margin` must be empty
-- @return boolean pass
-- @usage lua rollE2eExpectBroadcast({ visible = true, resultClass = "Failure", successes = 2 })
function DEBUG.rollE2eExpectBroadcast(expected)
    if type(expected) ~= "table" then
        print("[rollE2eExpectBroadcast] FAIL: usage rollE2eExpectBroadcast({ visible = true, ... })")
        return false
    end

    local failures = {}
    local panelVisible = rollE2eBroadcastPanelVisible()
    local wantsContent = type(expected.resultClass) == "string"
        or type(expected.successes) == "number"
        or type(expected.margin) == "number"
        or expected.marginAbsent == true
    -- Field assertions require a visible panel; omitting visible=true still implies it.
    local mustBeVisible = expected.visible == true
        or (expected.visible == nil and wantsContent)

    if expected.visible == false then
        if panelVisible then
            failures[#failures + 1] = "rollResult_panel: visible but expected hidden"
        end
        if wantsContent then
            failures[#failures + 1] = "rollResult_panel: field assertions require visible panel"
        end
    elseif mustBeVisible and not panelVisible then
        failures[#failures + 1] = "rollResult_panel: not visible"
    end

    if panelVisible and mustBeVisible then
        local classText = tostring(UI.getValue("rollResult_class") or "")
        if type(expected.resultClass) == "string" then
            if not rollE2eBroadcastClassMatches(classText, expected.resultClass) then
                failures[#failures + 1] = "rollResult_class: got \""
                    .. classText .. "\", want contains \"" .. expected.resultClass .. "\""
            end
        end

        if type(expected.successes) == "number" then
            local succText = tostring(UI.getValue("rollResult_successes") or "")
            local wantSucc = string.format("%d success", expected.successes)
            local wantSucces = string.format("%d successes", expected.successes)
            if succText ~= wantSucc and succText ~= wantSucces then
                failures[#failures + 1] = "rollResult_successes: got \""
                    .. succText .. "\", want \"" .. wantSucc .. "\" or \"" .. wantSucces .. "\""
            end
        end

        if type(expected.margin) == "number" then
            local margText = tostring(UI.getValue("rollResult_margin") or "")
            local wantMarg = string.format("Margin: %+d", expected.margin)
            if margText ~= wantMarg then
                failures[#failures + 1] = "rollResult_margin: got \""
                    .. margText .. "\", want \"" .. wantMarg .. "\""
            end
        end

        if expected.marginAbsent == true then
            local margText = tostring(UI.getValue("rollResult_margin") or "")
            if margText ~= "" then
                failures[#failures + 1] = "rollResult_margin: expected empty, got \""
                    .. margText .. "\""
            end
        end
    end

    if #failures == 0 then
        print("[rollE2eExpectBroadcast] PASS")
        return true
    end
    print("[rollE2eExpectBroadcast] FAIL")
    for i, line in ipairs(failures) do
        print(string.format("  %d) %s", i, line))
    end
    return false
end

--- Clears all Storyteller roll drawer slots (live + resolved rows).
local function clearAllStorytellerRollSlots()
    local STR = require("core.storyteller_rolls")
    for slotIndex = 1, 3 do
        STR.cancelSlot(slotIndex)
    end
end

--- Cancels the active roll for a single player. Useful for mid-test cleanup.
-- Destroys staged/released bag dice and table dice for the roll (via RC.cancelRoll).
-- On Black, also clears all ST dashboard slots and drawer dice.
-- @param color string  Player seat color
-- @usage lua rollCancel("Brown")
function DEBUG.rollCancel(color)
    if RC == nil then print("[DEBUG.rollCancel] RC not loaded"); return end
    if type(color) ~= "string" then print("Usage: rollCancel(color)"); return end
    local cancelled = RC.cancelRoll(color)
    if color == "Black" then
        clearAllStorytellerRollSlots()
    end
    if color ~= E2E_RETURN_SEAT then
        rollE2eReturnHostSeat()
    end
    print(string.format("[DEBUG.rollCancel] %s: %s",
        color, cancelled and "roll cancelled" or "no active roll to cancel"))
end

--- E2E console banner width (fixed line length for visual scan in TTS log).
local E2E_PRINT_HEADER_WIDTH = 100
local E2E_PRINT_HEADER_LEAD = 10

--- Padding character for `printHeader` by level: 1 = *, 2 = =, 3 = -.
-- @param level number 1..3
-- @return string|nil
local function e2ePrintHeaderPadChar(level)
    if level == 1 then
        return "*"
    end
    if level == 2 then
        return "="
    end
    if level == 3 then
        return "-"
    end
    return nil
end

--- Build a fixed-width E2E section banner (100 chars) and print it to the console.
-- Layout: 10 pad chars + optional " " + text + " " + pad fill to 100.
-- @param text string Banner label (use "" for pad-only separator line)
-- @param level number Header level 1..3 (*, =, -)
-- @return string|nil Printed line, or nil on validation error
-- @usage lua printHeader("Suite 0: Cleanup", 1)
-- @usage lua printHeader("", 1)
function DEBUG.printHeader(text, level)
    if type(text) ~= "string" then
        print("[DEBUG.printHeader] FAIL: text must be a string")
        return nil
    end
    if type(level) ~= "number" or level < 1 or level > 3 then
        print("[DEBUG.printHeader] FAIL: level must be 1, 2, or 3")
        return nil
    end

    local padChar = e2ePrintHeaderPadChar(level)
    local lead = string.rep(padChar, E2E_PRINT_HEADER_LEAD)
    local mid = ""
    if text ~= "" then
        mid = " " .. text .. " "
    end

    local used = E2E_PRINT_HEADER_LEAD + #mid
    if used > E2E_PRINT_HEADER_WIDTH then
        local maxText = E2E_PRINT_HEADER_WIDTH - E2E_PRINT_HEADER_LEAD - 2
        print(string.format(
            "[DEBUG.printHeader] FAIL: text too long (%d chars; max %d)",
            #text,
            maxText
        ))
        return nil
    end

    local trailLen = E2E_PRINT_HEADER_WIDTH - used
    local line = lead .. mid .. string.rep(padChar, trailLen)
    print(line)
    return line
end

--- Active campaign for DEBUG.RunTest / RunTest (console step runner).
local e2eRunTestState = {
    campaign = nil,
    playbook = nil,
    index = 0,
}

--- Normalize playbook campaign name (Dice, Scenes, Gameboard).
-- @param name string|nil
-- @return string|nil
local function normalizeE2eCampaignName(name)
    if type(name) ~= "string" then
        return nil
    end
    local trimmed = name:match("^%s*(.-)%s*$")
    if trimmed == "" then
        return nil
    end
    local lower = string.lower(trimmed)
    if lower == "dice" then
        return "Dice"
    end
    if lower == "scenes" then
        return "Scenes"
    end
    if lower == "gameboard" then
        return "Gameboard"
    end
    return nil
end

--- Load generated playbook module for a prepared campaign.
-- @param campaign string Dice | Scenes | Gameboard
-- @return table|nil playbook
-- @return string|nil err
local function e2eLoadPlaybookModule(campaign)
    if campaign == "Dice" then
        local ok, mod = pcall(require, "lib.e2e_playbook_dice")
        if not ok then
            return nil, "require failed (run npm run e2e-playbook:generate && Save & Play): " .. tostring(mod)
        end
        if type(mod) ~= "table" or type(mod.steps) ~= "table" or type(mod.stepCount) ~= "number" then
            return nil, "lib.e2e_playbook_dice is missing steps/stepCount — regenerate playbook Lua"
        end
        return mod, nil
    end
    return nil, "not yet prepared"
end

--- Run the next E2E playbook step, or initialize a campaign.
-- With a campaign name: reset index and arm the playbook (does not run a step).
-- With no args: advance index by one and execute the next U.RunSequence from the armed campaign.
-- @param campaignName string|nil "Dice" | "Scenes" | "Gameboard"
-- @usage lua RunTest("Dice")
-- @usage lua RunTest()
function DEBUG.RunTest(campaignName)
    if campaignName ~= nil then
        local key = normalizeE2eCampaignName(campaignName)
        if key == nil then
            print(string.format(
                "[RunTest] Unknown campaign '%s'. Known: Dice, Scenes, Gameboard",
                tostring(campaignName)
            ))
            return false
        end

        if key == "Scenes" or key == "Gameboard" then
            print(string.format("[RunTest] Campaign '%s' is not yet prepared.", key))
            return false
        end

        local playbook, err = e2eLoadPlaybookModule(key)
        if playbook == nil then
            print("[RunTest] " .. tostring(err))
            return false
        end

        e2eRunTestState.campaign = key
        e2eRunTestState.playbook = playbook
        e2eRunTestState.index = 0
        print(string.format(
            "[RunTest] Initialized '%s' — %d steps from %s. Call RunTest() for step 1.",
            key,
            playbook.stepCount,
            tostring(playbook.sourceMarkdown)
        ))
        return true
    end

    if e2eRunTestState.playbook == nil then
        print("[RunTest] No campaign active. Start with RunTest(\"Dice\").")
        return false
    end

    local nextIndex = e2eRunTestState.index + 1
    local playbook = e2eRunTestState.playbook
    if nextIndex > playbook.stepCount then
        print(string.format(
            "[RunTest] '%s' complete (%d steps). Re-init with RunTest(\"%s\") to restart.",
            e2eRunTestState.campaign,
            playbook.stepCount,
            e2eRunTestState.campaign
        ))
        return false
    end

    local steps = playbook.steps
    local sequence = steps[nextIndex]
    if type(sequence) ~= "table" then
        print(string.format("[RunTest] FAIL: step %d is not a sequence table", nextIndex))
        return false
    end

    e2eRunTestState.index = nextIndex
    print(string.format(
        "[RunTest] %s step %d/%d",
        e2eRunTestState.campaign,
        nextIndex,
        playbook.stepCount
    ))
    U.RunSequence(sequence)

    local humanGates = playbook.humanGateAfterStep
    if type(humanGates) == "table" and humanGates[nextIndex] == true then
        print("[RunTest] HUMAN GATE — perform the [HUMAN] action, then call RunTest() for the next step.")
    elseif nextIndex >= playbook.stepCount then
        print("[RunTest] Final step dispatched. Campaign will report complete on the next RunTest().")
    end

    return true
end

--- Cancels all active rolls across every player color. Quick full reset between tests.
-- @usage lua rollCancelAll()
function DEBUG.rollCancelAll()
    if RC == nil then print("[DEBUG.rollCancelAll] RC not loaded"); return end
    local count = 0
    for _, color in ipairs(C.PlayerColors) do
        if RC.cancelRoll(color) then count = count + 1 end
    end
    if RC.cancelRoll("Black") then count = count + 1 end
    clearAllStorytellerRollSlots()
    rollE2eReturnHostSeat()
    print(string.format("[DEBUG.rollCancelAll] Cancelled %d active roll(s).", count))
end

--- Initiates a Storyteller NPC roll on Black (uses drawer slot 1..3).
-- @param label string|nil
-- @param rollType string|nil
-- @usage lua rollStTest("Evangeline Dupont")
-- @usage lua rollStTest("Garou", C.RollType.WEREWOLF)
function DEBUG.rollStTest(label, rollType)
    if rollE2eSeatPrepInternal("Black") ~= true then
        print("[DEBUG.rollStTest] E2E seat prep failed — aborting.")
        return
    end
    local STR = require("core.storyteller_rolls")
    local lbl = (type(label) == "string" and label ~= "") and label or "Debug NPC"
    local ok = STR.initiateNpcRoll(lbl, rollType)
    print(string.format("[DEBUG.rollStTest] initiate: %s", ok and "ok" or "blocked"))
end

--- Prints gameState.storytellerRolls slots.
-- @usage lua rollStSlots()
function DEBUG.rollStSlots()
    local root = S.getStateVal("storytellerRolls") or {}
    print("[DEBUG.rollStSlots] " .. JSON.encode_pretty(root))
end

--- Force-confirms the active roll (clicks CONFIRM). Use after POST_ROLL settle/recalc.
-- @param color string  Player seat color
-- @usage lua rollForceConfirm("Brown")
function DEBUG.rollForceConfirm(color)
    if RC == nil then print("[DEBUG.rollForceConfirm] RC not loaded"); return end
    if type(color) ~= "string" then print("Usage: rollForceConfirm(color)"); return end
    local ok = RC.confirmRoll(color)
    print(string.format("[DEBUG.rollForceConfirm] %s: %s",
        color, ok and "roll confirmed and resolved" or "confirm failed — is the roll in POST_ROLL?"))
end

-- Uses U.rotateAroundPoint to keep angle conventions consistent.
-- @param obj Object|table|userdata TTS object to move (GameObject)
-- @param distance number Distance from center in world units
-- @param angle number World angle in degrees (0 = +Z, 90 = +X, 180 = -Z, 270 = -X)
-- @param center Vector|table Optional center position (default: table center at object's current Y)
-- @usage lua DEBUG.tableRotateTo(obj, 30, 180)
function DEBUG.tableRotateTo(obj, distance, angle, center)
    local resolvedObj = U.getObject(obj, true) or obj
    U.Val("DEBUG.tableRotateTo", resolvedObj, U.isGameObject(resolvedObj), "obj must be a valid GameObject or GUID")
    U.Val("DEBUG.tableRotateTo", distance, U.Type(distance) == "number", "distance must be a number")
    U.Val("DEBUG.tableRotateTo", angle, U.Type(angle) == "number", "angle must be a number")

    local objPos = resolvedObj.getPosition()
    local centerPos
    if center ~= nil then
        centerPos = Vector(center)
    else
        centerPos = Vector(0, objPos.y, 0)
    end

    local targetPos = U.rotateAroundPoint(centerPos, distance, angle, centerPos.y)
    resolvedObj.setPosition(targetPos)
    print("DEBUG.tableRotateTo: Moved " .. resolvedObj.getName() .. " to " .. tostring(targetPos))
end

-- ============================================================================
-- Look-at calibration + 3D positioning helpers (console/admin use)
-- ============================================================================

-- Vars stored on each object to correct its default forward direction
-- when rotation is not adjusted by a look-at function.
local LOOKAT_VAR_PITCH = "lookAtOffsetPitchDeg"
local LOOKAT_VAR_YAW = "lookAtOffsetYawDeg"
local LOOKAT_VAR_ROLL = "lookAtOffsetRollDeg"

--- Resolves a TTS GameObject from either a GUID string or an object reference.
-- @param objOrGuid Object|string TTS object or GUID
-- @param source string Debug call site label for errors
-- @return table|userdata GameObject
local function resolveDebugObject(objOrGuid, source)
    local resolved = U.getObject(objOrGuid, true)
    if resolved ~= nil then
        return resolved
    end
    if U.isGameObject(objOrGuid) then
        return objOrGuid
    end
    U.error(source, "objOrGuid must be a valid GameObject or GUID string", objOrGuid)
    return nil -- U.error throws; this return is for completeness
end

--- Safely reads a numeric `obj.getVar(varName)` value.
-- Returns nil if var missing or not numeric.
-- @param obj userdata GameObject
-- @param varName string Variable name
-- @return number|nil
local function safeGetVarNumber(obj, varName)
    if obj == nil or obj.getVar == nil then return nil end
    local val = obj.getVar(varName)
    if val == nil then return nil end
    if type(val) == "number" then return val end
    if type(val) == "string" then
        return tonumber(val)
    end
    return nil
end

--- Safely writes a numeric `obj.setVar(varName, number)` value.
-- @param obj userdata GameObject
-- @param varName string Variable name
-- @param value number
local function safeSetVarNumber(obj, varName, value)
    if obj == nil or obj.setVar == nil then
        U.error("DEBUG.safeSetVarNumber", "Object does not support setVar()", obj)
        return
    end
    obj.setVar(varName, value)
end

--- Resolves a target position from either:
-- 1) an Object (uses getPosition())
-- 2) a table/Vector {x,y,z}
-- @param targetOrPos Object|table|userdata
-- @param source string Debug call site label
-- @return Vector
local function resolveTargetPosition(targetOrPos, source)
    if targetOrPos == nil then
        U.error(source, "lookAtTargetOrPos cannot be nil")
        return Vector(0, 0, 0)
    end

    -- Accept GUID strings for targets as well.
    -- This keeps setRotationLookAt() consistent with other DEBUG helpers that accept GUIDs.
    if U.Type(targetOrPos) == "string" then
        local targetObj = U.getObject(targetOrPos, true)
        if targetObj ~= nil then
            return targetObj.getPosition()
        end
    end

    if U.isGameObject(targetOrPos) then
        local pos = targetOrPos.getPosition()
        U.Val(source, pos, pos ~= nil, "Target object's getPosition() failed")
        return pos
    end

    -- Accept Vector userdata or a table-like {x,y,z} or {[1],[2],[3]}
    local vec = Vector(targetOrPos)
    if vec == nil then
        U.error(source, "lookAtTargetOrPos must be a GameObject or a {x,y,z} table/Vector", targetOrPos)
    end
    return vec
end

--- Internal helper: Resolves the configured center object (or fallback to table center).
-- If the GUID isn't set or can't be resolved, returns Vector(0,0,0).
-- @return table|userdata Vector|GameObject (GameObject preserves local frame conversions)
local function resolveCenterArg()
    local centerGuid = S.getStateVal("debug", "centerObjGuid")
    if type(centerGuid) == "string" and centerGuid ~= "" then
        local centerObj = U.getObject(centerGuid, true)
        if centerObj ~= nil then
            return centerObj
        end
    end
    return Vector(0, 0, 0)
end

--- Gets the per-object look-at correction offset.
-- If the calibration vars are missing on the object, returns Vector(0,0,0).
-- @param objOrGuid Object|string GameObject or GUID
-- @return Vector
function DEBUG.getLookAtOffset(objOrGuid)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.getLookAtOffset")

    local pitch = safeGetVarNumber(obj, LOOKAT_VAR_PITCH)
    local yaw = safeGetVarNumber(obj, LOOKAT_VAR_YAW)
    local roll = safeGetVarNumber(obj, LOOKAT_VAR_ROLL)

    -- Default when calibration vars are absent.
    if pitch == nil and yaw == nil and roll == nil then
        return Vector(0, 0, 0)
    end

    return Vector(pitch or 0, yaw or 0, roll or 0)
end

--- Applies a look-at rotation, adjusted by the per-object calibration offset (if present).
-- @param objOrGuid Object|string GameObject or GUID
-- @param lookAtTargetOrPos Object|table|Vector target object or position
-- @param useCalibration boolean Optional; default is true
function DEBUG.setRotationLookAt(objOrGuid, lookAtTargetOrPos, useCalibration)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.setRotationLookAt")
    local targetPos = resolveTargetPosition(lookAtTargetOrPos, "DEBUG.setRotationLookAt")

    if obj == nil then
      U.error("DEBUG.setRotationLookAt", "Object is nil", objOrGuid)
      return
    end

    local baseRot = U.lookAtRotation(obj.getPosition(), targetPos)
    if baseRot == nil or baseRot.x == nil or baseRot.y == nil or baseRot.z == nil then
        U.error("DEBUG.setRotationLookAt", "U.lookAtRotation failed", baseRot)
        return
    end

    local offset = Vector(0, 0, 0)
    if useCalibration == nil or useCalibration ~= false then
        offset = DEBUG.getLookAtOffset(obj)
    end
    if offset == nil or offset.x == nil or offset.y == nil or offset.z == nil then
        offset = Vector(0, 0, 0)
    end

    local finalRot = Vector(
        baseRot.x + offset.x,
        baseRot.y + offset.y,
        baseRot.z + offset.z
    )

    if obj.setRotation ~= nil then
        obj.setRotation(finalRot)
    elseif obj.setRotationSmooth ~= nil then
        obj.setRotationSmooth(finalRot, false, false)
    else
        U.error("DEBUG.setRotationLookAt", "Object has neither setRotation nor setRotationSmooth()", obj)
        return
    end

    local objName = (obj.getName and obj.getName()) or "Object"
    print("DEBUG.setRotationLookAt: Set rotation for " .. tostring(objName) .. " to " .. tostring(finalRot) .. " (base=" .. tostring(baseRot) .. ", offset=" .. tostring(offset) .. ")")
end

--- Calibrates per-object look-at offset vars so the object correctly aims at the target.
-- This is meant for admin/setup time.
-- @param objOrGuid Object|string GameObject or GUID
-- @param lookAtTargetOrPos Object|table|Vector target object or position
-- @param roundIntervalDeg number Optional rounding interval in degrees (default: 90)
function DEBUG.calibrateLookAtOffset(objOrGuid, lookAtTargetOrPos, roundIntervalDeg)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.calibrateLookAtOffset")
    local targetPos = resolveTargetPosition(lookAtTargetOrPos, "DEBUG.calibrateLookAtOffset")

    local interval = roundIntervalDeg
    if interval == nil then interval = 90 end
    U.Val("DEBUG.calibrateLookAtOffset", interval, U.Type(interval) == "number" and interval > 0, "roundIntervalDeg must be a positive number")

    if obj == nil then
      U.error("DEBUG.calibrateLookAtOffset", "Object is nil", objOrGuid)
      return
    end

    local baseRot = U.lookAtRotation(obj.getPosition(), targetPos)
    local currentRot = obj.getRotation()

    if baseRot == nil or baseRot.x == nil or baseRot.y == nil or baseRot.z == nil then
        U.error("DEBUG.calibrateLookAtOffset", "U.lookAtRotation returned nil/invalid Vector", baseRot)
        return
    end
    if currentRot == nil or currentRot.x == nil or currentRot.y == nil or currentRot.z == nil then
        U.error("DEBUG.calibrateLookAtOffset", "obj.getRotation() returned nil/invalid Vector", currentRot)
        return
    end

    local baseRounded = Vector(
        U.pAngle(baseRot.x, interval),
        U.pAngle(baseRot.y, interval),
        U.pAngle(baseRot.z, interval)
    )
    local currentRounded = Vector(
        U.pAngle(currentRot.x, interval),
        U.pAngle(currentRot.y, interval),
        U.pAngle(currentRot.z, interval)
    )

    local offset = Vector(
        currentRounded.x - baseRounded.x,
        currentRounded.y - baseRounded.y,
        currentRounded.z - baseRounded.z
    )

    safeSetVarNumber(obj, LOOKAT_VAR_PITCH, offset.x)
    safeSetVarNumber(obj, LOOKAT_VAR_YAW, offset.y)
    safeSetVarNumber(obj, LOOKAT_VAR_ROLL, offset.z)

    print(
        "DEBUG.calibrateLookAtOffset: Stored offset " ..
        tostring(offset) ..
        " (baseRounded=" .. tostring(baseRounded) .. ", currentRounded=" .. tostring(currentRounded) .. ")"
    )
end

--- Sets the center object used for coordinate conversions in the positioning helpers.
-- Stores the object GUID in game state (session-oriented; save whitelist may exclude it).
-- @param objOrGuid Object|string GameObject or GUID string
function DEBUG.setCenterObject(objOrGuid)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.setCenterObject")

    if obj == nil then
      U.error("DEBUG.setCenterObject", "Object is nil", objOrGuid)
      return
    end

    local guid = nil
    if obj.getGUID ~= nil then
        guid = obj.getGUID()
    end
    if guid == nil then
        guid = obj.guid
    end
    if guid == nil or U.Type(guid) ~= "string" then
        U.error("DEBUG.setCenterObject", "Object GUID could not be resolved", guid)
        return
    end

    S.setStateVal(guid, "debug", "centerObjGuid")
    print("DEBUG.setCenterObject: Stored center GUID = " .. tostring(guid))
end

--- Clears the stored center object GUID used for coordinate conversions.
function DEBUG.clearCenterObject()
    S.setStateVal(nil, "debug", "centerObjGuid")
    print("DEBUG.clearCenterObject: Cleared stored center GUID")
end

--- Positions an object in cylindrical coordinates relative to the stored center.
-- If `lookAtTargetOrPos` is provided, also applies a calibration-aware look-at rotation.
function DEBUG.setPositionCylindrical(objOrGuid, radius, angleDeg, height, lookAtTargetOrPos)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.setPositionCylindrical")
    U.Val("DEBUG.setPositionCylindrical", radius, U.Type(radius) == "number", "radius must be a number")
    U.Val("DEBUG.setPositionCylindrical", angleDeg, U.Type(angleDeg) == "number", "angleDeg must be a number")
    U.Val("DEBUG.setPositionCylindrical", height, U.Type(height) == "number", "height must be a number")

    local centerArg = resolveCenterArg()
    local xyz = U.resolvePositionData(
        { position = { radius = radius, angle = angleDeg, height = height } },
        "cylindrical",
        centerArg
    )
    if xyz == nil then
        U.error("DEBUG.setPositionCylindrical", "Failed to resolve cylindrical coordinates to XYZ")
        return
    end

    if obj == nil then
        U.error("DEBUG.setPositionCylindrical", "Object is nil", objOrGuid)
        return
    end

    if obj.setPosition == nil then
        U.error("DEBUG.setPositionCylindrical", "Object does not support setPosition()", obj)
        return
    end

    obj.setPosition(xyz)

    if lookAtTargetOrPos ~= nil then
        DEBUG.setRotationLookAt(obj, lookAtTargetOrPos, true)
    end

    local objName = (obj.getName and obj.getName()) or "Object"
    print("DEBUG.setPositionCylindrical: Moved " .. tostring(objName) .. " to " .. tostring(xyz))
end

--- Positions an object in spherical coordinates relative to the stored center.
-- If `lookAtTargetOrPos` is provided, also applies a calibration-aware look-at rotation.
function DEBUG.setPositionSpherical(objOrGuid, radius, angleDeg, angle2Deg, lookAtTargetOrPos)
    local obj = resolveDebugObject(objOrGuid, "DEBUG.setPositionSpherical")
    U.Val("DEBUG.setPositionSpherical", radius, U.Type(radius) == "number", "radius must be a number")
    U.Val("DEBUG.setPositionSpherical", angleDeg, U.Type(angleDeg) == "number", "angleDeg must be a number")
    U.Val("DEBUG.setPositionSpherical", angle2Deg, U.Type(angle2Deg) == "number", "angle2Deg must be a number")

    local centerArg = resolveCenterArg()
    local xyz = U.resolvePositionData(
        { position = { radius = radius, angle = angleDeg, angle2 = angle2Deg } },
        "spherical",
        centerArg
    )
    if xyz == nil then
        U.error("DEBUG.setPositionSpherical", "Failed to resolve spherical coordinates to XYZ")
        return
    end

    if obj == nil then
        U.error("DEBUG.setPositionSpherical", "Object is nil", objOrGuid)
        return
    end

    if obj.setPosition == nil then
        U.error("DEBUG.setPositionSpherical", "Object does not support setPosition()", obj)
        return
    end

    obj.setPosition(xyz)

    if lookAtTargetOrPos ~= nil then
        DEBUG.setRotationLookAt(obj, lookAtTargetOrPos, true)
    end

    local objName = (obj.getName and obj.getName()) or "Object"
    print("DEBUG.setPositionSpherical: Moved " .. tostring(objName) .. " to " .. tostring(xyz))
end

--[[
    File Logging Functions
    These functions write debug information to files in the workspace using
    the TTS Tools extension's sendExternalMessage API.
]]

--- Logs a message to a file with timestamp
-- @param level string Log level: "INFO", "WARN", "ERROR", "DEBUG"
-- @param message string Message to log
-- @param filename string Optional filename (default: "debug_log")
function DEBUG.logToFile(level, message, filename)
    filename = filename or "debug_log"
    local timestamp = getTimestamp()
    local logEntry = string.format("[%s] [%s] %s\n", timestamp, level, message)

    -- Append to existing cached content
    writeToFile(filename, logEntry, "none", true)
end

--- Logs current game state to a file as JSON
-- @param filename string Optional filename (default: "game_state")
function DEBUG.logStateToFile(filename)
    filename = filename or "game_state"
    local state = S.getGameState()
    local stateJson = JSON.encode_pretty(state)
    local timestamp = getTimestamp()
    local content = string.format("Game State Dump - %s\n%s\n", timestamp, stateJson)

    -- State dumps are overwritten (not appended) - each dump is a complete snapshot
    writeToFile(filename, content, "auto", false)
    print("DEBUG: Game state logged to " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. LOG_DIR .. "/" .. filename .. "." .. LOG_EXTENSION)
end

--- @param lightRef string
--- @param seatColor string
--- @return boolean
local function debugLightRefMatchesSeatColor(lightRef, seatColor)
    if type(lightRef) ~= "string" or type(seatColor) ~= "string" then
        return false
    end
    return string.sub(lightRef, -#seatColor) == seatColor
end

--- @param seatKey string
--- @return boolean
local function debugIsSeatPresentInActiveLayout(seatKey)
    if type(seatKey) ~= "string" then
        return false
    end
    local currentTableKey = S.getStateVal("seatLayout", "currentTableKey")
    if type(currentTableKey) ~= "string" or currentTableKey == "" then
        return true
    end
    local tableCfg = C.Tables[currentTableKey]
    if type(tableCfg) ~= "table" then
        return true
    end
    ---@diagnostic disable-next-line: undefined-field
    local map = tableCfg.playerToPositionMap
    if type(map) ~= "table" then
        return true
    end
    return map[seatKey] ~= nil
end

--- @param seatKey string
--- @return boolean
local function debugIsPlayerSeatKey(seatKey)
    return type(seatKey) == "string" and U.isIn(seatKey, C.PlayerColors or {})
end

--- @param seatKey string
--- @param lData table
--- @return string|nil
local function debugComputeDesiredSeatLightMode(seatKey, lData)
    if type(seatKey) ~= "string" or type(lData) ~= "table" then
        return nil
    end

    local isPlayerSeat = debugIsPlayerSeatKey(seatKey)
    if isPlayerSeat then
        local playerID = S.getPlayerID(seatKey)
        local isRolling = playerID ~= nil and S.getStateVal("playerData", playerID, "lighting", "isRolling") == true
        if isRolling and lData.ROLLING ~= nil then
            return "ROLLING"
        end
    end

    local currentScene = Scenes.getCurrentScene and Scenes.getCurrentScene() or S.getStateVal("currentScene")
    local isDark = type(currentScene) == "string" and string.lower(currentScene) == "dark"
    local seatPresent = debugIsSeatPresentInActiveLayout(seatKey)
    if (isDark or not seatPresent) and lData.OFF ~= nil then
        return "OFF"
    end

    if isPlayerSeat then
        local hunger = tonumber(S.getPlayerVal(seatKey, "hunger")) or 0
        if hunger >= 4 and lData.HUNGRY ~= nil then
            return "HUNGRY"
        end
    end

    if lData.STANDARD ~= nil then
        return "STANDARD"
    end
    if type(lData.default) == "string" and lData[lData.default] ~= nil then
        return lData.default
    end
    if lData.OFF ~= nil then
        return "OFF"
    end
    return nil
end

--- @return table<string, boolean>
local function debugGetOccupiedNPCSlotSet()
    local occupied = S.getStateVal("seatLayout", "occupiedNPCSlots")
    local out = {}
    if type(occupied) ~= "table" then
        return out
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local val = occupied[seatKey]
        if val ~= nil and val ~= false then
            out[seatKey] = true
        end
    end
    return out
end

--- Logs a per-seat light diagnostic snapshot to a workspace file.
-- Output includes: color | resolvedPlayerID | hunger | desired vs persisted `lights` per ref | smokeWanted.
-- (`current` column is `S.getStateVal("lights", ...)`, not live Light component intensity.)
-- @param filename string Optional filename (default: "seat_lights")
function DEBUG.logSeatLightsToFile(filename)
    filename = filename or "seat_lights"
    local timestamp = getTimestamp()
    local rows = {
        "Seat Light Diagnostics - " .. tostring(timestamp),
        "seat | seatType | occupant | playerID | hunger | rolling | scene | seatPresent | desired | current | smokeWanted",
    }

    local occupiedNpcSlots = debugGetOccupiedNPCSlotSet()
    local orderedSeats = {}
    for _, seatColor in ipairs(C.PlayerColors or {}) do
        orderedSeats[#orderedSeats + 1] = seatColor
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if occupiedNpcSlots[seatKey] == true then
            orderedSeats[#orderedSeats + 1] = seatKey
        end
    end

    for _, seatKey in ipairs(orderedSeats) do
        local isPlayerSeat = debugIsPlayerSeatKey(seatKey)
        local seatType = isPlayerSeat and "PLAYER" or "NPC"
        local occupiedRaw = S.getStateVal("seatLayout", "occupiedNPCSlots", seatKey)
        local occupant = isPlayerSeat and seatKey or tostring(occupiedRaw)
        local playerID = isPlayerSeat and S.getPlayerID(seatKey) or nil
        local hunger = isPlayerSeat and (tonumber(S.getPlayerVal(seatKey, "hunger")) or 0) or 0
        local rolling = playerID ~= nil and S.getStateVal("playerData", playerID, "lighting", "isRolling") == true
        local currentScene = Scenes.getCurrentScene and Scenes.getCurrentScene() or S.getStateVal("currentScene")
        local seatPresent = debugIsSeatPresentInActiveLayout(seatKey)
        local smokeWanted = isPlayerSeat and hunger >= 4

        local refs = {}
        for lightRef, lData in pairs(L.LIGHTMODES or {}) do
            if type(lightRef) == "string"
                and type(lData) == "table"
                and debugLightRefMatchesSeatColor(lightRef, seatKey)
            then
                refs[#refs + 1] = lightRef
            end
        end
        table.sort(refs)

        local desiredParts = {}
        local currentParts = {}
        for _, lightRef in ipairs(refs) do
            local lData = L.LIGHTMODES[lightRef]
            local desiredMode = debugComputeDesiredSeatLightMode(seatKey, lData) or "nil"
            local currentMode = tostring(S.getStateVal("lights", lightRef) or "nil")
            desiredParts[#desiredParts + 1] = lightRef .. "=" .. desiredMode
            currentParts[#currentParts + 1] = lightRef .. "=" .. currentMode
        end

        rows[#rows + 1] = string.format(
            "%s | %s | %s | %s | %d | %s | %s | %s | %s | %s | %s",
            tostring(seatKey),
            tostring(seatType),
            tostring(occupant),
            tostring(playerID),
            hunger,
            tostring(rolling),
            tostring(currentScene),
            tostring(seatPresent),
            table.concat(desiredParts, ", "),
            table.concat(currentParts, ", "),
            tostring(smokeWanted)
        )
    end

    local content = table.concat(rows, "\n") .. "\n"
    writeToFile(filename, content, "none", false)
    print("DEBUG: Seat light diagnostics logged to " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. LOG_DIR .. "/" .. filename .. "." .. LOG_EXTENSION)
end

--- Logs Step Zero placement intent plus occupied slots for NPC reconcile verification.
--- After scene edits, run `Sync.full({ force = true })`, then compare world to intent:
--- 1) byArea + seatSlots same char → target area; 2) seat only → target seat + physicalSeatAllowed;
--- 3) seat on table without slot → target preload, assignment retained; 4) assigned + present false → seated layout, hidden props;
--- 5) seat-only scene change → no full pool stash; 6) save load bootstrap → one successful reconcile.
--- @param filename string Optional filename (default: "npc_placement_intent")
function DEBUG.logNpcPlacementIntentToFile(filename)
    filename = filename or "npc_placement_intent"
    local NPCS = require("core.npcs")
    local intent = NPCS.resolveNpcPlacementIntent()
    local rows = {
        "character | target | areaKey | slot | seatKey | pendingSeat",
        "seat | assigned | character | tableHasSlot | present | physicalSeatAllowed | occupiedNPCSlots",
    }
    local byCharacter = intent.byCharacter or {}
    local charKeys = {}
    for name, _ in pairs(byCharacter) do
        charKeys[#charKeys + 1] = name
    end
    table.sort(charKeys)
    for i = 1, #charKeys do
        local name = charKeys[i]
        local ci = byCharacter[name]
        rows[#rows + 1] = table.concat({
            tostring(name),
            tostring(ci and ci.target or ""),
            tostring(ci and ci.areaKey or ""),
            tostring(ci and ci.slotIndex or ""),
            tostring(ci and ci.seatKey or ""),
            tostring(ci and ci.pendingSeatKey or ""),
        }, " | ")
    end
    rows[#rows + 1] = ""
    local occupied = S.getStateVal("seatLayout", "occupiedNPCSlots") or {}
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local info = (intent.bySeat or {})[seatKey] or {}
        rows[#rows + 1] = table.concat({
            tostring(seatKey),
            tostring(info.assigned),
            tostring(info.assignedCharacter or ""),
            tostring(info.tableHasSlot),
            tostring(info.present),
            tostring(info.physicalSeatAllowed),
            tostring(occupied[seatKey] or ""),
        }, " | ")
    end
    rows[#rows + 1] = "tableKey=" .. tostring(intent.tableKey or "")
    writeToFile(filename, table.concat(rows, "\n") .. "\n", "none", false)
    print(
        "DEBUG: NPC placement intent logged to "
            .. WORKSPACE_DEBUG_WRITE_ROOT
            .. "/"
            .. LOG_DIR
            .. "/"
            .. filename
            .. "."
            .. LOG_EXTENSION
    )
end

--- Display name for export rows (Nickname wins over Name, matching layout conventions).
--- @param obj Object|nil
--- @return string
local function exportObjectDisplayName(obj)
    if not U.isGameObject(obj) then
        return ""
    end
    if obj.getNickname ~= nil then
        local nickname = obj.getNickname()
        if U.Type(nickname) == "string" and nickname ~= "" then
            return nickname
        end
    end
    if obj.getName ~= nil then
        return tostring(obj.getName() or "")
    end
    return ""
end

--- True when an `NPC#Object`-tagged object is a seat figurine (pooled NPC cutout or workshop `SEAT_FIGURE_*`).
--- @param obj Object|nil
--- @param npcsModule table core.npcs
--- @return boolean
local function isNpcSeatFigurineObject(obj, npcsModule)
    if not U.isGameObject(obj) then
        return false
    end
    if type(npcsModule.isPooledFigurineObject) == "function" and npcsModule.isPooledFigurineObject(obj) then
        return true
    end
    local disp = exportObjectDisplayName(obj)
    local roleKey = string.match(disp, "^(.+)_")
    if roleKey == "SEAT_FIGURE" then
        return true
    end
    if disp == "Figurine_Custom" then
        return true
    end
    return false
end

--- Collect `NPC1Object`..`NPC4Object` figurines and write a short Lua table `{ name, guid }` to workspace debug logs.
--- Run from the External Editor / TTS console: `lua DEBUG.exportNpcSeatFigurinesToFile()`.
--- Requires TTS Tools bridge on port 39998 for file write (`.dev/.debug/debug_logs/...`).
--- @param relativePath string|nil default `debug_logs/npc_seat_figurines.lua`
--- @return table rows `{ tag, name, guid }[]`
--- @return boolean wrote true when sendExternalMessage write succeeded
function DEBUG.exportNpcSeatFigurinesToFile(relativePath)
    relativePath = relativePath or "debug_logs/npc_seat_figurines.lua"
    local NPCS = require("core.npcs")
    local rows = {}
    local seenGuids = {}

    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local tag = tostring(seatKey) .. "Object"
        local objs = getObjectsWithTag(tag)
        if type(objs) ~= "table" then
            objs = {}
        end
        for _, obj in ipairs(objs) do
            if isNpcSeatFigurineObject(obj, NPCS) then
                local guid = obj.getGUID and obj.getGUID() or nil
                if U.Type(guid) == "string" and guid ~= "" and seenGuids[guid] ~= true then
                    seenGuids[guid] = true
                    rows[#rows + 1] = {
                        tag = tag,
                        name = exportObjectDisplayName(obj),
                        guid = guid,
                    }
                end
            end
        end
    end

    table.sort(rows, function(a, b)
        local ta = tostring(a.tag)
        local tb = tostring(b.tag)
        if ta ~= tb then
            return ta < tb
        end
        return tostring(a.name) < tostring(b.name)
    end)

    local ts = getTimestamp()
    local lines = {
        "-- Generated by DEBUG.exportNpcSeatFigurinesToFile at " .. tostring(ts),
        "-- Tags: NPC1Object .. NPC4Object; figurines only (SEAT_FIGURE_* / pooled npc figurine / Figurine_Custom).",
        "",
        "return {",
    }
    for i = 1, #rows do
        local row = rows[i]
        local nameEsc = string.gsub(tostring(row.name), "\"", "\\\"")
        lines[#lines + 1] = string.format(
            "  { tag = \"%s\", name = \"%s\", guid = \"%s\" },",
            tostring(row.tag),
            nameEsc,
            tostring(row.guid)
        )
    end
    lines[#lines + 1] = "}"
    lines[#lines + 1] = ""

    local content = table.concat(lines, "\n")
    local wrote = DEBUG.writeWorkspaceFile(relativePath, content, "none", false)
    print("DEBUG.exportNpcSeatFigurinesToFile: " .. tostring(#rows) .. " figurine(s) → " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. relativePath)
    if JSON ~= nil and JSON.encode ~= nil then
        print(JSON.encode({ count = #rows, wrote = wrote, path = relativePath, rows = rows }))
    end
    return rows, wrote
end

--- Logs current scene information to a file
-- @param filename string Optional filename (default: "scene_info")
function DEBUG.logSceneToFile(filename)
    filename = filename or "scene_info"
    local currentScene = Scenes.getCurrentScene()
    local scene = Scenes.getScene(currentScene)
    local timestamp = getTimestamp()

    local content = string.format("Scene Information - %s\n", timestamp)
    content = content .. string.format("Current Scene: %s\n", currentScene or "nil")
    if scene then
        content = content .. string.format("Scene Data:\n")
        content = content .. JSON.encode_pretty(scene)
    else
        content = content .. "Scene data not found\n"
    end
    content = content .. "\n"

    -- Scene dumps are overwritten (not appended) - each dump is a complete snapshot
    writeToFile(filename, content, "auto", false)
    print("DEBUG: Scene info logged to " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. LOG_DIR .. "/" .. filename .. "." .. LOG_EXTENSION)
end

--- Logs zone information to a file
-- @param filename string Optional filename (default: "zone_info")
function DEBUG.logZonesToFile(filename)
    filename = filename or "zone_info"
    local zonesState = S.getStateVal("zones")
    local timestamp = getTimestamp()

    local content = string.format("Zone Information - %s\n", timestamp)
    if zonesState then
        content = content .. JSON.encode_pretty(zonesState)
    else
        content = content .. "No zone state found\n"
    end
    content = content .. "\n"

    -- Zone dumps are overwritten (not appended) - each dump is a complete snapshot
    writeToFile(filename, content, "auto", false)
    print("DEBUG: Zone info logged to " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. LOG_DIR .. "/" .. filename .. "." .. LOG_EXTENSION)
end

--- Logs a test result to a file
-- @param testName string Name of the test
-- @param passed boolean Whether the test passed
-- @param details string Optional details
-- @param filename string Optional filename (default: "test_results")
function DEBUG.logTestToFile(testName, passed, details, filename)
    filename = filename or "test_results"
    local timestamp = getTimestamp()
    local status = passed and "PASS" or "FAIL"

    local content = string.format("[%s] %s: %s\n", timestamp, status, testName)
    if details then
        content = content .. string.format("  Details: %s\n", details)
    end
    content = content .. "\n"

    -- Append to existing cached content
    writeToFile(filename, content, "none", true)
end

--- Logs all debug information to separate files
-- Creates: game_state, scene_info, zone_info, and a general debug log
function DEBUG.logAllToFiles()
    print("DEBUG: Logging all information to files...")
    DEBUG.logStateToFile("game_state")
    DEBUG.logSceneToFile("scene_info")
    DEBUG.logZonesToFile("zone_info")
    DEBUG.logToFile("INFO", "Full debug dump completed", "debug_log")
    print("DEBUG: All logs written under " .. WORKSPACE_DEBUG_WRITE_ROOT .. "/" .. LOG_DIR .. "/")
end

--- Clears all log files (writes empty/header content to reset them)
-- Called automatically on game load to start fresh logs
-- Also clears the in-memory cache
function DEBUG.clearAllLogs()
    local timestamp = getTimestamp()
    local sessionHeader = string.format("=== DEBUG LOG SESSION STARTED - %s ===\n\n", timestamp)

    -- Clear the cache
    logCache = {}

    -- Do not call writeToFile() for workspace logs on load: TTS Tools opens each written file
    -- in the editor, which is disruptive on every Save & Play (see prior test_results note).
    -- Seed append-style logs in memory only; first log line triggers the first disk write.
    logCache["debug_log"] = sessionHeader
    logCache["test_results"] = sessionHeader

    print("DEBUG: Debug log session started (cache cleared; no log files written on load)")
end

--[[
    Custom UI Asset Upload Helpers
    These functions spawn temporary Custom_Token objects from generated manifest data.
    Use these tokens with Cloud Manager "Upload All Loaded Files", then save and run
    the Node merge script to update top-level CustomUIAssets.
]]

local DEBUG_UPLOAD_GMNOTES_PREFIX = "debug-custom-ui-upload:"
local DEBUG_UPLOAD_TAG = "debug-custom-ui-upload"
local DEBUG_UPLOAD_MANIFEST_MODULE = "lib.custom_ui_upload_manifest"

--- Load a generated manifest module at Global init without bricking Save & Play.
--- pcall: module file may be missing on a fresh clone, or fail parse before npm manifest scripts run;
--- propagating would abort core/debug.ttslua load. Literal require() in each caller keeps luabundle embedding
--- (TTS_BUNDLING_SETUP.md § Issue 2a). Empty fallback keeps unrelated DEBUG helpers usable.
--- @param moduleName string
--- @param fallback table
--- @return table
local function loadGeneratedManifestAtInit(moduleName, fallback)
    local ok, result = pcall(require, moduleName)
    if ok and U.Type(result) == "table" then
        return result
    end
    print(
        "[DEBUG] Generated module '"
            .. tostring(moduleName)
            .. "' not loaded — using empty fallback. "
            .. "Run the matching npm custom-ui-assets:manifest-* script, then Save & Play. "
            .. "Error: "
            .. tostring(result)
    )
    return fallback
end

-- Module-level literal requires (via helper) so luabundle ships these modules (Issue 2a).
local CUSTOM_UI_UPLOAD_MANIFEST = loadGeneratedManifestAtInit("lib.custom_ui_upload_manifest", { assets = {} })
local NPC_TOKEN_UPLOAD_MANIFEST = loadGeneratedManifestAtInit("lib.npc_token_upload_manifest", { assets = {} })
local NPC_TOKEN_HOSTED_URLS = loadGeneratedManifestAtInit("lib.npc_token_hosted_urls", {})
DEBUG.customUiUploadManifest = CUSTOM_UI_UPLOAD_MANIFEST

--- Parse an optional options table for upload spawn settings.
-- @param options table|nil
-- @param assetCount number|nil
-- @return table Parsed options with defaults
local function parseUploadOptions(options, assetCount)
    local resolved = options or {}
    local spawnX = resolved.startX
    local spawnY = resolved.startY
    local spawnZ = resolved.startZ
    local gap = resolved.gap
    local columns = resolved.columns
    local offset = resolved.offset
    local limit = resolved.limit

    local count = assetCount
    if U.Type(count) ~= "number" or count < 1 then
        count = 1
    end

    -- Auto-size columns when not provided:
    -- keep rows compact while avoiding very wide spawn grids.
    local autoColumns = math.ceil(math.sqrt(count))
    if autoColumns < 4 then autoColumns = 4 end
    if autoColumns > 12 then autoColumns = 12 end

    if U.Type(spawnX) ~= "number" then spawnX = 0 end
    if U.Type(spawnY) ~= "number" then spawnY = 3 end
    if U.Type(spawnZ) ~= "number" then spawnZ = 0 end
    if U.Type(gap) ~= "number" or gap <= 0 then gap = 2 end
    if U.Type(columns) ~= "number" or columns < 1 then columns = autoColumns end
    if U.Type(offset) ~= "number" or offset < 0 then offset = 0 end
    if U.Type(limit) ~= "number" or limit < 1 then limit = 999999 end

    return {
        startX = spawnX,
        startY = spawnY,
        startZ = spawnZ,
        gap = gap,
        columns = math.floor(columns),
        offset = math.floor(offset),
        limit = math.floor(limit)
    }
end

--- Normalize a manifest-like table into an asset list.
-- Accepted shapes:
--   { assets = { { name = "...", fileUrl = "file:///..." }, ... } }
--   { { name = "...", fileUrl = "file:///..." }, ... }
-- `name` may be supplied as `image` (Custom UI asset name) instead of `name`.
-- @param manifest table Manifest object or direct asset array
-- @return table|nil Array of normalized assets, or nil on validation failure
local function normalizeUploadManifest(manifest)
    if U.Type(manifest) ~= "table" then
        print("DEBUG.spawnCustomUiUploadBatchFromManifest: manifest must be a table")
        return nil
    end

    local assets = manifest.assets
    if U.Type(assets) ~= "table" then
        assets = manifest
    end
    if U.Type(assets) ~= "table" then
        print("DEBUG.spawnCustomUiUploadBatchFromManifest: manifest.assets must be a table")
        return nil
    end

    local normalized = {}
    local seenNames = {}

    for i, asset in ipairs(assets) do
        if U.Type(asset) ~= "table" then
            print("DEBUG: Skipping non-table asset at index " .. tostring(i))
        else
            local name = asset.name or asset.Name or asset.assetName or asset.image
            local fileUrl = asset.fileUrl or asset.url or asset.URL
            if U.Type(name) ~= "string" or name == "" then
                print("DEBUG: Skipping asset with invalid name at index " .. tostring(i))
            elseif U.Type(fileUrl) ~= "string" or fileUrl == "" then
                print("DEBUG: Skipping asset '" .. name .. "' with invalid fileUrl/url")
            elseif not string.find(fileUrl, "^file:///") then
                print("DEBUG: Skipping asset '" .. name .. "' because URL is not file:/// (" .. tostring(fileUrl) .. ")")
            elseif seenNames[name] then
                print("DEBUG: Skipping duplicate asset name '" .. name .. "'")
            else
                seenNames[name] = true
                table.insert(normalized, {
                    name = name,
                    fileUrl = fileUrl
                })
            end
        end
    end

    if #normalized == 0 then
        print("DEBUG.spawnCustomUiUploadBatchFromManifest: no valid assets found")
        return nil
    end

    return normalized
end

--- Spawn a batch of temporary Custom_Token objects from a manifest table.
-- Each token is named with `asset.name`, configured with the local `fileUrl`, then locked to avoid physics scatter.
-- @param manifest table Manifest object (with .assets) or direct assets array
-- @param options table|nil Optional controls: startX/startY/startZ/gap/columns/offset/limit
-- @return number Count of spawned tokens
function DEBUG.spawnCustomUiUploadBatchFromManifest(manifest, options)
    local assets = normalizeUploadManifest(manifest)
    if assets == nil then
        return 0
    end

    local opts = parseUploadOptions(options, #assets)
    local spawned = 0
    local processed = 0

    for i, asset in ipairs(assets) do
        if i > opts.offset and spawned < opts.limit then
            local row = math.floor(processed / opts.columns)
            local col = processed % opts.columns

            local spawnPos = {
                x = opts.startX + (col * opts.gap),
                y = opts.startY,
                z = opts.startZ + (row * opts.gap)
            }

            ---@diagnostic disable-next-line: undefined-global
            local obj = spawnObject({
                type = "Custom_Token",
                position = spawnPos,
                sound = false
            })

            if obj ~= nil then
                obj.setName(asset.name)
                obj.setGMNotes(DEBUG_UPLOAD_GMNOTES_PREFIX .. asset.name)
                if obj.setTags ~= nil then
                    obj.setTags({ DEBUG_UPLOAD_TAG, asset.name })
                end
                obj.setCustomObject({
                    image = asset.fileUrl,
                    thickness = 0.2,
                    merge_distance = 15,
                    stackable = false
                })
                if obj.setLock ~= nil then
                    obj.setLock(true)
                end
                spawned = spawned + 1
                processed = processed + 1
            else
                print("DEBUG: Failed to spawn token for " .. asset.name)
            end
        end
    end

    print("DEBUG.spawnCustomUiUploadBatchFromManifest: Spawned " .. tostring(spawned) .. " uploader tokens")
    return spawned
end

--- Spawn a batch from a JSON string generated by build-upload-manifest.js.
-- @param manifestJson string JSON string containing { assets: [ {name,fileUrl}, ... ] }
-- @param options table|nil Optional controls: startX/startY/startZ/gap/columns/offset/limit
-- @return number Count of spawned tokens
function DEBUG.spawnCustomUiUploadBatchFromJson(manifestJson, options)
    if U.Type(manifestJson) ~= "string" or manifestJson == "" then
        print("DEBUG.spawnCustomUiUploadBatchFromJson: manifestJson must be a non-empty string")
        return 0
    end

    local parsed = JSON.decode(manifestJson)
    if U.Type(parsed) ~= "table" then
        print("DEBUG.spawnCustomUiUploadBatchFromJson: failed to parse JSON manifest")
        return 0
    end

    return DEBUG.spawnCustomUiUploadBatchFromManifest(parsed, options)
end

--- Load a generated custom UI upload manifest Lua module via require().
-- This requires Save & Play after regenerating the module file.
-- @param moduleName string|nil Optional module name (default: lib.custom_ui_upload_manifest)
-- @param forceReload boolean|nil If true, clears require cache before loading (default: true)
-- @return table|nil Loaded manifest table or nil on failure
function DEBUG.loadCustomUiUploadManifest(moduleName, forceReload)
    local targetModule = moduleName
    if U.Type(targetModule) ~= "string" or targetModule == "" then
        targetModule = DEBUG_UPLOAD_MANIFEST_MODULE
    end
    local shouldForceReload = forceReload
    if shouldForceReload == nil then
        shouldForceReload = true
    end

    if shouldForceReload then
        if U.Type(package) == "table" and U.Type(package.loaded) == "table" then
            package.loaded[targetModule] = nil
        end
    end

    -- pcall: same rationale as loadGeneratedManifestAtInit — runtime reload after npm regen must not throw.
    local ok, manifest = pcall(require, targetModule)
    if not ok then
        print(
            "DEBUG.loadCustomUiUploadManifest: failed to require '"
                .. tostring(targetModule)
                .. "': "
                .. tostring(manifest)
        )
        return nil
    end

    if U.Type(manifest) ~= "table" then
        print("DEBUG.loadCustomUiUploadManifest: module '" .. tostring(targetModule) .. "' did not return a table")
        return nil
    end

    DEBUG.customUiUploadManifest = manifest
    local count = 0
    if U.Type(manifest.assets) == "table" then
        count = #manifest.assets
    end
    print("DEBUG.loadCustomUiUploadManifest: loaded " .. tostring(count) .. " assets from " .. tostring(targetModule))
    if count == 0 then
        print(
            "DEBUG.loadCustomUiUploadManifest: manifest is empty — run the matching npm custom-ui-assets:manifest-* script, then Save & Play"
        )
    end
    return manifest
end

--- Spawn upload tokens from lib.npc_token_upload_manifest (tokenFront_* / tokenBack_* WEBPs).
-- @param options table|nil Optional grid: columns, gap, startY, etc.
-- @return number Count of spawned tokens
function DEBUG.spawnNpcTokenUploadBatch(options)
    return DEBUG.spawnCustomUiUploadBatch(options, "lib.npc_token_upload_manifest")
end

--- Spawn a batch from the default generated manifest module.
-- @param options table|nil Optional controls: startX/startY/startZ/gap/columns/offset/limit
-- @param moduleName string|nil Optional module name override
-- @return number Count of spawned tokens
function DEBUG.spawnCustomUiUploadBatch(options, moduleName)
    -- Always force reload so this uses the latest generated manifest file.
    local manifest = DEBUG.loadCustomUiUploadManifest(moduleName, true)
    if U.Type(manifest) ~= "table" then
        print("DEBUG.spawnCustomUiUploadBatch: no manifest loaded")
        return 0
    end
    return DEBUG.spawnCustomUiUploadBatchFromManifest(manifest, options)
end

--- Delete spawned uploader tokens created by DEBUG.spawnCustomUiUploadBatchFromManifest().
-- @return number Count of deleted objects
function DEBUG.clearCustomUiUploadTokens()
    local allObjects = getAllObjects()
    local deleted = 0

    for _, obj in ipairs(allObjects) do
        if obj ~= nil and obj.getGMNotes ~= nil then
            local notes = obj.getGMNotes()
            local matchesNotes = U.Type(notes) == "string" and string.find(notes, "^" .. DEBUG_UPLOAD_GMNOTES_PREFIX) ~= nil
            local matchesTag = false
            if obj.getTags ~= nil then
                local tags = obj.getTags()
                if U.Type(tags) == "table" then
                    for _, tag in ipairs(tags) do
                        if tag == DEBUG_UPLOAD_TAG then
                            matchesTag = true
                            break
                        end
                    end
                end
            end

            if matchesNotes or matchesTag then
                obj.destruct()
                deleted = deleted + 1
            end
        end
    end

    print("DEBUG.clearCustomUiUploadTokens: Deleted " .. tostring(deleted) .. " uploader tokens (matched by tag or GM notes)")
    return deleted
end

--[[
    NPC control-board tokens (paired front/back Custom_Tile on CONTROL_BOARD).
    Distinct from upload-batch Custom_Token spawns (Cloud Manager upload only).
]]

local NPC_GAMEBOARD_DATA = require("lib.npc_gameboard_data")

--- Lazy: avoid loading gameboard during `core.state` registration (see `lib.npc_placements_convert`).
--- @return table
local function npcGameboardModule()
    return require("core.npc_gameboard")
end
local NPC_CONTROL_TOKEN_TAG = NPC_GAMEBOARD_DATA.TAG_NPC_CONTROL_TOKEN
local NPC_TOKEN_GM_PREFIX = NPC_GAMEBOARD_DATA.TOKEN_GM_PREFIX
local NPC_TOKEN_MANIFEST_MODULE = "lib.npc_token_upload_manifest"
--- Custom_Tile.Type: 0 square, 1 hex, 2 circle (round), 3 rounded square (.dev/tts-api Custom Tile).
local NPC_CONTROL_TOKEN_TILE_TYPE = 2
local NPC_CONTROL_TOKEN_TILE_THICKNESS = 0.1

--- @param url string|nil
--- @return boolean
local function isFileUrl(url)
    return U.Type(url) == "string" and string.find(url, "^file:///") ~= nil
end

--- @param url string|nil
--- @return boolean
local function isHostedSteamUrl(url)
    return U.Type(url) == "string"
        and string.find(url, "^https?://") ~= nil
        and (
            string.find(url, "steamusercontent") ~= nil
            or string.find(url, "steamusercontent%-a%.akamaihd%.net") ~= nil
        )
end

--- @param manifest table
--- @return table|nil characterKey -> { front: string, back: string }
local function indexNpcTokenPairsFromManifest(manifest)
    if U.Type(manifest) ~= "table" then
        return nil
    end
    local assets = manifest.assets
    if U.Type(assets) ~= "table" then
        return nil
    end
    local pairsByKey = {}
    for _, asset in ipairs(assets) do
        if U.Type(asset) == "table" then
            local characterKey = asset.characterKey
            local side = asset.side
            local fileUrl = asset.fileUrl or asset.url or asset.URL
            if U.Type(characterKey) == "string" and characterKey ~= "" and U.Type(fileUrl) == "string" and fileUrl ~= "" then
                local row = pairsByKey[characterKey]
                if row == nil then
                    row = {}
                    pairsByKey[characterKey] = row
                end
                if side == "front" then
                    row.front = fileUrl
                elseif side == "back" then
                    row.back = fileUrl
                end
            end
        end
    end
    return pairsByKey
end

--- Prefer Steam URLs from lib.npc_token_hosted_urls; else file:/// rows from upload manifest.
--- @param options table|nil { preferHosted?: boolean }
--- @return table|nil pairsByKey, string sourceLabel
local function loadNpcControlTokenPairUrls(options)
    local opts = options or {}
    local preferHosted = opts.preferHosted
    if preferHosted == nil then
        preferHosted = true
    end

    if preferHosted and U.Type(NPC_TOKEN_HOSTED_URLS) == "table" then
        local hosted = NPC_TOKEN_HOSTED_URLS
        local pairsByKey = {}
        for characterKey, row in pairs(hosted) do
            if U.Type(characterKey) == "string" and U.Type(row) == "table" then
                local front = row.front or row.Front
                local back = row.back or row.Back
                if isHostedSteamUrl(front) and isHostedSteamUrl(back) then
                    pairsByKey[characterKey] = { front = front, back = back }
                end
            end
        end
        local count = 0
        for _ in pairs(pairsByKey) do
            count = count + 1
        end
        if count > 0 then
            return pairsByKey, "lib.npc_token_hosted_urls"
        end
    end

    local manifest = DEBUG.loadCustomUiUploadManifest(NPC_TOKEN_MANIFEST_MODULE, true)
    if manifest == nil then
        return nil, "none"
    end
    return indexNpcTokenPairsFromManifest(manifest), NPC_TOKEN_MANIFEST_MODULE
end

--- @param pairsByKey table
--- @return string[] sorted character keys with both sides
local function sortedCompleteNpcTokenKeys(pairsByKey)
    local keys = {}
    for characterKey, row in pairs(pairsByKey) do
        if U.Type(row) == "table" then
            local frontOk = isFileUrl(row.front) or isHostedSteamUrl(row.front)
            local backOk = isFileUrl(row.back) or isHostedSteamUrl(row.back)
            if frontOk and backOk then
                keys[#keys + 1] = characterKey
            end
        end
    end
    table.sort(keys)
    return keys
end

--- Save-format spawn data for a flip-capable NPC control token (matches dual-image Custom_Tile in save).
--- @param worldPos { x: number, y: number, z: number }
--- @param yawDeg number
--- @param characterKey string
--- @param frontUrl string
--- @param backUrl string
--- @param scale number|nil
--- @param faceUp boolean|nil
--- @return table
local function buildNpcControlTokenSpawnData(worldPos, yawDeg, characterKey, frontUrl, backUrl, scale, faceUp)
    local s = tonumber(scale)
    if s == nil or s ~= s or s <= 0 then
        s = 0.38
    end
    local showFront = faceUp ~= false
    return {
        GUID = "",
        Name = "Custom_Tile",
        Transform = {
            posX = worldPos.x,
            posY = worldPos.y,
            posZ = worldPos.z,
            rotX = 0,
            rotY = yawDeg,
            rotZ = showFront and 0 or 180,
            scaleX = s,
            scaleY = 1,
            scaleZ = s,
        },
        Nickname = characterKey,
        Description = "",
        GMNotes = NPC_TOKEN_GM_PREFIX .. characterKey,
        AltLookAngle = { x = 0, y = 0, z = 0 },
        ColorDiffuse = { r = 1, g = 1, b = 1 },
        LayoutGroupSortIndex = 0,
        Value = 0,
        Locked = false,
        Grid = false,
        Snap = false,
        IgnoreFoW = false,
        MeasureMovement = false,
        DragSelectable = true,
        Autoraise = true,
        Sticky = false,
        Tooltip = true,
        GridProjection = false,
        HideWhenFaceDown = false,
        Hands = false,
        CustomImage = {
            ImageURL = frontUrl,
            ImageSecondaryURL = backUrl,
            ImageScalar = 1,
            WidthScale = 0,
            CustomTile = {
                Type = NPC_CONTROL_TOKEN_TILE_TYPE,
                Thickness = NPC_CONTROL_TOKEN_TILE_THICKNESS,
                Stackable = false,
                Stretch = true,
            },
        },
        LuaScript = "",
        LuaScriptState = "",
        XmlUI = "",
        Tags = { NPC_CONTROL_TOKEN_TAG },
    }
end

--- Enforce round Custom_Tile (type 2) and thin thickness on an NPC control token.
--- spawnObjectData can omit CustomTile fields; setCustomObject + reload applies them in-game.
--- @param obj Object
--- @param frontUrl string
--- @param backUrl string
--- @return boolean
local function applyNpcControlTokenTileShape(obj, frontUrl, backUrl)
    if obj == nil or obj.setCustomObject == nil then
        return false
    end
    obj.setCustomObject({
        image = frontUrl,
        image_bottom = backUrl,
        type = NPC_CONTROL_TOKEN_TILE_TYPE,
        thickness = NPC_CONTROL_TOKEN_TILE_THICKNESS,
        stackable = false,
        stretch = true,
    })
    if obj.reload ~= nil then
        obj.reload()
    end
    return true
end

--- @return Object|nil
local function getControlBoardObject()
    local guid = G.GUIDS and G.GUIDS.CONTROL_BOARD
    if U.Type(guid) ~= "string" or guid == "" then
        return nil
    end
    local board = getObjectFromGUID(guid)
    if board == nil then
        return nil
    end
    return board
end

--- Delete every `npc_control_token` on or off the control board.
-- @return number
function DEBUG.clearNpcControlBoardTokens()
    local deleted = 0
    local tagObjs = getObjectsWithTag(NPC_CONTROL_TOKEN_TAG) or {}
    for _, obj in ipairs(tagObjs) do
        if obj ~= nil and obj.destruct ~= nil then
            obj.destruct()
            deleted = deleted + 1
        end
    end
    print("DEBUG.clearNpcControlBoardTokens: Deleted " .. tostring(deleted) .. " control-board token(s)")
    return deleted
end

--- Apply hosted front/back URLs to existing control-board tokens (after merge + extract).
-- @return number count updated
function DEBUG.applyNpcControlTokenHostedImages()
    local pairsByKey, source = loadNpcControlTokenPairUrls({ preferHosted = true })
    if pairsByKey == nil then
        print("DEBUG.applyNpcControlTokenHostedImages: no hosted URL pairs (" .. tostring(source) .. ")")
        return 0
    end
    local updated = 0
    local tagObjs = getObjectsWithTag(NPC_CONTROL_TOKEN_TAG) or {}
    for _, obj in ipairs(tagObjs) do
        if obj ~= nil and obj.getGMNotes ~= nil and obj.setCustomObject ~= nil then
            local notes = obj.getGMNotes()
            if U.Type(notes) == "string" and string.find(notes, "^" .. NPC_TOKEN_GM_PREFIX) ~= nil then
                local characterKey = string.sub(notes, #NPC_TOKEN_GM_PREFIX + 1)
                local row = pairsByKey[characterKey]
                if U.Type(row) == "table" and isHostedSteamUrl(row.front) and isHostedSteamUrl(row.back) then
                    if applyNpcControlTokenTileShape(obj, row.front, row.back) then
                        npcGameboardModule().setHiddenFromPlayerColors(obj)
                        updated = updated + 1
                    end
                end
            end
        end
    end
    print("DEBUG.applyNpcControlTokenHostedImages: Updated " .. tostring(updated) .. " token(s) from " .. tostring(source))
    return updated
end

--- Spawn paired front/back NPC control tokens on CONTROL_BOARD (palette UV grid on the minimap).
-- Uses `lib.npc_token_hosted_urls` when populated; otherwise `lib.npc_token_upload_manifest` file:/// URLs.
-- Tiles: Custom_Tile type 2 (circle), thickness 0.1 — enforced via spawn data + setCustomObject after spawn.
-- @param options table|nil { destroyExisting?, columns?, total?, uMin?, uMax?, vMin?, vMax?, scale?, preferHosted?, faceUp?, boardYaw? }
-- @return number spawned
function DEBUG.spawnNpcControlBoardTokens(options)
    local opts = options or {}
    if opts.destroyExisting ~= false then
        DEBUG.clearNpcControlBoardTokens()
    end

    local palette = getObjectFromGUID(G.GUIDS.CONTROL_BOARD_PALETTE)
    if palette == nil then
        print(
            "DEBUG.spawnNpcControlBoardTokens: CONTROL_BOARD_PALETTE missing (GUID "
                .. tostring(G.GUIDS.CONTROL_BOARD_PALETTE)
                .. ")"
        )
        return 0
    end
    npcGameboardModule().installPaletteSnaps(palette, { force = true })

    local pairsByKey, source = loadNpcControlTokenPairUrls(opts)
    if pairsByKey == nil then
        print("DEBUG.spawnNpcControlBoardTokens: no token URL pairs — run npm run custom-ui-assets:manifest-npc-tokens")
        return 0
    end

    local keys = sortedCompleteNpcTokenKeys(pairsByKey)
    if #keys == 0 then
        print("DEBUG.spawnNpcControlBoardTokens: manifest has no complete front+back pairs")
        return 0
    end

    local paletteRot = palette.getRotation()
    local boardYaw = (paletteRot and paletteRot.y) or 0
    if U.Type(opts.boardYaw) == "number" then
        boardYaw = opts.boardYaw
    end

    local faceUp = opts.faceUp
    if faceUp == nil then
        faceUp = true
    end

    local Palette = require("lib.npc_control_board_palette")
    local spawnPos = Palette.worldPositionForSnapIndex(palette, 0)
    if spawnPos == nil then
        print("DEBUG.spawnNpcControlBoardTokens: could not resolve palette snap world position")
        return 0
    end

    local spawned = 0
    local skipped = 0
    for i, characterKey in ipairs(keys) do
        local row = pairsByKey[characterKey]
        local worldPos = Vector(spawnPos.x, spawnPos.y, spawnPos.z)
        local data = buildNpcControlTokenSpawnData(
            { x = worldPos.x, y = worldPos.y, z = worldPos.z },
            boardYaw,
            characterKey,
            row.front,
            row.back,
            opts.scale,
            faceUp
        )
        ---@diagnostic disable-next-line: undefined-global
        local obj = spawnObjectData({ data = data })
        if obj == nil then
            print("DEBUG.spawnNpcControlBoardTokens: spawn failed for " .. characterKey)
            skipped = skipped + 1
        else
            applyNpcControlTokenTileShape(obj, row.front, row.back)
            if obj.setTags ~= nil then
                obj.setTags({ NPC_CONTROL_TOKEN_TAG })
            end
            if obj.setGMNotes ~= nil then
                obj.setGMNotes(NPC_TOKEN_GM_PREFIX .. characterKey)
            end
            if obj.setName ~= nil then
                obj.setName(characterKey)
            end
            npcGameboardModule().setHiddenFromPlayerColors(obj)
            spawned = spawned + 1
        end
    end

    local parked = npcGameboardModule().syncTokensToPalette()
    print(
        "DEBUG.spawnNpcControlBoardTokens: Spawned "
            .. tostring(spawned)
            .. "/"
            .. tostring(#keys)
            .. " → parked on CONTROL_BOARD_PALETTE ("
            .. tostring(source)
            .. "; tile type="
            .. tostring(NPC_CONTROL_TOKEN_TILE_TYPE)
            .. " circle, thickness="
            .. tostring(NPC_CONTROL_TOKEN_TILE_THICKNESS)
            .. "; layout sync moved "
            .. tostring(parked)
            .. ")"
    )
    if skipped > 0 then
        print("DEBUG.spawnNpcControlBoardTokens: Skipped " .. tostring(skipped))
    end
    print("  Drag tokens onto CONTROL_BOARD polar snaps, then Apply (or lua GlobalGameboardApply())")
    return spawned
end

--[[
    Help/Documentation
]]

--- Display help for all debug functions
function DEBUG.help()
    print("\n" .. string.rep("=", 70))
    print("TORONTO RISING — DEBUG CONSOLE COMMANDS")
    print(string.rep("=", 70))
    print("\nUse in TTS console: lua <command>()  |  Manual E2E: .dev/E2E Playbooks/")
    print("\nINSPECTION:")
    print("  showState()              - Full gameState JSON")
    print("  showScene()              - sessionScene + sceneLibrary keys")
    print("  showZones()              - Zone lock state")
    print("  inspectSoundscapeAudio() - Emitter GUID/tag/effect inventory")
    print("  dumpConditions(color)    - Active conditions + resolved effects")
    print("  dumpEffectiveStats(color) - Effective stat getters (tracker max, BP, …)")
    print("  dumpRollPolicy(color)    - Merged roll policy on active roll")
    print("\nFILE LOGGING:")
    print("  logToFile(level, msg, filename?) - Log a message to file")
    print("  logStateToFile(filename?)       - Log game state to file (JSON)")
    print("  logNpcPlacementIntentToFile(filename?) - Log Step Zero NPC placement intent (reconcile verify)")
    print("  exportNpcSeatFigurinesToFile(path?)     - Export NPC#Object figurines (name + GUID) to debug_logs")
    print("  logSceneToFile(filename?)       - Log scene info to file")
    print("  logZonesToFile(filename?)       - Log zone info to file")
    print("  logTestToFile(name, passed, details?, filename?) - Log test result")
    print("  logAllToFiles()                   - Log all debug info to files")
    print("  clearAllLogs()                    - Clear all log files (starts new session)")
    print("\nDICE DEBUG (solo — no second player):")
    print("  RunTest(\"Dice\")            - Arm Dice E2E playbook (npm run e2e-playbook:generate)")
    print("  RunTest()                  - Run next playbook step (after each [HUMAN] gate)")
    print("  rollTest(color, diff?, type?, label?, hungerLevel?) - Arm PRE_ROLL (auto seat + camera prep)")
    print("  rollTestNoDiff(color, type?, label?, hungerLevel?) - Arm PRE_ROLL without ST difficulty")
    print("  rollE2eSeatPrep(color)     - Manual prep only; rollTest/rollStTest include this")
    print("  rollSetFaces(color, { normal={7,7}, hunger={10,1} }) - Set faces + recalculate (POST_ROLL)")
    print("  rollE2eApplyConditions(color, { 'e2eBestialNull' }) / rollE2eClearConditions(color, ids?)")
    print("  rollE2eSetPoolAndSpawn / rollE2eSetPoolAutoHunger / rollE2eAddPoolKindSpawn / rollE2eExpectBroadcast")
    print("  rollState(color)         - Print active roll record for a player")
    print("  rollConfirm(color, expected) - Assert roll state; prints PASS/FAIL (E2E)")
    print("  rollConfirmTracker(color, { hunger?, stains?, willpowerSuperficial? })")
    print("  rollStConfirm({ liveSlotIndex?, initiateBlocked? }) - ST slots E2E")
    print("  rollE2eSettlePresetCheck(color, faces) - Spawn pool + startRolling + preset faces + settle")
    print("  setHumanityStains(color, n) / setWillpowerSuperficial(color, n)")
    print("  rollForceConfirm(color)  - Force-confirm POST_ROLL (UI CONFIRM)")
    print("  rollCancel(color)        - Cancel roll; Black also clears ST slots/drawers")
    print("  rollCancelAll()          - Cancel all rolls + ST slots")
    print("  printHeader(text, level) - E2E banner line (level 1..3: *, =, -; 100 chars)")
    print("  rollStTest(label?, type?) - ST NPC roll on Black (e2e seat/camera prep)")
    print("  rollStSlots()            - Print gameState.storytellerRolls")
    print("\nGAMEBOARD E2E (TOR-141 — .dev/E2E Playbooks/Gameboard-E2E.md):")
    print("  gbE2ePrereqCheck()       - Boards, tokens, fixture NPCs, scene row")
    print("  gbE2eReset()             - Empty placements + fixture preload baseline")
    print("  gbE2eRunSmoke()          - Smoke macro; then human scene Apply + gbE2eContinue()")
    print("  gbE2eRunFull()           - Deep reconcile suites (+ optional reload gate)")
    print("  gbE2eRunDeferred()       - Expected FAIL until TOR-172/173/175/174 dedupe")
    print("  gbE2eContinue()          - Resume after HUMAN GATE (scene_apply / reload)")
    print("  gbConfirm(label, expected) - Single assert (placements, intent, probes)")
