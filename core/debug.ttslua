--- Quick test: Set player hunger
-- @param color string Player color
-- @param value number Hunger value (0-5)
function DEBUG.setHunger(color, value)
    if not color or not value then
        print("Usage: setHunger(color, value)")
        print("Example: setHunger('Red', 3)")
        return
    end

    local playerID = S.getPlayerID(color)
    if not playerID then
        print("ERROR: Could not find player ID for color: " .. color)
        return
    end

    setHungerAndSync(color, value)
    print("Set " .. color .. " player (ID: " .. playerID .. ") hunger to " .. tostring(value))

    UpdateUIDisplays()
end

--- Debug helper: Move an object to a world-angle position around table center
-- Positions an object at a given distance and world angle around the table center.
-- ============================================================================
-- DICE SYSTEM DEBUG HELPERS
-- Solo/dev-mode shortcuts for testing roll flow without a second player.
-- Call from the TTS console with:  lua rollTest("Brown", 3)
-- Or via the "DICE DEBUG" buttons in the admin panel (Host only).
-- E2E harness (TOR-164): rollE2eSeatPrep, rollSetFaces, rollE2eApplyConditions.
-- ============================================================================

local DK = require("lib.dice_kinds")

--- Optional 5th argument to rollTest: hunger level (number) only.
-- @param extra number|nil
-- @return table opts { hunger? }
local function parseRollTestExtras(extra)
    local opts = {}
    if type(extra) == "number" then
        opts.hunger = extra
    end
    return opts
end

--- Host seat color after E2E roll tests (Storyteller).
local E2E_RETURN_SEAT = "Black"

--- Seated Host player (any seat). Do not use Player.Black when Host is on Brown, etc.
-- @return table|nil TTS Player
local function rollE2eGetHostPlayer()
    if Player == nil then
        return nil
    end
    local seated = Player.getPlayers()
    if type(seated) == "table" then
        for _, p in ipairs(seated) do
            if p ~= nil and p.host == true then
                return p
            end
        end
    end
    local black = Player[E2E_RETURN_SEAT]
    if black ~= nil and black.seated == true then
        return black
    end
    return nil
end

--- Move Host to seat, hide loading overlay, apply Debug Camera spoof for that seat.
-- @param targetColor string
-- @return boolean ok
local function rollE2eSeatPrepInternal(targetColor)
    if type(targetColor) ~= "string" or targetColor == "" then
        return false
    end

    local hostPlayer = rollE2eGetHostPlayer()
    if hostPlayer == nil then
        U.AlertGM("rollE2eSeatPrep: no seated Host found (join as Host first)")
        return false
    end

    local currentColor = hostPlayer.color
    if currentColor ~= targetColor and type(hostPlayer.changeColor) == "function" then
        local changed = hostPlayer.changeColor(targetColor)
        -- TTS returns false when already on targetColor; re-read seat after change.
        currentColor = hostPlayer.color
        if changed ~= true and currentColor ~= targetColor then
            U.AlertGM("rollE2eSeatPrep: changeColor failed for " .. targetColor
                .. " (Host on " .. tostring(currentColor) .. ")")
            return false
        end
    end

    UI.hide("overlay_loadingScreen_" .. tostring(targetColor))

    local CameraDebugFocus = require("core.camera_debug_focus")
    local ok = CameraDebugFocus.onSpoofColor(hostPlayer, targetColor)
    if ok ~= true then
        U.AlertGM("rollE2eSeatPrep: camera spoof failed for " .. targetColor)
        return false
    end
    return true
end

--- Return Host to Black after testing another seat.
local function rollE2eReturnHostSeat()
    local hostPlayer = rollE2eGetHostPlayer()
    if hostPlayer == nil or type(hostPlayer.changeColor) ~= "function" then
        return
    end
    if hostPlayer.color == E2E_RETURN_SEAT then
        return
    end
    hostPlayer.changeColor(E2E_RETURN_SEAT)
end

--- Manual seat prep only; rollTest / rollStTest run prep automatically.
-- @param targetColor string
function DEBUG.rollE2eSeatPrep(targetColor)
    if type(targetColor) ~= "string" or targetColor == "" then
        print("Usage: rollE2eSeatPrep(targetColor)")
        return
    end
    rollE2eSeatPrepInternal(targetColor)
end

--- Initiates, opens, and arms a roll for a player in one shot.
-- Always runs E2E seat prep: Host changeColor → target seat, loading overlay hide, camera spoof.
--
-- @param color      string       Player seat color (e.g. "Brown")
-- @param difficulty number|nil   Required successes; default 2
-- @param rollType   string|nil   C.RollType value; default C.RollType.STANDARD
-- @param label      string|nil   Roll label shown in the panel; default "Debug Test"
-- @param hungerLevel number|nil  Sets player hunger 0–5 before arming (Suite G, etc.)
-- @usage lua rollTest("Brown", 3)
-- @usage lua rollTest("Brown", 3, C.RollType.STANDARD, "E2E G2", 2)
function DEBUG.rollTest(color, difficulty, rollType, label, hungerLevel)
    if type(color) ~= "string" then
        print("Usage: rollTest(color, difficulty?, rollType?, label?, hungerLevel?)")
        return
    end
    if RC == nil then
        print("[DEBUG.rollTest] RC (roll_controller) is not loaded yet.")
        return
    end

    local opts = parseRollTestExtras(hungerLevel)
    local diff  = (type(difficulty) == "number") and difficulty or 2
    local rType = (type(rollType) == "string" and rollType ~= "") and rollType or C.RollType.STANDARD
    local lbl   = (type(label) == "string" and label ~= "") and label or "Debug Test"

    if rollE2eSeatPrepInternal(color) ~= true then
        print("[DEBUG.rollTest] E2E seat prep failed — aborting.")
        return
    end

    if type(opts.hunger) == "number" then
        setHungerAndSync(color, opts.hunger)
    end

    RC.cancelRoll(color)

    local ok = RC.initiateRoll(color, { rollType = rType, label = lbl })
    if not ok then
        print(string.format("[DEBUG.rollTest] initiateRoll failed for %s (already active?)", color))
        rollE2eReturnHostSeat()
        return
    end
    RC.openRoll(color)
    RC.setDifficulty(color, diff)

    print(string.format("[DEBUG.rollTest] %s PRE_ROLL — diff=%d type=%s label='%s'", color, diff, rType, lbl))
end

--- Arms PRE_ROLL without setting ST difficulty (optional-difficulty E2E).
-- @param color string
-- @param rollType string|nil
-- @param label string|nil
-- @param hungerLevel number|nil
function DEBUG.rollTestNoDiff(color, rollType, label, hungerLevel)
    if type(color) ~= "string" then
        print("Usage: rollTestNoDiff(color, rollType?, label?, hungerLevel?)")
        return
    end
    if RC == nil then
        print("[DEBUG.rollTestNoDiff] RC (roll_controller) is not loaded yet.")
        return
    end

    local opts = parseRollTestExtras(hungerLevel)
    local rType = (type(rollType) == "string" and rollType ~= "") and rollType or C.RollType.STANDARD
    local lbl   = (type(label) == "string" and label ~= "") and label or "Debug Test No Diff"

    if rollE2eSeatPrepInternal(color) ~= true then
        print("[DEBUG.rollTestNoDiff] E2E seat prep failed — aborting.")
        return
    end

    if type(opts.hunger) == "number" then
        setHungerAndSync(color, opts.hunger)
    end

    RC.cancelRoll(color)

    local ok = RC.initiateRoll(color, { rollType = rType, label = lbl })
    if not ok then
        print(string.format("[DEBUG.rollTestNoDiff] initiateRoll failed for %s (already active?)", color))
        rollE2eReturnHostSeat()
        return
    end
    RC.openRoll(color)

    print(string.format("[DEBUG.rollTestNoDiff] %s PRE_ROLL — no diff type=%s label='%s'", color, rType, lbl))
end

--- Normalizes E2E phase strings to C.RollPhase values.
-- @param phase string|nil
-- @return string|nil
local function normalizeRollPhaseAlias(phase)
    if type(phase) ~= "string" then
        return nil
    end
    local key = string.gsub(phase, "[%s_]", "")
    key = string.lower(key)
    local map = {
        setup = C.RollPhase.SETUP,
        preroll = C.RollPhase.PRE_ROLL,
        rolling = C.RollPhase.ROLLING,
        postroll = C.RollPhase.POST_ROLL,
        resolved = C.RollPhase.RESOLVED,
    }
    return map[key] or phase
end

--- True when `expected` is a numeric/presence matcher table (not a data subtree).
-- @param expected table
-- @return boolean
local function isRollExpectMatcher(expected)
    if type(expected) ~= "table" then
        return false
    end
    local hasMatcher = expected.present == true
        or expected.present == false
        or type(expected.min) == "number"
        or type(expected.max) == "number"
        or type(expected.gte) == "number"
        or type(expected.lte) == "number"
        or type(expected.oneOf) == "table"
    if not hasMatcher then
        return false
    end
    for k, _ in pairs(expected) do
        if k ~= "present" and k ~= "min" and k ~= "max" and k ~= "gte" and k ~= "lte" and k ~= "oneOf" then
            return false
        end
    end
    return true
end

--- Compares actual vs expected for rollConfirm; appends failure lines to `failures`.
-- @param actual any
-- @param expected any
-- @param path string
-- @param failures table
local function rollExpectCompare(actual, expected, path, failures)
    if expected == nil then
        return
    end

    if type(expected) == "table" and isRollExpectMatcher(expected) then
        if expected.present == false then
            if actual ~= nil then
                failures[#failures + 1] = path .. ": expected nil/absent, got " .. tostring(actual)
            end
            return
        end
        if expected.present == true then
            if actual == nil then
                failures[#failures + 1] = path .. ": expected value to be present, got nil"
            end
            return
        end
        if type(actual) ~= "number" then
            failures[#failures + 1] = path .. ": expected number, got " .. type(actual)
            return
        end
        if type(expected.min) == "number" and actual < expected.min then
            failures[#failures + 1] = path .. ": " .. tostring(actual) .. " < min " .. tostring(expected.min)
        end
        if type(expected.max) == "number" and actual > expected.max then
            failures[#failures + 1] = path .. ": " .. tostring(actual) .. " > max " .. tostring(expected.max)
        end
        if type(expected.gte) == "number" and actual < expected.gte then
            failures[#failures + 1] = path .. ": " .. tostring(actual) .. " < gte " .. tostring(expected.gte)
        end
        if type(expected.lte) == "number" and actual > expected.lte then
            failures[#failures + 1] = path .. ": " .. tostring(actual) .. " > lte " .. tostring(expected.lte)
        end
        if type(expected.oneOf) == "table" then
            local found = false
            for _, allowed in ipairs(expected.oneOf) do
                if actual == allowed then
                    found = true
                    break
                end
            end
            if not found then
                failures[#failures + 1] = path .. ": " .. tostring(actual) .. " not in oneOf list"
            end
        end
        return
    end

    if type(expected) ~= "table" then
        if actual ~= expected then
            failures[#failures + 1] = path
                .. ": got " .. tostring(actual) .. ", want " .. tostring(expected)
        end
        return
    end

    if type(actual) ~= "table" then
        failures[#failures + 1] = path .. ": expected table, got " .. type(actual)
        return
    end

    -- Mixed matcher + fields, e.g. { present = true, resultClass = { present = true } }:
    -- `present` means the actual table exists; other keys compare into actual (not actual.present).
    if expected.present == true and actual == nil then
        failures[#failures + 1] = path .. ": expected value to be present, got nil"
        return
    end

    for key, subExpected in pairs(expected) do
        if key == "marginAbsent" then
            if subExpected == true then
                if type(actual) ~= "table" or actual.margin ~= nil then
                    failures[#failures + 1] = path
                        .. ": expected margin absent (nil), got "
                        .. tostring(type(actual) == "table" and actual.margin or actual)
                end
            end
        elseif key == "present" then
            if subExpected == true then
                if actual == nil then
                    failures[#failures + 1] = path .. ": expected value to be present, got nil"
                end
            else
                rollExpectCompare(actual, subExpected, path, failures)
            end
        else
            rollExpectCompare(actual[key], subExpected, path .. "." .. tostring(key), failures)
        end
    end
end

--- Resolves seat color + expectation table from rollConfirm call shapes.
-- @param colorOrSpec string|table
-- @param maybeExpected table|nil
-- @return string|nil color, table|nil expected, string|nil err
local function parseRollConfirmArgs(colorOrSpec, maybeExpected)
    if type(colorOrSpec) == "table" and maybeExpected == nil then
        local spec = colorOrSpec
        return spec.color, spec, nil
    end
    if type(colorOrSpec) ~= "string" then
        return nil, nil, "first argument must be seat color or { color = ... }"
    end
    if string.lower(colorOrSpec) == "global" then
        if type(maybeExpected) ~= "table" then
            return nil, nil, "\"Global\" is deprecated — use rollConfirm(\"Brown\", { phase = \"preRoll\", ... })"
        end
        local seat = maybeExpected.color
        if type(seat) ~= "string" then
            return nil, nil, "with legacy \"Global\", pass expected.color = seat (e.g. \"Brown\")"
        end
        return seat, maybeExpected, nil
    end
    if type(maybeExpected) ~= "table" then
        return nil, nil, "second argument must be expectation table"
    end
    return colorOrSpec, maybeExpected, nil
end

--- Asserts roll state against expected values; prints PASS/FAIL with details.
-- @param colorOrSpec string|table  Seat color, or { color, phase?, active?, pool?, ... }
-- @param expected table|nil  e.g. { phase = "preRoll", active = { difficulty = 3, rollType = ... } }
-- @return boolean pass
-- @usage lua rollConfirm("Brown", { phase = "preRoll", active = { difficulty = 3, rollType = C.RollType.STANDARD } })
-- @usage lua rollConfirm({ color = "Brown", phase = "postRoll", active = { result = { present = true } } })
function DEBUG.rollConfirm(colorOrSpec, maybeExpected)
    -- Legacy one-arg form (pre–TOR-141 E2E harness): force-confirm POST_ROLL.
    if maybeExpected == nil and type(colorOrSpec) == "string" then
        print("[rollConfirm] DEPRECATED: one-arg rollConfirm(color) — use rollForceConfirm(color)")
        return DEBUG.rollForceConfirm(colorOrSpec)
    end

    local color, expected, err = parseRollConfirmArgs(colorOrSpec, maybeExpected)
    if err ~= nil then
        print("[rollConfirm] FAIL: " .. err)
        return false
    end

    local failures = {}
    local label = color

    if expected.noActive == true then
        label = color .. " noActive"
        local pid = S.getPlayerID(color)
        local active = pid and S.getStateVal("playerData", pid, "hud", "rollData", "active")
        if active ~= nil then
            failures[#failures + 1] = "expected no active roll, but active roll exists"
        end
    else
        local pid = S.getPlayerID(color)
        if pid == nil then
            failures[#failures + 1] = "no playerID for seat " .. tostring(color)
        else
            local active = S.getStateVal("playerData", pid, "hud", "rollData", "active")
            if active == nil then
                failures[#failures + 1] = "expected active roll, got nil"
            else
                local phaseExpected = expected.phase or expected.preRoll or expected.postRoll
                    or expected.rolling or expected.setup or expected.resolved
                if type(phaseExpected) == "string" then
                    local wantPhase = normalizeRollPhaseAlias(phaseExpected)
                    local actualPhase = active.phase
                    if Global ~= nil and type(Global.call) == "function" then
                        local gPhase = Global.call("GlobalGetRollPhase", { color = color })
                        if type(gPhase) == "string" then
                            actualPhase = gPhase
                        end
                    end
                    if actualPhase ~= wantPhase then
                        failures[#failures + 1] = "phase: got "
                            .. tostring(actualPhase) .. ", want " .. tostring(wantPhase)
                    end
                end

                if type(expected.pool) == "table" then
                    expected.active = expected.active or {}
                    expected.active.pool = expected.active.pool or {}
                    for k, v in pairs(expected.pool) do
                        expected.active.pool[k] = v
                    end
                end
                if type(expected.meta) == "table" then
                    expected.active = expected.active or {}
                    expected.active.meta = expected.active.meta or {}
                    for k, v in pairs(expected.meta) do
                        expected.active.meta[k] = v
                    end
                end
                if type(expected.result) == "table" then
                    expected.active = expected.active or {}
                    expected.active.result = expected.active.result or {}
                    for k, v in pairs(expected.result) do
                        expected.active.result[k] = v
                    end
                end

                if type(expected.active) == "table" then
                    rollExpectCompare(active, expected.active, "active", failures)
                end

                if type(expected.rouseStripLabel) == "string" then
                    local strips = active.rouseOutcomeStrips
                    local found = false
                    if type(strips) == "table" then
                        for _, strip in ipairs(strips) do
                            if type(strip) == "table" and strip.label == expected.rouseStripLabel then
                                found = true
                                break
                            end
                        end
                    end
                    if not found then
                        failures[#failures + 1] = "rouseOutcomeStrips: no strip labeled "
                            .. expected.rouseStripLabel
                    end
                end

                if type(expected.rouseOutcomeStripsMin) == "number" then
                    local n = (type(active.rouseOutcomeStrips) == "table") and #active.rouseOutcomeStrips or 0
                    if n < expected.rouseOutcomeStripsMin then
                        failures[#failures + 1] = "rouseOutcomeStrips: count "
                            .. tostring(n) .. " < min " .. tostring(expected.rouseOutcomeStripsMin)
                    end
                end

                if type(expected.rouseStrip) == "table" then
                    local wantLabel = expected.rouseStrip.label
                    local wantNarrative = expected.rouseStrip.narrative
                    local strips = active.rouseOutcomeStrips
                    local found = false
                    if type(strips) == "table" then
                        for _, strip in ipairs(strips) do
                            if type(strip) == "table" then
                                local labelOk = type(wantLabel) ~= "string" or strip.label == wantLabel
                                local narrOk = type(wantNarrative) ~= "string"
                                    or strip.narrative == wantNarrative
                                if labelOk and narrOk then
                                    found = true
                                    break
                                end
                            end
                        end
                    end
                    if not found then
                        failures[#failures + 1] = "rouseOutcomeStrips: no strip matching "
                            .. JSON.encode(expected.rouseStrip)
                    end
                end

                if type(expected.wpRerollChosenCount) == "number" then
                    local guids = (type(active.willpower) == "table")
                        and active.willpower.rerollRandomizedGuids or nil
                    local nChosen = 0
                    if type(guids) == "table" then
                        for _ in pairs(guids) do
                            nChosen = nChosen + 1
                        end
                    end
                    if nChosen ~= expected.wpRerollChosenCount then
                        failures[#failures + 1] = "willpower.rerollRandomizedGuids: count "
                            .. tostring(nChosen) .. ", want "
                            .. tostring(expected.wpRerollChosenCount)
                    end
                end

                if type(expected.contributingIncludes) == "table" then
                    local contrib = (type(active.rollPolicy) == "table")
                        and active.rollPolicy.contributingConditions or {}
                    for _, wantId in ipairs(expected.contributingIncludes) do
                        local foundId = false
                        if type(contrib) == "table" then
                            for _, cid in ipairs(contrib) do
                                if cid == wantId then
                                    foundId = true
                                    break
                                end
                            end
                        end
                        if not foundId then
                            failures[#failures + 1] = "rollPolicy.contributingConditions: missing "
                                .. tostring(wantId)
                        end
                    end
                end
            end
        end
    end

    if #failures == 0 then
        print("[rollConfirm] PASS — " .. label)
        return true
    end
    print("[rollConfirm] FAIL — " .. label)
    for i, line in ipairs(failures) do
        print(string.format("  %d) %s", i, line))
    end
    return false
end

--- Reads humanity stain count for a seat (player PCs only).
-- @param color string
-- @return number
local function readHumanityStains(color)
    local pid = S.getPlayerID(color)
    if pid == nil then
        return 0
    end
    local stats = S.getStateVal("playerData", pid, "stats")
    if type(stats) ~= "table" then
        return 0
    end
    if type(stats.humanity) == "table" then
        return math.max(0, math.floor(tonumber(stats.humanity.stains) or 0))
    end
    return math.max(0, math.floor(tonumber(stats.stains) or 0))
end

--- Asserts tracker fields (hunger, stains, superficial willpower) for E2E.
-- @param color string
-- @param expected table  { hunger?, stains?, willpowerSuperficial? }
-- @return boolean pass
-- @usage lua rollConfirmTracker("Brown", { hunger = 3 })
function DEBUG.rollConfirmTracker(color, expected)
    if type(color) ~= "string" or type(expected) ~= "table" then
        print("[rollConfirmTracker] FAIL: usage rollConfirmTracker(color, { hunger = N, ... })")
        return false
    end
    local failures = {}
    if type(expected.hunger) == "number" then
        local actual = math.floor(tonumber(S.getPlayerVal(color, "hunger")) or 0)
        if actual ~= expected.hunger then
            failures[#failures + 1] = "hunger: got " .. tostring(actual)
                .. ", want " .. tostring(expected.hunger)
        end
    end
    if type(expected.stains) == "number" then
        local actual = readHumanityStains(color)
        if actual ~= expected.stains then
            failures[#failures + 1] = "stains: got " .. tostring(actual)
                .. ", want " .. tostring(expected.stains)
        end
    end
    if type(expected.willpowerSuperficial) == "number" then
        local pid = S.getPlayerID(color)
        local actual = 0
        if pid ~= nil then
            local stats = S.getStateVal("playerData", pid, "stats")
            if type(stats) == "table" and type(stats.willpower) == "table" then
                actual = math.floor(tonumber(stats.willpower.superficial) or 0)
            end
        end
        if actual ~= expected.willpowerSuperficial then
            failures[#failures + 1] = "willpower.superficial: got " .. tostring(actual)
                .. ", want " .. tostring(expected.willpowerSuperficial)
        end
    end
    if #failures == 0 then
        print("[rollConfirmTracker] PASS — " .. color)
        return true
    end
    print("[rollConfirmTracker] FAIL — " .. color)
    for i, line in ipairs(failures) do
        print(string.format("  %d) %s", i, line))
    end
    return false
end

--- Sets humanity stain count for a seat and syncs presentation.
-- @param color string
-- @param value number
-- @usage lua setHumanityStains("Purple", 2)
function DEBUG.setHumanityStains(color, value)
    if type(color) ~= "string" or type(value) ~= "number" then
        print("Usage: setHumanityStains(color, value)")
        return
    end
    local pid = S.getPlayerID(color)
    if pid == nil then
        print("[setHumanityStains] no playerID for " .. color)
        return
    end
    local n = math.max(0, math.floor(value))
    S.setStateVal(n, "playerData", pid, "stats", "humanity", "stains")
    local Conditions = require("core.conditions")
    Conditions.reconcileDerivedForPlayer(pid)
    Conditions.afterChange(pid)
    Sync.player(color)
    print(string.format("[setHumanityStains] %s stains=%d", color, n))
end

--- Sets superficial willpower boxes for a seat and syncs presentation.
-- @param color string
-- @param value number
-- @usage lua setWillpowerSuperficial("Brown", 3)
function DEBUG.setWillpowerSuperficial(color, value)
    if type(color) ~= "string" or type(value) ~= "number" then
