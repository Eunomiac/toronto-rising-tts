--- Quick test: enable/disable scheduled thunder, or trigger one hit immediately.
-- @param mode string|boolean|nil Use true/"on" to schedule, false/"off" to cancel, "hit" to play once.
-- @param hitKey string|nil Optional thunder hit key when mode is "hit".
function DEBUG.soundscapeThunder(mode, hitKey)
    local ok, message
    if mode == "hit" then
        ok, message = Soundscape.triggerThunder(hitKey)
    else
        local enabled = mode == true or mode == "true" or mode == "on" or mode == "enable"
        ok, message = Soundscape.setThunderEnabled(enabled)
    end
    printTestResult("Soundscape thunder", ok, message)
    UpdateUIDisplays()
end

