--[[
    Try chronicle seat assignment when a player connects (Steam ID → C.PlayerData.color).
    @param color string Current TTS seat color (often White before assignment).
]]
function M.tryAutoAssignSeatFromChronicle(color)
    if color == "Grey" then
        return
    end

    local player = Player[color]
    if player == nil or not U.isPlayer(player) then
        return
    end

    local playerID = S.getStorageID(player)
    if playerID == nil then
        return
    end

    local chronicle = C.PlayerData[playerID]
    if type(chronicle) ~= "table" or type(chronicle.color) ~= "string" then
        return
    end

    local targetColor = chronicle.color
    if not U.isIn(targetColor, C.PlayerColors) then
        return
    end

    if color == targetColor then
        M.onPlayerChangeColor(color)
        return
    end

    local occupant = Player[targetColor]
    if occupant ~= nil and U.isPlayer(occupant) then
        local occupantId = S.getStorageID(occupant)
        if type(occupantId) == "string" and occupantId ~= playerID then
            return
        end
    end

    player.changeColor(targetColor)
end

--[[
    Handle player color/seat selection
    Triggered when a player chooses a seat color (Brown, Orange, Red, Pink).
    Extracts their steam_id and ensures they have a state entry. New players get
    a minimal entry and the GM is notified to set up their character details.

    @param color string The color the player selected. "Grey" = disconnect (ignored).
]]
function M.onPlayerChangeColor(color)
    -- Ignore disconnects (TTS passes "Grey" when a player disconnects)
    if color == "Grey" then
        return
    end

    -- Only act when a player selects a defined seat color (not Black/Storyteller, not spectator)
    if not U.isIn(color, C.PlayerColors) then
        return
    end

    local player = Player[color]
    if player == nil or not U.isPlayer(player) then
        return
    end

    local playerID = S.getStorageID(player)
    if playerID == nil then
        return
    end

    -- Check if they already have state data
    local state = S.getGameState(false)
    if state and state.playerData and state.playerData[playerID] then
        -- Update their color in case they switched seats
        state.playerData[playerID].color = color
        return
    end

    -- New player: initialize state and notify GM
    S.initNewPlayer(playerID, color, player.steam_name)
end

-- Alternate entry name used by some load paths
M.Initialize = M.onLoad

return M
