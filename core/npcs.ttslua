--[[
    NPC spawning, areas, paired spotlights, and gameboard/reconciler integration.
    Data: lib/npcs_data.ttslua (NPCS.characters, NPCS.lights, NPCS.areas — includes off-table `preload` pool at world y=-200).
    Spec: .dev/NPC Object Spawning & Spotlighting/NPC Object Overview.md
    Related: .dev/NPC Object Spawning & Spotlighting/NPC Light Object Data.jsonc; .dev/Game State Data.jsonc;
    .dev/Chronicle Data/NPCS_*.md (content keys); .dev/DEBUG_FILE_LOGGING.md.
]]

local NPCS = {}

local U = require("lib.util")
local S = require("core.state")
local C = require("lib.constants")
local L = require("core.lighting")
local DATA = require("lib.npcs_data")
local NLIGHT = require("lib.npcs_light_spawn_defaults")
local SRI = require("lib.seat-role-identity")

NPCS.characters = DATA.characters or {}
NPCS.lights = DATA.lights or {}
NPCS.stageLights = DATA.stageLights or {}
NPCS.areas = DATA.areas or {}

local TAG_FIG = "npc_figurine"
local TAG_LIT = "npc_light"
local TAG_SPOTLIGHT = "Spotlight"
local GM_PREFIX = "npcInstance:"
--- Spawn nickname for pooled NPC spotlights (`spawnObjectData` / save `Nickname`).
local NPC_LIGHT_NICKNAME_PREFIX = "NPC Light "

--- Area key whose `distance` / `rotation = 0` define canonical slot layout in table XZ (similarity about origin).
local REF_AREA_KEY = "centerForward"

--- Off-table `preload` area in `npcs_data` holds the **global** small-scale NPC + light pool (`NPCS.ensureAllNpcsPreload*`).
local PRELOAD_AREA_KEY = "preload"
NPCS.PRELOAD_AREA_KEY = PRELOAD_AREA_KEY

--- Non-area key for `applyNpcPairPhysicalPresentation` at table seats (active scale, tooltips on).
local SEAT_PLACEMENT_KEY = "seat"

--- Forward declarations for reconcile pipeline (defined later in this module).
local resolveNpcPlacementIntent
local occupiedNpcSeatsFingerprint

--- Grow `areas.preload.positions` at runtime so every `characters` entry gets a stable under-table slot.
local function ensurePreloadLayoutCapacity()
    local area = NPCS.areas[PRELOAD_AREA_KEY]
    if area == nil or U.Type(area.positions) ~= "table" then
        return
    end
    local want = 0
    for _ in pairs(NPCS.characters or {}) do
        want = want + 1
    end
    local spacing = 14
    local cols = 10
    while #area.positions < want do
        local i = #area.positions + 1
        local zero = i - 1
        local col = zero % cols
        local row = math.floor(zero / cols)
        area.positions[i] = { x = col * spacing, z = row * spacing }
    end
end

ensurePreloadLayoutCapacity()

--- Sentinel `areaKey` while figurines are parked at `NPC_DISABLE_WORLD_Y` before applying a new scene NPC layout.
local STASH_AREA_KEY = "__npcSceneStash"
NPCS.STASH_AREA_KEY = STASH_AREA_KEY

--- Sentinel `areaKey` for free-placement figurines driven by `npcWorld.placements` (gameboard).
local STAGE_BOARD_AREA_KEY = "__stage_board__"
NPCS.STAGE_BOARD_AREA_KEY = STAGE_BOARD_AREA_KEY
--- World Y used to hide NPC figurines under the table when clearing a scene layout (must be below playfield).
NPCS.NPC_DISABLE_WORLD_Y = -200
local NPC_DISABLE_WORLD_Y = -200

--- Fingerprint of authored `sessionScene.npcWorld` so repeated `Sync.full` does not re-run stash/spawn.
local lastSessionNpcWorldFingerprint = nil

--- Unified NPC reconcile fingerprint (placements + seats + table + presence).
local lastNpcReconcileFingerprint = nil

--- Last successful layout commit for Step Three skip verification.
local lastNpcLayoutCommit = {
    tableKey = "",
    fingerprint = "",
}

--- When true, defer async `requestSeatLayoutSync`; orchestrator runs synchronous layout commit.
local npcReconcileInProgress = false

--- One-shot layout context for `lib.rotational-seat-layout` during orchestrated reconcile.
local npcReconcileLayoutContext = nil

--- While true, instance uses spotlight mode until mouse up (not persisted).
local spotlightHeld = {}

--- Spawn callback only: `buildResolvedLightModeTable` prefers this object over `getObjectFromGUID` (GUID index can lag the live `fig`).
local lightAlignFigOverride = {}
--- Bumped when a new deferred stage light-align sequence starts; stale sequences no-op on completion.
local deferredLightAlignGeneration = {}

--- Custom_Assetbundle spotlights: `L.GetLight` can be true while `loading_custom` is still true; component `set` calls are then ignored (matches `U.waitUntil` object-resting checks in `lib.util`).
--- @param lightGuid string
--- @param reg string `npcLight_<guid>`
--- @return boolean
local function npcSpotlightReadyForApply(lightGuid, reg)
    if U.Type(lightGuid) ~= "string" or lightGuid == "" or U.Type(reg) ~= "string" or reg == "" then
        return false
    end
    local litObj = getObjectFromGUID(lightGuid)
    if litObj == nil then
        return false
    end
    if litObj.loading_custom == true then
        return false
    end
    return L.GetLight(reg, true) ~= nil
end

--- World offset from figurine root position to NPC spotlight spawn (matches prior clone placement).
local NPC_LIGHT_SPAWN_OFFSET = { x = 3, y = 8, z = 3 }
--- After `npcSpotlightReadyForApply`, extra wall-clock delay before `SetLightMode` so the spotlight beam reliably applies on spawn.
local NPC_LIGHT_POST_READY_DELAY_SEC = 1.5
--- Minimum figurine `getBounds().size.y` before bounds-based spotlight Y (guards `image_scalar` + `reload()` race).
local NPC_FIGURINE_LIGHT_ALIGN_MIN_BOUNDS_Y = 10
--- After figurine bounds pass, brief settle before `buildResolvedLightModeTable` (stage reposition; shorter than spawn).
local NPC_STAGE_LIGHT_POST_BOUNDS_DELAY_SEC = 0.25

--- Extra yaw (degrees) for figurines in NPC **area** slots only. `Figurine_Custom` front/back UVs face opposite the legacy single-image cutouts for the same `atan2` pivot math toward table center.
--- Table **seats**: pooled figurine gets the seat `*Object` tag and is moved as `SEAT_FIGURE` by rotational layout.
local AREA_NPC_FIGURINE_YAW_OFFSET_DEG = 180

--- World scale for paired NPC objects while parked in the global under-table preload pool (`preload` area).
local NPC_PRELOAD_FIGURE_SCALE = 0.12
local NPC_PRELOAD_LIGHT_SCALE = 0.12
local NPC_ACTIVE_FIGURE_SCALE = 1
local NPC_ACTIVE_LIGHT_SCALE = 1

--- Custom Figurine ImageScalar at table seats (TTS figurine custom-property scale — not Transform `setScale`).
local NPC_SEAT_FIGURINE_IMAGE_SCALAR = 53

--- Baseline registry scalar for bounds-based spotlight Y; larger cutouts need look-at + position tweaks.
--- Lord Lucien (53): head ≈ 41.8 — bounds formula correct with no extra. Ian Rammond (63): head ≈ 57.91 (+ fudge for upper-face aim).
local NPC_FIGURINE_LIGHT_BASELINE_SCALAR = 53
local NPC_FIGURINE_LIGHT_CAL_REF_SCALAR = 63
local NPC_FIGURINE_LIGHT_CAL_FACE_DELTA_Y = 24
local NPC_FIGURINE_LIGHT_CAL_POSITION_DELTA_Y = 12

--- Tolerance when comparing figurine ImageScalar before skipping `reload()`.
local FIGURINE_IMAGE_SCALAR_EPS = 0.05

--- Deep-clone TTS object state for `spawnObjectData` and clear `GUID` so the engine assigns a new id (avoids mutating live template data).
--- @param data table|nil
--- @return table|nil
local function cloneObjectDataForSpawn(data)
    if U.Type(data) ~= "table" then
        return nil
    end
    if JSON ~= nil and U.Type(JSON.encode) == "function" and U.Type(JSON.decode) == "function" then
        -- pcall: JSON.encode of spawn data can throw when TTS object snapshots include values the encoder rejects. Propagating would abort NPC spawn even though a shallow copy can still produce a spawnable payload.
        local encOk, encoded = pcall(function()
            return JSON.encode(data)
        end)
        if encOk and U.Type(encoded) == "string" then
            -- pcall: decode guards against rare malformed/intermediate strings during iterative encode fixes. Propagating would block spawn when falling back to shallow copy is still viable.
            local decOk, decoded = pcall(function()
                return JSON.decode(encoded)
            end)
            if decOk and U.Type(decoded) == "table" then
                decoded.GUID = ""
                return decoded
            end
        end
    end
    local shallow = U.clone(data)
    if U.Type(shallow) == "table" then
        shallow.GUID = ""
    end
    return shallow
end

--- Avoid C# null-ref when alerting: U.AlertGM uses U.getHost().color (host may be missing in edge setups).
--- @param message string
local function safeAlertGM(message)
    local msg = U.Type(message) == "string" and message or tostring(message)
    U.AlertGM(msg)
    if broadcastToAll ~= nil then
        broadcastToAll("[NPCS] " .. msg, Color(1, 0.55, 0.2))
    end
end

--- @param base table|nil
--- @param override table|nil
--- @return table
local function deepMerge(base, override)
    local out = U.clone(base) or {}
    if U.Type(override) ~= "table" then
        return out
    end
    for k, v in pairs(override or {}) do
        if U.Type(v) == "table" and U.Type(out[k]) == "table" then
            out[k] = deepMerge(out[k], v)
        else
            out[k] = v
        end
    end
    return out
end

--- @return table
local function getInstances()
    local t = S.getStateVal("npcs", "instances")
    if U.Type(t) ~= "table" then
        return {}
    end
    return t
end

--- Runtime O(1) lookup: figurine GUID → npc instance name (TOR-197).
local figurineGuidToNpcName = {}

--- Rebuild figurine GUID cache from persisted instances (after load or bulk replace).
local function rebuildFigurineGuidCache()
    figurineGuidToNpcName = {}
    for npcName, rec in pairs(getInstances()) do
        if U.Type(npcName) == "string" and U.Type(rec) == "table" then
            local figGuid = rec.figurineGuid
            if U.Type(figGuid) == "string" and figGuid ~= "" then
                figurineGuidToNpcName[figGuid] = npcName
            end
        end
    end
end

--- @param npcName string
--- @param prevRec table|nil
--- @param newRec table|nil
local function syncFigurineGuidCacheForRecord(npcName, prevRec, newRec)
    if U.Type(prevRec) == "table" then
        local prevGuid = prevRec.figurineGuid
        if U.Type(prevGuid) == "string" and prevGuid ~= "" and figurineGuidToNpcName[prevGuid] == npcName then
            figurineGuidToNpcName[prevGuid] = nil
        end
    end
    if U.Type(newRec) == "table" then
        local newGuid = newRec.figurineGuid
        if U.Type(newGuid) == "string" and newGuid ~= "" then
            figurineGuidToNpcName[newGuid] = npcName
        end
    end
end

--- @return table<string, string|boolean>
local function getOccupiedNpcSeatMap()
    local seatLayout = S.getStateVal("seatLayout")
    if U.Type(seatLayout) ~= "table" then
        return {}
    end
    local slots = seatLayout.occupiedNPCSlots
    if U.Type(slots) ~= "table" then
        return {}
    end
    return slots
end

--- @param occupied table<string, string|boolean>
local function setOccupiedNpcSeatMap(occupied)
    S.setStateVal(occupied, "seatLayout", "occupiedNPCSlots")
end

--- @param instances table
local function setAllInstances(instances)
    S.setStateVal(instances, "npcs", "instances")
    rebuildFigurineGuidCache()
end

--- @param npcName string
--- @param rec table|nil
local function setInstanceRecord(npcName, rec)
    local prev = getInstances()[npcName]
    syncFigurineGuidCacheForRecord(npcName, prev, rec)
    local all = U.clone(getInstances())
    all[npcName] = rec
    S.setStateVal(all, "npcs", "instances")
end

--- @param npcName string
--- @return string|nil
local function findSeatByNpcKey(npcName)
    if U.Type(npcName) ~= "string" or npcName == "" then
        return nil
    end
    local occupied = getOccupiedNpcSeatMap()
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if occupied[seatKey] == npcName then
            return seatKey
        end
    end
    return nil
end

--- @param seatKey string
--- @return string|boolean|nil
local function getSeatOccupant(seatKey)
    if U.Type(seatKey) ~= "string" or seatKey == "" then
        return nil
    end
    return getOccupiedNpcSeatMap()[seatKey]
end

--- @param seatKey string
--- @return boolean
local function isValidNpcSeatKey(seatKey)
    return U.Type(seatKey) == "string" and U.isIn(seatKey, C.NPCSeats or {})
end

--- @param rec table|nil
--- @return boolean
local function isNpcSeatedAtTable(rec)
    if U.Type(rec) ~= "table" then
        return false
    end
    return U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey)
end

--- @param npcName string
--- @return boolean
local function validateNpcNameKey(npcName)
    return U.Type(npcName) == "string" and string.match(npcName, "^[%a_][%w_]*$") ~= nil
end

--- Deterministic preload grid slot per character key (sorted `NPCS.characters` keys).
--- Must precede `assignNpcToSeat` / `resolvePreloadSlotForMove` (Lua local scope).
--- @param npcName string
--- @return number|nil
local function stablePreloadSlotIndex(npcName)
    if not validateNpcNameKey(npcName) or NPCS.characters[npcName] == nil then
        return nil
    end
    local keys = {}
    for k, _ in pairs(NPCS.characters or {}) do
        keys[#keys + 1] = k
    end
    table.sort(keys)
    for i, k in ipairs(keys) do
        if k == npcName then
            return i
        end
    end
    return nil
end

local seatSyncQueued = false

local function requestSeatLayoutSync()
    if npcReconcileInProgress then
        return
    end
    if seatSyncQueued then
        return
    end
    local rsl = require("lib.rotational-seat-layout")
    if rsl ~= nil and type(rsl.isLayoutSyncCurrent) == "function" and rsl.isLayoutSyncCurrent() then
        return
    end
    seatSyncQueued = true
    U.delay(function()
        seatSyncQueued = false
        if rsl ~= nil and type(rsl.isLayoutSyncCurrent) == "function" and rsl.isLayoutSyncCurrent() then
            return
        end
        if rsl ~= nil and type(rsl.SyncTable) == "function" then
            rsl.SyncTable()
        end
    end, 0.08)
end

--- Viewer colors for NPC seat presence hide/show (all seated players + spectators).
--- @return string[]
local function allViewerColorsForInvisibility()
    local out = { "White", "Black", "Grey" }
    for i = 1, #(C.PlayerColors or {}) do
        out[#out + 1] = C.PlayerColors[i]
    end
    return out
end

--- Narrative presence for one seat (`seatSlots.isPresent` wins over `seatPresent`).
--- @param seatKey string
--- @return boolean
local function resolveSeatPresenceForSeat(seatKey)
    local ss = S.getStateVal("sessionScene", "seatSlots")
    if U.Type(ss) == "table" then
        local row = ss[seatKey]
        if U.Type(row) == "table" and row.isPresent ~= nil then
            return row.isPresent ~= false
        end
    end
    local sp = S.getStateVal("sessionScene", "seatPresent")
    if U.Type(sp) == "table" and sp[seatKey] ~= nil then
        return sp[seatKey] ~= false
    end
    return true
end

--- Assigned NPC character for a seat from validated `occupiedNPCSlots`.
--- @param seatKey string
--- @return string|nil
local function resolveAssignedCharacterForSeat(seatKey)
    local occ = getOccupiedNpcSeatMap()[seatKey]
    if U.Type(occ) == "string" and occ ~= "" then
        return occ
    end
    return nil
end

--- True when `occupiedNPCSlots[seatKey]` is assigned and that character has a control-board stage row.
--- @param seatKey string
--- @return boolean
local function isNpcSeatOccupantStageBound(seatKey)
    if not isValidNpcSeatKey(seatKey) then
        return false
    end
    local occupant = resolveAssignedCharacterForSeat(seatKey)
    if U.Type(occupant) ~= "string" or occupant == "" then
        return false
    end
    local placements = S.getStateVal("sessionScene", "npcWorld", "placements")
    if U.Type(placements) ~= "table" then
        return false
    end
    local row = placements[occupant]
    return U.Type(row) == "table" and tonumber(row.u) ~= nil and tonumber(row.v) ~= nil
end

--- @param seatKey string
--- @return string
local function seatTagForKey(seatKey)
    return seatKey .. "Object"
end

--- @param fig Object|nil
--- @param seatKey string
--- @return boolean
local function figurineHasSeatTag(fig, seatKey)
    if fig == nil or fig.getTags == nil then
        return false
    end
    local want = seatTagForKey(seatKey)
    local tags = fig.getTags() or {}
    if U.Type(tags) ~= "table" then
        return false
    end
    for _, t in ipairs(tags) do
        if t == want then
            return true
        end
    end
    return false
end

--- @param fig Object|nil
--- @return boolean
local function figurineHasAnySeatTag(fig)
    if fig == nil or fig.getTags == nil then
        return false
    end
    local tags = fig.getTags() or {}
    if U.Type(tags) ~= "table" then
        return false
    end
    for _, sk in ipairs(C.NPCSeats or {}) do
        if figurineHasSeatTag(fig, sk) then
            return true
        end
    end
    return false
end

--- @param npcName string
--- @return boolean
local function npcInstanceInStageArea(npcName)
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" then
        return false
    end
    if rec.areaKey == STAGE_BOARD_AREA_KEY then
        return true
    end
    local ak = rec.areaKey
    if U.Type(ak) ~= "string" or ak == PRELOAD_AREA_KEY or ak == STASH_AREA_KEY then
        return false
    end
    local area = NPCS.areas[ak]
    return U.Type(area) == "table" and area.excludeFromNpcPanel ~= true
end

--- Stage figurine (legacy area or gameboard `placements`).
--- @param npcName string
--- @return boolean
local function npcInstanceOnStage(npcName)
    return npcInstanceInStageArea(npcName)
end

--- @param seatKey string
--- @return boolean
local function isNpcPhysicallyAtSeat(seatKey)
    for _, rec in pairs(getInstances()) do
        if U.Type(rec) == "table" and rec.seatedSeatKey == seatKey then
            return true
        end
    end
    local tag = seatTagForKey(seatKey)
    local objs = getObjectsWithTag(tag)
    if U.Type(objs) ~= "table" then
        return false
    end
    for i = 1, #objs do
        local o = objs[i]
        if o ~= nil and NPCS.isPooledFigurineObject(o) and figurineHasSeatTag(o, seatKey) then
            return true
        end
    end
    return false
end

--- @param obj Object|nil
--- @return boolean
local function hasNpcInstanceGmNotes(obj)
    if not U.isGameObject(obj) then
        return false
    end
    local desc = ""
    if obj.getDescription ~= nil then
        desc = tostring(obj.getDescription() or "")
    end
    if desc == "" and obj.getGMNotes ~= nil then
        desc = tostring(obj.getGMNotes() or "")
    end
    return string.find(desc, GM_PREFIX, 1, true) ~= nil
end

--- True for pooled `Figurine_Custom` cutouts in the NPC instance pool.
--- Preload/stage: `npc_figurine` tag + `npcInstance:` GM Notes. Table seat: seat `*Object` tag + `SEAT_FIGURE_<seat>` GM Notes (same identity model as PC figurines).
--- @param obj Object|nil
--- @return boolean
function NPCS.isPooledFigurineObject(obj)
    if not U.isGameObject(obj) then
        return false
    end
    if obj.getCustomObject == nil or U.Type(obj.getCustomObject()) ~= "table" then
        return false
    end
    local hasFigTag = obj.hasTag ~= nil and obj.hasTag(TAG_FIG) == true
    if not hasFigTag and not figurineHasAnySeatTag(obj) then
        return false
    end
    if hasNpcInstanceGmNotes(obj) then
        return true
    end
    local guid = obj.getGUID and obj.getGUID() or ""
    if guid ~= "" then
        for _, rec in pairs(getInstances()) do
            if U.Type(rec) == "table" and rec.figurineGuid == guid then
                return true
            end
        end
    end
    return false
end

--- Homeland seat assigned in `occupiedNPCSlots` and character has a control-board stage placement row (TOR-178 phase C).
--- @param seatKey string
--- @return boolean
function NPCS.isNpcSeatOccupantStageBound(seatKey)
    return isNpcSeatOccupantStageBound(seatKey)
end

local NPC_HOMELAND_SEAT_LIGHT_REFS = {
    NPC1 = { "npcLight2NPC1", "npcLight1NPC1" },
    NPC2 = { "npcLight2NPC2", "npcLight1NPC2" },
    NPC3 = { "npcLight2NPC3", "npcLight1NPC3" },
    NPC4 = { "npcLight2NPC4", "npcLight1NPC4" },
}

--- Fingerprint of stage-bound homeland seats (placements + occupied slots); gates duplicate OFF applies.
--- @return string
local function homelandStageBoundSpotlightsFingerprint()
    local parts = {}
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if isNpcSeatOccupantStageBound(seatKey) then
            parts[#parts + 1] = seatKey .. "=OFF"
        end
    end
    table.sort(parts)
    return table.concat(parts, "\n")
end

local lastHomelandStageBoundSpotlightsFingerprint = nil

--- Persist OFF and apply homeland seat spotlights for one NPC seat (TOR-178 stage-bound).
--- @param seatKey string
--- @param opts table|nil `{ force?: boolean }`
local function syncNpcHomelandSeatSpotlightsOff(seatKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    if not isValidNpcSeatKey(seatKey) then
        return
    end
    local lightRefs = NPC_HOMELAND_SEAT_LIGHT_REFS[seatKey]
    if U.Type(lightRefs) ~= "table" then
        return
    end
    local force = opts.force == true
    for i = 1, #lightRefs do
        local lightRef = lightRefs[i]
        if U.Type(lightRef) == "string" and lightRef ~= "" then
            S.setStateVal("OFF", "lights", lightRef)
            L.reconcileLightRef(lightRef, 0, { force = force })
        end
    end
end

--- Sole orchestrator pass: homeland seat spotlights OFF for every stage-bound NPC seat.
local function reconcileNpcHomelandSeatSpotlightsWhenStageBound()
    local fp = homelandStageBoundSpotlightsFingerprint()
    if fp == lastHomelandStageBoundSpotlightsFingerprint then
        return
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if isNpcSeatOccupantStageBound(seatKey) then
            syncNpcHomelandSeatSpotlightsOff(seatKey, { force = false })
        end
    end
    lastHomelandStageBoundSpotlightsFingerprint = fp
end

function NPCS.reconcileHomelandSeatSpotlightsForStageBound()
    reconcileNpcHomelandSeatSpotlightsWhenStageBound()
end

--- Clear homeland spotlight reconcile skip cache (e.g. `Sync.invalidateAllReconcileCaches`).
function NPCS.invalidateHomelandStageBoundSpotlightsCache()
    lastHomelandStageBoundSpotlightsFingerprint = nil
end

--- @param lit Object|nil
--- @param hidden boolean
local function setPooledSpotlightHidden(lit, hidden)
    if not U.isGameObject(lit) or lit.setInvisibleTo == nil then
        return
    end
    if hidden then
        lit.setInvisibleTo(C.HideFromPcSeatsAndSpectators or {})
    else
        lit.setInvisibleTo({})
    end
end

--- While seated, pooled area spotlight lives at preload slot (OFF, hidden, small scale); workshop seat lights own the table.
--- Cancels pending deferred stage light-align sequences.
--- @param npcName string
--- @param lit Object|nil
local function parkPooledSpotlightForSeatedNpc(npcName, lit)
    if U.Type(npcName) ~= "string" or npcName == "" or not U.isGameObject(lit) then
        return
    end
    deferredLightAlignGeneration[npcName] = (deferredLightAlignGeneration[npcName] or 0) + 1
    local slot = stablePreloadSlotIndex(npcName)
    if U.Type(slot) == "number" then
        local pos = NPCS.computeSlotWorldPosition(PRELOAD_AREA_KEY, slot)
        if lit.setPosition ~= nil then
            lit.setPosition(Vector(
                pos.x + NPC_LIGHT_SPAWN_OFFSET.x,
                pos.y + NPC_LIGHT_SPAWN_OFFSET.y,
                pos.z + NPC_LIGHT_SPAWN_OFFSET.z
            ))
        end
    end
    if lit.setScale ~= nil then
        lit.setScale(Vector(NPC_PRELOAD_LIGHT_SCALE, NPC_PRELOAD_LIGHT_SCALE, NPC_PRELOAD_LIGHT_SCALE))
    end
    setPooledSpotlightHidden(lit, true)
    local rec = getInstances()[npcName]
    if U.Type(rec) == "table" then
        rec.npcLightMode = "OFF"
        setInstanceRecord(npcName, rec)
        NPCS.applyCurrentLightMode(npcName, 0, { force = true })
    end
end

--- NPC figurines stay TTS-locked at all times (players cannot drag); `rec.locked` is Storyteller "pin" for script moves only.
--- @param fig Object|nil
local function ensureNpcFigurinePhysicsLocked(fig)
    if U.isGameObject(fig) and fig.setLock ~= nil then
        fig.setLock(true)
    end
end

--- Custom Figurine `ImageScalar` from `figurine.scale` in npcs_data (save inject + spotlight bounds gating).
--- Not Transform `setScale` — see `applyNpcPairPhysicalPresentation` for Transform (preload 0.12 / active 1).
--- @param npcName string
--- @return number
local function figurineImageScalarForNpc(npcName)
    local def = NPCS.characters[npcName]
    local figDef = U.Type(def) == "table" and def.figurine or nil
    local scalar = tonumber(figDef and figDef.scale)
    if scalar == nil or scalar ~= scalar or scalar < 1 then
        scalar = 8
    end
    if scalar > 500 then
        scalar = 500
    end
    return scalar
end

--- ImageScalar expected for the NPC's current placement (seat 53 vs registry off-seat scale).
--- @param npcName string
--- @return number
local function expectedFigurineImageScalarForNpcPlacement(npcName)
    local rec = getInstances()[npcName]
    if U.Type(rec) == "table" and rec.areaKey == SEAT_PLACEMENT_KEY then
        return NPC_SEAT_FIGURINE_IMAGE_SCALAR
    end
    return figurineImageScalarForNpc(npcName)
end

--- Linear extra world Y for registry scalars above baseline (0 at scalar 53, full delta at ref scalar).
--- @param scalar number
--- @param refDeltaY number
--- @return number
local function extraNpcSpotlightScalarRampY(scalar, refDeltaY)
    local s = tonumber(scalar)
    local delta = tonumber(refDeltaY)
    if s == nil or delta == nil or delta == 0 or s <= NPC_FIGURINE_LIGHT_BASELINE_SCALAR then
        return 0
    end
    local span = NPC_FIGURINE_LIGHT_CAL_REF_SCALAR - NPC_FIGURINE_LIGHT_BASELINE_SCALAR
    if span <= 0 then
        return 0
    end
    return (s - NPC_FIGURINE_LIGHT_BASELINE_SCALAR) * (delta / span)
end

--- Extra look-at (face) world Y for large ImageScalar cutouts (Ian Rammond anchor).
--- @param scalar number
--- @return number
local function extraNpcSpotlightFaceYForScalar(scalar)
    return extraNpcSpotlightScalarRampY(scalar, NPC_FIGURINE_LIGHT_CAL_FACE_DELTA_Y)
end

--- Extra spotlight object world Y for large ImageScalar cutouts (modest; aim fix carries most of the lift).
--- @param scalar number
--- @return number
local function extraNpcSpotlightLightYForScalar(scalar)
    return extraNpcSpotlightScalarRampY(scalar, NPC_FIGURINE_LIGHT_CAL_POSITION_DELTA_Y)
end

--- Read current Custom Figurine ImageScalar (custom-property card scale), not Transform scale.
--- @param fig Object|nil
--- @return number|nil
local function readFigurineImageScalar(fig)
    if not U.isGameObject(fig) then
        return nil
    end
    if fig.getData ~= nil then
        local data = fig.getData()
        if U.Type(data) == "table" and U.Type(data.CustomImage) == "table" then
            local ci = data.CustomImage
            local fromData = tonumber(ci.ImageScalar) or tonumber(ci.ImageScale)
            if fromData ~= nil then
                return fromData
            end
        end
    end
    if fig.getCustomObject ~= nil then
        local co = fig.getCustomObject()
        if U.Type(co) == "table" then
            local fromCo = tonumber(co.image_scalar) or tonumber(co.card_scale) or tonumber(co.scale)
            if fromCo ~= nil then
                return fromCo
            end
        end
    end
    return nil
end

--- @param current number|nil
--- @param target number
--- @return boolean
local function figurineImageScalarMatches(current, target)
    if current == nil or target == nil then
        return false
    end
    return math.abs(current - target) <= FIGURINE_IMAGE_SCALAR_EPS
end

--- Apply figurine ImageScalar when it differs; requires `setCustomObject` + `reload()`.
--- @param fig Object|nil
--- @param targetScalar number
--- @return boolean reloaded
local function applyFigurineImageScalarIfNeeded(fig, targetScalar)
    if not U.isGameObject(fig) or fig.setCustomObject == nil or fig.reload == nil then
        return false
    end
    local target = tonumber(targetScalar)
    if target == nil or target ~= target or target < 1 then
        return false
    end
    if target > 500 then
        target = 500
    end
    if figurineImageScalarMatches(readFigurineImageScalar(fig), target) then
        return false
    end
    local co = fig.getCustomObject()
    if U.Type(co) ~= "table" then
        return false
    end
    local image = co.image
    if U.Type(image) ~= "string" or image == "" then
        return false
    end
    local params = {
        image = image,
        image_secondary = co.image_secondary or image,
        image_scalar = target,
    }
    fig.setCustomObject(params)
    fig.reload()
    return true
end

--- Seat vs off-seat ImageScalar for pooled NPC figurines (TOR-223).
--- @param fig Object|nil
--- @param npcName string|nil
--- @param areaKey string
--- @return boolean reloaded
local function applyNpcFigurineImageScalarForPlacement(fig, npcName, areaKey)
    if not U.isGameObject(fig) or U.Type(npcName) ~= "string" or npcName == "" then
        return false
    end
    if areaKey == SEAT_PLACEMENT_KEY then
        return applyFigurineImageScalarIfNeeded(fig, NPC_SEAT_FIGURINE_IMAGE_SCALAR)
    end
    return applyFigurineImageScalarIfNeeded(fig, figurineImageScalarForNpc(npcName))
end

--- ImageScalar to use for spotlight Y ramp — must match the mesh that produced `getBounds`, not registry alone.
--- @param fig Object|nil
--- @param npcName string
--- @return number
local function figurineImageScalarForLightAlign(fig, npcName)
    local scalar = readFigurineImageScalar(fig)
    if scalar ~= nil then
        return scalar
    end
    return expectedFigurineImageScalarForNpcPlacement(npcName)
end

--- Figurine custom mesh loaded and bounds tall enough for spotlight Y from `getBounds` (not preload-scale feet).
--- Script-locked stage placements may keep `resting == false` after `setPosition`; do not gate on resting.
--- @param fig Object|nil
--- @param npcName string
--- @return boolean
local function npcFigurineReadyForLightAlign(fig, npcName)
    if not U.isGameObject(fig) then
        return false
    end
    if fig.loading_custom == true then
        return false
    end
    if not figurineImageScalarMatches(
        readFigurineImageScalar(fig),
        expectedFigurineImageScalarForNpcPlacement(npcName)
    ) then
        return false
    end
    if fig.getBounds == nil then
        return false
    end
    local b = fig.getBounds()
    if b == nil or b.size == nil then
        return false
    end
    local sy = b.size.y or b.size[2] or 0
    local alignScalar = expectedFigurineImageScalarForNpcPlacement(npcName)
    local minSy = math.max(
        NPC_FIGURINE_LIGHT_ALIGN_MIN_BOUNDS_Y,
        alignScalar * 0.75
    )
    return sy >= minSy
end

--- Figurine Transform scale + tooltip and paired spotlight scale (preload = small, tooltips off; active areas/seats = full, tooltips on).
--- ImageScalar (figurine custom-property scale) applied separately when placement changes — see `applyNpcFigurineImageScalarForPlacement`.
--- @param fig Object|nil
--- @param lit Object|nil
--- @param areaKey string
--- @param npcName string|nil
local function applyNpcPairPhysicalPresentation(fig, lit, areaKey, npcName)
    local isPreload = (areaKey == PRELOAD_AREA_KEY)
    local fs = isPreload and NPC_PRELOAD_FIGURE_SCALE or NPC_ACTIVE_FIGURE_SCALE
    local ls = isPreload and NPC_PRELOAD_LIGHT_SCALE or NPC_ACTIVE_LIGHT_SCALE
    if U.isGameObject(fig) and fig.setScale ~= nil then
        fig.setScale(Vector(fs, fs, fs))
        if fig.tooltip ~= nil then
            fig.tooltip = not isPreload
        end
    end
    if U.isGameObject(lit) and lit.setScale ~= nil then
        lit.setScale(Vector(ls, ls, ls))
    end
    ensureNpcFigurinePhysicsLocked(fig)
    applyNpcFigurineImageScalarForPlacement(fig, npcName, areaKey)
end

--- Swap pooled figurine tags for table-seat layout (`SEAT_FIGURE` role); hide paired area spotlight.
--- @param fig Object
--- @param lit Object|nil
--- @param npcName string
--- @param seatKey string
local function applyNpcFigurineSeatIdentity(fig, lit, npcName, seatKey)
    local def = NPCS.characters[npcName]
    local seatTag = seatTagForKey(seatKey)
    local tags = fig.getTags and fig.getTags() or {}
    if U.Type(tags) ~= "table" then
        tags = {}
    end
    local out = {}
    for _, t in ipairs(tags) do
        if t ~= TAG_FIG then
            table.insert(out, t)
        end
    end
    local hasSeatTag = false
    for _, t in ipairs(out) do
        if t == seatTag then
            hasSeatTag = true
            break
        end
    end
    if not hasSeatTag then
        table.insert(out, seatTag)
    end
    if fig.setTags ~= nil then
        fig.setTags(out)
    end
    if fig.setName ~= nil and def ~= nil then
        fig.setName(def.fullName or def.name or npcName)
    end
    SRI.setRoleColorIdentity(fig, "SEAT_FIGURE", seatKey)
    applyNpcPairPhysicalPresentation(fig, lit, SEAT_PLACEMENT_KEY, npcName)
    setPooledSpotlightHidden(lit, true)
    parkPooledSpotlightForSeatedNpc(npcName, lit)
end

--- Restore preload/area tags after leaving a table seat; reset GM Notes to `npcInstance:` identity.
--- @param fig Object
--- @param lit Object|nil
--- @param npcName string|nil When omitted, resolved from instance record or `npcInstance:` GM Notes.
local function clearNpcFigurineSeatIdentity(fig, lit, npcName)
    local tags = fig.getTags and fig.getTags() or {}
    if U.Type(tags) ~= "table" then
        tags = {}
    end
    local out = {}
    for _, t in ipairs(tags) do
        local drop = false
        for _, sk in ipairs(C.NPCSeats or {}) do
            if t == seatTagForKey(sk) then
                drop = true
                break
            end
        end
        if not drop then
            table.insert(out, t)
        end
    end
    local hasFigTag = false
    for _, t in ipairs(out) do
        if t == TAG_FIG then
            hasFigTag = true
            break
        end
    end
    if not hasFigTag then
        table.insert(out, TAG_FIG)
    end
    if fig.setTags ~= nil then
        fig.setTags(out)
    end
    if U.Type(npcName) ~= "string" or npcName == "" then
        if U.isGameObject(fig) then
            local guid = fig.getGUID and fig.getGUID() or ""
            if guid ~= "" then
                for name, rec in pairs(getInstances()) do
                    if U.Type(rec) == "table" and rec.figurineGuid == guid then
                        npcName = name
                        break
                    end
                end
            end
            if (U.Type(npcName) ~= "string" or npcName == "") and fig.getGMNotes ~= nil then
                local notes = tostring(fig.getGMNotes() or "")
                npcName = string.match(notes, "^" .. GM_PREFIX .. "(.+)$")
            end
        end
    end
    if U.Type(npcName) == "string" and npcName ~= "" and fig.setGMNotes ~= nil then
        fig.setGMNotes(GM_PREFIX .. npcName)
    end
    setPooledSpotlightHidden(lit, false)
end

--- Persist `gameState.lights` mode for a pooled NPC spotlight (no world apply).
--- @param npcName string
--- @param desiredMode string OFF|STANDARD|SPOTLIGHT
local function syncStageNpcLightState(npcName, desiredMode)
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" or U.Type(rec.lightGuid) ~= "string" or rec.lightGuid == "" then
        return
    end
    local reg = NPCS.lightRegistryName(rec.lightGuid)
    local modeKey = spotlightHeld[npcName] and "SPOTLIGHT" or desiredMode
    if L.LIGHTMODES[reg] == nil then
        L.registerNpcSpotlightModes(npcName, rec.lightGuid)
    end
    S.setStateVal(modeKey, "lights", reg)
end

--- Cancel pending `deferNpcSpotlightAlignedToFigurine` sequences (e.g. before lerp commit or immediate re-apply).
--- @param npcName string
function NPCS.cancelDeferredSpotlightAlign(npcName)
    if U.Type(npcName) == "string" and npcName ~= "" then
        deferredLightAlignGeneration[npcName] = (deferredLightAlignGeneration[npcName] or 0) + 1
    end
end

--- Resolve spotlight from figurine bounds after active-scale presentation (not preload-scale feet offset).
--- @param npcName string
--- @param fig Object|nil
--- @param transitionTime number|nil
local function applyNpcSpotlightAlignedToFigurine(npcName, fig, transitionTime)
    if not U.isGameObject(fig) then
        return
    end
    lightAlignFigOverride[npcName] = fig
    NPCS.applyCurrentLightMode(npcName, transitionTime, { force = true })
    lightAlignFigOverride[npcName] = nil
end

--- Apply current stage light mode to state + visibility; bounds align only when ImageScalar and mesh are ready.
--- @param npcName string
--- @param fig Object|nil
--- @param lit Object|nil
--- @param transitionTime number|nil
local function applyStageNpcSpotlightNow(npcName, fig, lit, transitionTime)
    if U.Type(npcName) ~= "string" or npcName == "" or not U.isGameObject(fig) then
        return
    end
    NPCS.cancelDeferredSpotlightAlign(npcName)
    if U.isGameObject(lit) then
        setPooledSpotlightHidden(lit, false)
    end
    local rec = getInstances()[npcName]
    if U.Type(rec) == "table" then
        syncStageNpcLightState(npcName, rec.npcLightMode or "STANDARD")
    end
    if npcFigurineReadyForLightAlign(fig, npcName) then
        applyNpcSpotlightAlignedToFigurine(npcName, fig, transitionTime or 0)
    end
end

--- Wait for figurine mesh bounds (`loading_custom` / `getBounds`) before spotlight Y align (stage placement race).
--- @param npcName string
--- @param fig Object|nil
--- @param lit Object|nil
--- @param transitionTime number|nil
local function deferNpcSpotlightAlignedToFigurine(npcName, fig, lit, transitionTime)
    if not U.isGameObject(fig) then
        return
    end
    deferredLightAlignGeneration[npcName] = (deferredLightAlignGeneration[npcName] or 0) + 1
    local gen = deferredLightAlignGeneration[npcName]
    local deferFig = fig
    local deferLit = lit
    local deferTrans = transitionTime
    local deferName = npcName
    U.RunSequence({
        function()
            return 0
        end,
        function()
            return function()
                if deferredLightAlignGeneration[deferName] ~= gen then
                    return true
                end
                return npcFigurineReadyForLightAlign(deferFig, deferName)
            end
        end,
        function()
            if U.isGameObject(deferLit) then
                local lg = deferLit.getGUID and deferLit.getGUID() or ""
                local reg = NPCS.lightRegistryName(lg)
                return function()
                    if deferredLightAlignGeneration[deferName] ~= gen then
                        return true
                    end
                    return npcSpotlightReadyForApply(lg, reg)
                end
            end
            return NPC_STAGE_LIGHT_POST_BOUNDS_DELAY_SEC
        end,
        function()
            return NPC_STAGE_LIGHT_POST_BOUNDS_DELAY_SEC
        end,
        function()
            if deferredLightAlignGeneration[deferName] ~= gen then
                return 0
            end
            applyNpcSpotlightAlignedToFigurine(deferName, deferFig, deferTrans)
            return 0
        end,
    })
end

--- Shortest angular distance in degrees (yaw wraps at 360).
--- @param a number|nil
--- @param b number|nil
--- @return number
local function yawDiffDeg(a, b)
    local da = tonumber(a) or 0
    local db = tonumber(b) or 0
    local d = math.abs(da - db) % 360
    if d > 180 then
        d = 360 - d
    end
    return d
end

--- @param stored table|nil last applied stage pose on the instance record
--- @param placement table current intent `{ u, v, groundLevel? }`
--- @return boolean
local function stagePlacementMatchesRecord(stored, placement)
    if type(stored) ~= "table" or type(placement) ~= "table" then
        return false
    end
    local u = tonumber(placement.u)
    local v = tonumber(placement.v)
    if u == nil or v == nil then
        return false
    end
    local du = math.abs((tonumber(stored.u) or 0) - u)
    local dv = math.abs((tonumber(stored.v) or 0) - v)
    if du >= 0.002 or dv >= 0.002 then
        return false
    end
    if (tonumber(stored.groundLevel) or nil) ~= (tonumber(placement.groundLevel) or nil) then
        return false
    end
    local Gameboard = require("core.npc_gameboard")
    local derivedYaw = 0
    if type(Gameboard.placementBoardRelYawDeg) == "function" then
        derivedYaw = Gameboard.placementBoardRelYawDeg(u, v)
    end
    return yawDiffDeg(stored.yaw, derivedYaw) < 1
end

--- @param placement table
--- @return string OFF|STANDARD|SPOTLIGHT
local function normalizedStageNpcLightMode(placement)
    local mode = placement.npcLightMode
    if mode == "OFF" or mode == "STANDARD" or mode == "SPOTLIGHT" then
        return mode
    end
    return "STANDARD"
end

--- @param rec table|nil
--- @return boolean
local function npcInstanceIsParkedInPreload(rec)
    if U.Type(rec) ~= "table" then
        return false
    end
    if rec.areaKey ~= PRELOAD_AREA_KEY then
        return false
    end
    if U.Type(rec.seatedSeatKey) == "string" and rec.seatedSeatKey ~= "" then
        return false
    end
    return true
end

--- Fail loudly when spawn/activate is attempted without the global preload pool.
--- @param message string
local function npcPoolPolicyError(message)
    error("[NPCS] " .. tostring(message), 2)
end

--- Seat identity + layout sync: figurine pose comes from rotational layout (`SEAT_FIGURE` role).
--- @param figurine Object
--- @param lit Object|nil
--- @param npcName string
--- @param seatKey string
--- @param opts table|nil optional `deferLayoutSync`
--- @return boolean, string|nil
local function prepareNpcFigurineForSeat(figurine, lit, npcName, seatKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    if not U.isGameObject(figurine) then
        return false, "Missing figurine for seat " .. tostring(seatKey) .. "."
    end
    applyNpcFigurineSeatIdentity(figurine, lit, npcName, seatKey)
    if opts.deferLayoutSync ~= true then
        requestSeatLayoutSync()
    end
    return true, nil
end

--- Physical teardown for one NPC seat; optional state retention (Step Two case 3).
--- @param seatKey string
--- @param opts table|nil `{ retainAssignment?: boolean, skipLayoutSync?: boolean }`
--- @return boolean, string|nil
local function clearNpcSeatPhysical(seatKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    if not isValidNpcSeatKey(seatKey) then
        return false, "Invalid NPC seat key."
    end
    local retainAssignment = opts.retainAssignment == true
    local toPark = {}
    local seen = {}
    for name, r in pairs(getInstances()) do
        if U.Type(name) == "string" and U.Type(r) == "table" and r.seatedSeatKey == seatKey then
            toPark[#toPark + 1] = name
            seen[name] = true
        end
    end
    local tag = seatTagForKey(seatKey)
    local tagged = getObjectsWithTag(tag)
    if U.Type(tagged) == "table" then
        for i = 1, #tagged do
            local o = tagged[i]
            if o ~= nil and NPCS.isPooledFigurineObject(o) then
                for name, r in pairs(getInstances()) do
                    if not seen[name] and U.Type(r) == "table" and r.figurineGuid == o.getGUID() then
                        toPark[#toPark + 1] = name
                        seen[name] = true
                        break
                    end
                end
            end
        end
    end
    if not retainAssignment then
        local occupied = U.clone(getOccupiedNpcSeatMap())
        occupied[seatKey] = false
        setOccupiedNpcSeatMap(occupied)
        local ss = S.getStateVal("sessionScene", "seatSlots")
        if U.Type(ss) ~= "table" then
            ss = {}
        end
        ss[seatKey] = { slotEmpty = true }
        S.setStateVal(ss, "sessionScene", "seatSlots")
    end
    for i = 1, #toPark do
        local name = toPark[i]
        local r = getInstances()[name]
        if U.Type(r) == "table" then
            local fig = getObjectFromGUID(r.figurineGuid or "")
            local lit = getObjectFromGUID(r.lightGuid or "")
            if fig ~= nil then
                clearNpcFigurineSeatIdentity(fig, lit)
            end
            r.seatedSeatKey = nil
            setInstanceRecord(name, r)
        end
        NPCS.retreatNpcInstanceToPreloadPool(name, { skipUiRefresh = true, skipSeatSync = true })
    end
    if opts.skipLayoutSync ~= true then
        requestSeatLayoutSync()
    end
    return true, nil
end

--- @param seatKey string
--- @return boolean, string|nil
local function clearNpcSeat(seatKey)
    return clearNpcSeatPhysical(seatKey, { retainAssignment = false })
end

--- @param seatKey string
--- @param intent table
--- @return boolean
local function seatNeedsPlacement(seatKey, intent)
    if U.Type(intent) ~= "table" or U.Type(intent.bySeat) ~= "table" then
        return true
    end
    local seatInfo = intent.bySeat[seatKey]
    if U.Type(seatInfo) ~= "table" or seatInfo.physicalSeatAllowed ~= true then
        return false
    end
    local npcName = seatInfo.assignedCharacter
    if U.Type(npcName) ~= "string" or npcName == "" then
        return false
    end
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" then
        return true
    end
    local fig = getObjectFromGUID(rec.figurineGuid or "")
    if fig == nil then
        return true
    end
    if not figurineHasSeatTag(fig, seatKey) then
        return true
    end
    if rec.seatedSeatKey ~= seatKey then
        return true
    end
    if rec.areaKey == PRELOAD_AREA_KEY or npcInstanceInStageArea(npcName) then
        return true
    end
    local tableKey = S.getStateVal("seatLayout", "currentTableKey") or ""
    local fp = occupiedNpcSeatsFingerprint()
    if lastNpcLayoutCommit.tableKey ~= tableKey or lastNpcLayoutCommit.fingerprint ~= fp then
        return true
    end
    return false
end

--- @param npcName string
--- @param seatKey string
--- @param opts table|nil optional `deferLayoutSync`, `blockAreaBound`
--- @return boolean, string|nil
local function assignNpcToSeat(npcName, seatKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    if U.Type(npcName) ~= "string" or string.match(npcName, "^[%a_][%w_]*$") == nil then
        return false, "Invalid NPC name."
    end
    if NPCS.characters[npcName] == nil then
        return false, "Unknown NPC: " .. tostring(npcName)
    end
    if not isValidNpcSeatKey(seatKey) then
        return false, "Invalid NPC seat key."
    end
    if opts.blockAreaBound == true then
        local intent = resolveNpcPlacementIntent()
        local ci = intent.byCharacter[npcName]
        if U.Type(ci) == "table" and ci.target == "stage" then
            return false, "NPC is stage-bound and cannot be seated."
        end
    end
    local rec = getInstances()[npcName]
    if rec == nil then
        local preOk, preErr = NPCS.ensureNpcInPreloadZone(npcName, {
            deferUiRefresh = true,
            skipSeatSync = true,
        })
        if not preOk then
            return false, preErr or "Could not spawn NPC into preload pool for seating."
        end
        rec = getInstances()[npcName]
        if rec == nil then
            return false, "NPC '"
                .. tostring(npcName)
                .. "' has no pooled instance; global preload pool is missing this entry (see console)."
        end
    end
    if not npcInstanceIsParkedInPreload(rec) then
        local seatedElsewhere = U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey)
        if rec.areaKey == STAGE_BOARD_AREA_KEY then
            -- TOR-178 phase B: keep figurine at stage pose; Step Three + layout commit seats directly.
            rec.stagePlacement = nil
            setInstanceRecord(npcName, rec)
            rec = getInstances()[npcName]
        elseif not seatedElsewhere then
            local rOk, rErr = NPCS.retreatNpcInstanceToPreloadPool(npcName, {
                skipUiRefresh = true,
                skipSeatSync = true,
            })
            if not rOk then
                return false, rErr or "Could not park NPC before seating."
            end
            rec = getInstances()[npcName]
            if rec == nil or not npcInstanceIsParkedInPreload(rec) then
                return false, "NPC '"
                    .. tostring(npcName)
                    .. "' must be parked in preload before seating (was area="
                    .. tostring(rec and rec.areaKey)
                    .. ")."
            end
        end
    end
    if U.Type(rec.seatedSeatKey) == "string" and rec.seatedSeatKey ~= seatKey then
        local prevFig = getObjectFromGUID(rec.figurineGuid or "")
        local prevLit = getObjectFromGUID(rec.lightGuid or "")
        if prevFig ~= nil then
            clearNpcFigurineSeatIdentity(prevFig, prevLit)
        end
        rec.seatedSeatKey = nil
        setInstanceRecord(npcName, rec)
    end
    local occupied = U.clone(getOccupiedNpcSeatMap())
    local prev = occupied[seatKey]
    if U.Type(prev) == "string" and prev ~= "" and prev ~= npcName then
        clearNpcSeat(seatKey)
        occupied = getOccupiedNpcSeatMap()
    end
    for _, key in ipairs(C.NPCSeats or {}) do
        if occupied[key] == npcName then
            occupied[key] = false
            local otherFig = getObjectFromGUID(rec.figurineGuid or "")
            local otherLit = getObjectFromGUID(rec.lightGuid or "")
            if otherFig ~= nil then
                clearNpcFigurineSeatIdentity(otherFig, otherLit)
            end
        end
    end
    occupied[seatKey] = npcName
    setOccupiedNpcSeatMap(occupied)
    rec = getInstances()[npcName]
    if rec == nil then
        return false, "NPC instance lost."
    end
    local fig = getObjectFromGUID(rec.figurineGuid or "")
    local lit = getObjectFromGUID(rec.lightGuid or "")
    if fig == nil then
        setInstanceRecord(npcName, nil)
        return false, "Figurine missing for seated NPC."
    end
    local placedOk, placedErr = prepareNpcFigurineForSeat(fig, lit, npcName, seatKey, opts)
    if not placedOk then
        return false, placedErr
    end
    rec.seatedSeatKey = seatKey
    rec.stagePlacement = nil
    rec.areaKey = SEAT_PLACEMENT_KEY
    rec.npcLightMode = "STANDARD"
    setInstanceRecord(npcName, rec)
    return true, nil
end

local isNpcLocked

--- @param npcName string
function NPCS.getInstanceRecord(npcName)
    return getInstances()[npcName]
end

--- Whether an NPC figurine is seated at a narrative table seat (group spawn must not pull them).
--- @param characterKey string
--- @return boolean
function NPCS.isCharacterSeatedAtTable(characterKey)
    if U.Type(characterKey) ~= "string" or characterKey == "" then
        return false
    end
    return isNpcSeatedAtTable(getInstances()[characterKey])
end

--- Registry key used in L.LIGHTMODES and gameState.lights.
--- @param lightGuid string
--- @return string
function NPCS.lightRegistryName(lightGuid)
    return "npcLight_" .. tostring(lightGuid)
end

--- @param areaKey string
--- @return table<number, string>|nil slotIndex -> npcName
function NPCS.getOccupiedSlots(areaKey)
    local occ = {}
    for name, rec in pairs(getInstances()) do
        if rec and rec.areaKey == areaKey and U.Type(rec.slotIndex) == "number" then
            occ[rec.slotIndex] = name
        end
    end
    return occ
end

--- @param areaKey string
--- @return boolean
function NPCS.isAreaCompletelyEmpty(areaKey)
    return next(NPCS.getOccupiedSlots(areaKey) or {}) == nil
end

--- @param areaKey string
--- @return boolean
function NPCS.areaHasFreeSlot(areaKey)
    local area = NPCS.areas[areaKey]
    if not area or U.Type(area.positions) ~= "table" then
        return false
    end
    local occ = NPCS.getOccupiedSlots(areaKey)
    for i = 1, #area.positions do
        if occ and occ[i] == nil then
            return true
        end
    end
    return false
end

--- @param areaKey string
--- @return number|nil
function NPCS.findNextFreeSlotIndex(areaKey)
    local area = NPCS.areas[areaKey]
    if not area or U.Type(area.positions) ~= "table" then
        return nil
    end
    local occ = NPCS.getOccupiedSlots(areaKey)
    for i = 1, #area.positions do
        if occ and occ[i] == nil then
            return i
        end
    end
    return nil
end

--- Prefer `preferred` when valid and free (or held by `excludeNpcName`); otherwise first free slot.
--- @param areaKey string
--- @param preferred number|nil
--- @param excludeNpcName string|nil moving NPC — its current slot counts as available
--- @return number|nil
local function resolveSlotForMove(areaKey, preferred, excludeNpcName)
    local area = NPCS.areas[areaKey]
    if not area or U.Type(area.positions) ~= "table" then
        return nil
    end
    local n = #area.positions
    if U.Type(preferred) == "number" and preferred >= 1 and preferred <= n then
        local occ = NPCS.getOccupiedSlots(areaKey)
        local holder = occ and occ[preferred]
        if holder == nil or (U.Type(excludeNpcName) == "string" and holder == excludeNpcName) then
            return preferred
        end
    end
    return NPCS.findNextFreeSlotIndex(areaKey)
end

--- Stable preload slot when free; otherwise first free slot in the preload grid (same occupancy rules as play areas).
--- @param npcName string
--- @param preferredSlot number|nil optional override (e.g. scene stash)
--- @return number|nil
local function resolvePreloadSlotForMove(npcName, preferredSlot)
    ensurePreloadLayoutCapacity()
    local preferred = U.Type(preferredSlot) == "number" and preferredSlot or stablePreloadSlotIndex(npcName)
    return resolveSlotForMove(PRELOAD_AREA_KEY, preferred, npcName)
end

--- Rotate (x, z) in the horizontal plane by `rad` around Y (matches NPC slot offset math).
--- @param x number
--- @param z number
--- @param rad number
--- @return number, number
local function rotateXZ(x, z, rad)
    local cr, sr = math.cos(rad), math.sin(rad)
    return x * cr - z * sr, x * sr + z * cr
end

--- Slot world position about table origin (0,0 in XZ). Canonical layout from `REF_AREA_KEY`: center on +Z at
--- refDistance, offsets (slot.x, slot.z). We rotate by `-area.rotation` (matches sin·D / cos·D pivot, fixes mirror).
--- Center ring uses scale sCenter = distance/refDistance; slot spread uses sSpread = 1 + (sCenter-1)*spreadBlend
--- so spread stays tight on outer rings unless `spreadBlend` (0..1) is set toward 1 (full similarity).
--- @param areaKey string
--- @param slotIndex number
--- @return Vector
function NPCS.computeSlotWorldPosition(areaKey, slotIndex)
    local area = NPCS.areas[areaKey]
    local refA = NPCS.areas[REF_AREA_KEY]
    local refDist = refA and tonumber(refA.distance) or nil
    local slot
    if refA and U.Type(refA.positions) == "table" then
        slot = refA.positions[slotIndex]
    end
    if slot == nil then
        slot = area.positions[slotIndex]
    end
    if refDist == nil or refDist < 1e-6 then
        local rad = math.rad(area.rotation)
        local rx, rz = rotateXZ(slot.x, slot.z, rad)
        local cx = math.sin(rad) * area.distance
        local cz = math.cos(rad) * area.distance
        return Vector(cx + rx, area.groundLevel, cz + rz)
    end
    local radNeg = -math.rad(area.rotation)
    local rxO, rzO = rotateXZ(0, refDist, radNeg)
    local rxD, rzD = rotateXZ(slot.x, slot.z, radNeg)
    local sCenter = tonumber(area.distance) / refDist
    if sCenter ~= sCenter or sCenter < 0 then
        sCenter = 1
    end
    local blend = tonumber(area.spreadBlend)
    if blend ~= blend then
        blend = 0
    end
    if blend < 0 then
        blend = 0
    elseif blend > 1 then
        blend = 1
    end
    local sSpread = 1 + (sCenter - 1) * blend
    return Vector(rxO * sCenter + rxD * sSpread, area.groundLevel, rzO * sCenter + rzD * sSpread)
end

--- Figurine_Custom pivot sits at the bottom of the mesh; world Y = area groundLevel places feet on the plane.
--- Yaw matches the whole area facing the table center: use the area pivot (distance + rotation, offset 0,0),
--- not each slot's world position — per-slot atan2 fans the group and breaks rigid "table" placement.
--- @param figurine Object
--- @param areaKey string
--- @param slotIndex number
function NPCS.applyFigurinePlacement(figurine, areaKey, slotIndex)
    local area = NPCS.areas[areaKey]
    local pos = NPCS.computeSlotWorldPosition(areaKey, slotIndex)
    figurine.setPosition(pos)
    local rad = math.rad(area.rotation)
    local pivotX = math.sin(rad) * area.distance
    local pivotZ = math.cos(rad) * area.distance
    local yawDeg = math.atan2(-pivotX, -pivotZ) * (180 / math.pi) + AREA_NPC_FIGURINE_YAW_OFFSET_DEG
    figurine.setRotation(Vector(0, yawDeg, 0))
    ensureNpcFigurinePhysicsLocked(figurine)
end

--- Place figurine at gameboard `placements` world pose (STAGE_BOARD u,v,yaw).
--- @param figurine Object
--- @param placement table `{ u, v, yaw? }`
function NPCS.applyFigurinePlacementAtWorld(figurine, placement)
    if not U.isGameObject(figurine) or type(placement) ~= "table" then
        return
    end
    local Gameboard = require("core.npc_gameboard")
    local u = tonumber(placement.u)
    local v = tonumber(placement.v)
    if u == nil or v == nil then
        return
    end
    local groundLevel = tonumber(placement.groundLevel)
    if groundLevel == nil and type(Gameboard.groundLevelForSnapUv) == "function" then
        groundLevel = Gameboard.groundLevelForSnapUv(u, v)
    end
    local pos = Gameboard.worldFromUv(u, v, {
        groundLevel = groundLevel,
    })
    figurine.setPosition(pos)
    local relYaw = Gameboard.placementBoardRelYawDeg(u, v)
    local yawDeg = relYaw
    if type(Gameboard.stageFigurineWorldYawDeg) == "function" then
        yawDeg = Gameboard.stageFigurineWorldYawDeg(relYaw)
    end
    figurine.setRotation(Vector(0, yawDeg, 0))
    ensureNpcFigurinePhysicsLocked(figurine)
    local notes = ""
    if figurine.getGMNotes ~= nil then
        notes = tostring(figurine.getGMNotes() or "")
    end
    local displayName = figurine.getName and figurine.getName() or "?"
    print(string.format(
        "[NPCS] figurine stage placement %s (%s) u=%.4f v=%.4f ringYaw=%.1f worldYaw=%.1f ground=%.3f → world (%.2f, %.2f, %.2f)",
        tostring(displayName),
        notes ~= "" and notes or "?",
        u,
        v,
        relYaw,
        yawDeg,
        tonumber(groundLevel) or 0,
        pos.x,
        pos.y,
        pos.z
    ))
end

--- @param npcName string
--- @param modeKey string
--- @return table
function NPCS.getMergedModeDefinition(npcName, modeKey)
    local def = NPCS.characters[npcName]
    local globalMode = NPCS.lights[modeKey] or {}
    local per = def and def.lighting and def.lighting[modeKey] or nil
    local merged = deepMerge(globalMode, per)
    local rec = getInstances()[npcName]
    if U.Type(rec) == "table" and rec.areaKey == STAGE_BOARD_AREA_KEY then
        local stageOverride = NPCS.stageLights[modeKey]
        if U.Type(stageOverride) == "table" then
            merged = deepMerge(merged, stageOverride)
        end
    end
    return merged
end

--- @param npcName string
--- @param modeKey string
--- @return table|nil mode table with position, rotation Vectors
function NPCS.buildResolvedLightModeTable(npcName, modeKey)
    local rec = NPCS.getInstanceRecord(npcName)
    if rec == nil then
        return nil
    end
    local fig = lightAlignFigOverride[npcName]
    if fig == nil or not U.isGameObject(fig) then
        fig = getObjectFromGUID(rec.figurineGuid or "")
    end
    if fig == nil then
        return nil
    end
    local mode = NPCS.getMergedModeDefinition(npcName, modeKey)
    local b = fig.getBounds()
    if b == nil or b.center == nil or b.size == nil then
        return mode
    end
    local cx = b.center.x or b.center[1] or 0
    local cy = b.center.y or b.center[2] or 0
    local cz = b.center.z or b.center[3] or 0
    local sy = b.size.y or b.size[2] or 1
    local topY = cy + sy / 2
    local lookFrac = tonumber(mode.lookAtYShift) or 0.5
    local posFrac = tonumber(mode.positionYShift) or 0.3
    local dist = tonumber(mode.distance) or 15
    local scalar = figurineImageScalarForLightAlign(fig, npcName)
    local faceY = topY - lookFrac * sy + extraNpcSpotlightFaceYForScalar(scalar)
    local lightY = topY - posFrac * sy + extraNpcSpotlightLightYForScalar(scalar)
    local px, pz = cx, cz
    local len2 = px * px + pz * pz
    local ux, uz
    if len2 < 1e-6 then
        ux, uz = 0, 1
    else
        local inv = 1 / math.sqrt(len2)
        ux = px * inv
        uz = pz * inv
    end
    local lightPos = Vector(px + ux * dist, lightY, pz + uz * dist)
    local facePos = Vector(cx, faceY, cz)
    local rot = U.lookAtRotation(lightPos, facePos)
    local out = U.clone(mode) or {}
    out.position = lightPos
    out.rotation = rot
    return out
end

--- @param lightGuid string
local function unregisterDynamicLightModes(lightGuid)
    L.unregisterLightModeEntry(NPCS.lightRegistryName(lightGuid))
end

--- Ensure a spawned/loaded NPC light also carries the global Spotlight tag used by admin tooling.
--- @param obj Object|nil
local function ensureSpotlightTag(obj)
    if obj == nil then
        return
    end
    local has = false
    if obj.hasTag ~= nil then
        has = obj.hasTag(TAG_SPOTLIGHT) == true
    end
    if not has and obj.addTag ~= nil then
        obj.addTag(TAG_SPOTLIGHT)
    end
end

--- @param npcName string
--- @param transitionTime number|nil
--- @param opts table|nil `{ force?: boolean }`
function NPCS.applyCurrentLightMode(npcName, transitionTime, opts)
    opts = type(opts) == "table" and opts or {}
    local rec = NPCS.getInstanceRecord(npcName)
    if rec == nil or rec.lightGuid == nil then
        return
    end
    if U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey) then
        return
    end
    local reg = NPCS.lightRegistryName(rec.lightGuid)
    local modeKey = spotlightHeld[npcName] and "SPOTLIGHT" or (rec.npcLightMode or "STANDARD")
    if L.LIGHTMODES[reg] == nil then
        L.registerNpcSpotlightModes(npcName, rec.lightGuid)
    end
    if transitionTime == nil then
        transitionTime = 0.35
    end
    -- State-first mutation; lighting module reconcile owns live-world writes.
    S.setStateVal(modeKey, "lights", reg)
    L.reconcileLightRef(reg, transitionTime, { force = opts.force == true })
end

--- Re-apply each spawned NPC's current light mode (used after scene transitions that force OFF).
--- @param transitionTime number|nil
function NPCS.reapplyAllCurrentLightModes(transitionTime)
    local instances = getInstances()
    for npcName, rec in pairs(instances) do
        if U.Type(npcName) == "string" and U.Type(rec) == "table" and U.Type(rec.lightGuid) == "string" and rec.lightGuid ~= "" then
            NPCS.applyCurrentLightMode(npcName, transitionTime)
        end
    end
end

--- @param obj Object
--- @return string|nil
function NPCS.resolveNpcNameFromFigurine(obj)
    if obj == nil then
        return nil
    end
    local notes = obj.getGMNotes and obj.getGMNotes() or ""
    local name = string.match(notes, "^" .. GM_PREFIX .. "(.+)$")
    local guid = obj.getGUID and obj.getGUID() or ""
    if name then
        if guid ~= "" then
            figurineGuidToNpcName[guid] = name
        end
        return name
    end
    if guid == "" then
        return nil
    end
    local cached = figurineGuidToNpcName[guid]
    if cached ~= nil then
        return cached
    end
    rebuildFigurineGuidCache()
    return figurineGuidToNpcName[guid]
end

--- Called when a figurine may have moved (drop or script move).
--- @param obj Object
function NPCS.onObjectDropped(obj)
    if not NPCS.isPooledFigurineObject(obj) then
        return
    end
    local npcName = NPCS.resolveNpcNameFromFigurine(obj)
    if npcName then
        ensureNpcFigurinePhysicsLocked(obj)
        NPCS.applyCurrentLightMode(npcName, 0)
    end
end

--- @param area table|nil
--- @param opts table|nil
--- @return string
local function effectiveNpcLightModeForAreaPlacement(area, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local forced = opts.forceNpcLightMode
    if U.Type(forced) == "string" then
        if forced == "OFF" or forced == "STANDARD" or forced == "SPOTLIGHT" then
            return forced
        end
    end
    return (area and area.autoLight == true) and "STANDARD" or "OFF"
end

--- Normalized rows from `sessionScene.npcWorld.placements` (gameboard schema v3).
--- @return table[]
local function collectSessionStagePlacements()
    local out = {}
    local placements = S.getStateVal("sessionScene", "npcWorld", "placements")
    if type(placements) ~= "table" then
        return out
    end
    local keys = U.getKeys(placements)
    table.sort(keys)
    for _, characterKey in ipairs(keys) do
        local row = placements[characterKey]
        if type(row) == "table" and type(characterKey) == "string" and characterKey ~= "" then
            local u = tonumber(row.u)
            local v = tonumber(row.v)
            if u ~= nil and v ~= nil then
                local lm = row.npcLightMode
                if lm ~= "OFF" and lm ~= "STANDARD" and lm ~= "SPOTLIGHT" then
                    lm = "STANDARD"
                end
                local groundLevel = tonumber(row.groundLevel)
                if groundLevel == nil then
                    local Gameboard = require("core.npc_gameboard")
                    if type(Gameboard.groundLevelForSnapUv) == "function" then
                        groundLevel = Gameboard.groundLevelForSnapUv(u, v)
                    end
                end
                local placementRow = {
                    characterKey = characterKey,
                    u = u,
                    v = v,
                    yaw = tonumber(row.yaw) or 0,
                    npcLightMode = lm,
                }
                if groundLevel ~= nil then
                    placementRow.groundLevel = groundLevel
                end
                out[#out + 1] = placementRow
            end
        end
    end
    return out
end

--- @return table[]
function NPCS.collectSessionStagePlacements()
    return collectSessionStagePlacements()
end

--- @return string
local function sessionNpcWorldFingerprint()
    local lines = {}
    local lock = S.getStateVal("sessionScene", "npcWorld", "layoutLock")
    lines[#lines + 1] = "layoutLock:" .. tostring(lock == true)
    for _, pl in ipairs(collectSessionStagePlacements()) do
        local lm = pl.npcLightMode or ""
        lines[#lines + 1] = string.format(
            "p:%s:%.4f:%.4f:%.1f:%s:%.3f",
            pl.characterKey,
            pl.u,
            pl.v,
            pl.yaw or 0,
            lm,
            tonumber(pl.groundLevel) or 0
        )
    end
    table.sort(lines)
    return table.concat(lines, "\n")
end

--- @return boolean
local function npcWorldHasPlacementIntent()
    return #collectSessionStagePlacements() > 0
end

--- Park every spawned NPC into the deterministic under-table preload grid before stage `placements` apply.
local function stashAllNpcFigurinesForSessionSceneLayout()
    for name, rec in pairs(getInstances()) do
        if U.Type(name) == "string" and U.Type(rec) == "table" and U.Type(rec.figurineGuid) == "string" and rec.figurineGuid ~= "" then
            local slot = stablePreloadSlotIndex(name)
            if slot ~= nil then
                local ok, err = NPCS.moveNpcToArea(name, PRELOAD_AREA_KEY, {
                    preferredSlot = slot,
                    forceNpcLightMode = "OFF",
                    skipUiRefresh = true,
                    skipSeatSync = true,
                    forceSessionLayoutStash = true,
                })
                if not ok then
                    print("[NPCS] stash to preload failed for " .. tostring(name) .. ": " .. tostring(err))
                end
            end
        end
    end
end

--- @param npcName string
--- @return Object|nil first unclaimed pooled figurine with `npcInstance:<npcName>` GM notes
local function findExistingPooledFigurineForNpcName(npcName)
    if not validateNpcNameKey(npcName) then
        return nil
    end
    local expectedNotes = GM_PREFIX .. npcName
    local objs = getObjectsWithTag(TAG_FIG) or {}
    local fallback = nil
    for i = 1, #objs do
        local obj = objs[i]
        if obj ~= nil and NPCS.isPooledFigurineObject(obj) then
            local notes = ""
            if obj.getGMNotes ~= nil then
                notes = tostring(obj.getGMNotes() or "")
            end
            if notes == expectedNotes then
                local figGuid = obj.getGUID and obj.getGUID() or ""
                local claimedByOther = false
                for otherName, rec in pairs(getInstances()) do
                    if otherName ~= npcName and U.Type(rec) == "table" and rec.figurineGuid == figGuid then
                        claimedByOther = true
                        break
                    end
                end
                if not claimedByOther then
                    return obj
                end
                if fallback == nil then
                    fallback = obj
                end
            end
        end
    end
    return fallback
end

--- @param npcName string
--- @return string
local function npcPooledLightExpectedNickname(npcName)
    return NPC_LIGHT_NICKNAME_PREFIX .. tostring(npcName)
end

--- Display name / save nickname for a pooled NPC spotlight object.
--- @param obj Object|nil
--- @return string|nil
local function pooledSpotlightDisplayName(obj)
    if not U.isGameObject(obj) then
        return nil
    end
    local nameRaw = obj.getName ~= nil and tostring(obj.getName() or "") or ""
    if nameRaw ~= "" then
        return nameRaw
    end
    if obj.getData ~= nil then
        local data = obj.getData() or {}
        local nick = tostring(data.Nickname or "")
        if nick ~= "" then
            return nick
        end
    end
    return nil
end

--- @param ownerNpcName string
--- @param lightGuid string
--- @return boolean
local function pooledSpotlightGuidClaimedByOtherInstance(ownerNpcName, lightGuid)
    if lightGuid == "" then
        return false
    end
    for otherName, rec in pairs(getInstances()) do
        if otherName ~= ownerNpcName and U.Type(rec) == "table" and rec.lightGuid == lightGuid then
            return true
        end
    end
    return false
end

--- @param npcName string
--- @return Object|nil paired spotlight: instance `lightGuid`, else first unclaimed `npc_light` with matching nickname
local function findExistingPooledSpotlightForNpcName(npcName)
    if not validateNpcNameKey(npcName) then
        return nil
    end
    local expectedNick = npcPooledLightExpectedNickname(npcName)
    local rec = getInstances()[npcName]
    local stalePreferredGuid = nil
    if U.Type(rec) == "table" and U.Type(rec.lightGuid) == "string" and rec.lightGuid ~= "" then
        local fromRec = getObjectFromGUID(rec.lightGuid)
        if fromRec ~= nil then
            return fromRec
        end
        stalePreferredGuid = rec.lightGuid
    end

    local objs = getObjectsWithTag(TAG_LIT) or {}
    local fallback = nil
    local preferredMatch = nil
    for i = 1, #objs do
        local obj = objs[i]
        if obj ~= nil and pooledSpotlightDisplayName(obj) == expectedNick then
            local lg = obj.getGUID and obj.getGUID() or ""
            if lg ~= "" then
                if stalePreferredGuid ~= nil and lg == stalePreferredGuid then
                    return obj
                end
                if pooledSpotlightGuidClaimedByOtherInstance(npcName, lg) then
                    if fallback == nil then
                        fallback = obj
                    end
                elseif preferredMatch == nil then
                    preferredMatch = obj
                end
            end
        end
    end
    return preferredMatch or fallback
end

--- When duplicate `npc_light` objects share a roster key, pick the GUID to keep (matches `findExistingPooledSpotlightForNpcName` priority).
--- @param npcName string
--- @param guidList string[]
--- @return string|nil
local function chooseKeeperPooledSpotlightGuid(npcName, guidList)
    if not validateNpcNameKey(npcName) or U.Type(guidList) ~= "table" then
        return nil
    end
    local candidates = {}
    for i = 1, #guidList do
        local g = guidList[i]
        if U.Type(g) == "string" and g ~= "" then
            candidates[#candidates + 1] = g
        end
    end
    if #candidates == 0 then
        return nil
    end

    local rec = getInstances()[npcName]
    local stateGuid = U.Type(rec) == "table" and U.Type(rec.lightGuid) == "string" and rec.lightGuid or ""

    if stateGuid ~= "" and getObjectFromGUID(stateGuid) ~= nil then
        for i = 1, #candidates do
            if candidates[i] == stateGuid then
                return stateGuid
            end
        end
    end

    for i = 1, #candidates do
        local g = candidates[i]
        if getObjectFromGUID(g) ~= nil and not pooledSpotlightGuidClaimedByOtherInstance(npcName, g) then
            return g
        end
    end

    if stateGuid ~= "" then
        for i = 1, #candidates do
            if candidates[i] == stateGuid then
                return stateGuid
            end
        end
    end

    for i = 1, #candidates do
        if not pooledSpotlightGuidClaimedByOtherInstance(npcName, candidates[i]) then
            return candidates[i]
        end
    end

    return candidates[1]
end

--- Remove one pooled spotlight object and drop its dynamic lighting registration.
--- @param lightGuid string
--- @return boolean true when destroy was attempted for a non-empty guid
local function destroyPooledSpotlightByGuid(lightGuid)
    if U.Type(lightGuid) ~= "string" or lightGuid == "" then
        return false
    end
    local lit = getObjectFromGUID(lightGuid)
    if lit ~= nil then
        if lit.getLock ~= nil and lit.getLock() and lit.setLock ~= nil then
            lit.setLock(false)
        end
        if lit.destruct ~= nil then
            lit.destruct()
        end
    end
    unregisterDynamicLightModes(lightGuid)
    local lights = U.clone(S.getStateVal("lights") or {})
    lights[NPCS.lightRegistryName(lightGuid)] = nil
    S.setStateVal(lights, "lights")
    return true
end

--- Point `npcs.instances[npcName].lightGuid` at the surviving pooled spotlight after dedupe.
--- @param npcName string
--- @param keeperGuid string
local function syncInstanceLightGuidAfterDedupe(npcName, keeperGuid)
    if not validateNpcNameKey(npcName) or U.Type(keeperGuid) ~= "string" or keeperGuid == "" then
        return
    end
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" then
        return
    end
    if rec.lightGuid == keeperGuid then
        return
    end
    rec.lightGuid = keeperGuid
    setInstanceRecord(npcName, rec)
    if getObjectFromGUID(keeperGuid) ~= nil then
        ensureSpotlightTag(getObjectFromGUID(keeperGuid))
        L.registerNpcSpotlightModes(npcName, keeperGuid)
    end
end

--- Spawn only the paired preload spotlight (figurine already exists in-world).
--- @param npcName string
--- @param slotIndex number
--- @return Object|nil
--- @return string|nil err
local function spawnPreloadSpotlightForNpc(npcName, slotIndex)
    local defaults = NLIGHT.NPC_LIGHT_OBJECT_DATA_DEFAULTS
    if U.Type(defaults) ~= "table" then
        return nil, "NPC_LIGHT_OBJECT_DATA_DEFAULTS missing"
    end
    local lightData = cloneObjectDataForSpawn(defaults)
    if lightData == nil then
        return nil, "NPC light spawn data copy failed"
    end
    lightData.Nickname = npcPooledLightExpectedNickname(npcName)
    lightData.Tags = { TAG_LIT }
    local lightUniformScale = NPC_PRELOAD_LIGHT_SCALE
    if U.Type(lightData.Transform) == "table" then
        lightData.Transform.scaleX = lightUniformScale
        lightData.Transform.scaleY = lightUniformScale
        lightData.Transform.scaleZ = lightUniformScale
    end
    local spawnPos = NPCS.computeSlotWorldPosition(PRELOAD_AREA_KEY, slotIndex)
    local lx = spawnPos.x + NPC_LIGHT_SPAWN_OFFSET.x
    local ly = spawnPos.y + NPC_LIGHT_SPAWN_OFFSET.y
    local lz = spawnPos.z + NPC_LIGHT_SPAWN_OFFSET.z
    ---@diagnostic disable-next-line: undefined-global
    local lit = spawnObjectData({
        data = lightData,
        position = { lx, ly, lz },
    })
    if lit == nil then
        return nil, "spawnObjectData returned nil for NPC light"
    end
    if lit.AssetBundle ~= nil and lit.AssetBundle.playLoopingEffect ~= nil then
        lit.AssetBundle.playLoopingEffect(1)
    end
    ensureSpotlightTag(lit)
    return lit, nil
end

--- Find in-world paired spotlight or spawn a new preload pool light when missing.
--- @param npcName string
--- @param slotIndex number
--- @return Object|nil
--- @return string|nil err
local function ensurePooledSpotlightForNpc(npcName, slotIndex)
    local lit = findExistingPooledSpotlightForNpcName(npcName)
    if lit ~= nil then
        return lit, nil
    end
    return spawnPreloadSpotlightForNpc(npcName, slotIndex)
end

--- Re-link an in-world figurine (`npcInstance:` GM notes) into the preload pool instead of spawning a duplicate.
--- @param npcName string
--- @param figurine Object
--- @param slotIndex number
--- @param opts table|nil
--- @return boolean
--- @return string|nil
local function adoptExistingPooledFigurineAtPreloadSlot(npcName, figurine, slotIndex, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local deferUiRefresh = opts.deferUiRefresh == true
    local skipSeatSync = opts.skipSeatSync == true
    local area = NPCS.areas[PRELOAD_AREA_KEY]
    if area == nil or U.Type(slotIndex) ~= "number" then
        return false, "Invalid preload adopt target."
    end
    if getInstances()[npcName] ~= nil then
        return false, "NPC already has instance record."
    end
    if not U.isGameObject(figurine) or not NPCS.isPooledFigurineObject(figurine) then
        return false, "Not a pooled NPC figurine."
    end
    ensureNpcFigurinePhysicsLocked(figurine)
    local figGuid = figurine.getGUID and figurine.getGUID() or ""
    if figGuid == "" then
        return false, "Adopt figurine has no GUID."
    end

    local lit, litErr = ensurePooledSpotlightForNpc(npcName, slotIndex)
    if lit == nil then
        return false, litErr or "Could not spawn paired NPC light."
    end
    local lg = lit.getGUID and lit.getGUID() or ""
    if lg == "" then
        return false, "Adopted NPC light has no GUID."
    end
    L.registerNpcSpotlightModes(npcName, lg)

    local rec = {
        figurineGuid = figGuid,
        lightGuid = lg,
        areaKey = PRELOAD_AREA_KEY,
        slotIndex = slotIndex,
        npcLightMode = effectiveNpcLightModeForAreaPlacement(area, opts),
        locked = false,
    }
    setInstanceRecord(npcName, rec)
    NPCS.applyFigurinePlacement(figurine, PRELOAD_AREA_KEY, slotIndex)
    local pos = NPCS.computeSlotWorldPosition(PRELOAD_AREA_KEY, slotIndex)
    if lit.setPosition ~= nil then
        lit.setPosition(Vector(pos.x + NPC_LIGHT_SPAWN_OFFSET.x, pos.y + NPC_LIGHT_SPAWN_OFFSET.y, pos.z + NPC_LIGHT_SPAWN_OFFSET.z))
    end
    applyNpcPairPhysicalPresentation(figurine, lit, PRELOAD_AREA_KEY, npcName)
    if not skipSeatSync then
        requestSeatLayoutSync()
    end
    NPCS.applyCurrentLightMode(npcName, 0)
    print("[NPCS] adopted existing figurine for " .. tostring(npcName) .. " at preload slot " .. tostring(slotIndex))
    return true, nil
end

--- @param npcName string
--- @return string
local function missingPooledFigurineErr(npcName)
    return "Missing workshop npc_figurine for "
        .. tostring(npcName)
        .. " (tag npc_figurine, GM notes "
        .. GM_PREFIX
        .. tostring(npcName)
        .. "). Run npm run custom-ui-assets:inject-npc-world on the save."
end

--- @param npcName string
--- @param areaKey string
--- @param slotIndex number
--- @param opts table|nil
--- @return boolean, string|nil
function NPCS.spawnNpcAtSlot(npcName, areaKey, slotIndex, opts)
    npcPoolPolicyError(
        "spawnNpcAtSlot removed: NPC figurines must exist in the workshop save. "
            .. missingPooledFigurineErr(npcName)
    )
end

--- True when figurine world pose matches the preload grid slot (guards state/physical desync).
--- @param fig Object|nil
--- @param slotIndex number
--- @return boolean
local function figurinePhysicallyAtPreloadSlot(fig, slotIndex)
    if not U.isGameObject(fig) or U.Type(slotIndex) ~= "number" then
        return false
    end
    local pos = fig.getPosition()
    if pos == nil then
        return false
    end
    local expected = NPCS.computeSlotWorldPosition(PRELOAD_AREA_KEY, slotIndex)
    local dy = math.abs((pos.y or 0) - expected.y)
    local dx = math.abs((pos.x or 0) - expected.x)
    local dz = math.abs((pos.z or 0) - expected.z)
    return dy < 2 and dx < 3 and dz < 3
end

--- Ensure `npcName` is linked in the global under-table preload pool (stable slot). Adopts in-world
--- workshop figurines only; does not spawn figurines. Spotlight repair still spawns missing `npc_light`.
--- @param npcName string
--- @param opts table|nil `deferUiRefresh`, `skipSeatSync`, `forceNpcLightMode`
--- @return boolean ok
--- @return string|nil err
function NPCS.ensureNpcInPreloadZone(npcName, opts)
    if not validateNpcNameKey(npcName) then
        return false, "Invalid NPC key."
    end
    if NPCS.characters[npcName] == nil then
        return false, "Unknown NPC: " .. tostring(npcName)
    end
    if NPCS.areas[PRELOAD_AREA_KEY] == nil then
        return false, "preload area missing from npcs_data.areas."
    end
    opts = U.Type(opts) == "table" and opts or {}
    local slot = stablePreloadSlotIndex(npcName)
    if slot == nil then
        return false, "NPC preload: no stable slot."
    end
    local rec = getInstances()[npcName]
    if rec ~= nil then
        local fig = getObjectFromGUID(rec.figurineGuid or "")
        if fig == nil then
            return false, missingPooledFigurineErr(npcName)
        end
        local resolvedSlot = resolvePreloadSlotForMove(npcName, slot)
        if resolvedSlot == nil then
            return false, "No free slot in preload pool."
        end
        local ak = rec.areaKey
        local seated = U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey)
        if ak == PRELOAD_AREA_KEY and U.Type(rec.slotIndex) == "number" and rec.slotIndex == resolvedSlot
            and not seated and figurinePhysicallyAtPreloadSlot(fig, resolvedSlot) then
            local lit = getObjectFromGUID(rec.lightGuid or "")
            if lit == nil then
                local litErr
                lit, litErr = ensurePooledSpotlightForNpc(npcName, resolvedSlot)
                if lit ~= nil then
                    local lg = lit.getGUID and lit.getGUID() or ""
                    if lg ~= "" then
                        rec.lightGuid = lg
                        L.registerNpcSpotlightModes(npcName, lg)
                        setInstanceRecord(npcName, rec)
                    end
                elseif litErr ~= nil then
                    print("[NPCS] ensureNpcInPreloadZone spotlight repair for "
                        .. tostring(npcName)
                        .. ": "
                        .. tostring(litErr))
                end
            end
            applyNpcPairPhysicalPresentation(fig, lit, PRELOAD_AREA_KEY, npcName)
            return true, nil
        end
        return NPCS.moveNpcToArea(npcName, PRELOAD_AREA_KEY, {
            preferredSlot = resolvedSlot,
            forceNpcLightMode = U.Type(opts.forceNpcLightMode) == "string" and opts.forceNpcLightMode or "OFF",
            skipUiRefresh = opts.deferUiRefresh == true,
            skipSeatSync = opts.skipSeatSync == true,
            forceSessionLayoutStash = true,
        })
    end
    local spawnSlot = resolvePreloadSlotForMove(npcName, slot)
    if spawnSlot == nil then
        return false, "No free slot in preload pool."
    end
    local existingFig = findExistingPooledFigurineForNpcName(npcName)
    if existingFig ~= nil then
        return adoptExistingPooledFigurineAtPreloadSlot(npcName, existingFig, spawnSlot, opts)
    end
    return false, missingPooledFigurineErr(npcName)
end

--- Applies `gameState.sessionScene.npcWorld.placements`: forwards to unified orchestrator.
--- @param opts table|nil `deferUiRefresh`, `forceSessionNpcWorld` (bypass fingerprint and re-apply)
function NPCS.reconcileSessionSceneNpcWorldFromState(opts)
    opts = U.Type(opts) == "table" and opts or {}
    NPCS.reconcileAllFromState({
        deferUiRefresh = opts.deferUiRefresh == true,
        force = opts.forceSessionNpcWorld == true or opts.force == true,
    })
end

--- Fingerprint of `seatLayout.occupiedNPCSlots` (from session `seatSlots` via `S.validateState`).
--- @return string
occupiedNpcSeatsFingerprint = function()
    local lines = {}
    local occupied = getOccupiedNpcSeatMap()
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local slotValue = occupied[seatKey]
        if slotValue == false then
            slotValue = ""
        end
        lines[#lines + 1] = seatKey .. "=" .. tostring(slotValue or "")
    end
    table.sort(lines)
    return table.concat(lines, "\n")
end

--- Unified reconcile fingerprint: placements + seats + table + NPC presence.
--- @return string
local function npcReconcileFingerprint()
    local lines = {}
    lines[#lines + 1] = "npcWorld:\n" .. sessionNpcWorldFingerprint()
    lines[#lines + 1] = "seats:\n" .. occupiedNpcSeatsFingerprint()
    local tableKey = S.getStateVal("seatLayout", "currentTableKey")
    lines[#lines + 1] = "table:" .. tostring(tableKey or "")
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        lines[#lines + 1] = "present:" .. seatKey .. "=" .. tostring(resolveSeatPresenceForSeat(seatKey))
    end
    return table.concat(lines, "\n")
end

--- Step Zero: resolve placement intent from authoring inputs (read-only).
--- @return table `{ byCharacter, bySeat, tableKey }`
resolveNpcPlacementIntent = function()
    local byCharacter = {}
    for _, pl in ipairs(collectSessionStagePlacements()) do
        byCharacter[pl.characterKey] = {
            target = "stage",
            u = pl.u,
            v = pl.v,
            yaw = pl.yaw,
            npcLightMode = pl.npcLightMode,
            groundLevel = pl.groundLevel,
        }
    end

    local tableKey = S.getStateVal("seatLayout", "currentTableKey")
    local tableCfg = U.Type(tableKey) == "string" and C.Tables[tableKey] or nil
    local map = U.Type(tableCfg) == "table" and tableCfg.playerToPositionMap or {}
    local bySeat = {}

    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local assignedChar = resolveAssignedCharacterForSeat(seatKey)
        local assigned = U.Type(assignedChar) == "string" and assignedChar ~= ""
        local tableHasSlot = map[seatKey] ~= nil
        local present = resolveSeatPresenceForSeat(seatKey)
        local ciAssigned = assigned and U.Type(byCharacter[assignedChar]) == "table" and byCharacter[assignedChar] or nil
        local areaBound = ciAssigned ~= nil and ciAssigned.target == "stage"
        local physicalSeatAllowed = assigned and tableHasSlot and not areaBound
        bySeat[seatKey] = {
            assigned = assigned,
            assignedCharacter = assignedChar,
            tableHasSlot = tableHasSlot,
            present = present,
            physicalSeatAllowed = physicalSeatAllowed,
            areaBoundOccupant = areaBound and assignedChar or nil,
        }
        if assigned and not areaBound and byCharacter[assignedChar] == nil then
            if tableHasSlot then
                byCharacter[assignedChar] = { target = "seat", seatKey = seatKey }
            else
                byCharacter[assignedChar] = { target = "preload", pendingSeatKey = seatKey }
            end
        end
    end

    for name, _ in pairs(getInstances()) do
        if U.Type(name) == "string" and byCharacter[name] == nil then
            byCharacter[name] = { target = "preload" }
        end
    end

    return {
        byCharacter = byCharacter,
        bySeat = bySeat,
        tableKey = tableKey,
    }
end

--- @param opts table|nil
--- @param stepNum number
--- @return boolean
local function reconcileStepEnabled(opts, stepNum)
    local only = opts.onlySteps
    if U.Type(only) ~= "table" or #only < 1 then
        return true
    end
    for i = 1, #only do
        if only[i] == stepNum then
            return true
        end
    end
    return false
end

--- Step One: remove NPCs from stage areas that resolved intent no longer assigns there.
--- @param intent table
--- @return boolean allOk
local function reconcileStepOneAreaRemovals(intent)
    local allOk = true
    for name, rec in pairs(getInstances()) do
        if U.Type(name) ~= "string" or U.Type(rec) ~= "table" then
            -- skip malformed instance row
        else
            local ci = intent.byCharacter[name]
            if npcInstanceOnStage(name) then
                local keep = false
                if U.Type(ci) == "table" then
                    if ci.target == "stage" and rec.areaKey == STAGE_BOARD_AREA_KEY then
                        local sp = rec.stagePlacement
                        if U.Type(sp) == "table" then
                            local du = math.abs((tonumber(sp.u) or 0) - (tonumber(ci.u) or 0))
                            local dv = math.abs((tonumber(sp.v) or 0) - (tonumber(ci.v) or 0))
                            -- Placement only: do not compare rec.npcLightMode here (step 5 applies intent mode).
                            keep = du < 0.002 and dv < 0.002 and yawDiffDeg(sp.yaw, ci.yaw) < 1
                        end
                    end
                end
                if not keep then
                    if U.Type(ci) == "table" and ci.target == "seat" then
                        -- Step Three re-seats from stage; avoid parking to preload first.
                    elseif U.Type(ci) == "table" and ci.target == "stage" then
                        -- Step Five repositions on stage (lerp or snap); do not park paired spotlight to preload first.
                    else
                        local ok, err = NPCS.retreatNpcInstanceToPreloadPool(name, {
                            skipUiRefresh = true,
                            skipSeatSync = true,
                        })
                        if not ok then
                            allOk = false
                            print("[NPCS] step1 area removal: " .. tostring(name) .. ": " .. tostring(err))
                        end
                    end
                end
            elseif U.Type(ci) == "table" and ci.target == "preload" and rec.areaKey == PRELOAD_AREA_KEY then
                local fig = getObjectFromGUID(rec.figurineGuid or "")
                local slot = resolvePreloadSlotForMove(name, stablePreloadSlotIndex(name))
                if fig ~= nil and U.Type(slot) == "number" and not figurinePhysicallyAtPreloadSlot(fig, slot) then
                    local ok, err = NPCS.retreatNpcInstanceToPreloadPool(name, {
                        skipUiRefresh = true,
                        skipSeatSync = true,
                    })
                    if not ok then
                        allOk = false
                        print("[NPCS] step1 preload resync: " .. tostring(name) .. ": " .. tostring(err))
                    end
                end
            end
        end
    end
    return allOk
end

--- @param seatKey string
--- @return string|nil npcName physically at seat, if any
local function physicalOccupantAtSeat(seatKey)
    for name, rec in pairs(getInstances()) do
        if U.Type(rec) == "table" and rec.seatedSeatKey == seatKey then
            return name
        end
    end
    local tag = seatTagForKey(seatKey)
    local tagged = getObjectsWithTag(tag)
    if U.Type(tagged) == "table" then
        for i = 1, #tagged do
            local o = tagged[i]
            if o ~= nil and NPCS.isPooledFigurineObject(o) and figurineHasSeatTag(o, seatKey) then
                for name, rec in pairs(getInstances()) do
                    if U.Type(rec) == "table" and rec.figurineGuid == o.getGUID() then
                        return name
                    end
                end
            end
        end
    end
    return nil
end

--- Step Two: remove NPCs from table seats per resolved intent.
--- @param intent table
--- @return boolean allOk
local function reconcileStepTwoSeatRemovals(intent)
    local allOk = true
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local info = intent.bySeat[seatKey]
        if U.Type(info) == "table" then
            if not (info.assigned and not info.present) then
                local physicalName = physicalOccupantAtSeat(seatKey)
                local atSeat = physicalName ~= nil
                if not info.assigned then
                    if atSeat then
                        local ok, err = clearNpcSeatPhysical(seatKey, { retainAssignment = false, skipLayoutSync = true })
                        if not ok then
                            allOk = false
                            print("[NPCS] step2 unassign clear " .. tostring(seatKey) .. ": " .. tostring(err))
                        end
                    end
                elseif U.Type(info.assignedCharacter) == "string" and physicalName ~= nil and physicalName ~= info.assignedCharacter then
                    local ok, err = clearNpcSeatPhysical(seatKey, { retainAssignment = false, skipLayoutSync = true })
                    if not ok then
                        allOk = false
                        print("[NPCS] step2 wrong occupant " .. tostring(seatKey) .. ": " .. tostring(err))
                    end
                elseif not info.physicalSeatAllowed and atSeat then
                    local retain = false
                    if info.assigned then
                        if not info.tableHasSlot then
                            retain = true
                        elseif U.Type(info.areaBoundOccupant) == "string" and info.areaBoundOccupant ~= "" then
                            retain = true
                        end
                    end
                    local ok, err = clearNpcSeatPhysical(seatKey, {
                        retainAssignment = retain,
                        skipLayoutSync = true,
                    })
                    if not ok then
                        allOk = false
                        print("[NPCS] step2 physical off " .. tostring(seatKey) .. ": " .. tostring(err))
                    end
                end
            end
        end
    end
    return allOk
end

--- Layout commit A: synchronous table layout using orchestrator context.
--- @param intent table
local function commitNpcSeatLayout(intent)
    local physicalSeatAllowedBySeat = {}
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local info = intent.bySeat[seatKey]
        if U.Type(info) == "table" then
            physicalSeatAllowedBySeat[seatKey] = info.physicalSeatAllowed == true
        end
    end
    npcReconcileLayoutContext = {
        physicalSeatAllowedBySeat = physicalSeatAllowedBySeat,
    }
    local tableKey = S.getStateVal("seatLayout", "currentTableKey")
    local rsl = require("lib.rotational-seat-layout")
    -- Fingerprint ignores in-area occupants (preload/stage); orchestrated seating must force layout.
    if rsl ~= nil and type(rsl.SyncTable) == "function" then
        rsl.SyncTable(tableKey, { force = true })
    end
    lastNpcLayoutCommit = {
        tableKey = U.Type(tableKey) == "string" and tableKey or "",
        fingerprint = occupiedNpcSeatsFingerprint(),
    }
    npcReconcileLayoutContext = nil
end

--- Step Three: seat-bound NPCs onto table seats (tags only; layout commit follows).
--- @param intent table
--- @return boolean allOk
local function reconcileStepThreeSeatPlacements(intent)
    local allOk = true
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if seatNeedsPlacement(seatKey, intent) then
            local info = intent.bySeat[seatKey]
            local npcName = info and info.assignedCharacter
            if U.Type(npcName) == "string" and npcName ~= "" then
                local ok, err = assignNpcToSeat(npcName, seatKey, {
                    deferLayoutSync = true,
                    blockAreaBound = true,
                })
                if not ok then
                    allOk = false
                    print(
                        "[NPCS] step3 seat "
                            .. tostring(seatKey)
                            .. " for "
                            .. tostring(npcName)
                            .. ": "
                            .. tostring(err)
                    )
                end
            end
        end
    end
    commitNpcSeatLayout(intent)
    return allOk
end

--- Step Four: narrative presence visibility; seat lights for non-stage-bound NPC seats only.
--- Stage-bound homeland spotlights reconcile once at orchestrator end (after Step Five).
--- @param intent table
local function reconcileSeatNarrativePresenceFromIntent(intent)
    local O = require("core.objects")
    if type(O.reconcilePcSeatHiddenObjectsFromState) == "function" then
        O.reconcilePcSeatHiddenObjectsFromState()
    end

    local hideColors = allViewerColorsForInvisibility()
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local info = intent.bySeat[seatKey]
        if U.Type(info) == "table" and info.assigned == true then
            local visible = info.present == true
            local tag = seatTagForKey(seatKey)
            local objs = getObjectsWithTag(tag)
            if U.Type(objs) == "table" then
                for i = 1, #objs do
                    local obj = objs[i]
                    if obj ~= nil and obj.setInvisibleTo ~= nil then
                        if visible then
                            obj.setInvisibleTo({})
                        else
                            obj.setInvisibleTo(hideColors)
                        end
                    end
                end
            end
            if U.Type(info.areaBoundOccupant) ~= "string" or info.areaBoundOccupant == "" then
                L.reconcileForPlayer(seatKey)
            end
        end
    end
end

--- Step Five (a): gameboard `placements` on STAGE_BOARD.
--- @param intent table
--- @param opts table|nil `{ reason?, animateStageMoves?, deferUiRefresh? }`
--- @return boolean allOk
local function reconcileStepFiveStagePlacements(intent, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local allOk = true
    for name, ci in pairs(intent.byCharacter) do
        if U.Type(ci) == "table" and ci.target == "stage" and getInstances()[name] == nil then
            local ok, err = NPCS.ensureNpcInPreloadZone(name, { deferUiRefresh = true, skipSeatSync = true })
            if not ok then
                allOk = false
                print("[NPCS] step5 stage adopt preload " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end
    local lerpCandidates = {}
    local NPCStageLerp = require("core.npc_stage_lerp")
    for name, ci in pairs(intent.byCharacter) do
        if U.Type(ci) == "table" and ci.target == "stage" then
            local placement = {
                u = ci.u,
                v = ci.v,
                yaw = ci.yaw,
                npcLightMode = ci.npcLightMode,
                groundLevel = ci.groundLevel,
            }
            local modeOpt = {
                skipUiRefresh = true,
                skipSeatSync = true,
            }
            local rec = getInstances()[name]
            local lerpCandidate = NPCStageLerp.evaluateCandidate(name, rec, placement, opts)
            if lerpCandidate ~= nil then
                lerpCandidates[#lerpCandidates + 1] = lerpCandidate
            else
                local ok, err = NPCS.moveNpcToStagePlacement(name, placement, modeOpt)
                if not ok then
                    local repairOk, repairErr = NPCS.ensureNpcInPreloadZone(name, {
                        deferUiRefresh = true,
                        skipSeatSync = true,
                        forceNpcLightMode = "OFF",
                    })
                    if repairOk then
                        ok, err = NPCS.moveNpcToStagePlacement(name, placement, modeOpt)
                    else
                        print("[NPCS] step5 stage preload repair " .. tostring(name) .. ": " .. tostring(repairErr))
                    end
                end
                if not ok then
                    allOk = false
                    print("[NPCS] step5 stage placement " .. tostring(name) .. ": " .. tostring(err))
                end
            end
        end
    end
    if #lerpCandidates > 0 then
        NPCStageLerp.runQueued(lerpCandidates)
    end
    return allOk
end

--- Step Five (b): park resolved **Preload** targets at `areas.preload` groundLevel (-200).
--- @param intent table
--- @return boolean allOk
local function reconcileStepFivePreloadPopulate(intent)
    local allOk = true
    for name, ci in pairs(intent.byCharacter) do
        if U.Type(ci) == "table" and ci.target == "preload" and getInstances()[name] == nil then
            local ok, err = NPCS.ensureNpcInPreloadZone(name, { deferUiRefresh = true, skipSeatSync = true })
            if not ok then
                allOk = false
                print("[NPCS] step5 preload adopt " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end
    for name, ci in pairs(intent.byCharacter) do
        if U.Type(ci) == "table" and ci.target == "preload" then
            local ok, err = NPCS.ensureNpcInPreloadZone(name, {
                deferUiRefresh = true,
                skipSeatSync = true,
                forceNpcLightMode = "OFF",
            })
            if not ok then
                allOk = false
                print("[NPCS] step5 preload park " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end
    return allOk
end

--- Unified NPC reconcile orchestrator (Steps Zero–Five). See `.dev/NPC Object Spawning & Spotlighting/NPC Reconciler Procedure.md`.
--- @param opts table|nil `{ deferUiRefresh?, force?, onlySteps?, skipPreloadPopulate? }`
function NPCS.reconcileAllFromState(opts)
    opts = U.Type(opts) == "table" and opts or {}
    local deferUiRefresh = opts.deferUiRefresh == true
    local force = opts.force == true

    local fp = npcReconcileFingerprint()
    if not force and fp == lastNpcReconcileFingerprint then
        --- Tail reconcilers with own fingerprint gates — same as full path end (TOR-178 / TOR-201).
        --- Skipping these violated sync contract when homeland cache was invalidated alone.
        reconcileNpcHomelandSeatSpotlightsWhenStageBound()
        local Gameboard = require("core.npc_gameboard")
        if type(Gameboard.reconcileControlBoardFromState) == "function" then
            Gameboard.reconcileControlBoardFromState()
        end
        return
    end

    if force then
        lastHomelandStageBoundSpotlightsFingerprint = nil
    end

    local intent = resolveNpcPlacementIntent()
    local allOk = true
    npcReconcileInProgress = true

    if reconcileStepEnabled(opts, 1) then
        if not reconcileStepOneAreaRemovals(intent) then
            allOk = false
        end
    end
    if reconcileStepEnabled(opts, 2) then
        if not reconcileStepTwoSeatRemovals(intent) then
            allOk = false
        end
    end
    if reconcileStepEnabled(opts, 3) then
        if not reconcileStepThreeSeatPlacements(intent) then
            allOk = false
        end
    end
    if reconcileStepEnabled(opts, 4) then
        reconcileSeatNarrativePresenceFromIntent(intent)
    end
    if reconcileStepEnabled(opts, 5) then
        if not reconcileStepFiveStagePlacements(intent, opts) then
            allOk = false
        end
        if opts.skipPreloadPopulate ~= true and not reconcileStepFivePreloadPopulate(intent) then
            allOk = false
        end
    end

    reconcileNpcHomelandSeatSpotlightsWhenStageBound()

    npcReconcileInProgress = false

    if allOk then
        lastNpcReconcileFingerprint = fp
        lastSessionNpcWorldFingerprint = sessionNpcWorldFingerprint()
    else
        print("[NPCS] reconcileAllFromState incomplete; fingerprint not committed (will retry on next Sync.full)")
    end


    local Gameboard = require("core.npc_gameboard")
    if type(Gameboard.reconcileControlBoardFromState) == "function" then
        Gameboard.reconcileControlBoardFromState()
    end
end

--- Read-only placement intent for debug/tests.
--- @return table
function NPCS.resolveNpcPlacementIntent()
    return resolveNpcPlacementIntent()
end

--- One-shot layout context for rotational seat layout during orchestrated reconcile.
--- @return table|nil
function NPCS.getReconcileLayoutContext()
    return npcReconcileLayoutContext
end

--- True while `NPCS.reconcileAllFromState` is running (layout/light deferral for stage-bound homelands).
--- @return boolean
function NPCS.isReconcileOrchestratorInProgress()
    return npcReconcileInProgress
end

--- Places pooled NPC figurines into table seats from `seatLayout.occupiedNPCSlots`.
--- Legacy entry; forwards to unified orchestrator.
--- @param opts table|nil `deferUiRefresh`, `forceOccupiedNpcSeats` or `force` (bypass fingerprint)
function NPCS.reconcileOccupiedNpcSeatsFromState(opts)
    opts = U.Type(opts) == "table" and opts or {}
    NPCS.reconcileAllFromState({
        deferUiRefresh = opts.deferUiRefresh == true,
        force = opts.forceOccupiedNpcSeats == true or opts.force == true,
    })
end

--- @param npcName string
--- @param areaKey string
--- @param opts table|nil optional `preferredSlot`, `forceNpcLightMode`, `skipUiRefresh`, `skipSeatSync`
--- @return boolean, string|nil
function NPCS.spawnOrMoveIndividual(npcName, areaKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local rec = getInstances()[npcName]
    if rec ~= nil and isNpcLocked(rec) and opts.forceSessionLayoutStash ~= true then
        return false, "NPC is locked in place. Unlock before moving."
    end
    if rec ~= nil then
        return NPCS.moveNpcToArea(npcName, areaKey, opts)
    end
    if areaKey ~= PRELOAD_AREA_KEY then
        return false, "NPC '"
            .. tostring(npcName)
            .. "' has no pooled instance; global preload pool is missing this entry (see console)."
    end
    return NPCS.ensureNpcInPreloadZone(npcName, opts)
end

--- @param npcName string
--- @param areaKey string
--- @param opts table|nil optional: `preferredSlot`, `forceNpcLightMode`, `skipUiRefresh`, `skipSeatSync`, `forceSessionLayoutStash` (scene stash bypasses lock)
--- @return boolean, string|nil
function NPCS.moveNpcToArea(npcName, areaKey, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local skipSeatSync = opts.skipSeatSync == true
    local bypassLock = opts.forceSessionLayoutStash == true
    local rec = getInstances()[npcName]
    if rec == nil then
        npcPoolPolicyError("moveNpcToArea: NPC '" .. tostring(npcName) .. "' has no pooled instance.")
    end
    if U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey) then
        local sk = rec.seatedSeatKey
        local seatFig = getObjectFromGUID(rec.figurineGuid or "")
        local seatLit = getObjectFromGUID(rec.lightGuid or "")
        if seatFig ~= nil then
            clearNpcFigurineSeatIdentity(seatFig, seatLit)
        end
        rec.seatedSeatKey = nil
        setInstanceRecord(npcName, rec)
        local occ = U.clone(getOccupiedNpcSeatMap())
        if occ[sk] == npcName then
            occ[sk] = false
        end
        setOccupiedNpcSeatMap(occ)
        if not skipSeatSync then
            requestSeatLayoutSync()
        end
        rec = getInstances()[npcName]
    end
    if rec == nil then
        return false, "NPC not spawned."
    end
    if areaKey ~= PRELOAD_AREA_KEY and not bypassLock then
        local ak = rec.areaKey
        local fromPreload = (ak == PRELOAD_AREA_KEY)
        local fromPlayArea = U.Type(ak) == "string"
            and ak ~= PRELOAD_AREA_KEY
            and ak ~= STASH_AREA_KEY
            and NPCS.areas[ak] ~= nil
        if not fromPreload and not fromPlayArea then
            npcPoolPolicyError(
                "moveNpcToArea: NPC '"
                    .. tostring(npcName)
                    .. "' must be parked in preload before stage placement."
            )
        end
    end
    if isNpcLocked(rec) and not bypassLock then
        return false, "NPC is locked in place. Unlock before moving."
    end
    local slot
    if areaKey == PRELOAD_AREA_KEY then
        if stablePreloadSlotIndex(npcName) == nil and U.Type(opts.preferredSlot) ~= "number" then
            return false, "No stable preload slot for NPC."
        end
        slot = resolvePreloadSlotForMove(npcName, opts.preferredSlot)
        if slot == nil then
            return false, "No free slot in preload pool."
        end
    else
        local preferredSlot = U.Type(opts.preferredSlot) == "number" and opts.preferredSlot or rec.slotIndex
        slot = resolveSlotForMove(areaKey, preferredSlot, npcName)
        if slot == nil then
            return false, "No free slot in area."
        end
    end
    local fig = getObjectFromGUID(rec.figurineGuid or "")
    local lit = getObjectFromGUID(rec.lightGuid or "")
    if fig == nil then
        setInstanceRecord(npcName, nil)
        unregisterDynamicLightModes(rec.lightGuid)
        return false, "Figurine missing; cleared record."
    end
    NPCS.applyFigurinePlacement(fig, areaKey, slot)
    local area = NPCS.areas[areaKey]
    rec.areaKey = areaKey
    rec.slotIndex = slot
    if areaKey == PRELOAD_AREA_KEY then
        rec.stagePlacement = nil
    end
    rec.npcLightMode = effectiveNpcLightModeForAreaPlacement(area, opts)
    setInstanceRecord(npcName, rec)
    if lit ~= nil and lit.setPosition ~= nil then
        local pos = NPCS.computeSlotWorldPosition(areaKey, slot)
        lit.setPosition(Vector(pos.x + NPC_LIGHT_SPAWN_OFFSET.x, pos.y + NPC_LIGHT_SPAWN_OFFSET.y, pos.z + NPC_LIGHT_SPAWN_OFFSET.z))
    end
    applyNpcPairPhysicalPresentation(fig, lit, areaKey, npcName)
    NPCS.applyCurrentLightMode(npcName, 0)
    if not skipSeatSync then
        requestSeatLayoutSync()
    end
    return true, nil
end

--- @param npcName string
--- @return boolean
function NPCS.isSpotlightHeld(npcName)
    return spotlightHeld[npcName] == true
end

--- Temporary figurine override for `buildResolvedLightModeTable` during stage lerp bake.
--- @param npcName string
--- @param fig Object|nil
function NPCS.setLightAlignFigOverride(npcName, fig)
    if fig == nil or not U.isGameObject(fig) then
        lightAlignFigOverride[npcName] = nil
    else
        lightAlignFigOverride[npcName] = fig
    end
end

--- Apply stage presentation + spotlight reconcile after TOR-173 lerp (figurine pose already at target).
--- @param npcName string
--- @param transitionTime number|nil
function NPCS.finalizeStageLerpWorld(npcName, transitionTime)
    if U.Type(npcName) ~= "string" or npcName == "" then
        return
    end
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" then
        return
    end
    local fig = getObjectFromGUID(rec.figurineGuid or "")
    local lit = getObjectFromGUID(rec.lightGuid or "")
    if not U.isGameObject(fig) then
        return
    end
    applyNpcPairPhysicalPresentation(fig, lit, STAGE_BOARD_AREA_KEY, npcName)
    applyStageNpcSpotlightNow(npcName, fig, lit, transitionTime)
    deferNpcSpotlightAlignedToFigurine(npcName, fig, lit, transitionTime or 0)
end

--- Commit stage placement + light mode to state without moving world objects (TOR-173 lerp prep).
--- @param npcName string
--- @param placement table
--- @return boolean
function NPCS.commitStagePlacementState(npcName, placement)
    if type(placement) ~= "table" then
        return false
    end
    local rec = getInstances()[npcName]
    if rec == nil then
        return false
    end
    local desiredMode = normalizedStageNpcLightMode(placement)
    rec.areaKey = STAGE_BOARD_AREA_KEY
    rec.slotIndex = 0
    local Gameboard = require("core.npc_gameboard")
    local derivedYaw = 0
    if type(Gameboard.placementBoardRelYawDeg) == "function" then
        derivedYaw = Gameboard.placementBoardRelYawDeg(placement.u, placement.v)
    end
    rec.stagePlacement = {
        u = tonumber(placement.u),
        v = tonumber(placement.v),
        yaw = derivedYaw,
        groundLevel = tonumber(placement.groundLevel),
    }
    rec.npcLightMode = desiredMode
    setInstanceRecord(npcName, rec)
    syncStageNpcLightState(npcName, desiredMode)
    return true
end

--- Move pooled NPC to a gameboard stage placement (not a legacy `areas` slot).
--- @param npcName string
--- @param placement table `{ u, v, yaw?, npcLightMode? }`
--- @param opts table|nil
--- @return boolean, string|nil
function NPCS.moveNpcToStagePlacement(npcName, placement, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local skipSeatSync = opts.skipSeatSync == true
    local bypassLock = opts.forceSessionLayoutStash == true
    if type(placement) ~= "table" then
        return false, "Invalid stage placement."
    end
    local rec = getInstances()[npcName]
    if rec == nil then
        return false, "NPC not spawned."
    end
    if isNpcLocked(rec) and not bypassLock then
        return false, "NPC is locked in place. Unlock before moving."
    end
    local didUnseat = false
    if U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey) then
        local seatFig = getObjectFromGUID(rec.figurineGuid or "")
        local seatLit = getObjectFromGUID(rec.lightGuid or "")
        if seatFig ~= nil then
            clearNpcFigurineSeatIdentity(seatFig, seatLit)
        end
        rec.seatedSeatKey = nil
        setInstanceRecord(npcName, rec)
        didUnseat = true
        rec = getInstances()[npcName]
    elseif figurineHasAnySeatTag(getObjectFromGUID(rec.figurineGuid or "")) then
        local seatFig = getObjectFromGUID(rec.figurineGuid or "")
        local seatLit = getObjectFromGUID(rec.lightGuid or "")
        if seatFig ~= nil then
            clearNpcFigurineSeatIdentity(seatFig, seatLit)
        end
        didUnseat = true
    end
    local fig = getObjectFromGUID(rec.figurineGuid or "")
    local lit = getObjectFromGUID(rec.lightGuid or "")
    if fig == nil then
        setInstanceRecord(npcName, nil)
        unregisterDynamicLightModes(rec.lightGuid)
        if didUnseat and not skipSeatSync then
            requestSeatLayoutSync()
        end
        return false, "Figurine missing; cleared record."
    end
    local desiredMode = normalizedStageNpcLightMode(placement)
    if opts.force ~= true
        and rec.areaKey == STAGE_BOARD_AREA_KEY
        and stagePlacementMatchesRecord(rec.stagePlacement, placement)
    then
        if rec.npcLightMode == desiredMode then
            return true, nil
        end
        rec.npcLightMode = desiredMode
        setInstanceRecord(npcName, rec)
        applyStageNpcSpotlightNow(npcName, fig, lit, 0)
        deferNpcSpotlightAlignedToFigurine(npcName, fig, lit, 0)
        return true, nil
    end
    NPCS.applyFigurinePlacementAtWorld(fig, placement)
    rec.areaKey = STAGE_BOARD_AREA_KEY
    rec.slotIndex = 0
    local Gameboard = require("core.npc_gameboard")
    local derivedYaw = 0
    if type(Gameboard.placementBoardRelYawDeg) == "function" then
        derivedYaw = Gameboard.placementBoardRelYawDeg(placement.u, placement.v)
    end
    rec.stagePlacement = {
        u = tonumber(placement.u),
        v = tonumber(placement.v),
        yaw = derivedYaw,
        groundLevel = tonumber(placement.groundLevel),
    }
    rec.npcLightMode = desiredMode
    setInstanceRecord(npcName, rec)
    applyNpcPairPhysicalPresentation(fig, lit, STAGE_BOARD_AREA_KEY, npcName)
    applyStageNpcSpotlightNow(npcName, fig, lit, 0)
    deferNpcSpotlightAlignedToFigurine(npcName, fig, lit, 0)
    if not skipSeatSync then
        requestSeatLayoutSync()
    end
    return true, nil
end

--- Single-NPC stage lerp entry (Apply-only eligibility); batch path uses `NPCStageLerp.runQueued`.
--- @param npcName string
--- @param placement table
--- @param opts table|nil `{ reason?, animateStageMoves? }`
--- @return boolean, string|nil
function NPCS.moveNpcToStagePlacementLerp(npcName, placement, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local rec = getInstances()[npcName]
    local NPCStageLerp = require("core.npc_stage_lerp")
    local candidate = NPCStageLerp.evaluateCandidate(npcName, rec, placement, opts)
    if candidate == nil then
        return NPCS.moveNpcToStagePlacement(npcName, placement, opts)
    end
    NPCStageLerp.runQueued({ candidate })
    return true, nil
end

--- @param groupId string
--- @param areaKey string
--- @return boolean, string|nil
function NPCS.spawnGroup(groupId, areaKey)
    local area = NPCS.areas[areaKey]
    if area == nil then
        return false, "Unknown area: " .. tostring(areaKey)
    end
    local rows = NPCS.collectGroupMembers(groupId)
    if #rows == 0 then
        return false, "No members in group: " .. tostring(groupId)
    end

    local membersByName = {}
    for _, row in ipairs(rows) do
        membersByName[row.name] = true
    end
    local instances = getInstances()
    for name, rec in pairs(instances) do
        if rec and rec.areaKey == areaKey then
            if not membersByName[name] then
                return false, "Area has non-group occupants; merge only supports same-group members."
            end
        end
    end

    local capacity = #area.positions
    if #rows > capacity then
        return false, "Group overflow: members exceed destination slot capacity."
    end

    local reserved = {}
    for name, rec in pairs(instances) do
        if membersByName[name] and rec and isNpcLocked(rec) and rec.areaKey == areaKey then
            reserved[rec.slotIndex] = true
        end
    end

    local function firstFreeSlot(used, total)
        for i = 1, total do
            if used[i] ~= true then
                return i
            end
        end
        return nil
    end

    local assignments = {}
    local used = U.clone(reserved)
    local movableCount = 0
    for _, row in ipairs(rows) do
        local rec = instances[row.name]
        local locked = rec and isNpcLocked(rec)
        local seated = rec and isNpcSeatedAtTable(rec)
        if not locked and not seated then
            movableCount = movableCount + 1
            local preferred = row.idx
            local slot = nil
            if U.Type(preferred) == "number" and preferred >= 1 and preferred <= capacity and used[preferred] ~= true then
                slot = preferred
            else
                slot = firstFreeSlot(used, capacity)
            end
            if slot == nil then
                return false, "Group overflow: could not assign slots in destination area."
            end
            used[slot] = true
            assignments[row.name] = slot
        end
    end
    local reservedCount = 0
    for _, isUsed in pairs(reserved) do
        if isUsed == true then
            reservedCount = reservedCount + 1
        end
    end
    if movableCount + reservedCount > capacity then
        return false, "Group overflow: destination capacity exceeded."
    end

    for _, row in ipairs(rows) do
        local rec = instances[row.name]
        local targetSlot = assignments[row.name]
        if targetSlot ~= nil then
            if rec == nil then
                return false, "NPC "
                    .. tostring(row.name)
                    .. " has no pooled instance; run global preload or spawn from the NPC panel first."
            end
            local ok, err = NPCS.moveNpcToArea(row.name, areaKey, {
                skipUiRefresh = true,
                preferredSlot = targetSlot,
            })
            if not ok then
                print("[NPCS] spawnGroup move failed for " .. tostring(row.name) .. ": " .. tostring(err))
                safeAlertGM("NPC group move: " .. tostring(err))
            end
        end
    end
    return true, nil
end

--- @param areaKey string
function NPCS.clearArea(areaKey)
    local toRemove = {}
    for name, rec in pairs(getInstances()) do
        if rec and rec.areaKey == areaKey then
            table.insert(toRemove, name)
        end
    end
    for _, name in ipairs(toRemove) do
        NPCS.retreatNpcInstanceToPreloadPool(name, { skipUiRefresh = true, skipSeatSync = true })
    end
end

--- Move paired NPC objects back under the table (default). Use `hardDestroy` to delete objects and state.
--- @param npcName string
--- @param opts table|nil optional: `skipUiRefresh`, `skipSeatSync`, `hardDestroy`
function NPCS.retreatNpcInstanceToPreloadPool(npcName, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local rec = getInstances()[npcName]
    if U.Type(rec) == "table" and U.Type(rec.seatedSeatKey) == "string" and isValidNpcSeatKey(rec.seatedSeatKey) then
        local sk = rec.seatedSeatKey
        local seatFig = getObjectFromGUID(rec.figurineGuid or "")
        local seatLit = getObjectFromGUID(rec.lightGuid or "")
        if seatFig ~= nil then
            clearNpcFigurineSeatIdentity(seatFig, seatLit)
        end
        rec.seatedSeatKey = nil
        setInstanceRecord(npcName, rec)
        local occ = U.clone(getOccupiedNpcSeatMap())
        if occ[sk] == npcName then
            occ[sk] = false
        end
        setOccupiedNpcSeatMap(occ)
    end
    local slot = stablePreloadSlotIndex(npcName)
    if slot == nil then
        return false, "No stable preload slot."
    end
    return NPCS.moveNpcToArea(npcName, PRELOAD_AREA_KEY, {
        preferredSlot = slot,
        forceNpcLightMode = "OFF",
        skipUiRefresh = opts.skipUiRefresh == true,
        skipSeatSync = opts.skipSeatSync == true,
        forceSessionLayoutStash = true,
    })
end

--- @param npcName string
--- @param opts table|nil optional: skipUiRefresh — when true, do not rebuild NPC panel (caller refreshes once).
function NPCS.removeNpc(npcName, opts)
    opts = U.Type(opts) == "table" and opts or {}
    local skipSeatSync = opts.skipSeatSync == true
    local rec = getInstances()[npcName]
    if rec == nil then
        return
    end
    if opts.hardDestroy ~= true then
        local okPark, errPark = NPCS.retreatNpcInstanceToPreloadPool(npcName, opts)
        if okPark then
            return
        end
        print("[NPCS] removeNpc park failed for " .. tostring(npcName) .. ": " .. tostring(errPark))
        return
    end
    local fig = rec.figurineGuid and getObjectFromGUID(rec.figurineGuid)
    local lit = rec.lightGuid and getObjectFromGUID(rec.lightGuid)
    if fig ~= nil and fig.destruct then
        fig.destruct()
    end
    if lit ~= nil and lit.destruct then
        lit.destruct()
    end
    unregisterDynamicLightModes(rec.lightGuid)
    local lights = U.clone(S.getStateVal("lights") or {})
    lights[NPCS.lightRegistryName(rec.lightGuid)] = nil
    S.setStateVal(lights, "lights")
    spotlightHeld[npcName] = nil
    setInstanceRecord(npcName, nil)
    local seatKey = findSeatByNpcKey(npcName)
    if seatKey ~= nil then
        local fig = rec.figurineGuid and getObjectFromGUID(rec.figurineGuid)
        local lit = rec.lightGuid and getObjectFromGUID(rec.lightGuid)
        if fig ~= nil then
            clearNpcFigurineSeatIdentity(fig, lit)
        end
    end
    if not skipSeatSync then
        requestSeatLayoutSync()
    end
end

function NPCS.destroyAllWorldAndState()
    local names = U.getKeys(getInstances())
    for _, name in ipairs(names) do
        NPCS.removeNpc(name, { skipUiRefresh = true, hardDestroy = true })
    end
    setAllInstances({})
    local lights = U.clone(S.getStateVal("lights") or {})
    for k, _ in pairs(lights) do
        if U.Type(k) == "string" and string.sub(k, 1, 9) == "npcLight_" then
            lights[k] = nil
        end
    end
    S.setStateVal(lights, "lights")
end

--- Preview NPC spotlight when a control token lands on a ring after palette pick-up (TOR-172).
--- Apply still reads flip via `scanControlBoardTokens`; only affects instances already on STAGE_BOARD.
--- @param npcName string character key
--- @param mode string OFF|STANDARD
function NPCS.applyControlTokenLightMode(npcName, mode)
    if mode ~= "OFF" and mode ~= "STANDARD" then
        return
    end
    if not validateNpcNameKey(npcName) then
        return
    end
    local rec = getInstances()[npcName]
    if U.Type(rec) ~= "table" or rec.areaKey ~= STAGE_BOARD_AREA_KEY then
        return
    end
    if rec.npcLightMode == mode then
        NPCS.applyCurrentLightMode(npcName, 0)
        return
    end
    rec.npcLightMode = mode
    setInstanceRecord(npcName, rec)
    NPCS.applyCurrentLightMode(npcName, 0)
end

--- @param npcName string
function NPCS.toggleOffStandard(npcName)
    local rec = getInstances()[npcName]
    if rec == nil then
        return
    end
    if rec.npcLightMode == "OFF" then
        rec.npcLightMode = "STANDARD"
    else
        rec.npcLightMode = "OFF"
    end
    setInstanceRecord(npcName, rec)
    -- Instant transition avoids overlapping coroutine sequences stomping enable/intensity.
    NPCS.applyCurrentLightMode(npcName, 0)
end

--- @param npcName string
function NPCS.spotlightPress(npcName)
    spotlightHeld[npcName] = true
    NPCS.applyCurrentLightMode(npcName, 0)
end

--- @param npcName string
function NPCS.spotlightRelease(npcName)
    spotlightHeld[npcName] = nil
    NPCS.applyCurrentLightMode(npcName, 0)
end

--- @return string[]
function NPCS.collectGroupIds()
    local seen = {}
    for _, def in pairs(NPCS.characters) do
        if def.groups then
            for gid, _ in pairs(def.groups) do
                seen[gid] = true
            end
        end
    end
    local list = U.getKeys(seen)
    table.sort(list)
    return list
end

--- @param rec table|nil
--- @return boolean
--- Storyteller "pin in place" for script-driven moves (`moveNpcToArea`, etc.). Independent of TTS `setLock` (always on).
isNpcLocked = function(rec)
    if U.Type(rec) ~= "table" then
        return false
    end
    return rec.locked == true or tostring(rec.locked) == "true"
end

--- @param groupId string
--- @return table[]
function NPCS.collectGroupMembers(groupId)
    local rows = {}
    for name, def in pairs(NPCS.characters or {}) do
        local idx = def and def.groups and def.groups[groupId]
        if U.Type(idx) == "number" then
            table.insert(rows, { name = name, idx = idx })
        end
    end
    table.sort(rows, function(a, b)
        if a.idx == b.idx then
            return tostring(a.name) < tostring(b.name)
        end
        return a.idx < b.idx
    end)
    return rows
end

--- Narrative presence for an NPC table seat (`seatSlots.isPresent` wins over `seatPresent`).
--- @param seatKey string
--- @return boolean
function NPCS.resolveSeatNarrativePresence(seatKey)
    if not isValidNpcSeatKey(seatKey) then
        return true
    end
    return resolveSeatPresenceForSeat(seatKey)
end

--- Writes `seatSlots.isPresent` and mirrored `seatPresent` for one NPC seat.
--- @param seatKey string
--- @param present boolean
--- @return boolean
function NPCS.setNpcSeatNarrativePresence(seatKey, present)
    if not isValidNpcSeatKey(seatKey) then
        return false
    end
    local ss = S.getStateVal("sessionScene", "seatSlots")
    if U.Type(ss) ~= "table" then
        ss = {}
    end
    local row = ss[seatKey]
    if U.Type(row) ~= "table" then
        row = {}
    else
        row = U.clone(row, true)
    end
    row.isPresent = present == true
    ss = U.clone(ss, true)
    ss[seatKey] = row
    S.setStateVal(ss, "sessionScene", "seatSlots")

    local sp = S.getStateVal("sessionScene", "seatPresent")
    if U.Type(sp) ~= "table" then
        sp = {}
    end
    sp = U.clone(sp, true)
    sp[seatKey] = present == true
    S.setStateVal(sp, "sessionScene", "seatPresent")
    return true
end

--- @param npcName string
--- @param seatKey string
--- @return boolean, string|nil
function NPCS.assignNpcToSeat(npcName, seatKey, opts)
    local ok, err = assignNpcToSeat(npcName, seatKey, opts)
    if not ok then
        return false, err
    end
    return true, nil
end

--- @param npcName string
--- @return boolean, string|nil
function NPCS.unseatNpc(npcName)
    local seatKey = findSeatByNpcKey(npcName)
    if seatKey == nil then
        return false, "NPC is not seated."
    end
    local ok, err = clearNpcSeat(seatKey)
    if not ok then
        return false, err
    end
    return true, nil
end

--- @param payload table
local function emitNpcPreloadMetrics(payload)
    if type(U.emitForAgent) ~= "function" then
        return
    end
    U.emitForAgent("npc_preload", payload)
end

--- Sanitize `npcs.instances`, register spotlights, and repair seated NPC rows from saved state (no preload spawns).
--- Call after `S.InitializeGameState`, before `L.InitLights`. Orphan `gameState.lights` keys are pruned by `L.cleanupLightsState`.
--- IMPORTANT: Never drop instance rows when `getObjectFromGUID` is nil on the first onLoad frame — objects can
--- appear slightly later; dropping them removed all NPC state and made Storyteller buttons no-ops.
function NPCS.registerRestoredInstancesFromState()
    local inst = getInstances()
    local cleaned = {}
    for name, rec in pairs(inst) do
        if U.Type(rec) == "table" and rec.figurineGuid and rec.lightGuid then
            if rec.npcLightMode ~= "OFF" and rec.npcLightMode ~= "STANDARD" then
                rec.npcLightMode = "STANDARD"
            end
            if rec.locked ~= true then
                rec.locked = false
            end
            cleaned[name] = rec
            local fig = getObjectFromGUID(rec.figurineGuid)
            local lit = getObjectFromGUID(rec.lightGuid)
            if fig ~= nil and lit ~= nil then
                ensureNpcFigurinePhysicsLocked(fig)
                ensureSpotlightTag(lit)
                L.registerNpcSpotlightModes(name, rec.lightGuid)
            end
        end
    end
    setAllInstances(cleaned)
    local occupied = getOccupiedNpcSeatMap()
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local occupant = occupied[seatKey]
        if U.Type(occupant) == "string" and occupant ~= "" then
            ---@cast occupant string
            local seatRec = getInstances()[occupant]
            if U.Type(seatRec) == "table" then
                seatRec.seatedSeatKey = seatKey
                setInstanceRecord(occupant, seatRec)
                local fig = getObjectFromGUID(seatRec.figurineGuid or "")
                local lit = getObjectFromGUID(seatRec.lightGuid or "")
                if fig ~= nil then
                    local pOk, pErr = prepareNpcFigurineForSeat(fig, lit, occupant, seatKey)
                    if not pOk then
                        print("[NPCS] restore seat placement failed for "
                            .. tostring(occupant)
                            .. " / "
                            .. tostring(seatKey)
                            .. ": "
                            .. tostring(pErr))
                    end
                end
            end
        end
    end
    requestSeatLayoutSync()
end

--- Scan in-world `npc_light` objects; warn when more than one pooled spotlight exists per roster key.
--- @param opts table|nil `phase`, `alert`, `destroyDuplicates` (remove extras; keep instance `lightGuid` else first live unclaimed)
--- @return table `{ ok, duplicateKeys, extraCount, totalTagged, destroyedCount?, repairedKeys? }`
function NPCS.auditDuplicatePooledSpotlights(opts)
    opts = U.Type(opts) == "table" and opts or {}
    local phase = U.Type(opts.phase) == "string" and opts.phase or "audit"
    local destroyDuplicates = opts.destroyDuplicates == true
    local objs = getObjectsWithTag(TAG_LIT) or {}
    local byKey = {}
    local totalTagged = 0

    for i = 1, #objs do
        local obj = objs[i]
        if obj ~= nil then
            totalTagged = totalTagged + 1
            local nick = pooledSpotlightDisplayName(obj)
            if U.Type(nick) == "string" and string.sub(nick, 1, #NPC_LIGHT_NICKNAME_PREFIX) == NPC_LIGHT_NICKNAME_PREFIX then
                local key = string.sub(nick, #NPC_LIGHT_NICKNAME_PREFIX + 1)
                if validateNpcNameKey(key) and NPCS.characters[key] ~= nil then
                    local bucket = byKey[key]
                    if bucket == nil then
                        bucket = {}
                        byKey[key] = bucket
                    end
                    local lg = obj.getGUID and obj.getGUID() or ""
                    bucket[#bucket + 1] = lg
                end
            end
        end
    end

    local function collectDuplicateKeys()
        local keys = {}
        local extras = 0
        for key, guids in pairs(byKey) do
            if #guids > 1 then
                keys[#keys + 1] = key
                extras = extras + (#guids - 1)
            end
        end
        table.sort(keys)
        return keys, extras
    end

    local duplicateKeys, extraCount = collectDuplicateKeys()
    local destroyedCount = 0
    local repairedKeys = {}

    if destroyDuplicates and #duplicateKeys > 0 then
        for _, key in ipairs(duplicateKeys) do
            local guids = byKey[key]
            local keeper = chooseKeeperPooledSpotlightGuid(key, guids)
            if U.Type(keeper) == "string" and keeper ~= "" then
                local recBefore = getInstances()[key]
                local priorGuid = U.Type(recBefore) == "table" and recBefore.lightGuid or nil
                syncInstanceLightGuidAfterDedupe(key, keeper)
                if priorGuid ~= keeper then
                    repairedKeys[#repairedKeys + 1] = key
                end
                for i = 1, #guids do
                    local g = guids[i]
                    if g ~= keeper and destroyPooledSpotlightByGuid(g) then
                        destroyedCount = destroyedCount + 1
                    end
                end
                byKey[key] = { keeper }
            end
        end
        duplicateKeys, extraCount = collectDuplicateKeys()
    end

    if #duplicateKeys == 0 then
        if destroyedCount > 0 then
            print(string.format(
                "[NPCS] %s: pooled spotlight dedupe removed %d extra npc_light (%d instance lightGuid repaired)",
                phase,
                destroyedCount,
                #repairedKeys
            ))
        else
            print(string.format("[NPCS] %s: pooled spotlight audit OK (%d npc_light)", phase, totalTagged))
        end
        return {
            ok = true,
            duplicateKeys = {},
            extraCount = 0,
            totalTagged = totalTagged,
            destroyedCount = destroyedCount,
            repairedKeys = repairedKeys,
        }
    end

    local lines = {}
    for _, key in ipairs(duplicateKeys) do
        local guids = byKey[key]
        lines[#lines + 1] = string.format("  %s: %d (%s)", key, #guids, table.concat(guids, ", "))
    end
    local suffix = destroyDuplicates
        and " (destroyDuplicates ran but duplicates remain — manual review)"
        or ". Orphans persist until removed; see console GUID list, destroyDuplicates opt, or destroyAllNpcWorldObjects."
    print(string.format(
        "[NPCS] ERROR %s: duplicate pooled npc_light — %d character key(s), %d extra object(s)%s\n%s",
        phase,
        #duplicateKeys,
        extraCount,
        suffix,
        table.concat(lines, "\n")
    ))
    if opts.alert == true then
        safeAlertGM("Duplicate NPC pooled lights (" .. tostring(#duplicateKeys) .. " keys). See TTS console.")
    end
    return {
        ok = false,
        duplicateKeys = duplicateKeys,
        extraCount = extraCount,
        totalTagged = totalTagged,
        destroyedCount = destroyedCount,
        repairedKeys = repairedKeys,
    }
end

--- Register restored instances and audit the workshop preload pool (save/load bootstrap entry point).
function NPCS.restoreAfterStateLoad()
    NPCS.registerRestoredInstancesFromState()
    NPCS.auditDuplicatePooledSpotlights({ phase = "load-after-register" })
    NPCS.auditPreloadPoolFigurines({ deferUiRefresh = true, auditAfterPreload = true, hardError = true })
end

--- Verify every `NPCS.characters` key has an in-world `npc_figurine`; adopt instance rows when needed.
--- @param opts table|nil `deferUiRefresh`, `auditAfterPreload`, `hardError` (default true on load bootstrap)
--- @return boolean ok
--- @return string|nil err
function NPCS.auditPreloadPoolFigurines(opts)
    ensurePreloadLayoutCapacity()
    opts = U.Type(opts) == "table" and opts or {}
    local names = U.getKeys(NPCS.characters or {})
    table.sort(names)

    local missingFigurines = {}
    for _, name in ipairs(names) do
        if validateNpcNameKey(name) and findExistingPooledFigurineForNpcName(name) == nil then
            missingFigurines[#missingFigurines + 1] = name
        end
    end

    if #missingFigurines > 0 then
        local msg = "Missing workshop npc_figurine for: " .. table.concat(missingFigurines, ", ")
        emitNpcPreloadMetrics({
            phase = "audit_failed",
            characterCount = #names,
            missingCount = #missingFigurines,
        })
        if opts.hardError ~= false then
            error("[NPCS] " .. msg, 2)
        end
        return false, msg
    end

    local adoptFailures = {}
    for _, name in ipairs(names) do
        if validateNpcNameKey(name) and getInstances()[name] == nil then
            local ok, err = NPCS.ensureNpcInPreloadZone(name, { deferUiRefresh = true, skipSeatSync = true })
            if not ok then
                adoptFailures[#adoptFailures + 1] = tostring(name) .. ": " .. tostring(err)
            end
        end
    end

    if #adoptFailures > 0 then
        local msg = "Preload pool adopt failed: " .. table.concat(adoptFailures, "; ")
        if opts.hardError ~= false then
            error("[NPCS] " .. msg, 2)
        end
        return false, msg
    end

    emitNpcPreloadMetrics({
        phase = "audit_ok",
        characterCount = #names,
        missingCount = 0,
    })
    if opts.deferUiRefresh == true then
        requestSeatLayoutSync()
    end
    if opts.auditAfterPreload == true then
        NPCS.auditDuplicatePooledSpotlights({ phase = "load-after-preload", alert = true })
    end
    return true, nil
end

--- @deprecated Use `NPCS.auditPreloadPoolFigurines` — runtime no longer spawns figurines.
function NPCS.ensureAllNpcsPreloaded(opts)
    return NPCS.auditPreloadPoolFigurines(opts)
end

--- Recursive stats text for Storyteller (console or UI).
--- @param npcName string
--- @param maxDepth number|nil
--- @return string
function NPCS.displayStats(npcName, maxDepth)
    maxDepth = maxDepth or 10
    local def = NPCS.characters[npcName]
    if def == nil or def.stats == nil then
        return "No stats for " .. tostring(npcName)
    end
    local lines = {}

    --- @param v any
    --- @param indent number
    --- @param depth number
    local function walk(v, indent, depth)
        if depth > maxDepth then
            table.insert(lines, string.rep("  ", indent) .. "...")
            return
        end
        local t = U.Type(v)
        if t == "table" then
            local isArray = true
            local maxn = 0
            for k, _ in pairs(v) do
                if U.Type(k) ~= "number" then
                    isArray = false
                    break
                end
                if k > maxn then
                    maxn = k
                end
            end
            if isArray and maxn > 0 then
                for i = 1, maxn do
                    if v[i] ~= nil then
                        walk(v[i], indent, depth + 1)
                    end
                end
            else
                for k, val in pairs(v) do
                    table.insert(lines, string.rep("  ", indent) .. tostring(k) .. ":")
                    walk(val, indent + 1, depth + 1)
                end
            end
        elseif t == "string" or t == "number" or t == "boolean" then
            table.insert(lines, string.rep("  ", indent) .. tostring(v))
        else
            table.insert(lines, string.rep("  ", indent) .. "(" .. t .. ")")
        end
    end

    table.insert(lines, (def.fullName or npcName) .. " — stats")
    walk(def.stats, 0, 0)
    return table.concat(lines, "\n")
end

return NPCS