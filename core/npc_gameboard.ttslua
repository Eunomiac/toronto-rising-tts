--[[
    Storyteller NPC gameboard: CONTROL_BOARD editor, STAGE_BOARD placement math, Apply/Clear.

    Authority: gameState.sessionScene.npcWorld.placements — never figurines directly on Apply.
    Reconcile: NPCS.reconcileAllFromState then mirror via reconcileControlBoardFromState.
]]

local Gameboard = {}

local U = require("lib.util")
local C = require("lib.constants")
local G = require("lib.guids")
local S = require("core.state")
local DATA = require("lib.npc_gameboard_data")
local Palette = require("lib.npc_control_board_palette")

local TAG_TOKEN = DATA.TAG_NPC_CONTROL_TOKEN
local TAG_PC = DATA.TAG_GAMEBOARD_PC_SEAT
local TAG_NPC_SEAT = DATA.TAG_GAMEBOARD_NPC_SEAT
local TAG_TABLE = DATA.TAG_GAMEBOARD_TABLE
local TAG_COMPONENT = DATA.TAG_GAMEBOARD_TABLE_COMPONENT

local clearArmExpireByColor = {}
local polarSnapInstallFingerprint = nil
--- @type table|nil Last config installed by installPolarSnaps (for remap baselines).
local installedPolarSnapConfig = nil
local lastControlBoardMirrorFingerprint = nil
--- @type table<string, { halfX: number, halfZ: number }>
local boardUvHalfExtentsCache = {}
--- @type table<string, boolean> token guid -> true when drop may trigger anchor-family spread.
local anchorDropEligibleByTokenGuid = {}
--- Forward declaration (Lua local-function order): defined after helper dependencies.
local rebuildAnchorDropEligibilityCache
--- World XZ tolerance when matching tokens to installed control-board snap points.
local CONTROL_BOARD_SNAP_MATCH_FUZZINESS = 0.45
--- Prevents recursive anchor-family spread when programmatic moves fire onObjectDrop.
local anchorFamilySpreadDepth = 0

--- @param obj Object|nil
--- @return boolean
local function isGameObject(obj)
    return U.isGameObject(obj)
end

--- @param board Object
--- @return number
local function snapMatchFuzzinessForBoard(board)
    if not isGameObject(board) or board.getBounds == nil then
        return CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    end
    local b = board.getBounds()
    if b == nil or b.size == nil then
        return CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    end
    local sx = b.size.x or b.size[1] or 1
    local sz = b.size.z or b.size[3] or 1
    local scaleHint = math.min(math.abs(sx), math.abs(sz))
    return math.max(CONTROL_BOARD_SNAP_MATCH_FUZZINESS, scaleHint * 0.035)
end

--- @param n number
--- @param lo number
--- @param hi number
--- @return number
local function clamp(n, lo, hi)
    if n < lo then
        return lo
    end
    if n > hi then
        return hi
    end
    return n
end

--- @param guid string|nil
--- @return Object|nil
local function objectFromGuid(guid)
    if type(guid) ~= "string" or guid == "" then
        return nil
    end
    return getObjectFromGUID(guid)
end

--- @return Object|nil
local function getStageBoard()
    return objectFromGuid(G.GUIDS.STAGE_BOARD)
end

--- @return Object|nil
local function getControlBoard()
    return objectFromGuid(G.GUIDS.CONTROL_BOARD)
end

--- @return Object|nil
local function getControlBoardPalette()
    return objectFromGuid(G.GUIDS.CONTROL_BOARD_PALETTE)
end

--- @return table
local function defaultStageWorld()
    local d = DATA.DEFAULT_STAGE_WORLD
    return {
        centerX = d.centerX,
        centerZ = d.centerZ,
        halfWidthX = d.halfWidthX,
        halfDepthZ = d.halfDepthZ,
        groundY = d.groundY,
    }
end

--- Derive world XZ extents from STAGE_BOARD bounds when present.
--- @return table
local function resolveStageWorldExtents()
    local board = getStageBoard()
    if not isGameObject(board) or board.getBounds == nil then
        return defaultStageWorld()
    end
    local b = board.getBounds()
    if b == nil or b.center == nil or b.size == nil then
        return defaultStageWorld()
    end
    local cx = b.center.x or b.center[1] or 0
    local cz = b.center.z or b.center[3] or 0
    local sx = b.size.x or b.size[1] or 1
    local sz = b.size.z or b.size[3] or 1
    local cy = b.center.y or b.center[2] or DATA.DEFAULT_STAGE_WORLD.groundY
    return {
        centerX = cx,
        centerZ = cz,
        halfWidthX = math.max(sx * 0.5, 50),
        halfDepthZ = math.max(sz * 0.5, 50),
        groundY = cy,
    }
end

--- @param a Vector
--- @param b Vector
--- @return number
local function vectorDot(a, b)
    return a.x * b.x + a.y * b.y + a.z * b.z
end

--- Custom_Tile boards use `positionToWorld` / `positionToLocal` (not `localToWorld`).
--- @param board Object
--- @param localPos Vector|table
--- @return Vector
local function boardLocalToWorld(board, localPos)
    local lp = Vector(localPos)
    if type(board.positionToWorld) == "function" then
        return board.positionToWorld(lp)
    end
    local origin = board.getPosition()
    local right = board.getTransformRight()
    local up = board.getTransformUp()
    local fwd = board.getTransformForward()
    return origin + right * lp.x + up * lp.y + fwd * lp.z
end

--- Custom_Tile `positionToLocal` / `positionToWorld` use object-local units (typically ±0.5 on X/Z for a unit tile).
--- `getBounds().size` is world-space and must not be used as the UV divisor/multiplier.
--- Derive local half-extents by projecting world bound corners through `positionToLocal`.
--- @param board Object
--- @return number halfX, number halfZ
local function boardLocalSurfaceHalfExtents(board)
    if not isGameObject(board) then
        return 0.5, 0.5
    end
    local guid = board.getGUID()
    if type(guid) == "string" and guid ~= "" then
        local cached = boardUvHalfExtentsCache[guid]
        if type(cached) == "table" and type(cached.halfX) == "number" and type(cached.halfZ) == "number" then
            return cached.halfX, cached.halfZ
        end
    end
    local halfX = 0.5
    local halfZ = 0.5
    if board.getBounds ~= nil and board.positionToLocal ~= nil then
        local b = board.getBounds()
        if b ~= nil and b.center ~= nil and b.size ~= nil then
            local cx = b.center.x or b.center[1] or 0
            local cy = b.center.y or b.center[2] or 0
            local cz = b.center.z or b.center[3] or 0
            local worldHalfX = (b.size.x or b.size[1] or 1) * 0.5
            local worldHalfZ = (b.size.z or b.size[3] or 1) * 0.5
            local cornerX = board.positionToLocal(Vector({ x = cx + worldHalfX, y = cy, z = cz }))
            local cornerZ = board.positionToLocal(Vector({ x = cx, y = cy, z = cz + worldHalfZ }))
            if cornerX ~= nil then
                halfX = math.abs(cornerX.x or 0)
            end
            if cornerZ ~= nil then
                halfZ = math.abs(cornerZ.z or 0)
            end
        end
    end
    if halfX < 0.01 then
        halfX = 0.5
    end
    if halfZ < 0.01 then
        halfZ = 0.5
    end
    if type(guid) == "string" and guid ~= "" then
        boardUvHalfExtentsCache[guid] = { halfX = halfX, halfZ = halfZ }
    end
    return halfX, halfZ
end

--- @param board Object
--- @param worldPos Vector|table
--- @return Vector|nil
local function boardWorldToLocal(board, worldPos)
    local wp = Vector(worldPos)
    if type(board.positionToLocal) == "function" then
        return board.positionToLocal(wp)
    end
    local origin = board.getPosition()
    local delta = wp - origin
    local right = board.getTransformRight()
    local up = board.getTransformUp()
    local fwd = board.getTransformForward()
    return Vector(vectorDot(delta, right), vectorDot(delta, up), vectorDot(delta, fwd))
end

--- @param board Object
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function uvFromWorldOnBoard(board, worldPos)
    if not isGameObject(board) or worldPos == nil then
        return nil, nil
    end
    local localPos = boardWorldToLocal(board, worldPos)
    if localPos == nil then
        return nil, nil
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local u = 0.5 + localPos.x / (2 * halfX)
    local v = 0.5 + localPos.z / (2 * halfZ)
    return clamp(u, 0, 1), clamp(v, 0, 1)
end

--- Tagged objects on CONTROL_BOARD surface. Custom_Tile exposes getObjects but throws on call —
--- never use `board.getObjects and board.getObjects()` (the `and` still invokes the method).
--- @param board Object
--- @param tag string
--- @return table
local function objectsOnControlBoard(board, tag)
    if not isGameObject(board) or type(tag) ~= "string" or tag == "" then
        return {}
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local margin = 2.5
    local maxLocalX = halfX * margin
    local maxLocalZ = halfZ * margin
    local out = {}
    local tagged = getObjectsWithTag(tag) or {}
    for _, obj in ipairs(tagged) do
        if isGameObject(obj) and obj.hasTag ~= nil and obj.hasTag(tag) == true then
            local localPos = boardWorldToLocal(board, obj.getPosition())
            if localPos ~= nil then
                local lx = math.abs(localPos.x or 0)
                local lz = math.abs(localPos.z or 0)
                if lx <= maxLocalX and lz <= maxLocalZ then
                    out[#out + 1] = obj
                end
            end
        end
    end
    return out
end

--- @param board Object
--- @param u number
--- @param v number
--- @return Vector local position on board surface (Y slightly above tile)
--- @param board Object
--- @param u number
--- @param v number
--- @param extraLocalY number|nil Additional lift in board-local Y (e.g. table mesh thickness)
local function boardLocalFromUv(board, u, v, extraLocalY)
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local surfaceY = tonumber(DATA.MINIMAP_SURFACE_LOCAL_Y) or 0.18
    local lift = tonumber(extraLocalY) or 0
    return Vector((u - 0.5) * 2 * halfX, surfaceY + lift, (v - 0.5) * 2 * halfZ)
end

--- Inverse of `boardLocalFromUv` for surface XZ (ignores local Y).
--- @param board Object
--- @param localPos Vector|table
--- @return number u, number v
local function uvFromBoardLocal(board, localPos)
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local lx = localPos.x or localPos[1] or 0
    local lz = localPos.z or localPos[3] or 0
    return 0.5 + lx / (2 * halfX), 0.5 + lz / (2 * halfZ)
end

--- Extent-based fallback when STAGE_BOARD is not in the save (workshop prep).
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function uvFromWorldFallbackExtents(worldPos)
    if worldPos == nil then
        return nil, nil
    end
    local ext = resolveStageWorldExtents()
    local x = worldPos.x or worldPos[1]
    local z = worldPos.z or worldPos[3]
    if type(x) ~= "number" or type(z) ~= "number" then
        return nil, nil
    end
    local u = 0.5 + (x - ext.centerX) / (2 * ext.halfWidthX)
    local v = 0.5 + (z - ext.centerZ) / (2 * ext.halfDepthZ)
    return clamp(u, 0, 1), clamp(v, 0, 1)
end

--- Normalized map UV (0–1) from a world position using STAGE_BOARD as the canonical minimap.
--- CONTROL_BOARD uses the same u,v via worldOnControlBoard; do not project world XZ through CONTROL_BOARD.
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function normalizedUvFromWorld(worldPos)
    if worldPos == nil then
        return nil, nil
    end
    local stage = getStageBoard()
    if isGameObject(stage) then
        return uvFromWorldOnBoard(stage, worldPos)
    end
    return uvFromWorldFallbackExtents(worldPos)
end

--- World position for figurine placement from normalized u/v on STAGE_BOARD.
--- X/Z come from STAGE_BOARD `positionToWorld`; `groundLevel` when set is **absolute world Y** (not board-local).
--- @param u number
--- @param v number
--- @param options table|nil `{ groundLevel?: number }` absolute world Y from snap ring (optional)
--- @return Vector
function Gameboard.worldFromUv(u, v, options)
    options = type(options) == "table" and options or {}
    local worldY = tonumber(options.groundLevel)
    local stage = getStageBoard()
    if isGameObject(stage) then
        local lp = boardLocalFromUv(stage, u, v)
        local wp = boardLocalToWorld(stage, lp)
        if worldY ~= nil then
            return Vector(wp.x, worldY, wp.z)
        end
        return wp
    end
    print("[Gameboard] worldFromUv: STAGE_BOARD missing (GUID "
        .. tostring(G.GUIDS.STAGE_BOARD)
        .. ") — using DEFAULT_STAGE_WORLD fallback")
    local ext = resolveStageWorldExtents()
    local x = ext.centerX + (u - 0.5) * 2 * ext.halfWidthX
    local z = ext.centerZ + (v - 0.5) * 2 * ext.halfDepthZ
    local y = worldY ~= nil and worldY or ext.groundY
    return Vector(x, y, z)
end

--- World Y rotation for a figurine on STAGE_BOARD at the same u,v as a control-board token.
--- `placementYaw` is board-relative (token Y minus CONTROL_BOARD Y at scan/Apply).
--- Adds STAGE_BOARD yaw plus `D.STAGE_FIGURINE_YAW_OFFSET_DEG` for `Figurine_Custom` cutout orientation.
--- @param placementYaw number|nil
--- @return number
function Gameboard.stageFigurineWorldYawDeg(placementYaw)
    local stage = getStageBoard()
    local stageYaw = isGameObject(stage) and (stage.getRotation().y or 0) or 0
    local rel = tonumber(placementYaw) or 0
    local offset = tonumber(DATA.STAGE_FIGURINE_YAW_OFFSET_DEG) or 0
    return (stageYaw + rel + offset) % 360
end

--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
function Gameboard.uvFromWorldFallback(worldPos)
    return uvFromWorldFallbackExtents(worldPos)
end

--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
function Gameboard.uvFromWorld(worldPos)
    return normalizedUvFromWorld(worldPos)
end

--- @param board Object
--- @param u number
--- @param v number
--- @param options table|nil { extraLocalY?: number }
--- @return Vector world position on CONTROL_BOARD surface (same u,v as STAGE_BOARD map)
function Gameboard.worldOnControlBoard(board, u, v, options)
    if not isGameObject(board) then
        return Vector(0, 0, 0)
    end
    local extraLocalY = options and options.extraLocalY or nil
    return boardLocalToWorld(board, boardLocalFromUv(board, u, v, extraLocalY))
end

--- @param obj Object
--- @return string|nil
local function readMarkerKey(obj, prefix)
    if not isGameObject(obj) then
        return nil
    end
    local notes = ""
    if obj.getGMNotes ~= nil then
        notes = tostring(obj.getGMNotes() or "")
    end
    if notes == "" and obj.getDescription ~= nil then
        notes = tostring(obj.getDescription() or "")
    end
    local key = string.match(notes, "^" .. prefix .. "([^,\r\n]+)")
    if type(key) == "string" then
        key = string.match(key, "^%s*(.-)%s*$")
    end
    if type(key) == "string" and key ~= "" then
        return key
    end
    return nil
end

--- @param compKey string|nil Raw value after `gameboardComponent:` prefix
--- @return string|nil parentTable, string|nil componentName
local function parseComponentMarkerKey(compKey)
    if type(compKey) ~= "string" or compKey == "" then
        return nil, nil
    end
    compKey = string.match(compKey, "^%s*(.-)%s*$") or compKey
    local pipeAt = compKey:find("|", 1, true)
    if pipeAt ~= nil then
        local parentTable = string.match(compKey:sub(1, pipeAt - 1), "^%s*(.-)%s*$")
        local componentName = string.match(compKey:sub(pipeAt + 1), "^%s*(.-)%s*$")
        if type(parentTable) == "string" and parentTable ~= ""
            and type(componentName) == "string" and componentName ~= "" then
            return parentTable, componentName
        end
    end
    for tk, cfg in pairs(C.Tables or {}) do
        if type(cfg) == "table" and type(cfg.components) == "table" and cfg.components[compKey] ~= nil then
            return tk, compKey
        end
    end
    return nil, compKey
end

--- @param obj Object
--- @return string|nil characterKey
local function resolveTokenCharacterKey(obj)
    if not isGameObject(obj) then
        return nil
    end
    local key = readMarkerKey(obj, DATA.TOKEN_GM_PREFIX)
    if key ~= nil then
        return key
    end
    if obj.getName ~= nil then
        local name = tostring(obj.getName() or "")
        if name ~= "" then
            return name
        end
    end
    return nil
end

--- Custom_Tile (and similar) have no `is_face_up` field — reading it throws.
--- Prefer transform up-vector sign (robust to parent rotations); fall back to X rotation.
--- @param token Object
--- @return boolean
local function tokenRotationIsFaceUp(token)
    if token ~= nil and token.getTransformUp ~= nil then
        local up = token.getTransformUp()
        if up ~= nil then
            local uy = up.y or up[2]
            if type(uy) == "number" then
                return uy >= 0
            end
        end
    end
    local rot = token.getRotation()
    if rot == nil then
        return true
    end
    local rx = rot.x or rot[1] or 0
    local norm = ((rx % 360) + 360) % 360
    return not (norm > 90 and norm < 270)
end

--- @param token Object
--- @return string OFF|STANDARD
local function tokenLightModeFromFlip(token)
    if tokenRotationIsFaceUp(token) then
        return "STANDARD"
    end
    return "OFF"
end

--- @param boardYaw number
--- @param yawDeg number
--- @param faceUp boolean
--- @return Vector
local function rotationForNpcControlToken(boardYaw, yawDeg, faceUp)
    local rx = faceUp and 0 or 180
    return Vector(rx, boardYaw + (yawDeg or 0), 0)
end

--- @param token Object
--- @param board Object
--- @return number|nil u, number|nil v, number|nil yaw
local function tokenPlacementOnBoard(token, board)
    if not isGameObject(token) or not isGameObject(board) then
        return nil, nil, nil
    end
    local u, v = uvFromWorldOnBoard(board, token.getPosition())
    local boardYaw = board.getRotation().y or 0
    local tokenYaw = token.getRotation().y or 0
    local yaw = ((tokenYaw - boardYaw) % 360 + 360) % 360
    return u, v, yaw
end

--- @param board Object
--- @return table[] rows with characterKey, u, v, yaw, npcLightMode
function Gameboard.scanControlBoardTokens(board)
    board = board or getControlBoard()
    local out = {}
    if not isGameObject(board) then
        print("[Gameboard] scan: CONTROL_BOARD missing (GUID " .. tostring(G.GUIDS.CONTROL_BOARD) .. ")")
        return out
    end
    local objs = objectsOnControlBoard(board, TAG_TOKEN)
    for _, obj in ipairs(objs) do
        if isGameObject(obj) then
            local characterKey = resolveTokenCharacterKey(obj)
            if type(characterKey) == "string" and characterKey ~= "" then
                local u, v, yaw = tokenPlacementOnBoard(obj, board)
                local palette = getControlBoardPalette()
                if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, obj) then
                    -- Inactive storage on CONTROL_BOARD_PALETTE — not a minimap placement until snapped + Apply.
                elseif type(u) == "number" and type(v) == "number" then
                    local groundLevel = Gameboard.groundLevelForSnapUv(u, v)
                    local row = {
                        characterKey = characterKey,
                        u = u,
                        v = v,
                        yaw = type(yaw) == "number" and yaw or 0,
                        npcLightMode = tokenLightModeFromFlip(obj),
                    }
                    if groundLevel ~= nil then
                        row.groundLevel = groundLevel
                    end
                    out[#out + 1] = row
                end
            end
        end
    end
    return out
end

--- @param row table|nil
--- @return table|nil normalized row for comparison
local function normalizePlacementRow(row)
    if type(row) ~= "table" then
        return nil
    end
    local u = tonumber(row.u)
    local v = tonumber(row.v)
    if u == nil or v == nil then
        return nil
    end
    local out = {
        u = u,
        v = v,
        yaw = tonumber(row.yaw) or 0,
        npcLightMode = row.npcLightMode,
    }
    local groundLevel = tonumber(row.groundLevel)
    if groundLevel ~= nil then
        out.groundLevel = groundLevel
    end
    if out.npcLightMode ~= "OFF" and out.npcLightMode ~= "STANDARD" and out.npcLightMode ~= "SPOTLIGHT" then
        out.npcLightMode = "STANDARD"
    end
    return out
end

--- @param a table|nil
--- @param b table|nil
--- @return boolean
local function placementRowsEqual(a, b)
    local na = normalizePlacementRow(a)
    local nb = normalizePlacementRow(b)
    if na == nil or nb == nil then
        return false
    end
    if math.abs(na.u - nb.u) > 0.0001 or math.abs(na.v - nb.v) > 0.0001 then
        return false
    end
    if math.abs(na.yaw - nb.yaw) > 0.5 then
        return false
    end
    if na.npcLightMode ~= nb.npcLightMode then
        return false
    end
    return (na.groundLevel or nil) == (nb.groundLevel or nil)
end

--- @param nextMap table|nil
--- @param prevMap table|nil
--- @return boolean
local function placementsMapsEqual(nextMap, prevMap)
    nextMap = type(nextMap) == "table" and nextMap or {}
    prevMap = type(prevMap) == "table" and prevMap or {}
    local keys = {}
    local seen = {}
    for key in pairs(nextMap) do
        if type(key) == "string" and key ~= "" then
            keys[#keys + 1] = key
            seen[key] = true
        end
    end
    for key in pairs(prevMap) do
        if type(key) == "string" and key ~= "" and not seen[key] then
            keys[#keys + 1] = key
            seen[key] = true
        end
    end
    table.sort(keys)
    for _, key in ipairs(keys) do
        if not placementRowsEqual(nextMap[key], prevMap[key]) then
            return false
        end
    end
    return true
end

--- Fingerprint for static marker + token mirror work on CONTROL_BOARD.
--- @param activeTable string|nil
--- @param layoutLocked boolean
--- @param placements table|nil
--- @return string
local function controlBoardMirrorFingerprint(activeTable, layoutLocked, placements)
    local lines = {}
    lines[#lines + 1] = "table:" .. tostring(activeTable or "")
    lines[#lines + 1] = "lock:" .. tostring(layoutLocked == true)
    local slots = S.getStateVal("seatLayout", "occupiedNPCSlots")
    if type(slots) == "table" then
        for _, seatKey in ipairs(C.NPCSeats or {}) do
            lines[#lines + 1] = "occ:" .. seatKey .. "=" .. tostring(slots[seatKey] or "")
        end
    end
    placements = type(placements) == "table" and placements or {}
    local keys = {}
    for key in pairs(placements) do
        if type(key) == "string" and key ~= "" then
            keys[#keys + 1] = key
        end
    end
    table.sort(keys)
    for _, characterKey in ipairs(keys) do
        local row = normalizePlacementRow(placements[characterKey])
        if row ~= nil then
            lines[#lines + 1] = string.format(
                "p:%s:%.4f:%.4f:%.1f:%s:%s",
                characterKey,
                row.u,
                row.v,
                row.yaw,
                row.npcLightMode or "",
                tostring(row.groundLevel or "")
            )
        end
    end
    return table.concat(lines, "\n")
end

--- Build placements map from scan rows.
--- @param rows table[]
--- @return table
local function placementsMapFromRows(rows)
    local placements = {}
    for _, row in ipairs(rows) do
        if type(row.characterKey) == "string" then
            placements[row.characterKey] = {
                u = row.u,
                v = row.v,
                yaw = row.yaw,
                npcLightMode = row.npcLightMode,
                groundLevel = row.groundLevel,
            }
        end
    end
    return placements
end

--- @param placements table|nil
--- @return number
local function placementsCount(placements)
    if type(placements) ~= "table" then
        return 0
    end
    local n = 0
    for _, row in pairs(placements) do
        if type(row) == "table" then
            n = n + 1
        end
    end
    return n
end

--- Shared fast Sync.npcs path used by control-board interactions.
--- @param reason string
local function syncNpcsFromControlBoard(reason)
    local Sync = require("core.sync")
    Sync.npcs({
        reason = reason,
        force = true,
        onlySteps = { 1, 5 },
        deferUiRefresh = true,
        skipAreaPopulate = true,
        skipPreloadPopulate = true,
    })
end

--- Apply CONTROL_BOARD tokens → state → Sync.npcs.
--- @return boolean ok, string|nil message
function Gameboard.applyFromControlBoard()
    local board = getControlBoard()
    if not isGameObject(board) then
        return false, "CONTROL_BOARD not found — set G.GUIDS.CONTROL_BOARD in lib/guids.ttslua"
    end
    local rows = Gameboard.scanControlBoardTokens(board)
    local placements = placementsMapFromRows(rows)
    local existing = S.getStateVal("sessionScene", "npcWorld", "placements")
    if placementsMapsEqual(placements, existing) then
        print("[Gameboard] Apply: placements unchanged (" .. tostring(#rows) .. " token(s)) — skipped figurine reconcile")
        return true, nil
    end
    S.setStateVal(placements, "sessionScene", "npcWorld", "placements")
    syncNpcsFromControlBoard("gameboard_apply")
    print("[Gameboard] Apply: " .. tostring(#rows) .. " token(s) → placements")
    return true, nil
end

--- Remove tokens from control board and clear placements in state.
--- @return boolean ok, string|nil message
function Gameboard.clearControlBoard()
    local hadPlacements = placementsCount(S.getStateVal("sessionScene", "npcWorld", "placements")) > 0
    S.setStateVal({}, "sessionScene", "npcWorld", "placements")
    local palette = getControlBoardPalette()
    local moved = 0
    if isGameObject(palette) then
        moved = Palette.syncTokensToPalette(palette)
        print("[Gameboard] Clear: placements emptied; " .. tostring(moved) .. " token(s) parked on palette")
    else
        print("[Gameboard] Clear: placements emptied (CONTROL_BOARD_PALETTE missing — tokens not parked)")
    end
    if not hadPlacements and moved == 0 then
        print("[Gameboard] Clear: no state/token changes — skipped figurine reconcile")
        Gameboard.reconcileControlBoardFromState({ force = true })
        return true, nil
    end
    syncNpcsFromControlBoard("gameboard_clear")
    return true, nil
end

--- Park all NPC control tokens on CONTROL_BOARD_PALETTE (group layout from npcs_data).
--- @return number moved
function Gameboard.syncTokensToPalette()
    local palette = getControlBoardPalette()
    if not isGameObject(palette) then
        print("[Gameboard] syncTokensToPalette: CONTROL_BOARD_PALETTE missing (GUID " .. tostring(G.GUIDS.CONTROL_BOARD_PALETTE) .. ")")
        return 0
    end
    return Palette.syncTokensToPalette(palette)
end

--- Install 20×40 snaps on CONTROL_BOARD_PALETTE.
--- @param board Object|nil
--- @param options table|nil { force?: boolean }
--- @return boolean
function Gameboard.installPaletteSnaps(board, options)
    board = board or getControlBoardPalette()
    return Palette.installSnaps(board, options)
end

--- @param playerColor string|nil
--- @return boolean consumed second click
function Gameboard.tryConfirmClear(playerColor)
    local color = type(playerColor) == "string" and playerColor or "Black"
    local now = os.time()
    if clearArmExpireByColor[color] == nil or now > clearArmExpireByColor[color] then
        clearArmExpireByColor[color] = now + 5
        if broadcastToColor ~= nil then
            broadcastToColor("Click Clear again within 5s to confirm.", color, { 1, 0.35, 0.35 })
        end
        return false
    end
    clearArmExpireByColor[color] = nil
    return true
end

--- PC seat colors only — Storyteller (Black) and spectators (White/Grey) still see control-board pieces.
--- @return string[]
local function playerColorsHiddenFromControlBoard()
    return C.PlayerColors or {}
end

--- Tokens and markers on CONTROL_BOARD are never visible to seated players.
--- @param obj Object|nil
function Gameboard.setHiddenFromPlayerColors(obj)
    if not isGameObject(obj) or obj.setInvisibleTo == nil then
        return
    end
    obj.setInvisibleTo(playerColorsHiddenFromControlBoard())
end

--- @param obj Object
--- @param activeForLayout boolean When false, marker is not positioned for the active table (still PC-hidden).
local function setMarkerVisible(obj, activeForLayout)
    if not isGameObject(obj) then
        return
    end
    Gameboard.setHiddenFromPlayerColors(obj)
end

local CONTROL_BOARD_COMPONENT_TAGS = {
    TAG_TABLE,
    TAG_PC,
    TAG_NPC_SEAT,
    TAG_COMPONENT,
    TAG_TOKEN,
}

--- Re-apply PC-only invisibility on every control-board marker and token.
local function applyControlBoardComponentPlayerInvisibility()
    for _, tag in ipairs(CONTROL_BOARD_COMPONENT_TAGS) do
        local objs = getObjectsWithTag(tag) or {}
        for _, obj in ipairs(objs) do
            Gameboard.setHiddenFromPlayerColors(obj)
        end
    end
end

--- @param tableKey string|nil
--- @return table|nil
local function tableConfig(tableKey)
    if type(tableKey) ~= "string" then
        return nil
    end
    return C.Tables[tableKey]
end

--- True when `seatLayout.occupiedNPCSlots[seatKey]` holds a character key (not false).
--- @param seatKey string
--- @return boolean
local function npcSeatOccupiedOnTable(seatKey)
    if type(seatKey) ~= "string" or seatKey == "" then
        return false
    end
    local slots = S.getStateVal("seatLayout", "occupiedNPCSlots")
    if type(slots) ~= "table" then
        return false
    end
    local assigned = slots[seatKey]
    return type(assigned) == "string" and assigned ~= ""
end

--- Same activation rule as `lib.rotational-seat-layout` `applyTableComponentsState`.
--- @param parentTable string
--- @param componentName string
--- @return boolean
local function tableComponentActiveForOccupiedSlots(parentTable, componentName)
    local cfg = tableConfig(parentTable)
    if cfg == nil or type(cfg.components) ~= "table" then
        return false
    end
    local comp = cfg.components[componentName]
    if type(comp) ~= "table" then
        return false
    end
    local usedBy = comp.usedBy
    if type(usedBy) ~= "string" or usedBy == "" then
        return true
    end
    return npcSeatOccupiedOnTable(usedBy)
end

--- World XZ around a table segment (seat arc), from C.Tables layout data.
--- Segment indices in `playerToPositionMap` are 1-based (same as rotational-seat-layout).
--- @param cfg table
--- @param segmentIndex1Based number
--- @return Vector|nil
local function worldPositionForTableSegment(cfg, segmentIndex1Based)
    if type(cfg) ~= "table" or type(segmentIndex1Based) ~= "number" or cfg.centerPoint == nil then
        return nil
    end
    local cp = Vector(cfg.centerPoint)
    local numSegments = cfg.numSegments or 10
    if numSegments < 1 then
        numSegments = 10
    end
    local angleSegmentOne = tonumber(cfg.angleSegmentOne) or 0
    local thetaDeg = angleSegmentOne + (segmentIndex1Based - 1) * (360 / numSegments)
    local angleRad = math.rad(thetaDeg)
    local radius = 12
    if cfg.referenceHandPosition ~= nil then
        radius = U.HorizontalDistance(cp, Vector(cfg.referenceHandPosition))
    elseif cfg.activePosition ~= nil then
        radius = U.HorizontalDistance(cp, Vector(cfg.activePosition))
    end
    if radius < 1 then
        radius = 12
    end
    return Vector(
        cp.x + math.sin(angleRad) * radius,
        cp.y,
        cp.z + math.cos(angleRad) * radius
    )
end

--- Playfield world XZ → shared map u,v (via STAGE_BOARD), for CONTROL_BOARD marker placement.
--- @param tableKey string
--- @return number|nil u, number|nil v
local function mapUvForTableCenter(tableKey)
    local cfg = tableConfig(tableKey)
    if cfg == nil or cfg.centerPoint == nil then
        return nil, nil
    end
    return normalizedUvFromWorld(Vector(cfg.centerPoint))
end

--- @param parentTable string
--- @param componentName string
--- @return number|nil u, number|nil v
local function mapUvForTableComponent(parentTable, componentName)
    local cfg = tableConfig(parentTable)
    if cfg == nil or type(cfg.components) ~= "table" then
        return nil, nil
    end
    local comp = cfg.components[componentName]
    if type(comp) ~= "table" then
        return nil, nil
    end
    if comp.activePosition ~= nil then
        return normalizedUvFromWorld(Vector(comp.activePosition))
    end
    return mapUvForTableCenter(parentTable)
end

--- UV for a table component marker: prefer the `usedBy` seat arc so leaves sit by their NPC slot.
--- @param parentTable string
--- @param componentName string
--- @return number|nil u, number|nil v
local function mapUvForTableComponentMarker(parentTable, componentName)
    local cfg = tableConfig(parentTable)
    if cfg == nil or type(cfg.components) ~= "table" then
        return nil, nil
    end
    local comp = cfg.components[componentName]
    if type(comp) ~= "table" then
        return nil, nil
    end
    local usedBy = comp.usedBy
    if type(usedBy) == "string" and usedBy ~= "" and type(cfg.playerToPositionMap) == "table" then
        local seg = cfg.playerToPositionMap[usedBy]
        if type(seg) == "number" then
            local worldSeat = worldPositionForTableSegment(cfg, seg)
            if worldSeat ~= nil then
                return normalizedUvFromWorld(worldSeat)
            end
        end
    end
    return mapUvForTableComponent(parentTable, componentName)
end

--- World-space XZ extents from `getBounds` (minimap marker scale ratios only — not UV math).
--- @param board Object
--- @return number sx, number sz
local function boardMapExtents(board)
    local sx = 1
    local sz = 1
    if isGameObject(board) and board.getBounds ~= nil then
        local b = board.getBounds()
        if b ~= nil and b.size ~= nil then
            sx = b.size.x or b.size[1] or sx
            sz = b.size.z or b.size[3] or sz
        end
    end
    if sx < 0.01 then
        sx = 0.01
    end
    if sz < 0.01 then
        sz = 0.01
    end
    return sx, sz
end

--- Stage vs control minimap scale divisors from board XZ bounds (e.g. ~40 when stage is 800×400 and control is 20×10).
--- Third return is a uniform divisor for marker scale on all axes (do not use board transform Y — both boards are Y scale 1).
--- @return number|nil ratioX, number|nil ratioZ, number|nil uniformRatio
function Gameboard.minimapScaleRatios()
    local stage = getStageBoard()
    local control = getControlBoard()
    if not isGameObject(stage) or not isGameObject(control) then
        return nil, nil, nil
    end
    local stageSx, stageSz = boardMapExtents(stage)
    local controlSx, controlSz = boardMapExtents(control)
    local ratioX = stageSx / controlSx
    local ratioZ = stageSz / controlSz
    return ratioX, ratioZ, (ratioX + ratioZ) * 0.5
end

--- @param source Object|nil
--- @return Vector|nil
local function objectScaleVector(source)
    if not isGameObject(source) or source.getScale == nil then
        return nil
    end
    local s = source.getScale()
    return Vector(s.x or 1, s.y or 1, s.z or 1)
end

--- Minimap marker scale:
--- - X/Z: source playfield object scale ÷ live STAGE:CONTROL board axis ratios.
--- - Y: source scale ÷ MINIMAP_SCALE_DIVISOR (fixed vertical lift control only).
--- @param marker Object
--- @param source Object|nil Playfield table, leaf, or seat chair being mimicked
local function applyMinimapMarkerScale(marker, source)
    if not isGameObject(marker) or marker.setScale == nil then
        return
    end
    local src = objectScaleVector(source)
    if src == nil then
        return
    end
    local ratioX, ratioZ, uniformRatio = Gameboard.minimapScaleRatios()
    local xDivisor = tonumber(ratioX) or tonumber(uniformRatio) or 40
    local zDivisor = tonumber(ratioZ) or tonumber(uniformRatio) or 40
    local yDivisor = tonumber(DATA.MINIMAP_SCALE_DIVISOR) or 40
    if xDivisor < 0.01 then xDivisor = 0.01 end
    if yDivisor < 0.01 then yDivisor = 0.01 end
    if zDivisor < 0.01 then zDivisor = 0.01 end
    marker.setScale({
        x = src.x / xDivisor,
        y = src.y / yDivisor,
        z = src.z / zDivisor,
    })
end

--- Minimap marker rotation = playfield source euler + CONTROL_BOARD euler (per axis).
--- @param marker Object
--- @param board Object
--- @param source Object|nil
local function applyMinimapMarkerRotation(marker, board, source)
    if not isGameObject(marker) or marker.setRotation == nil or not isGameObject(board) then
        return
    end
    local boardRot = board.getRotation and board.getRotation() or nil
    local bx = 0
    local by = 0
    local bz = 0
    if boardRot ~= nil then
        bx = boardRot.x or 0
        by = boardRot.y or 0
        bz = boardRot.z or 0
    end
    local sx = 0
    local sy = 0
    local sz = 0
    if isGameObject(source) and source.getRotation ~= nil then
        local srcRot = source.getRotation()
        sx = srcRot.x or 0
        sy = srcRot.y or 0
        sz = srcRot.z or 0
    end
    marker.setRotation(Vector(sx + bx, sy + by, sz + bz))
end

--- @param tableKey string
--- @return Object|nil
local function sourceObjectForTable(tableKey)
    local cfg = tableConfig(tableKey)
    if cfg == nil or type(cfg.guid) ~= "string" or cfg.guid == "" then
        return nil
    end
    return objectFromGuid(cfg.guid)
end

--- @param parentTable string
--- @param componentName string
--- @return Object|nil
local function sourceObjectForTableComponent(parentTable, componentName)
    local cfg = tableConfig(parentTable)
    if cfg == nil or type(cfg.components) ~= "table" then
        return nil
    end
    local comp = cfg.components[componentName]
    if type(comp) ~= "table" or type(comp.guid) ~= "string" or comp.guid == "" then
        return nil
    end
    return objectFromGuid(comp.guid)
end

--- Playfield seat chair for minimap scale (SEAT_CHAIR_* via G.GetThroneGUID), not arbitrary *Object tags.
--- @param seatKey string PC color or NPC1–NPC4
--- @return Object|nil
local function sourceObjectForSeat(seatKey)
    if type(seatKey) ~= "string" or seatKey == "" then
        return nil
    end
    local guid = G.GetThroneGUID(seatKey)
    if type(guid) == "string" and guid ~= "" then
        return objectFromGuid(guid)
    end
    return nil
end

--- Deep copy plain tables (nested `snapGroups` entries).
--- @param src table
--- @return table
local function deepCopyPlainTable(src)
    if type(src) ~= "table" then
        return {}
    end
    local copy = {}
    for k, v in pairs(src) do
        if type(v) == "table" then
            copy[k] = deepCopyPlainTable(v)
        else
            copy[k] = v
        end
    end
    return copy
end

--- Working copy for validate/install — never return `DATA.CONTROL_BOARD_SNAP` by reference.
--- @param config table|nil
--- @return table
local function resolveControlBoardSnapConfig(config)
    local src = type(config) == "table" and config or (DATA.CONTROL_BOARD_SNAP or {})
    return deepCopyPlainTable(src)
end

--- @param cfg table
--- @return table cfg, number rings
local function validateControlBoardSnapConfig(cfg)
    if type(cfg) ~= "table" then
        error("CONTROL_BOARD_SNAP config must be a table")
    end
    local origin = cfg.origin
    if type(origin) ~= "table" or type(origin.u) ~= "number" or type(origin.v) ~= "number" then
        error("CONTROL_BOARD_SNAP.origin must be { u = number, v = number }")
    end
    local rings = tonumber(cfg.rings)
    if rings == nil or rings < 1 or math.floor(rings) ~= rings then
        error("CONTROL_BOARD_SNAP.rings must be an integer >= 1")
    end
    rings = math.floor(rings)
    local innerRingMaxU = tonumber(cfg.innerRingMaxU)
    local innerRingMaxV = tonumber(cfg.innerRingMaxV)
    local outerRingMaxU = tonumber(cfg.outerRingMaxU)
    local outerRingMaxV = tonumber(cfg.outerRingMaxV)
    local hasGlobalRingMax = innerRingMaxU ~= nil
        and innerRingMaxV ~= nil
        and outerRingMaxU ~= nil
        and outerRingMaxV ~= nil
    local legacyRays = tonumber(cfg.rays)
    local snapGroups = cfg.snapGroups
    if type(snapGroups) ~= "table" or #snapGroups ~= rings then
        error("CONTROL_BOARD_SNAP.snapGroups must have exactly " .. tostring(rings) .. " entries (one per ring)")
    end
    for ringIndex = 1, rings do
        local group = snapGroups[ringIndex]
        if type(group) ~= "table" then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "] must be a table")
        end
        local num = tonumber(group.num)
        if num == nil or num < 1 or math.floor(num) ~= num then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "].num must be an integer >= 1")
        end
        if tonumber(group.angleDelta) == nil then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "].angleDelta must be a number")
        end
        local rays = tonumber(group.rays)
        if rays == nil and legacyRays ~= nil then
            rays = legacyRays
        end
        if rays == nil or rays < 1 or math.floor(rays) ~= rays then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].rays must be an integer >= 1 (or set legacy top-level rays)"
            )
        end
        group.rays = math.floor(rays)
        local ringMaxU = tonumber(group.maxU)
        local ringMaxV = tonumber(group.maxV)
        if group.maxU ~= nil and ringMaxU == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].maxU must be a number when set"
            )
        end
        if group.maxV ~= nil and ringMaxV == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].maxV must be a number when set"
            )
        end
        if (ringMaxU ~= nil) ~= (ringMaxV ~= nil) then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "] must set both maxU and maxV together"
            )
        end
        if group.groundLevel ~= nil and tonumber(group.groundLevel) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].groundLevel must be a number when set"
            )
        end
        if group.radialStagger ~= nil and tonumber(group.radialStagger) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].radialStagger must be a number when set"
            )
        end
    end
    if not hasGlobalRingMax then
        for ringIndex = 1, rings do
            local group = snapGroups[ringIndex]
            if tonumber(group.maxU) == nil or tonumber(group.maxV) == nil then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].maxU/maxV required when inner/outer ring max omitted"
                )
            end
        end
    end
    return cfg, rings
end

--- Absolute world Y for figurines on a ring when `snapGroups[ring].groundLevel` is set.
--- @param group table
--- @return number|nil
local function resolveSnapGroupGroundLevel(group)
    if type(group) == "table" and tonumber(group.groundLevel) ~= nil then
        return tonumber(group.groundLevel)
    end
    return nil
end

--- Absolute board maxU/maxV for ring index (1 = innermost).
--- Per-ring `snapGroups[ringIndex].maxU/maxV` override inner→outer interpolation when set.
--- @param cfg table
--- @param ringIndex number
--- @param rings number
--- @return number maxU, number maxV
local function ringMaxUvForIndex(cfg, ringIndex, rings)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[ringIndex] or nil
    if type(group) == "table" then
        local maxU = tonumber(group.maxU)
        local maxV = tonumber(group.maxV)
        if maxU ~= nil and maxV ~= nil then
            return maxU, maxV
        end
    end
    local innerRingMaxU = tonumber(cfg.innerRingMaxU)
    local innerRingMaxV = tonumber(cfg.innerRingMaxV)
    local outerRingMaxU = tonumber(cfg.outerRingMaxU)
    local outerRingMaxV = tonumber(cfg.outerRingMaxV)
    if innerRingMaxU == nil or innerRingMaxV == nil or outerRingMaxU == nil or outerRingMaxV == nil then
        error(
            "CONTROL_BOARD_SNAP ring "
                .. tostring(ringIndex)
                .. " needs snapGroups.maxU/maxV or top-level inner/outer ring max"
        )
    end
    local t = 0
    if rings > 1 then
        t = (ringIndex - 1) / (rings - 1)
    end
    local maxU = innerRingMaxU + t * (outerRingMaxU - innerRingMaxU)
    local maxV = innerRingMaxV + t * (outerRingMaxV - innerRingMaxV)
    return maxU, maxV
end

--- Board u/v on an axis-aligned ellipse: at angleDeg, u reaches maxU on +u axis and v reaches maxV on +v axis.
--- @param cfg table
--- @param angleDeg number
--- @param maxU number absolute board u at theta=0
--- @param maxV number absolute board v at theta=90
--- @return number u, number v
local function uvOnEllipse(cfg, angleDeg, maxU, maxV)
    local ou = cfg.origin.u
    local ov = cfg.origin.v
    local theta = math.rad(angleDeg)
    local u = ou + math.cos(theta) * (maxU - ou)
    local v = ov + math.sin(theta) * (maxV - ov)
    return u, v
end

--- True when normalized board u/v lies on the minimap tile (inclusive 0–1).
--- @param u number
--- @param v number
--- @return boolean
local function snapUvOnBoard(u, v)
    if type(u) ~= "number" or type(v) ~= "number" then
        return false
    end
    return u >= 0 and u <= 1 and v >= 0 and v <= 1
end

--- Push snap u/v outward from polar origin by `abs(familyK) * radialStagger` along STAGE world XZ.
--- Anchor (`familyK == 0`) is unchanged. Units are STAGE_BOARD / playfield world inches (not CONTROL_BOARD minimap inches).
--- @param cfg table validated CONTROL_BOARD_SNAP (for origin u/v)
--- @param familyK number
--- @param radialStagger number world XZ inches on STAGE_BOARD per family step from anchor
--- @param u number
--- @param v number
--- @return number u, number v
local function applyRadialStaggerUv(cfg, familyK, radialStagger, u, v)
    local k = tonumber(familyK) or 0
    local staggerStep = tonumber(radialStagger) or 0
    if k == 0 or staggerStep == 0 then
        return u, v
    end
    local ou = cfg.origin.u
    local ov = cfg.origin.v
    local du = u - ou
    local dv = v - ov
    local stage = getStageBoard()
    if not isGameObject(stage) then
        local ext = defaultStageWorld()
        local x0 = ext.centerX + (ou - 0.5) * 2 * ext.halfWidthX
        local z0 = ext.centerZ + (ov - 0.5) * 2 * ext.halfDepthZ
        local x1 = ext.centerX + (u - 0.5) * 2 * ext.halfWidthX
        local z1 = ext.centerZ + (v - 0.5) * 2 * ext.halfDepthZ
        local dx = x1 - x0
        local dz = z1 - z0
        local worldDist = math.sqrt(dx * dx + dz * dz)
        if worldDist < 1e-6 then
            return u, v
        end
        local scale = (worldDist + math.abs(k) * staggerStep) / worldDist
        return ou + du * scale, ov + dv * scale
    end
    local originLp = boardLocalFromUv(stage, ou, ov)
    local snapLp = boardLocalFromUv(stage, u, v)
    local originWp = boardLocalToWorld(stage, originLp)
    local snapWp = boardLocalToWorld(stage, snapLp)
    local dx = snapWp.x - originWp.x
    local dz = snapWp.z - originWp.z
    local worldDist = math.sqrt(dx * dx + dz * dz)
    if worldDist < 1e-6 then
        return u, v
    end
    local scale = (worldDist + math.abs(k) * staggerStep) / worldDist
    local newWp = Vector(originWp.x + dx * scale, snapWp.y, originWp.z + dz * scale)
    local newLp = boardWorldToLocal(stage, newWp)
    if newLp == nil then
        return u, v
    end
    -- Unclamped u/v so off-board stagger candidates are pruned by snapUvOnBoard (not pinned to edges).
    return uvFromBoardLocal(stage, newLp)
end

--- Ellipse u/v + optional radial stagger for one family member; nil when off the minimap tile.
--- @param board Object|nil Used for snap local position on CONTROL_BOARD (stagger uses STAGE_BOARD)
--- @param cfg table
--- @param rings number
--- @param ringIndex number
--- @param rayIndex number 0-based
--- @param familyK number
--- @return number|nil u, number|nil v, Vector|nil localPos
local function controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, familyK)
    local group = cfg.snapGroups[ringIndex]
    local rays = tonumber(group.rays)
    local angleDelta = tonumber(group.angleDelta) or 0
    local radialStagger = tonumber(group.radialStagger) or 0
    local maxU, maxV = ringMaxUvForIndex(cfg, ringIndex, rings)
    local anchorDeg = (rayIndex / rays) * 360
    local angleDeg = anchorDeg + familyK * angleDelta
    local u, v = uvOnEllipse(cfg, angleDeg, maxU, maxV)
    if radialStagger ~= 0 and familyK ~= 0 then
        u, v = applyRadialStaggerUv(cfg, familyK, radialStagger, u, v)
    end
    if not snapUvOnBoard(u, v) then
        return nil, nil, nil
    end
    local lp = nil
    if isGameObject(board) then
        lp = boardLocalFromUv(board, u, v)
    end
    return u, v, lp
end

--- Pick the ring whose ellipse best matches normalized board u/v (same geometry as snap generation).
--- @param cfg table
--- @param u number
--- @param v number
--- @param rings number
--- @return number ringIndex 1-based
local function resolveRingIndexForUv(cfg, u, v, rings)
    local ou = cfg.origin.u
    local ov = cfg.origin.v
    local du = u - ou
    local dv = v - ov
    local angleDeg = math.deg(math.atan2(dv, du))
    local bestRing = 1
    local bestDist = math.huge
    for ringIndex = 1, rings do
        local maxU, maxV = ringMaxUvForIndex(cfg, ringIndex, rings)
        local eu, ev = uvOnEllipse(cfg, angleDeg, maxU, maxV)
        local dist = (u - eu) * (u - eu) + (v - ev) * (v - ev)
        if dist < bestDist then
            bestDist = dist
            bestRing = ringIndex
        end
    end
    return bestRing
end

--- Yaw in board-local space so snapped tokens face the polar origin.
--- @param board Object
--- @param u number
--- @param v number
--- @param originU number
--- @param originV number
--- @return number yawDeg
local function snapYawTowardOriginDeg(board, u, v, originU, originV)
    local snapLp = boardLocalFromUv(board, u, v)
    local originLp = boardLocalFromUv(board, originU, originV)
    local dx = originLp.x - snapLp.x
    local dz = originLp.z - snapLp.z
    return math.deg(math.atan2(dx, dz))
end

--- Rich snap catalog entry (install order matches TTS getSnapPoints indices).
--- @param board Object
--- @param cfg table validated CONTROL_BOARD_SNAP config
--- @param rings number
--- @return table[]
local function buildControlBoardSnapEntries(board, cfg, rings)
    local ou = cfg.origin.u
    local ov = cfg.origin.v
    local entries = {}
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local ringGroundLevel = resolveSnapGroupGroundLevel(group)
        local half = math.floor(num / 2)
        for rayIndex = 0, rays - 1 do
            local familyId = tostring(ringIndex) .. ":" .. tostring(rayIndex)
            for k = -half, half do
                local u, v, lp = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil and lp ~= nil then
                    --- ringGroundLevel (when set) is absolute world Y for figurines on Apply — catalog metadata only; snaps stay on tile surface.
                    local yawOffset = tonumber(cfg.snapYawOffsetDeg) or 0
                    local yawDeg = ((snapYawTowardOriginDeg(board, u, v, ou, ov) + yawOffset) % 360 + 360) % 360
                    entries[#entries + 1] = {
                        snapIndex = #entries + 1,
                        ringIndex = ringIndex,
                        rayIndex = rayIndex,
                        familyId = familyId,
                        familyK = k,
                        isAnchor = (k == 0),
                        u = u,
                        v = v,
                        yawDeg = yawDeg,
                        localPos = lp,
                        worldPos = boardLocalToWorld(board, lp),
                        groundLevel = ringGroundLevel,
                    }
                end
            end
        end
    end
    return entries
end

--- @param config table|nil
--- @return number total, table perRingCounts indexed by ring
function Gameboard.countControlBoardSnapPoints(config)
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local board = getControlBoard()
    local perRing = {}
    local total = 0
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local half = math.floor(num / 2)
        local ringTotal = 0
        for rayIndex = 0, rays - 1 do
            for k = -half, half do
                local u, _, _ = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil then
                    ringTotal = ringTotal + 1
                end
            end
        end
        perRing[ringIndex] = ringTotal
        total = total + ringTotal
    end
    return total, perRing
end

local SNAP_FAMILY_ROLE_BY_K = {
    [-2] = "farLeft",
    [-1] = "nearLeft",
    [0] = "center",
    [1] = "nearRight",
    [2] = "farRight",
}

--- @param familyK number
--- @return string
local function familyRoleLabelForK(familyK)
    local label = SNAP_FAMILY_ROLE_BY_K[familyK]
    if label ~= nil then
        return label
    end
    return "k" .. tostring(familyK)
end

--- Collect on-board snap positions grouped by family role (farLeft … center … farRight).
--- World X/Z use STAGE_BOARD via `worldFromUv`; Y omitted from each point.
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @param options table|nil `{ useInterpolatedRings?: boolean }` when true, ignore per-ring maxU/maxV and interpolate inner→outer
--- @return table<string, table[]> roleName → `{ { x, z, u, v, ringIndex, rayIndex, familyK }, ... }`
function Gameboard.exportSnapFamiliesByRole(config, options)
    options = type(options) == "table" and options or {}
    local cfg = resolveControlBoardSnapConfig(config)
    if options.useInterpolatedRings == true then
        local ringCount = tonumber(cfg.rings) or #(cfg.snapGroups or {})
        local firstGroup = type(cfg.snapGroups) == "table" and cfg.snapGroups[1] or nil
        local lastGroup = type(cfg.snapGroups) == "table" and cfg.snapGroups[ringCount] or nil
        if cfg.innerRingMaxU == nil and type(firstGroup) == "table" then
            cfg.innerRingMaxU = firstGroup.maxU
        end
        if cfg.innerRingMaxV == nil and type(firstGroup) == "table" then
            cfg.innerRingMaxV = firstGroup.maxV
        end
        if cfg.outerRingMaxU == nil and type(lastGroup) == "table" then
            cfg.outerRingMaxU = lastGroup.maxU
        end
        if cfg.outerRingMaxV == nil and type(lastGroup) == "table" then
            cfg.outerRingMaxV = lastGroup.maxV
        end
        for ringIndex = 1, #(cfg.snapGroups or {}) do
            local group = cfg.snapGroups[ringIndex]
            if type(group) == "table" then
                group.maxU = nil
                group.maxV = nil
            end
        end
    end
    local rings
    cfg, rings = validateControlBoardSnapConfig(cfg)
    local board = getControlBoard()
    local byRole = {}
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local ringGroundLevel = resolveSnapGroupGroundLevel(group)
        local half = math.floor(num / 2)
        for rayIndex = 0, rays - 1 do
            for k = -half, half do
                local u, v = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil then
                    local wp = Gameboard.worldFromUv(u, v, { groundLevel = ringGroundLevel })
                    local role = familyRoleLabelForK(k)
                    local bucket = byRole[role]
                    if bucket == nil then
                        bucket = {}
                        byRole[role] = bucket
                    end
                    bucket[#bucket + 1] = {
                        x = wp.x,
                        z = wp.z,
                        u = u,
                        v = v,
                        ringIndex = ringIndex,
                        rayIndex = rayIndex,
                        familyK = k,
                    }
                end
            end
        end
    end
    return byRole
end

--- Serialize `exportSnapFamiliesByRole` output as a Lua table literal (1-based slot indices per role).
--- @param byRole table
--- @return string
function Gameboard.formatSnapFamiliesLua(byRole)
    if type(byRole) ~= "table" then
        return "return {}"
    end
    local roleNames = {}
    for roleName, _ in pairs(byRole) do
        roleNames[#roleNames + 1] = roleName
    end
    table.sort(roleNames)
    local lines = { "return {" }
    for _, roleName in ipairs(roleNames) do
        lines[#lines + 1] = "  " .. roleName .. " = {"
        local points = byRole[roleName]
        if type(points) == "table" then
            for slotIndex, pt in ipairs(points) do
                if type(pt) == "table" and type(pt.x) == "number" and type(pt.z) == "number" then
                    lines[#lines + 1] = string.format(
                        "    [%d] = { x = %.6f, z = %.6f },",
                        slotIndex,
                        pt.x,
                        pt.z
                    )
                end
            end
        end
        lines[#lines + 1] = "  },"
    end
    lines[#lines + 1] = "}"
    return table.concat(lines, "\n")
end

--- Serialize `exportSnapFamiliesByRole` as CSV: area, slot, x, z (area = family role name).
--- @param byRole table
--- @return string
function Gameboard.formatSnapFamiliesCsv(byRole)
    if type(byRole) ~= "table" then
        return "area,slot,x,z"
    end
    local roleNames = {}
    for roleName, _ in pairs(byRole) do
        roleNames[#roleNames + 1] = roleName
    end
    table.sort(roleNames)
    local lines = { "area,slot,x,z" }
    for _, roleName in ipairs(roleNames) do
        local points = byRole[roleName]
        if type(points) == "table" then
            for slotIndex, pt in ipairs(points) do
                if type(pt) == "table" and type(pt.x) == "number" and type(pt.z) == "number" then
                    lines[#lines + 1] = string.format(
                        "%s,%d,%.6f,%.6f",
                        roleName,
                        slotIndex,
                        pt.x,
                        pt.z
                    )
                end
            end
        end
    end
    return table.concat(lines, "\n")
end

--- Snap catalog with family metadata (anchor = familyK 0 at each ray).
--- @param board Object
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table[]
function Gameboard.buildControlBoardSnapCatalog(board, config)
    if not isGameObject(board) then
        error("Gameboard.buildControlBoardSnapCatalog: board object required")
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    return buildControlBoardSnapEntries(board, cfg, rings)
end

--- Build TTS snap points in board-local space (combined ray + family angles per ring).
--- @param board Object
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table[]
function Gameboard.buildControlBoardSnapPoints(board, config)
    if not isGameObject(board) then
        error("Gameboard.buildControlBoardSnapPoints: board object required")
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local entries = buildControlBoardSnapEntries(board, cfg, rings)
    local points = {}
    for _, entry in ipairs(entries) do
        points[#points + 1] = {
            position = { entry.localPos.x, entry.localPos.y, entry.localPos.z },
            rotation = { 0, entry.yawDeg, 0 },
            rotation_snap = true,
            tags = { TAG_TOKEN },
        }
    end
    return points
end

--- @param board Object
--- @param config table|nil
--- @return string
local function controlBoardSnapFingerprintFor(board, config)
    local cfg = resolveControlBoardSnapConfig(config)
    local sx, sz = boardMapExtents(board)
    local parts = {
        tostring(board.getGUID()),
        string.format("%.3f,%.3f", sx, sz),
        string.format("%.4f,%.4f", cfg.origin.u, cfg.origin.v),
        tostring(cfg.rings),
        table.concat({
            tostring(cfg.innerRingMaxU or ""),
            tostring(cfg.innerRingMaxV or ""),
            tostring(cfg.outerRingMaxU or ""),
            tostring(cfg.outerRingMaxV or ""),
        }, ","),
    }
    local rings = tonumber(cfg.rings) or 0
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        if type(group) == "table" then
            parts[#parts + 1] = tostring(group.num)
                .. ":"
                .. tostring(group.angleDelta)
                .. ":"
                .. tostring(group.rays)
                .. ":"
                .. tostring(group.groundLevel or "")
                .. ":"
                .. tostring(group.radialStagger or "")
                .. ":"
                .. tostring(group.maxU or "")
                .. ":"
                .. tostring(group.maxV or "")
        end
    end
    parts[#parts + 1] = "snapTag:" .. TAG_TOKEN
    parts[#parts + 1] = "yawOff:" .. tostring(tonumber(cfg.snapYawOffsetDeg) or 0)
    return table.concat(parts, ":")
end

--- Install CONTROL_BOARD snap points (idempotent; safe from Global reconcile).
--- @param board Object|nil Defaults to G.GUIDS.CONTROL_BOARD
--- @param options table|nil { force?: boolean, config?: table }
--- @return boolean installed
function Gameboard.installPolarSnaps(board, options)
    options = type(options) == "table" and options or {}
    board = board or getControlBoard()
    boardUvHalfExtentsCache = {}
    if not isGameObject(board) or board.setSnapPoints == nil then
        print("[Gameboard] installPolarSnaps: CONTROL_BOARD missing or has no setSnapPoints")
        return false
    end
    local cfg = resolveControlBoardSnapConfig(options.config)
    local fp = controlBoardSnapFingerprintFor(board, cfg)
    if options.force ~= true and polarSnapInstallFingerprint == fp then
        return true
    end
    local points = Gameboard.buildControlBoardSnapPoints(board, cfg)
    if #points < 1 then
        print("[Gameboard] installPolarSnaps: no snap points built")
        return false
    end
    local ok = board.setSnapPoints(points)
    if ok then
        polarSnapInstallFingerprint = fp
        installedPolarSnapConfig = resolveControlBoardSnapConfig(cfg)
        print(
            "[Gameboard] Control-board snaps installed ("
                .. tostring(#points)
                .. " points on "
                .. tostring(board.getGUID())
                .. ")"
        )
    else
        print("[Gameboard] installPolarSnaps: setSnapPoints returned false on " .. tostring(board.getGUID()))
    end
    return ok == true
end

--- Alias for installPolarSnaps (same behavior).
Gameboard.installControlBoardSnaps = Gameboard.installPolarSnaps

--- Last installed CONTROL_BOARD snap config, captured from installPolarSnaps.
--- @return table|nil
function Gameboard.getInstalledControlBoardSnapConfig()
    if type(installedPolarSnapConfig) ~= "table" then
        return nil
    end
    return resolveControlBoardSnapConfig(installedPolarSnapConfig)
end

--- Anchor ray angle (degrees) for a catalog entry.
--- @param cfg table
--- @param entry table
--- @return number
local function anchorDegForSnapEntry(cfg, entry)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[entry.ringIndex] or nil
    local rays = tonumber(group and group.rays) or 1
    if rays < 1 then
        rays = 1
    end
    return (entry.rayIndex / rays) * 360
end

--- Family spread offset (degrees) = familyK * angleDelta on that ring.
--- @param cfg table
--- @param entry table
--- @return number
local function spreadOffsetForSnapEntry(cfg, entry)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[entry.ringIndex] or nil
    local angleDelta = tonumber(group and group.angleDelta) or 0
    return (entry.familyK or 0) * angleDelta
end

--- @param a number degrees
--- @param b number degrees
--- @return number shortest arc distance in [0, 180]
local function angularDeltaDeg(a, b)
    local d = ((a - b) % 360 + 360) % 360
    if d > 180 then
        d = 360 - d
    end
    return d
end

--- Best snap on `ringIndex` matching spread offset, then anchor ray.
--- @param catalog table[]
--- @param cfg table
--- @param ringIndex number
--- @param targetSpread number
--- @param targetAnchor number
--- @return table|nil
local function findBestCatalogEntryOnRing(catalog, cfg, ringIndex, targetSpread, targetAnchor)
    local best = nil
    local bestSpreadDiff = math.huge
    local bestAnchorDiff = math.huge
    for _, entry in ipairs(catalog) do
        if entry.ringIndex == ringIndex then
            local spreadDiff = math.abs(spreadOffsetForSnapEntry(cfg, entry) - targetSpread)
            local anchorDiff = angularDeltaDeg(anchorDegForSnapEntry(cfg, entry), targetAnchor)
            if spreadDiff < bestSpreadDiff
                or (spreadDiff == bestSpreadDiff and anchorDiff < bestAnchorDiff) then
                bestSpreadDiff = spreadDiff
                bestAnchorDiff = anchorDiff
                best = entry
            end
        end
    end
    return best
end

--- Park one token on its palette grid cell when `buildTokenSnapAssignments` has a slot.
--- @param token Object
--- @param characterKey string
--- @return boolean
local function parkNpcTokenOnPalette(token, characterKey)
    local palette = getControlBoardPalette()
    if not isGameObject(palette) or not isGameObject(token) or type(characterKey) ~= "string" then
        return false
    end
    local assignments = Palette.buildTokenSnapAssignments()
    local wantIndex = assignments[characterKey]
    if type(wantIndex) ~= "number" then
        return false
    end
    local wp = Palette.worldPositionForSnapIndex(palette, wantIndex)
    if wp == nil then
        return false
    end
    token.setPosition(wp)
    if token.setInvisibleTo ~= nil then
        token.setInvisibleTo(C.PlayerColors or {})
    end
    return true
end

--- Log each NPC token on CONTROL_BOARD (not palette) with ring from snap catalog match.
--- @param board Object|nil
--- @param config table|nil Snap config used to build the catalog for matching
--- @return table[] rows { characterKey, ringIndex?, rayIndex?, familyK?, spreadOffset?, anchorDeg?, reason? }
function Gameboard.logControlBoardTokenSnapRings(board, config)
    board = board or getControlBoard()
    local cfg = resolveControlBoardSnapConfig(config)
    local fuzziness = isGameObject(board) and snapMatchFuzzinessForBoard(board) or CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    local rows = {}
    if not isGameObject(board) then
        print("[Gameboard] logControlBoardTokenSnapRings: CONTROL_BOARD missing")
        return rows
    end
    for _, token in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if isGameObject(token) then
            local characterKey = resolveTokenCharacterKey(token)
            if type(characterKey) == "string" and characterKey ~= "" then
                local palette = getControlBoardPalette()
                if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
                    rows[#rows + 1] = { characterKey = characterKey, reason = "on_palette" }
                    print("[Gameboard] token " .. characterKey .. ": on palette (skipped)")
                else
                    local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, cfg)
                    if entry ~= nil then
                        local spread = spreadOffsetForSnapEntry(cfg, entry)
                        local anchor = anchorDegForSnapEntry(cfg, entry)
                        rows[#rows + 1] = {
                            characterKey = characterKey,
                            ringIndex = entry.ringIndex,
                            rayIndex = entry.rayIndex,
                            familyK = entry.familyK,
                            spreadOffset = spread,
                            anchorDeg = anchor,
                        }
                        print(
                            "[Gameboard] token "
                                .. characterKey
                                .. ": ring "
                                .. tostring(entry.ringIndex)
                                .. " ray "
                                .. tostring(entry.rayIndex)
                                .. " familyK "
                                .. tostring(entry.familyK)
                                .. " spreadOffset "
                                .. string.format("%.2f", spread)
                                .. " anchorDeg "
                                .. string.format("%.1f", anchor)
                        )
                    else
                        rows[#rows + 1] = { characterKey = characterKey, reason = "no_snap_match" }
                        print("[Gameboard] token " .. characterKey .. ": no snap match")
                    end
                end
            end
        end
    end
    return rows
end

--- Install a new CONTROL_BOARD snap grid and remap tokens + placements to the nearest snap on each ring (by spread offset).
--- Tokens on a ring that no longer exists are parked on CONTROL_BOARD_PALETTE and removed from placements.
--- @param oldConfig table|nil Config that matches current token positions (default DATA.CONTROL_BOARD_SNAP)
--- @param newConfig table New CONTROL_BOARD_SNAP table to install
--- @param options table|nil `{ skipSync?: boolean }`
--- @return table stats
function Gameboard.remapControlBoardSnapsToConfig(oldConfig, newConfig, options)
    options = type(options) == "table" and options or {}
    local board = getControlBoard()
    local stats = {
        logged = 0,
        remapped = 0,
        palette = 0,
        skipped = 0,
    }
    if not isGameObject(board) then
        print("[Gameboard] remapControlBoardSnapsToConfig: CONTROL_BOARD missing")
        return stats
    end
    if type(newConfig) ~= "table" then
        error("remapControlBoardSnapsToConfig: newConfig table required")
    end
    local oldCfg = type(oldConfig) == "table"
        and resolveControlBoardSnapConfig(oldConfig)
        or Gameboard.getInstalledControlBoardSnapConfig()
        or resolveControlBoardSnapConfig(DATA.CONTROL_BOARD_SNAP)
    local newCfg, newRings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(newConfig))
    local fuzziness = snapMatchFuzzinessForBoard(board)

    print("[Gameboard] remap: logging token rings (old snap config)")
    local tokenPlans = {}
    for _, token in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if isGameObject(token) then
            local characterKey = resolveTokenCharacterKey(token)
            if type(characterKey) == "string" and characterKey ~= "" then
                local palette = getControlBoardPalette()
                if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
                    stats.skipped = stats.skipped + 1
                else
                    stats.logged = stats.logged + 1
                    local oldEntry = resolveTokenSnapCatalogEntry(board, token, fuzziness, oldCfg)
                    tokenPlans[#tokenPlans + 1] = {
                        token = token,
                        characterKey = characterKey,
                        oldEntry = oldEntry,
                        npcLightMode = tokenLightModeFromFlip(token),
                    }
                    if oldEntry ~= nil then
                        print(
                            "[Gameboard] remap log "
                                .. characterKey
                                .. ": ring "
                                .. tostring(oldEntry.ringIndex)
                        )
                    else
                        print("[Gameboard] remap log " .. characterKey .. ": no snap match (old config)")
                    end
                end
            end
        end
    end

    Gameboard.installPolarSnaps(board, { force = true, config = newCfg })
    local newCatalog = Gameboard.buildControlBoardSnapCatalog(board, newCfg)
    local placements = {}
    local existing = S.getStateVal("sessionScene", "npcWorld", "placements")
    if type(existing) == "table" then
        for ck, row in pairs(existing) do
            if type(ck) == "string" and type(row) == "table" then
                placements[ck] = row
            end
        end
    end
    local boardYaw = board.getRotation().y or 0

    for _, plan in ipairs(tokenPlans) do
        local token = plan.token
        local characterKey = plan.characterKey
        local oldEntry = plan.oldEntry
        if oldEntry == nil then
            placements[characterKey] = nil
            stats.skipped = stats.skipped + 1
        elseif oldEntry.ringIndex > newRings then
            placements[characterKey] = nil
            if parkNpcTokenOnPalette(token, characterKey) then
                stats.palette = stats.palette + 1
            else
                stats.skipped = stats.skipped + 1
            end
            print(
                "[Gameboard] remap "
                    .. characterKey
                    .. ": ring "
                    .. tostring(oldEntry.ringIndex)
                    .. " removed → palette"
            )
        else
            local targetSpread = spreadOffsetForSnapEntry(oldCfg, oldEntry)
            local targetAnchor = anchorDegForSnapEntry(oldCfg, oldEntry)
            local newEntry = findBestCatalogEntryOnRing(
                newCatalog,
                newCfg,
                oldEntry.ringIndex,
                targetSpread,
                targetAnchor
            )
            if newEntry == nil then
                placements[characterKey] = nil
                stats.skipped = stats.skipped + 1
                print("[Gameboard] remap " .. characterKey .. ": no target snap on ring " .. tostring(oldEntry.ringIndex))
            else
                placeTokenOnControlBoardSnap(token, newEntry, board, boardYaw)
                local row = {
                    u = newEntry.u,
                    v = newEntry.v,
                    yaw = newEntry.yawDeg,
                    npcLightMode = plan.npcLightMode,
                }
                if newEntry.groundLevel ~= nil then
                    row.groundLevel = newEntry.groundLevel
                end
                placements[characterKey] = row
                stats.remapped = stats.remapped + 1
                print(
                    "[Gameboard] remap "
                        .. characterKey
                        .. ": ring "
                        .. tostring(oldEntry.ringIndex)
                        .. " → ray "
                        .. tostring(newEntry.rayIndex)
                        .. " familyK "
                        .. tostring(newEntry.familyK)
                )
            end
        end
    end

    S.setStateVal(placements, "sessionScene", "npcWorld", "placements")
    local palette = getControlBoardPalette()
    if isGameObject(palette) then
        Palette.syncTokensToPalette(palette)
    end

    if options.skipSync ~= true then
        local Sync = require("core.sync")
        Sync.npcs({
            reason = "gameboard_snap_remap",
            force = true,
            onlySteps = { 1, 5 },
            deferUiRefresh = true,
            skipAreaPopulate = true,
            skipPreloadPopulate = true,
        })
    end

    print(
        "[Gameboard] remap complete: logged="
            .. tostring(stats.logged)
            .. " remapped="
            .. tostring(stats.remapped)
            .. " palette="
            .. tostring(stats.palette)
            .. " skipped="
            .. tostring(stats.skipped)
    )
    return stats
end

--- Absolute world Y for a normalized u/v on the control-board snap grid (from matching ring `groundLevel`).
--- When the ring omits `groundLevel`, returns nil and `worldFromUv` uses STAGE_BOARD surface world Y at u,v.
--- @param u number
--- @param v number
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return number|nil
function Gameboard.groundLevelForSnapUv(u, v, config)
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local ringIndex = resolveRingIndexForUv(cfg, u, v, rings)
    local group = cfg.snapGroups[ringIndex]
    return resolveSnapGroupGroundLevel(group)
end

--- @param u number
--- @param v number
--- @param config table|nil
--- @return number ringIndex 1-based
function Gameboard.resolveSnapRingIndexForUv(u, v, config)
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    return resolveRingIndexForUv(cfg, u, v, rings)
end

--- Minimal object Lua when the save has no bundled CONTROL_BOARD script (GUID bea29a).
--- 3D/XmlUI buttons call `click_*` on the board object; Global reconcile installs buttons but cannot define handlers without this.
local CONTROL_BOARD_FALLBACK_LUA_SCRIPT = [=[--- Toronto Rising — CONTROL_BOARD fallback (Global-injected when save LuaScript is empty).
--- Persist a bundled script: `.tts/objects/CONTROL_BOARD.*.ttslua` → require("objects.npc_control_board") → Save & Play.

local function resolveControlBoardClickColor(arg1, arg2)
    if arg1 ~= nil and type(arg1.color) == "string" and arg1.color ~= "" then
        return arg1.color
    end
    if type(arg2) == "string" and arg2 ~= "" then
        return arg2
    end
    return nil
end

function click_apply(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    Global.call("GlobalGameboardApply", {})
end

function click_clear(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    Global.call("GlobalGameboardClearClick", { player_color = player_color })
end

function click_read_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Read: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end

function click_lock_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Lock: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end

function click_load_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Load: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end
]=]

--- @param script string|nil
--- @return boolean
local function controlBoardScriptDefinesClickApply(script)
    return type(script) == "string"
        and script:find("function click_apply", 1, true) ~= nil
        and script:find("resolveControlBoardClickColor", 1, true) ~= nil
end

--- Inject `click_*` handlers when the workshop save has empty CONTROL_BOARD LuaScript.
--- @param board Object|nil
--- @return boolean true when handlers are present (already or after inject)
function Gameboard.ensureControlBoardObjectCallbacks(board)
    board = board or getControlBoard()
    if not isGameObject(board) or board.getLuaScript == nil or board.setLuaScript == nil then
        return false
    end
    local existing = board.getLuaScript() or ""
    if controlBoardScriptDefinesClickApply(existing) then
        return true
    end
    local ok = board.setLuaScript(CONTROL_BOARD_FALLBACK_LUA_SCRIPT)
    if ok ~= true then
        print(
            "[Gameboard] ensureControlBoardObjectCallbacks: setLuaScript failed on "
                .. tostring(board.getGUID())
        )
        return false
    end
    print(
        "[Gameboard] installed CONTROL_BOARD click_* fallback on "
            .. tostring(board.getGUID())
            .. " — Save & Play with require(\"objects.npc_control_board\") to persist the full bundle"
    )
    return true
end

--- Install Apply/Clear/Read/Lock/Load 3D buttons when the save has no object script on CONTROL_BOARD yet.
--- @param board Object|nil
function Gameboard.ensureControlBoardObjectUi(board)
    board = board or getControlBoard()
    if not isGameObject(board) then
        return
    end
    local BoardUi = require("objects.npc_control_board_ui")
    BoardUi.installObjectButtons(board)
end

--- Static minimap markers (not npc_control_token): locked so physics does not shove them apart.
--- @param marker Object|nil
local function lockControlBoardMarker(marker)
    if not isGameObject(marker) or marker.setLock == nil then
        return
    end
    marker.setLock(true)
end

--- Park empty / inactive NPC seat markers off the play surface (locked).
--- @param marker Object
--- @param npcSeatKey string|nil Used to spread stash X slightly per slot
local function stashNpcSeatMarker(marker, npcSeatKey)
    if not isGameObject(marker) or marker.setPosition == nil then
        return
    end
    local stashY = tonumber(DATA.MARKER_STASH_WORLD_Y) or -200
    local pos = marker.getPosition()
    local offsetX = 0
    if type(npcSeatKey) == "string" then
        for i = 1, #(C.NPCSeats or {}) do
            if C.NPCSeats[i] == npcSeatKey then
                offsetX = (i - 1) * 0.75
                break
            end
        end
    end
    marker.setPosition(Vector({ x = pos.x + offsetX, y = stashY, z = pos.z }))
    lockControlBoardMarker(marker)
end

--- Park inactive table-component markers off the control surface (locked).
--- @param marker Object
--- @param componentName string|nil Used to spread stash X slightly per component
local function stashTableComponentMarker(marker, componentName)
    if not isGameObject(marker) or marker.setPosition == nil then
        return
    end
    local stashY = tonumber(DATA.MARKER_STASH_WORLD_Y) or -200
    local pos = marker.getPosition()
    local offsetX = 0
    if type(componentName) == "string" then
        offsetX = (string.byte(componentName, 1) or 0) * 0.01
    end
    marker.setPosition(Vector({ x = pos.x + offsetX, y = stashY, z = pos.z }))
    lockControlBoardMarker(marker)
end

--- @param marker Object
--- @param board Object
--- @param u number|nil
--- @param v number|nil
--- @param source Object|nil Playfield object this minimap piece mimics (scale + rotation)
--- @param options table|nil { extraLocalY?: number }
local function placeControlBoardMarker(marker, board, u, v, source, options)
    local opts = options or {}
    if u ~= nil and v ~= nil then
        marker.setPosition(Gameboard.worldOnControlBoard(board, u, v, {
            extraLocalY = opts.extraLocalY,
        }))
    end
    if isGameObject(source) then
        applyMinimapMarkerScale(marker, source)
    end
    applyMinimapMarkerRotation(marker, board, source)
    lockControlBoardMarker(marker)
end

--- Position static table/seat markers for active table.
--- @param opts table|nil `{ force?: boolean }`
function Gameboard.reconcileControlBoardFromState(opts)
    opts = type(opts) == "table" and opts or {}
    boardUvHalfExtentsCache = {}
    local board = getControlBoard()
    if not isGameObject(board) then
        return
    end
    Gameboard.installPolarSnaps(board)
    Gameboard.ensureControlBoardObjectCallbacks(board)
    Gameboard.ensureControlBoardObjectUi(board)

    local npcWorld = S.getStateVal("sessionScene", "npcWorld")
    local activeTable = S.getStateVal("seatLayout", "currentTableKey")
    local layoutLocked = type(npcWorld) == "table" and npcWorld.layoutLock == true
    local placements = type(npcWorld) == "table" and npcWorld.placements or {}
    local mirrorFp = controlBoardMirrorFingerprint(activeTable, layoutLocked, placements)
    if opts.force ~= true and mirrorFp == lastControlBoardMirrorFingerprint then
        rebuildAnchorDropEligibilityCache(board)
        return
    end
    lastControlBoardMirrorFingerprint = mirrorFp
    local allMarkers = getObjectsWithTag(TAG_TABLE) or {}
    for _, tag in ipairs({ TAG_PC, TAG_NPC_SEAT, TAG_COMPONENT }) do
        local extra = getObjectsWithTag(tag) or {}
        for i = 1, #extra do
            allMarkers[#allMarkers + 1] = extra[i]
        end
    end

    for _, obj in ipairs(allMarkers) do
        if isGameObject(obj) then
            lockControlBoardMarker(obj)
            local tableKey = readMarkerKey(obj, DATA.MARKER_TABLE_PREFIX)
            local compKey = readMarkerKey(obj, DATA.MARKER_COMPONENT_PREFIX)
            local pcSeat = readMarkerKey(obj, DATA.MARKER_PC_SEAT_PREFIX)
            local npcSeat = readMarkerKey(obj, DATA.MARKER_NPC_SEAT_PREFIX)

            if tableKey ~= nil then
                local show = tableKey == activeTable
                setMarkerVisible(obj, show)
                if show then
                    local u, v = mapUvForTableCenter(tableKey)
                    placeControlBoardMarker(
                        obj,
                        board,
                        u,
                        v,
                        sourceObjectForTable(tableKey),
                        {
                            extraLocalY = tonumber(DATA.MINIMAP_TABLE_EXTRA_LOCAL_Y) or 0.06,
                        }
                    )
                end
            elseif compKey ~= nil then
                local parentTable, componentName = parseComponentMarkerKey(compKey)
                local show = parentTable == activeTable
                    and type(componentName) == "string"
                    and componentName ~= ""
                    and tableComponentActiveForOccupiedSlots(parentTable, componentName)
                setMarkerVisible(obj, show)
                if show and parentTable ~= nil and componentName ~= nil then
                    local u, v = mapUvForTableComponentMarker(parentTable, componentName)
                    if u == nil or v == nil then
                        u, v = mapUvForTableComponent(parentTable, componentName)
                    end
                    if u ~= nil and v ~= nil then
                        placeControlBoardMarker(
                            obj,
                            board,
                            u,
                            v,
                            sourceObjectForTableComponent(parentTable, componentName)
                        )
                    else
                        print(
                            "[Gameboard] component marker "
                                .. tostring(componentName)
                                .. " active on "
                                .. tostring(parentTable)
                                .. " but u,v mapping failed"
                        )
                        stashTableComponentMarker(obj, componentName)
                    end
                else
                    stashTableComponentMarker(obj, componentName)
                end
            elseif pcSeat ~= nil then
                local show = activeTable ~= nil
                setMarkerVisible(obj, show)
                local u, v = nil, nil
                local seg = nil
                if show then
                    local cfg = tableConfig(activeTable)
                    seg = cfg and cfg.playerToPositionMap and cfg.playerToPositionMap[pcSeat]
                    if type(seg) == "number" then
                        local worldSeat = worldPositionForTableSegment(cfg, seg)
                        u, v = normalizedUvFromWorld(worldSeat)
                        placeControlBoardMarker(
                            obj,
                            board,
                            u,
                            v,
                            sourceObjectForSeat(pcSeat)
                        )
                    end
                end
            elseif npcSeat ~= nil then
                setMarkerVisible(obj, false)
                local cfg = tableConfig(activeTable)
                local seg = cfg and cfg.playerToPositionMap and cfg.playerToPositionMap[npcSeat]
                local show = activeTable ~= nil
                    and type(seg) == "number"
                    and npcSeatOccupiedOnTable(npcSeat)
                local u, v = nil, nil
                if show then
                    local worldSeat = worldPositionForTableSegment(cfg, seg)
                    if worldSeat ~= nil then
                        u, v = normalizedUvFromWorld(worldSeat)
                        placeControlBoardMarker(
                            obj,
                            board,
                            u,
                            v,
                            sourceObjectForSeat(npcSeat)
                        )
                    end
                else
                    stashNpcSeatMarker(obj, npcSeat)
                end
            end
        end
    end

    --- Mirror NPC tokens from placements (skip when layout locked — manual board edits preserved).
    if not layoutLocked then
        --- Tag scan + board-local bounds — Custom_Tile has no working getObjects(); tokens lack getParent.
        local byChar = {}
        local tokenObjs = objectsOnControlBoard(board, TAG_TOKEN)
        for _, obj in ipairs(tokenObjs) do
            if isGameObject(obj) then
                local ck = resolveTokenCharacterKey(obj)
                if ck ~= nil then
                    byChar[ck] = obj
                end
            end
        end
        for characterKey, row in pairs(placements) do
            if type(row) == "table" and type(row.u) == "number" and type(row.v) == "number" then
                local token = byChar[characterKey]
                if isGameObject(token) then
                    token.setPosition(Gameboard.worldOnControlBoard(board, row.u, row.v))
                    local boardYaw = board.getRotation().y or 0
                    local yaw = tonumber(row.yaw) or 0
                    local faceUp = row.npcLightMode ~= "OFF"
                    token.setRotation(rotationForNpcControlToken(boardYaw, yaw, faceUp))
                    Gameboard.setHiddenFromPlayerColors(token)
                end
            end
        end
    end

    applyControlBoardComponentPlayerInvisibility()
    rebuildAnchorDropEligibilityCache(board)
end

--- @param obj Object|nil
--- @return boolean
local function isNpcControlToken(obj)
    return isGameObject(obj) and obj.hasTag ~= nil and obj.hasTag(TAG_TOKEN) == true
end

--- True when token is on CONTROL_BOARD minimap, excluding CONTROL_BOARD_PALETTE storage.
--- @param board Object
--- @param token Object
--- @return boolean
local function isTokenOnControlBoardSurface(board, token)
    if not isGameObject(board) or not isGameObject(token) then
        return false
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
        return false
    end
    for _, obj in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if obj == token then
            return true
        end
    end
    return false
end

--- Nearest installed snap catalog entry for a token on CONTROL_BOARD (world XZ within fuzziness).
--- @param board Object
--- @param token Object
--- @param fuzziness number|nil
--- @param config table|nil
--- @return table|nil catalog entry with snapIndex, isAnchor, familyK, worldPos, …
local function resolveTokenSnapCatalogEntry(board, token, fuzziness, config)
    if not isGameObject(board) or not isGameObject(token) then
        return nil
    end
    fuzziness = tonumber(fuzziness) or snapMatchFuzzinessForBoard(board)
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, config)
    if #catalog == 0 then
        return nil
    end
    local pos = token.getPosition()
    if pos == nil then
        return nil
    end
    local fuzzSq = fuzziness * fuzziness
    local best = nil
    local bestDistSq = math.huge
    for _, entry in ipairs(catalog) do
        local wp = entry.worldPos
        if wp ~= nil then
            local dx = (pos.x or 0) - (wp.x or 0)
            local dz = (pos.z or 0) - (wp.z or 0)
            local distSq = dx * dx + dz * dz
            if distSq <= fuzzSq and distSq < bestDistSq then
                bestDistSq = distSq
                best = entry
            end
        end
    end
    return best
end

--- @param board Object
--- @param token Object
--- @param fuzziness number|nil
--- @return number|nil snapIndex 1-based in installed getSnapPoints order
local function resolveTokenSnapSlot(board, token, fuzziness)
    local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, nil)
    return entry and entry.snapIndex or nil
end

--- @param result table
local function logAnchorSpreadResult(result)
    if type(result) ~= "table" or result.reason == "suppressed" then
        return
    end
    if (result.placed or 0) > 0 then
        print(
            "[Gameboard] anchor spread: placed "
                .. tostring(result.placed)
                .. " token(s) for group "
                .. tostring(result.groupId)
        )
        return
    end
    local detail = tostring(result.reason or "unknown")
    if type(result.groupId) == "string" and result.groupId ~= "" then
        detail = detail .. " (group=" .. result.groupId .. ")"
    end
    if result.matchedSnapIndex ~= nil then
        detail = detail
            .. " snap="
            .. tostring(result.matchedSnapIndex)
            .. " familyK="
            .. tostring(result.familyK)
    end
    print("[Gameboard] anchor spread skipped: " .. detail)
end

--- @return table<string, Object>
local function buildTokenByCharacterKey()
    local byKey = {}
    local tagged = getObjectsWithTag(TAG_TOKEN) or {}
    for _, tok in ipairs(tagged) do
        if isGameObject(tok) then
            local ck = resolveTokenCharacterKey(tok)
            if type(ck) == "string" and ck ~= "" and byKey[ck] == nil then
                byKey[ck] = tok
            end
        end
    end
    return byKey
end

--- Build fast lookup for drop events: only group-leading (slotIndex 1) tokens that are currently off CONTROL_BOARD.
--- @param board Object|nil
rebuildAnchorDropEligibilityCache = function(board)
    anchorDropEligibleByTokenGuid = {}
    if not isGameObject(board) then
        return
    end
    local byKey = buildTokenByCharacterKey()
    for characterKey, token in pairs(byKey) do
        if isGameObject(token) and not isTokenOnControlBoardSurface(board, token) then
            local _, slotIndex = Palette.resolveGroupForCharacterKey(characterKey)
            if tonumber(slotIndex) == 1 then
                anchorDropEligibleByTokenGuid[tostring(token.getGUID())] = true
            end
        end
    end
end

--- @param board Object
--- @param worldPos Vector|table
--- @param fuzziness number
--- @param ignoreToken Object|nil
--- @return Object|nil
local function findOccupyingTokenAtSnapWorld(board, worldPos, fuzziness, ignoreToken)
    if worldPos == nil then
        return nil
    end
    local singleSnap = { { position = worldPos } }
    for _, tok in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if tok ~= ignoreToken and isGameObject(tok) then
            local slot = U.findSnapPoint(singleSnap, tok.getPosition(), fuzziness)
            if slot ~= nil then
                return tok
            end
        end
    end
    return nil
end

--- @param token Object
--- @param snapEntry table
--- @param board Object
--- @param boardYaw number
local function placeTokenOnControlBoardSnap(token, snapEntry, board, boardYaw)
    token.setPosition(snapEntry.worldPos)
    local faceUp = tokenRotationIsFaceUp(token)
    token.setRotation(rotationForNpcControlToken(boardYaw, snapEntry.yawDeg, faceUp))
    Gameboard.setHiddenFromPlayerColors(token)
end

--- When an anchor snap receives a grouped token and the rest of the family is empty,
--- park remaining group members on sibling snaps (lowest slotIndex first).
--- @param droppedToken Object
--- @return table result { placed: number, reason?: string, groupId?: string }
function Gameboard.tryAnchorFamilyGroupSpread(droppedToken)
    if anchorFamilySpreadDepth > 0 then
        return { placed = 0, reason = "suppressed" }
    end
    local board = getControlBoard()
    if not isGameObject(board) or not isNpcControlToken(droppedToken) then
        return { placed = 0, reason = "invalid_token" }
    end
    if not isTokenOnControlBoardSurface(board, droppedToken) then
        return { placed = 0, reason = "not_on_board" }
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, droppedToken) then
        return { placed = 0, reason = "on_palette" }
    end
    local characterKey = resolveTokenCharacterKey(droppedToken)
    if type(characterKey) ~= "string" or characterKey == "" then
        return { placed = 0, reason = "no_character_key" }
    end
    local groupId, _ = Palette.resolveGroupForCharacterKey(characterKey)
    if groupId == nil then
        return { placed = 0, reason = "no_group" }
    end
    if board.getSnapPoints == nil then
        return { placed = 0, reason = "no_snaps" }
    end
    local installedSnaps = board.getSnapPoints()
    if type(installedSnaps) ~= "table" or #installedSnaps == 0 then
        return { placed = 0, reason = "no_snaps" }
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, nil)
    if #catalog ~= #installedSnaps then
        print(
            "[Gameboard] anchor spread: snap catalog mismatch (installed="
                .. tostring(#installedSnaps)
                .. " catalog="
                .. tostring(#catalog)
                .. "); Save & Play or Sync.npcs to reinstall snaps"
        )
    end
    local anchorEntry = resolveTokenSnapCatalogEntry(board, droppedToken, fuzziness, nil)
    if anchorEntry == nil then
        return { placed = 0, reason = "no_snap_match" }
    end
    if anchorEntry.isAnchor ~= true then
        return {
            placed = 0,
            reason = "not_anchor",
            matchedSnapIndex = anchorEntry.snapIndex,
            familyK = anchorEntry.familyK,
        }
    end
    for _, entry in ipairs(catalog) do
        if entry.familyId == anchorEntry.familyId and entry.isAnchor ~= true then
            local occupant = findOccupyingTokenAtSnapWorld(
                board,
                entry.worldPos,
                fuzziness,
                droppedToken
            )
            if occupant ~= nil then
                return { placed = 0, reason = "family_not_empty", groupId = groupId }
            end
        end
    end
    local members = Palette.getSortedGroupMembers(groupId)
    local byKey = buildTokenByCharacterKey()
    local toPlace = {}
    for _, member in ipairs(members) do
        local tok = byKey[member.characterKey]
        if tok ~= nil and tok ~= droppedToken and not isTokenOnControlBoardSurface(board, tok) then
            toPlace[#toPlace + 1] = {
                token = tok,
                slotIndex = member.slotIndex,
            }
        end
    end
    table.sort(toPlace, function(a, b)
        if a.slotIndex == b.slotIndex then
            return tostring(a.token.getGUID()) < tostring(b.token.getGUID())
        end
        return a.slotIndex < b.slotIndex
    end)
    local emptyFamilySnaps = {}
    for _, entry in ipairs(catalog) do
        if entry.familyId == anchorEntry.familyId and entry.isAnchor ~= true then
            emptyFamilySnaps[#emptyFamilySnaps + 1] = entry
        end
    end
    table.sort(emptyFamilySnaps, function(a, b)
        return a.familyK < b.familyK
    end)
    if #toPlace == 0 then
        return { placed = 0, reason = "nothing_to_place", groupId = groupId }
    end
    if #emptyFamilySnaps == 0 then
        return { placed = 0, reason = "family_has_no_sibling_snaps", groupId = groupId }
    end
    local boardYaw = board.getRotation().y or 0
    anchorFamilySpreadDepth = anchorFamilySpreadDepth + 1
    local placed = 0
    local limit = math.min(#toPlace, #emptyFamilySnaps)
    for i = 1, limit do
        placeTokenOnControlBoardSnap(toPlace[i].token, emptyFamilySnaps[i], board, boardYaw)
        placed = placed + 1
    end
    anchorFamilySpreadDepth = anchorFamilySpreadDepth - 1
    return { placed = placed, reason = "ok", groupId = groupId }
end

--- Global onObjectDrop hook: wait for TTS snap to settle, then try anchor-family spread.
--- @param token Object
--- @param playerColor string|nil
function Gameboard.onNpcControlTokenDropped(token, playerColor)
    if not isNpcControlToken(token) then
        return
    end
    local tokenGuid = tostring(token.getGUID() or "")
    if tokenGuid == "" or anchorDropEligibleByTokenGuid[tokenGuid] ~= true then
        return
    end
    local board = getControlBoard()
    if not isGameObject(board) then
        return
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    U.waitForCondition(
        function()
            if not isGameObject(token) then
                return
            end
            logAnchorSpreadResult(Gameboard.tryAnchorFamilyGroupSpread(token))
        end,
        function()
            if not isGameObject(token) then
                return true
            end
            if not isTokenOnControlBoardSurface(board, token) then
                return false
            end
            local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, nil)
            return entry ~= nil and entry.isAnchor == true
        end,
        1.0
    )
end

--- @param placements table|nil
function Gameboard.populateControlBoardFromPlacements(placements)
    placements = type(placements) == "table" and placements or S.getStateVal("sessionScene", "npcWorld", "placements")
    if type(placements) ~= "table" then
        placements = {}
    end
    S.setStateVal(placements, "sessionScene", "npcWorld", "placements")
    Gameboard.reconcileControlBoardFromState()
end

return Gameboard