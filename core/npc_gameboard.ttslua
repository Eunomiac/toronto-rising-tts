--[[
    Storyteller NPC gameboard: CONTROL_BOARD editor, STAGE_BOARD placement math, Apply/Clear.

    Authority: gameState.sessionScene.npcWorld.placements — never figurines directly on Apply.
    Reconcile: NPCS.reconcileAllFromState then mirror via reconcileControlBoardFromState.
]]

local Gameboard = {}

local U = require("lib.util")
local C = require("lib.constants")
local G = require("lib.guids")
local DATA = require("lib.npc_gameboard_data")
local DK = require("lib.dice_kinds")
local NPCS_DATA = require("lib.npcs_data")

--- First `require("core.state")` during luabundle registration can return nil (circular load).
--- Re-fetch until `core.state` has finished registering.
--- @type table|nil
local stateModuleCache = nil

--- @return table|nil
local function stateModule()
    if type(stateModuleCache) == "table" and type(stateModuleCache.getStateVal) == "function" then
        return stateModuleCache
    end
    local loaded = require("core.state")
    if type(loaded) == "table" then
        stateModuleCache = loaded
    end
    return loaded
end
local Palette = require("lib.npc_control_board_palette")

local TAG_TOKEN = DATA.TAG_NPC_CONTROL_TOKEN
local CONTROL_BOARD_SNAP_TAGS = DATA.CONTROL_BOARD_SNAP_TAGS
    or { TAG_TOKEN, DATA.TAG_PC_CONTROL_TOKEN or "pc_control_token" }
local TAG_PC = DATA.TAG_GAMEBOARD_PC_SEAT
local TAG_NPC_SEAT = DATA.TAG_GAMEBOARD_NPC_SEAT
local TAG_TABLE = DATA.TAG_GAMEBOARD_TABLE
local TAG_COMPONENT = DATA.TAG_GAMEBOARD_TABLE_COMPONENT
local SNAP_KIND_SEAT = "seat"

local clearArmExpireByColor = {}
local polarSnapInstallFingerprint = nil
--- @type table|nil Last config installed by installPolarSnaps (for remap baselines).
local installedPolarSnapConfig = nil
local lastControlBoardMirrorFingerprint = nil
--- @type table<string, { halfX: number, halfZ: number }>
local boardUvHalfExtentsCache = {}
--- @type table<string, boolean> token guid -> true when drop may trigger anchor-family spread.
local anchorDropEligibleByTokenGuid = {}
--- @type table<string, boolean> token guid -> picked up while on CONTROL_BOARD_PALETTE (TOR-172 palette-drop flip).
local tokenPickedUpFromPaletteGuid = {}
--- Default-config snap catalog cache: key = boardGuid:fingerprint → catalog entries.
--- @type table<string, table[]>
local defaultSnapCatalogCache = {}
--- @type table|nil Last completed interaction profile snapshot (Apply/Clear/drop).
local lastInteractionProfile = nil
--- @type table|nil In-flight profile counters for the current interaction.
local activeInteractionProfile = nil
--- Forward declaration (Lua local-function order): defined after helper dependencies.
local rebuildAnchorDropEligibilityCache
local resolveTokenSnapCatalogEntry
local isNpcSeatRowColumn
local parkVacatedNpcControlTokensToPalette
local buildTokenByCharacterKey
local controlBoardSnapFingerprintFor
--- World XZ tolerance when matching tokens to installed control-board snap points.
local CONTROL_BOARD_SNAP_MATCH_FUZZINESS = 0.45
--- Prevents recursive anchor-family spread when programmatic moves fire onObjectDrop.
local anchorFamilySpreadDepth = 0

--- @param obj Object|nil
--- @return boolean
local function isGameObject(obj)
    return U.isGameObject(obj)
end

--- @param obj Object|nil
--- @return number
local function objectYawDeg(obj)
    if not isGameObject(obj) or obj.getRotation == nil then
        return 0
    end
    local rot = obj.getRotation()
    if type(rot) ~= "table" then
        return 0
    end
    return rot.y or 0
end

--- @param board Object
--- @return number
local function snapMatchFuzzinessForBoard(board)
    if not isGameObject(board) or board.getBounds == nil then
        return CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    end
    local b = board.getBounds()
    if b == nil or b.size == nil then
        return CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    end
    local sx = b.size.x or b.size[1] or 1
    local sz = b.size.z or b.size[3] or 1
    local scaleHint = math.min(math.abs(sx), math.abs(sz))
    return math.max(CONTROL_BOARD_SNAP_MATCH_FUZZINESS, scaleHint * 0.035)
end

--- @param n number
--- @param lo number
--- @param hi number
--- @return number
local function clamp(n, lo, hi)
    if n < lo then
        return lo
    end
    if n > hi then
        return hi
    end
    return n
end

--- @param guid string|nil
--- @return Object|nil
local function objectFromGuid(guid)
    if type(guid) ~= "string" or guid == "" then
        return nil
    end
    return getObjectFromGUID(guid)
end

--- @return Object|nil
local function getStageBoard()
    return objectFromGuid(G.GUIDS.STAGE_BOARD)
end

--- @return Object|nil
local function getControlBoard()
    return objectFromGuid(G.GUIDS.CONTROL_BOARD)
end

--- @return Object|nil
local function getControlBoardPalette()
    return objectFromGuid(G.GUIDS.CONTROL_BOARD_PALETTE)
end

--- @return table
local function defaultStageWorld()
    local d = DATA.DEFAULT_STAGE_WORLD
    return {
        centerX = d.centerX,
        centerZ = d.centerZ,
        halfWidthX = d.halfWidthX,
        halfDepthZ = d.halfDepthZ,
        groundY = d.groundY,
    }
end

--- Derive world XZ extents from STAGE_BOARD bounds when present.
--- @return table
local function resolveStageWorldExtents()
    local board = getStageBoard()
    if not isGameObject(board) or board.getBounds == nil then
        return defaultStageWorld()
    end
    local b = board.getBounds()
    if b == nil or b.center == nil or b.size == nil then
        return defaultStageWorld()
    end
    local cx = b.center.x or b.center[1] or 0
    local cz = b.center.z or b.center[3] or 0
    local sx = b.size.x or b.size[1] or 1
    local sz = b.size.z or b.size[3] or 1
    local cy = b.center.y or b.center[2] or DATA.DEFAULT_STAGE_WORLD.groundY
    return {
        centerX = cx,
        centerZ = cz,
        halfWidthX = math.max(sx * 0.5, 50),
        halfDepthZ = math.max(sz * 0.5, 50),
        groundY = cy,
    }
end

--- @param a Vector
--- @param b Vector
--- @return number
local function vectorDot(a, b)
    return a.x * b.x + a.y * b.y + a.z * b.z
end

--- Custom_Tile boards use `positionToWorld` / `positionToLocal` (not `localToWorld`).
--- @param board Object
--- @param localPos Vector|table
--- @return Vector
local function boardLocalToWorld(board, localPos)
    local lp = Vector(localPos)
    if type(board.positionToWorld) == "function" then
        return board.positionToWorld(lp)
    end
    local origin = board.getPosition()
    local right = board.getTransformRight()
    local up = board.getTransformUp()
    local fwd = board.getTransformForward()
    return origin + right * lp.x + up * lp.y + fwd * lp.z
end

--- Custom_Tile `positionToLocal` / `positionToWorld` use object-local units (typically ±0.5 on X/Z for a unit tile).
--- `getBounds().size` is world-space and must not be used as the UV divisor/multiplier.
--- Derive local half-extents by projecting world bound corners through `positionToLocal`.
--- @param board Object
--- @return number halfX, number halfZ
local function boardLocalSurfaceHalfExtents(board)
    if not isGameObject(board) then
        return 0.5, 0.5
    end
    local guid = board.getGUID()
    if type(guid) == "string" and guid ~= "" then
        local cached = boardUvHalfExtentsCache[guid]
        if type(cached) == "table" and type(cached.halfX) == "number" and type(cached.halfZ) == "number" then
            return cached.halfX, cached.halfZ
        end
    end
    local halfX = 0.5
    local halfZ = 0.5
    if board.getBounds ~= nil and board.positionToLocal ~= nil then
        local b = board.getBounds()
        if b ~= nil and b.center ~= nil and b.size ~= nil then
            local cx = b.center.x or b.center[1] or 0
            local cy = b.center.y or b.center[2] or 0
            local cz = b.center.z or b.center[3] or 0
            local worldHalfX = (b.size.x or b.size[1] or 1) * 0.5
            local worldHalfZ = (b.size.z or b.size[3] or 1) * 0.5
            local cornerX = board.positionToLocal(Vector({ x = cx + worldHalfX, y = cy, z = cz }))
            local cornerZ = board.positionToLocal(Vector({ x = cx, y = cy, z = cz + worldHalfZ }))
            if cornerX ~= nil then
                halfX = math.abs(cornerX.x or 0)
            end
            if cornerZ ~= nil then
                halfZ = math.abs(cornerZ.z or 0)
            end
        end
    end
    if halfX < 0.01 then
        halfX = 0.5
    end
    if halfZ < 0.01 then
        halfZ = 0.5
    end
    if type(guid) == "string" and guid ~= "" then
        boardUvHalfExtentsCache[guid] = { halfX = halfX, halfZ = halfZ }
    end
    return halfX, halfZ
end

--- @param board Object
--- @param worldPos Vector|table
--- @return Vector|nil
local function boardWorldToLocal(board, worldPos)
    local wp = Vector(worldPos)
    if type(board.positionToLocal) == "function" then
        return board.positionToLocal(wp)
    end
    local origin = board.getPosition()
    local delta = wp - origin
    local right = board.getTransformRight()
    local up = board.getTransformUp()
    local fwd = board.getTransformForward()
    return Vector(vectorDot(delta, right), vectorDot(delta, up), vectorDot(delta, fwd))
end

--- @param board Object
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function uvFromWorldOnBoard(board, worldPos)
    if not isGameObject(board) or worldPos == nil then
        return nil, nil
    end
    local localPos = boardWorldToLocal(board, worldPos)
    if localPos == nil then
        return nil, nil
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local u = 0.5 + localPos.x / (2 * halfX)
    local v = 0.5 + localPos.z / (2 * halfZ)
    return clamp(u, 0, 1), clamp(v, 0, 1)
end

--- Tagged objects on CONTROL_BOARD surface. Custom_Tile exposes getObjects but throws on call —
--- never use `board.getObjects and board.getObjects()` (the `and` still invokes the method).
--- @param board Object
--- @param tag string
--- @return table
local function objectsOnControlBoard(board, tag)
    if not isGameObject(board) or type(tag) ~= "string" or tag == "" then
        return {}
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local margin = 2.5
    local maxLocalX = halfX * margin
    local maxLocalZ = halfZ * margin
    local out = {}
    local tagged = getObjectsWithTag(tag) or {}
    for _, obj in ipairs(tagged) do
        if isGameObject(obj) and obj.hasTag ~= nil and obj.hasTag(tag) == true then
            local localPos = boardWorldToLocal(board, obj.getPosition())
            if localPos ~= nil then
                local lx = math.abs(localPos.x or 0)
                local lz = math.abs(localPos.z or 0)
                if lx <= maxLocalX and lz <= maxLocalZ then
                    out[#out + 1] = obj
                end
            end
        end
    end
    return out
end

--- Max board-local |Y − surface| for a token to count as on the minimap (not dragged off / in the air).
local MINIMAP_TOKEN_SURFACE_Y_TOLERANCE = 0.4

--- Token on CONTROL_BOARD face (not palette): tight XZ on tile + near surface Y.
--- @param board Object
--- @param token Object
--- @return boolean
local function isTokenOnMinimapTokenSurface(board, token)
    if not isGameObject(board) or not isGameObject(token) then
        return false
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
        return false
    end
    local localPos = boardWorldToLocal(board, token.getPosition())
    if localPos == nil then
        return false
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local xzMargin = 1.05
    if math.abs(localPos.x or 0) > halfX * xzMargin or math.abs(localPos.z or 0) > halfZ * xzMargin then
        return false
    end
    local surfaceY = tonumber(DATA.MINIMAP_SURFACE_LOCAL_Y) or 0.18
    if math.abs((localPos.y or 0) - surfaceY) > MINIMAP_TOKEN_SURFACE_Y_TOLERANCE then
        return false
    end
    return true
end

--- Token on CONTROL_BOARD minimap (not palette): loose XZ (2.5× tile) — drop handlers, snap settle, scans.
--- Does not require surface Y (tokens mid-snap or seat scale still count as on-board).
--- @param board Object
--- @param token Object
--- @return boolean
local function isTokenOnControlBoardSurface(board, token)
    if not isGameObject(board) or not isGameObject(token) then
        return false
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
        return false
    end
    for _, obj in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if obj == token then
            return true
        end
    end
    return false
end

--- Same XZ band as `isTokenOnControlBoardSurface` plus surface Y — Clear parking / stray recovery only.
--- Off-world tokens under the board footprint are not treated as on-board.
--- @param board Object
--- @param token Object
--- @return boolean
local function isTokenOnControlBoardFace(board, token)
    if not isGameObject(board) or not isGameObject(token) then
        return false
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
        return false
    end
    local localPos = boardWorldToLocal(board, token.getPosition())
    if localPos == nil then
        return false
    end
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local margin = 2.5
    if math.abs(localPos.x or 0) > halfX * margin or math.abs(localPos.z or 0) > halfZ * margin then
        return false
    end
    local surfaceY = tonumber(DATA.MINIMAP_SURFACE_LOCAL_Y) or 0.18
    if math.abs((localPos.y or 0) - surfaceY) > MINIMAP_TOKEN_SURFACE_Y_TOLERANCE then
        return false
    end
    return true
end

--- @param board Object
--- @param u number
--- @param v number
--- @return Vector local position on board surface (Y slightly above tile)
--- @param board Object
--- @param u number
--- @param v number
--- @param extraLocalY number|nil Additional lift in board-local Y (e.g. table mesh thickness)
local function boardLocalFromUv(board, u, v, extraLocalY)
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local surfaceY = tonumber(DATA.MINIMAP_SURFACE_LOCAL_Y) or 0.18
    local lift = tonumber(extraLocalY) or 0
    return Vector((u - 0.5) * 2 * halfX, surfaceY + lift, (v - 0.5) * 2 * halfZ)
end

--- Inverse of `boardLocalFromUv` for surface XZ (ignores local Y).
--- @param board Object
--- @param localPos Vector|table
--- @return number u, number v
local function uvFromBoardLocal(board, localPos)
    local halfX, halfZ = boardLocalSurfaceHalfExtents(board)
    local lx = localPos.x or localPos[1] or 0
    local lz = localPos.z or localPos[3] or 0
    return 0.5 + lx / (2 * halfX), 0.5 + lz / (2 * halfZ)
end

--- Extent-based fallback when STAGE_BOARD is not in the save (workshop prep).
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function uvFromWorldFallbackExtents(worldPos)
    if worldPos == nil then
        return nil, nil
    end
    local ext = resolveStageWorldExtents()
    local x = worldPos.x or worldPos[1]
    local z = worldPos.z or worldPos[3]
    if type(x) ~= "number" or type(z) ~= "number" then
        return nil, nil
    end
    local u = 0.5 + (x - ext.centerX) / (2 * ext.halfWidthX)
    local v = 0.5 + (z - ext.centerZ) / (2 * ext.halfDepthZ)
    return clamp(u, 0, 1), clamp(v, 0, 1)
end

--- Normalized map UV (0–1) from a world position using STAGE_BOARD as the canonical minimap.
--- CONTROL_BOARD uses the same u,v via worldOnControlBoard; do not project world XZ through CONTROL_BOARD.
--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
local function normalizedUvFromWorld(worldPos)
    if worldPos == nil then
        return nil, nil
    end
    local stage = getStageBoard()
    if isGameObject(stage) then
        return uvFromWorldOnBoard(stage, worldPos)
    end
    return uvFromWorldFallbackExtents(worldPos)
end

--- World position for figurine placement from normalized u/v on STAGE_BOARD.
--- X/Z come from STAGE_BOARD `positionToWorld`; `groundLevel` when set is **absolute world Y** (not board-local).
--- @param u number
--- @param v number
--- @param options table|nil `{ groundLevel?: number }` absolute world Y from snap ring (optional)
--- @return Vector
function Gameboard.worldFromUv(u, v, options)
    options = type(options) == "table" and options or {}
    local worldY = tonumber(options.groundLevel)
    local stage = getStageBoard()
    if isGameObject(stage) then
        local lp = boardLocalFromUv(stage, u, v)
        local wp = boardLocalToWorld(stage, lp)
        if worldY ~= nil then
            return Vector(wp.x, worldY, wp.z)
        end
        return wp
    end
    print("[Gameboard] worldFromUv: STAGE_BOARD missing (GUID "
        .. tostring(G.GUIDS.STAGE_BOARD)
        .. ") — using DEFAULT_STAGE_WORLD fallback")
    local ext = resolveStageWorldExtents()
    local x = ext.centerX + (u - 0.5) * 2 * ext.halfWidthX
    local z = ext.centerZ + (v - 0.5) * 2 * ext.halfDepthZ
    local y = worldY ~= nil and worldY or ext.groundY
    return Vector(x, y, z)
end

--- World Y rotation for a figurine on STAGE_BOARD at u,v (master-origin facing; ignores stored placement yaw).
--- @param placementYaw number|nil Legacy / unused when u,v supplied via caller; kept for API compat.
--- @return number
function Gameboard.stageFigurineWorldYawDeg(placementYaw)
    local stageYaw = Gameboard.getStageBoardYawDeg()
    local rel = tonumber(placementYaw) or 0
    local offset = tonumber(DATA.STAGE_FIGURINE_YAW_OFFSET_DEG) or 0
    return (stageYaw + rel + offset) % 360
end

--- STAGE_BOARD world Y rotation (degrees), or 0 when the board object is missing.
--- @return number
function Gameboard.getStageBoardYawDeg()
    local stage = getStageBoard()
    return objectYawDeg(stage)
end

--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
function Gameboard.uvFromWorldFallback(worldPos)
    return uvFromWorldFallbackExtents(worldPos)
end

--- @param worldPos Vector|table
--- @return number|nil u, number|nil v
function Gameboard.uvFromWorld(worldPos)
    return normalizedUvFromWorld(worldPos)
end

--- @param board Object
--- @param u number
--- @param v number
--- @param options table|nil { extraLocalY?: number }
--- @return Vector world position on CONTROL_BOARD surface (same u,v as STAGE_BOARD map)
function Gameboard.worldOnControlBoard(board, u, v, options)
    if not isGameObject(board) then
        return Vector(0, 0, 0)
    end
    local extraLocalY = options and options.extraLocalY or nil
    return boardLocalToWorld(board, boardLocalFromUv(board, u, v, extraLocalY))
end

--- @param obj Object
--- @return string|nil
local function readMarkerKey(obj, prefix)
    if not isGameObject(obj) then
        return nil
    end
    local notes = ""
    if obj.getGMNotes ~= nil then
        notes = tostring(obj.getGMNotes() or "")
    end
    if notes == "" and obj.getDescription ~= nil then
        notes = tostring(obj.getDescription() or "")
    end
    local key = string.match(notes, "^" .. prefix .. "([^,\r\n]+)")
    if type(key) == "string" then
        key = string.match(key, "^%s*(.-)%s*$")
    end
    if type(key) == "string" and key ~= "" then
        return key
    end
    return nil
end

--- @param compKey string|nil Raw value after `gameboardComponent:` prefix
--- @return string|nil parentTable, string|nil componentName
local function parseComponentMarkerKey(compKey)
    if type(compKey) ~= "string" or compKey == "" then
        return nil, nil
    end
    compKey = string.match(compKey, "^%s*(.-)%s*$") or compKey
    local pipeAt = compKey:find("|", 1, true)
    if pipeAt ~= nil then
        local parentTable = string.match(compKey:sub(1, pipeAt - 1), "^%s*(.-)%s*$")
        local componentName = string.match(compKey:sub(pipeAt + 1), "^%s*(.-)%s*$")
        if type(parentTable) == "string" and parentTable ~= ""
            and type(componentName) == "string" and componentName ~= "" then
            return parentTable, componentName
        end
    end
    for tk, cfg in pairs(C.Tables or {}) do
        if type(cfg) == "table" and type(cfg.components) == "table" and cfg.components[compKey] ~= nil then
            return tk, compKey
        end
    end
    return nil, compKey
end

--- @param obj Object
--- @return string|nil characterKey
local function resolveTokenCharacterKey(obj)
    if not isGameObject(obj) then
        return nil
    end
    local key = readMarkerKey(obj, DATA.TOKEN_GM_PREFIX)
    if key ~= nil then
        return key
    end
    if obj.getName ~= nil then
        local name = tostring(obj.getName() or "")
        if name ~= "" then
            return name
        end
    end
    return nil
end

--- @param obj Object|nil
--- @return boolean
local function isNpcControlToken(obj)
    return isGameObject(obj) and obj.hasTag ~= nil and obj.hasTag(TAG_TOKEN) == true
end

--- Live control token for a character key (CONTROL_BOARD or palette).
--- @param characterKey string
--- @return Object|nil
local function controlTokenForCharacterKey(characterKey)
    if type(characterKey) ~= "string" or characterKey == "" then
        return nil
    end
    for _, obj in ipairs(getObjectsWithTag(TAG_TOKEN) or {}) do
        if isGameObject(obj) and resolveTokenCharacterKey(obj) == characterKey then
            return obj
        end
    end
    return nil
end

--- Unassign homeland seats when the character's token is not on the CONTROL_BOARD minimap (palette / off-board = out of play).
--- @param board Object|nil
--- @return boolean changed
local function releaseHomelandSeatsForOffBoardTokens(board)
    board = board or getControlBoard()
    if not isGameObject(board) then
        return false
    end
    local NPCS = require("core.npcs")
    local occupied = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(occupied) ~= "table" then
        return false
    end
    local changed = false
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local ck = occupied[seatKey]
        if type(ck) == "string" and ck ~= "" then
            local token = controlTokenForCharacterKey(ck)
            local onBoard = isGameObject(token) and isTokenOnControlBoardSurface(board, token)
            if not onBoard then
                local ok, err = NPCS.unseatNpc(ck)
                if not ok then
                    print(
                        "[Gameboard] release homeland seat (token off board): "
                            .. tostring(ck)
                            .. ": "
                            .. tostring(err)
                    )
                else
                    changed = true
                end
            end
        end
    end
    if changed then
        print("[Gameboard] homeland seat(s) released — token not on CONTROL_BOARD")
    end
    return changed
end

--- @param deg number|nil
--- @return boolean true when axis reads as flipped (~180°)
local function eulerAxisFlippedDeg(deg)
    local norm = ((tonumber(deg) or 0) % 360 + 360) % 360
    return norm > 90 and norm < 270
end

--- Custom_Tile (and similar) have no `is_face_up` field — reading it throws.
--- Prefer transform up-vector sign; flip is Z=180 (TTS Flip key). Legacy tokens may have X=180.
--- @param token Object
--- @return boolean
local function tokenRotationIsFaceUp(token)
    if not U.isGameObject(token) then
        return true
    end
    if type(token.getTransformUp) == "function" then
        local up = token.getTransformUp()
        if up ~= nil then
            local uy = up.y or up[2]
            if type(uy) == "number" then
                return uy >= 0
            end
        end
    end
    if type(token.getRotation) ~= "function" then
        return true
    end
    local rot = token.getRotation()
    if rot == nil then
        return true
    end
    if eulerAxisFlippedDeg(rot.z) or eulerAxisFlippedDeg(rot.x) then
        return false
    end
    return true
end

--- @param token Object
--- @return string OFF|STANDARD
local function tokenLightModeFromFlip(token)
    if tokenRotationIsFaceUp(token) then
        return "STANDARD"
    end
    return "OFF"
end

--- Board-plane yaw on Y; flip (face up/down) on Z only — independent axes for control tokens.
--- @param boardYaw number
--- @param yawDeg number
--- @param faceUp boolean
--- @return Vector
local function rotationForNpcControlToken(boardYaw, yawDeg, faceUp)
    local rz = faceUp and 0 or 180
    return Vector(0, boardYaw + (yawDeg or 0), rz)
end

local TOKEN_SCALE_MATCH_EPS = 0.02

--- @param token Object
--- @param sx number
--- @param sy number
--- @param sz number
--- @return boolean
local function tokenScaleIsNear(token, sx, sy, sz)
    if not isGameObject(token) or token.getScale == nil then
        return false
    end
    local s = token.getScale()
    if s == nil then
        return false
    end
    return math.abs((s.x or 0) - sx) <= TOKEN_SCALE_MATCH_EPS
        and math.abs((s.y or 0) - sy) <= TOKEN_SCALE_MATCH_EPS
        and math.abs((s.z or 0) - sz) <= TOKEN_SCALE_MATCH_EPS
end

--- @param token Object
--- @param sx number
--- @param sy number
--- @param sz number
local function setNpcControlTokenScale(token, sx, sy, sz)
    if isGameObject(token) and token.setScale ~= nil then
        token.setScale({ x = sx, y = sy, z = sz })
    end
end

--- Revert enlarged seat-row token scale when leaving seat snaps (TOR-199).
--- @param token Object
--- @return boolean true when scale was changed
local function ensureDefaultNpcControlTokenScale(token)
    local d = DATA.NPC_CONTROL_TOKEN_SCALE_POLAR
    if not tokenScaleIsNear(token, d.x, d.y, d.z) then
        setNpcControlTokenScale(token, d.x, d.y, d.z)
        return true
    end
    return false
end

--- @param token Object
local function applySeatRowNpcControlTokenScale(token)
    local s = DATA.NPC_CONTROL_TOKEN_SCALE_SEAT_ROW
    if not tokenScaleIsNear(token, s.x, s.y, s.z) then
        setNpcControlTokenScale(token, s.x, s.y, s.z)
    end
end

--- @param board Object
--- @param u number
--- @param v number
--- @return boolean
local function isNearSeatRowUv(board, u, v)
    if not isGameObject(board) or type(u) ~= "number" or type(v) ~= "number" then
        return false
    end
    local seatCfg = DATA.CONTROL_BOARD_SEAT_ROW
    if type(seatCfg) ~= "table" then
        return false
    end
    local rowV = tonumber(seatCfg.v) or 0.15
    local uMin = tonumber(seatCfg.uMin) or 0.35
    local uMax = tonumber(seatCfg.uMax) or 0.65
    return math.abs(v - rowV) <= 0.08 and u >= (uMin - 0.05) and u <= (uMax + 0.05)
end

--- Programmatic mirror onto a seat-row catalog entry (Apply / Clear / reconcile — manual drops use `rotation_snap` only).
--- @param token Object
--- @param board Object
--- @param entry table catalog entry with `u`, `v`, `yawDeg`
--- @param faceUp boolean|nil narrative presence; default from token flip
local function mirrorSeatRowControlToken(token, board, entry, faceUp)
    if not isGameObject(token) or not isGameObject(board) or type(entry) ~= "table" then
        return
    end
    if faceUp == nil then
        faceUp = tokenRotationIsFaceUp(token)
    end
    token.setPosition(Gameboard.worldOnControlBoard(board, entry.u, entry.v))
    applySeatRowNpcControlTokenScale(token)
    local boardYaw = objectYawDeg(board)
    token.setRotation(rotationForNpcControlToken(boardYaw, entry.yawDeg, faceUp))
    Gameboard.setHiddenFromPlayerColors(token)
end

--- @param token Object
--- @param board Object
--- @return number|nil u, number|nil v, number|nil yaw
local function tokenPlacementOnBoard(token, board)
    if not isGameObject(token) or not isGameObject(board) then
        return nil, nil, nil
    end
    local u, v = uvFromWorldOnBoard(board, token.getPosition())
    local boardYaw = objectYawDeg(board)
    local tokenYaw = objectYawDeg(token)
    local yaw = ((tokenYaw - boardYaw) % 360 + 360) % 360
    return u, v, yaw
end

--- @param reason string
local function beginInteractionProfile(reason)
    activeInteractionProfile = {
        reason = reason,
        catalog_builds = 0,
        tag_scans = 0,
        startedAt = os.clock(),
    }
end

--- @param t0 number os.clock at interaction start
local function finishInteractionProfile(t0)
    if type(activeInteractionProfile) ~= "table" then
        return
    end
    activeInteractionProfile.phaseA_ms = (os.clock() - (t0 or activeInteractionProfile.startedAt)) * 1000
    lastInteractionProfile = activeInteractionProfile
    activeInteractionProfile = nil
end

--- @param count number|nil defaults to 1
local function noteInteractionTagScan(count)
    if type(activeInteractionProfile) ~= "table" then
        return
    end
    activeInteractionProfile.tag_scans = (activeInteractionProfile.tag_scans or 0) + (tonumber(count) or 1)
end

--- NPC seat-row tokens on CONTROL_BOARD (`snapKind = seat`, `kind = npc` columns only).
--- @param board Object
--- @return table<string, table> seatKey -> `{ seatKey, characterKey, present }`
local function scanSeatRowTokensBySeatKey(board)
    local out = {}
    if not isGameObject(board) then
        return out
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    for _, obj in ipairs(getObjectsWithTag(TAG_TOKEN) or {}) do
        if isGameObject(obj) and isTokenOnMinimapTokenSurface(board, obj) then
            local characterKey = resolveTokenCharacterKey(obj)
            if type(characterKey) == "string" and characterKey ~= "" then
                local entry = resolveTokenSnapCatalogEntry(board, obj, fuzziness, nil)
                if type(entry) == "table"
                    and entry.snapKind == SNAP_KIND_SEAT
                    and isNpcSeatRowColumn({ seatKey = entry.seatKey, kind = "npc" }) then
                    out[entry.seatKey] = {
                        seatKey = entry.seatKey,
                        characterKey = characterKey,
                        present = tokenRotationIsFaceUp(obj),
                    }
                end
            end
        end
    end
    return out
end

--- @param board Object
--- @return table[] rows with characterKey, u, v, yaw, npcLightMode (polar/stage snaps only; not seat row)
function Gameboard.scanControlBoardTokens(board)
    board = board or getControlBoard()
    local out = {}
    if not isGameObject(board) then
        print("[Gameboard] scan: CONTROL_BOARD missing (GUID " .. tostring(G.GUIDS.CONTROL_BOARD) .. ")")
        return out
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    noteInteractionTagScan(1)
    for _, obj in ipairs(getObjectsWithTag(TAG_TOKEN) or {}) do
        if isGameObject(obj) and isTokenOnMinimapTokenSurface(board, obj) then
            local characterKey = resolveTokenCharacterKey(obj)
            if type(characterKey) == "string" and characterKey ~= "" then
                local u, v, _ = tokenPlacementOnBoard(obj, board)
                if type(u) == "number" and type(v) == "number" then
                    local entry = resolveTokenSnapCatalogEntry(board, obj, fuzziness, nil)
                    if type(entry) == "table" and entry.snapKind == SNAP_KIND_SEAT then
                        -- Seat row: assign/presence via `applySeatRowFromControlBoard`, not `placements`.
                    else
                        local groundLevel = Gameboard.groundLevelForSnapUv(u, v)
                        local row = {
                            characterKey = characterKey,
                            u = u,
                            v = v,
                            yaw = Gameboard.placementBoardRelYawDeg(u, v),
                            npcLightMode = tokenLightModeFromFlip(obj),
                        }
                        if groundLevel ~= nil then
                            row.groundLevel = groundLevel
                        end
                        out[#out + 1] = row
                    end
                end
            end
        end
    end
    return out
end

--- @param row table|nil
--- @return table|nil normalized row for comparison
local function normalizePlacementRow(row)
    if type(row) ~= "table" then
        return nil
    end
    local u = tonumber(row.u)
    local v = tonumber(row.v)
    if u == nil or v == nil then
        return nil
    end
    local out = {
        u = u,
        v = v,
        yaw = tonumber(row.yaw) or 0,
        npcLightMode = row.npcLightMode,
    }
    local groundLevel = tonumber(row.groundLevel)
    if groundLevel ~= nil then
        out.groundLevel = groundLevel
    end
    if out.npcLightMode ~= "OFF" and out.npcLightMode ~= "STANDARD" and out.npcLightMode ~= "SPOTLIGHT" then
        out.npcLightMode = "STANDARD"
    end
    return out
end

--- @param a table|nil
--- @param b table|nil
--- @return boolean
local function placementRowsEqual(a, b)
    local na = normalizePlacementRow(a)
    local nb = normalizePlacementRow(b)
    if na == nil or nb == nil then
        return false
    end
    if math.abs(na.u - nb.u) > 0.0001 or math.abs(na.v - nb.v) > 0.0001 then
        return false
    end
    if math.abs(na.yaw - nb.yaw) > 0.5 then
        return false
    end
    if na.npcLightMode ~= nb.npcLightMode then
        return false
    end
    return (na.groundLevel or nil) == (nb.groundLevel or nil)
end

--- @param nextMap table|nil
--- @param prevMap table|nil
--- @return boolean
local function placementsMapsEqual(nextMap, prevMap)
    nextMap = type(nextMap) == "table" and nextMap or {}
    prevMap = type(prevMap) == "table" and prevMap or {}
    local keys = {}
    local seen = {}
    for key in pairs(nextMap) do
        if type(key) == "string" and key ~= "" then
            keys[#keys + 1] = key
            seen[key] = true
        end
    end
    for key in pairs(prevMap) do
        if type(key) == "string" and key ~= "" and not seen[key] then
            keys[#keys + 1] = key
            seen[key] = true
        end
    end
    table.sort(keys)
    for _, key in ipairs(keys) do
        if not placementRowsEqual(nextMap[key], prevMap[key]) then
            return false
        end
    end
    return true
end

--- Fingerprint for static marker + token mirror work on CONTROL_BOARD.
--- @param activeTable string|nil
--- @param layoutLocked boolean
--- @param placements table|nil
--- @return string
local function controlBoardMirrorFingerprint(activeTable, layoutLocked, placements)
    local lines = {}
    lines[#lines + 1] = "table:" .. tostring(activeTable or "")
    lines[#lines + 1] = "lock:" .. tostring(layoutLocked == true)
    local slots = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(slots) == "table" then
        for _, seatKey in ipairs(C.NPCSeats or {}) do
            lines[#lines + 1] = "occ:" .. seatKey .. "=" .. tostring(slots[seatKey] or "")
        end
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local NPCS = require("core.npcs")
        local present = true
        if type(NPCS.resolveSeatNarrativePresence) == "function" then
            present = NPCS.resolveSeatNarrativePresence(seatKey) == true
        end
        lines[#lines + 1] = "present:" .. seatKey .. "=" .. tostring(present)
    end
    placements = type(placements) == "table" and placements or {}
    local keys = {}
    for key in pairs(placements) do
        if type(key) == "string" and key ~= "" then
            keys[#keys + 1] = key
        end
    end
    table.sort(keys)
    for _, characterKey in ipairs(keys) do
        local row = normalizePlacementRow(placements[characterKey])
        if row ~= nil then
            lines[#lines + 1] = string.format(
                "p:%s:%.4f:%.4f:%.1f:%s:%s",
                characterKey,
                row.u,
                row.v,
                row.yaw,
                row.npcLightMode or "",
                tostring(row.groundLevel or "")
            )
        end
    end
    return table.concat(lines, "\n")
end

--- Build placements map from scan rows.
--- @param rows table[]
--- @return table
local function placementsMapFromRows(rows)
    local placements = {}
    for _, row in ipairs(rows) do
        if type(row.characterKey) == "string" then
            placements[row.characterKey] = {
                u = row.u,
                v = row.v,
                yaw = row.yaw,
                npcLightMode = row.npcLightMode,
                groundLevel = row.groundLevel,
            }
        end
    end
    return placements
end

--- @param placements table|nil
--- @return number
local function placementsCount(placements)
    if type(placements) ~= "table" then
        return 0
    end
    local n = 0
    for _, row in pairs(placements) do
        if type(row) == "table" then
            n = n + 1
        end
    end
    return n
end

--- Shared fast Sync.npcs path used by control-board interactions.
--- Orchestrator fingerprint skip (npcReconcileFingerprint) applies when force is false.
--- RSL layout force inside commitNpcSeatLayout (TOR-210) is separate and unchanged.
--- @param reason string
--- @param opts table|nil `{ seatMutation?: boolean, placementMutation?: boolean }`
local function syncNpcsFromControlBoard(reason, opts)
    opts = type(opts) == "table" and opts or {}
    local seatMutation = opts.seatMutation == true
    local placementMutation = opts.placementMutation == true
    local Sync = require("core.sync")
    --- Clear: vacate off-board homelands first; on-board homelands re-seat via Step Three (TOR-178).
    --- Placement-only Apply (seat → stage) needs Steps Three–Four for homeland chair/lights (TOR-178).
    local onlySteps = { 1, 5 }
    if seatMutation or placementMutation or reason == "gameboard_clear" then
        onlySteps = { 1, 2, 3, 4, 5 }
    end
    Sync.npcs({
        reason = reason,
        force = false,
        onlySteps = onlySteps,
        deferUiRefresh = true,
        skipPreloadPopulate = true,
        animateStageMoves = reason == "gameboard_apply",
    })
end

--- @return table|nil
function Gameboard.getLastInteractionProfile()
    return lastInteractionProfile
end

--- Clear profile snapshot (does not affect catalog cache).
function Gameboard.resetInteractionProfile()
    lastInteractionProfile = nil
    activeInteractionProfile = nil
end

--- @param board Object|nil When nil, clears entire default-config catalog cache.
local function invalidateDefaultSnapCatalogCache(board)
    if not isGameObject(board) then
        defaultSnapCatalogCache = {}
        return
    end
    local guidPrefix = tostring(board.getGUID()) .. ":"
    local nextCache = {}
    for key, catalog in pairs(defaultSnapCatalogCache) do
        if type(key) ~= "string" or string.sub(key, 1, #guidPrefix) ~= guidPrefix then
            nextCache[key] = catalog
        end
    end
    defaultSnapCatalogCache = nextCache
end

--- True when an empty NPC seat snap should clear `occupiedNPCSlots` on Apply.
--- Keep assignment only while the token remains on the CONTROL_BOARD minimap (polar/stage snap this scan).
--- Palette and off-board tokens do not retain a homeland seat.
--- @param characterKey string
--- @param polarOnBoardByCharacter table<string, boolean>
--- @return boolean
local function shouldUnassignNpcSeatWhenSnapEmpty(characterKey, polarOnBoardByCharacter)
    if type(characterKey) ~= "string" or characterKey == "" then
        return false
    end
    if polarOnBoardByCharacter[characterKey] == true then
        return false
    end
    return true
end

--- Seat-row Apply: assign/unassign NPC seats and narrative presence from seat snaps (TOR-180).
--- @param board Object
--- @param polarOnBoardByCharacter table<string, boolean> characters on polar snaps (live scan)
--- @return boolean changed, string[] vacatedCharacterKeys
local function applySeatRowFromControlBoard(board, polarOnBoardByCharacter)
    polarOnBoardByCharacter = type(polarOnBoardByCharacter) == "table" and polarOnBoardByCharacter or {}
    local bySeat = scanSeatRowTokensBySeatKey(board)
    local NPCS = require("core.npcs")
    local occupied = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(occupied) ~= "table" then
        occupied = {}
    end
    local changed = false
    local vacatedKeys = {}
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local scan = bySeat[seatKey]
        local current = occupied[seatKey]
        if type(current) ~= "string" or current == "" then
            current = nil
        end
        if scan == nil then
            if current ~= nil and shouldUnassignNpcSeatWhenSnapEmpty(current, polarOnBoardByCharacter) then
                local ok, err = NPCS.unseatNpc(current)
                if not ok then
                    print("[Gameboard] Apply seat row: unseat " .. tostring(current) .. ": " .. tostring(err))
                else
                    changed = true
                    vacatedKeys[#vacatedKeys + 1] = current
                end
            end
        else
            local ck = scan.characterKey
            if current ~= ck then
                local ok, err = NPCS.assignNpcToSeat(ck, seatKey, { deferLayoutSync = true })
                if not ok then
                    print("[Gameboard] Apply seat row: assign " .. tostring(ck) .. " → " .. seatKey .. ": " .. tostring(err))
                else
                    changed = true
                end
            end
            local wantPresent = scan.present == true
            local wasPresent = NPCS.resolveSeatNarrativePresence(seatKey)
            if wantPresent ~= wasPresent then
                NPCS.setNpcSeatNarrativePresence(seatKey, wantPresent)
                changed = true
            end
        end
    end
    if changed then
        print("[Gameboard] Apply: seat row updated")
    end
    return changed, vacatedKeys
end

--- Apply CONTROL_BOARD tokens → state → Sync.npcs.
--- @return boolean ok, string|nil message
function Gameboard.applyFromControlBoard()
    beginInteractionProfile("apply")
    local t0 = os.clock()
    local board = getControlBoard()
    if not isGameObject(board) then
        finishInteractionProfile(t0)
        return false, "CONTROL_BOARD not found — set G.GUIDS.CONTROL_BOARD in lib/guids.ttslua"
    end
    local rows = Gameboard.scanControlBoardTokens(board)
    local polarOnBoardByCharacter = {}
    for _, row in ipairs(rows) do
        if type(row.characterKey) == "string" then
            polarOnBoardByCharacter[row.characterKey] = true
        end
    end
    local seatChanged, vacatedKeys = applySeatRowFromControlBoard(board, polarOnBoardByCharacter)
    local placements = placementsMapFromRows(rows)
    if seatChanged and type(vacatedKeys) == "table" then
        for i = 1, #vacatedKeys do
            local ck = vacatedKeys[i]
            if type(ck) == "string" and polarOnBoardByCharacter[ck] ~= true then
                placements[ck] = nil
            end
        end
    end
    local existing = stateModule().getStateVal("sessionScene", "npcWorld", "placements")
    local placementChanged = not placementsMapsEqual(placements, existing)
    if not seatChanged and not placementChanged then
        print("[Gameboard] Apply: placements and seat row unchanged — skipped figurine reconcile")
        finishInteractionProfile(t0)
        return true, nil
    end
    if placementChanged then
        stateModule().setStateVal(placements, "sessionScene", "npcWorld", "placements")
    end
    if seatChanged and type(vacatedKeys) == "table" and #vacatedKeys > 0 then
        parkVacatedNpcControlTokensToPalette(vacatedKeys, board)
        lastControlBoardMirrorFingerprint = nil
    elseif seatChanged then
        lastControlBoardMirrorFingerprint = nil
    end
    syncNpcsFromControlBoard("gameboard_apply", {
        seatMutation = seatChanged,
        placementMutation = placementChanged,
    })
    print(
        "[Gameboard] Apply: "
            .. tostring(#rows)
            .. " stage token(s)"
            .. (seatChanged and "; seat row" or "")
            .. " → Sync.npcs"
    )
    finishInteractionProfile(t0)
    return true, nil
end

--- Remove tokens from control board and clear placements in state.
--- @return boolean ok, string|nil message
function Gameboard.clearControlBoard()
    beginInteractionProfile("clear")
    local t0 = os.clock()
    local hadPlacements = placementsCount(stateModule().getStateVal("sessionScene", "npcWorld", "placements")) > 0
    if hadPlacements then
        stateModule().setStateVal({}, "sessionScene", "npcWorld", "placements")
    end
    local board = getControlBoard()
    local seatReleased = releaseHomelandSeatsForOffBoardTokens(board)
    local palette = getControlBoardPalette()
    local moved = 0
    if isGameObject(palette) then
        moved = Palette.syncTokensToPalette(palette, {
            skipParkIf = function(token, ck)
                if not isGameObject(board) then
                    return false
                end
                if not isTokenOnControlBoardFace(board, token) then
                    return false
                end
                if type(ck) ~= "string" or ck == "" then
                    return false
                end
                local fuzz = snapMatchFuzzinessForBoard(board)
                local entry = resolveTokenSnapCatalogEntry(board, token, fuzz, nil)
                if type(entry) == "table"
                    and entry.snapKind == SNAP_KIND_SEAT
                    and entry.columnKind == "pc" then
                    return true
                end
                local occupied = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
                if type(occupied) ~= "table" then
                    return false
                end
                for _, assigned in pairs(occupied) do
                    if assigned == ck then
                        return type(entry) == "table" and entry.snapKind == SNAP_KIND_SEAT
                    end
                end
                return false
            end,
        })
        if isGameObject(board) then
            Gameboard.relocateHomelandSeatTokensAfterClear(board)
        end
        if hadPlacements then
            print("[Gameboard] Clear: placements emptied; " .. tostring(moved) .. " token(s) parked on palette")
        else
            print("[Gameboard] Clear: placements already empty; " .. tostring(moved) .. " token(s) parked on palette")
        end
    else
        if hadPlacements then
            print("[Gameboard] Clear: placements emptied (CONTROL_BOARD_PALETTE missing — tokens not parked)")
        else
            print("[Gameboard] Clear: placements already empty (CONTROL_BOARD_PALETTE missing — tokens not parked)")
        end
    end
    if not hadPlacements and moved == 0 and not seatReleased then
        print("[Gameboard] Clear: no state/token changes — skipped figurine sync")
        Gameboard.reconcileControlBoardFromState({ force = true })
        finishInteractionProfile(t0)
        return true, nil
    end
    syncNpcsFromControlBoard("gameboard_clear")
    finishInteractionProfile(t0)
    return true, nil
end

--- Return lost tokens (not on CONTROL_BOARD or palette) to palette parking slots.
--- Used by console / tooling; confirmed Clear parks via `Palette.syncTokensToPalette`.
--- @return number moved
function Gameboard.recoverStrayNpcTokensToPalette()
    local palette = getControlBoardPalette()
    local board = getControlBoard()
    if not isGameObject(palette) then
        return 0
    end
    return Palette.recoverStrayTokensToPalette(palette, {
        isOnControlBoard = function(token)
            return isGameObject(board) and isTokenOnControlBoardFace(board, token)
        end,
    })
end

--- Park all NPC control tokens on CONTROL_BOARD_PALETTE (group layout from npcs_data).
--- @param options table|nil Forwarded to `Palette.syncTokensToPalette` (e.g. `skipParkIf`).
--- @return number moved
function Gameboard.syncTokensToPalette(options)
    local palette = getControlBoardPalette()
    if not isGameObject(palette) then
        print("[Gameboard] syncTokensToPalette: CONTROL_BOARD_PALETTE missing (GUID " .. tostring(G.GUIDS.CONTROL_BOARD_PALETTE) .. ")")
        return 0
    end
    return Palette.syncTokensToPalette(palette, options)
end

--- Install palette snaps (one per token parking slot, not full 20×40 grid).
--- @param board Object|nil
--- @param options table|nil { force?: boolean }
--- @return boolean
function Gameboard.installPaletteSnaps(board, options)
    board = board or getControlBoardPalette()
    return Palette.installSnaps(board, options)
end

--- @param playerColor string|nil
--- @return boolean consumed second click
function Gameboard.tryConfirmClear(playerColor)
    local color = type(playerColor) == "string" and playerColor or "Black"
    local now = os.time()
    if clearArmExpireByColor[color] == nil or now > clearArmExpireByColor[color] then
        clearArmExpireByColor[color] = now + 5
        if broadcastToColor ~= nil then
            broadcastToColor("Click Clear again within 5s to confirm.", color, { 1, 0.35, 0.35 })
        end
        return false
    end
    clearArmExpireByColor[color] = nil
    return true
end

--- PC seat colors only — Storyteller (Black) and spectators (White/Grey) still see control-board pieces.
--- @return string[]
local function playerColorsHiddenFromControlBoard()
    return C.PlayerColors or {}
end

--- Tokens and markers on CONTROL_BOARD are never visible to seated players.
--- @param obj Object|nil
function Gameboard.setHiddenFromPlayerColors(obj)
    if not isGameObject(obj) or obj.setInvisibleTo == nil then
        return
    end
    obj.setInvisibleTo(playerColorsHiddenFromControlBoard())
end

--- @param obj Object
--- @param activeForLayout boolean When false, marker is not positioned for the active table (still PC-hidden).
local function setMarkerVisible(obj, activeForLayout)
    if not isGameObject(obj) then
        return
    end
    Gameboard.setHiddenFromPlayerColors(obj)
end

local CONTROL_BOARD_COMPONENT_TAGS = {
    TAG_TABLE,
    TAG_PC,
    TAG_NPC_SEAT,
    TAG_COMPONENT,
    TAG_TOKEN,
}

--- Re-apply PC-only invisibility on every control-board marker and token.
local function applyControlBoardComponentPlayerInvisibility()
    for _, tag in ipairs(CONTROL_BOARD_COMPONENT_TAGS) do
        local objs = getObjectsWithTag(tag) or {}
        for _, obj in ipairs(objs) do
            Gameboard.setHiddenFromPlayerColors(obj)
        end
    end
end

--- @param tableKey string|nil
--- @return table|nil
local function tableConfig(tableKey)
    if type(tableKey) ~= "string" then
        return nil
    end
    return C.Tables[tableKey]
end

--- True when `seatLayout.occupiedNPCSlots[seatKey]` holds a character key (not false).
--- @param seatKey string
--- @return boolean
local function npcSeatOccupiedOnTable(seatKey)
    if type(seatKey) ~= "string" or seatKey == "" then
        return false
    end
    local slots = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(slots) ~= "table" then
        return false
    end
    local assigned = slots[seatKey]
    return type(assigned) == "string" and assigned ~= ""
end

--- Same activation rule as `lib.rotational-seat-layout` `applyTableComponentsState`.
--- @param parentTable string
--- @param componentName string
--- @return boolean
local function tableComponentActiveForOccupiedSlots(parentTable, componentName)
    local cfg = tableConfig(parentTable)
    if cfg == nil or type(cfg.components) ~= "table" then
        return false
    end
    local comp = cfg.components[componentName]
    if type(comp) ~= "table" then
        return false
    end
    local usedBy = comp.usedBy
    if type(usedBy) ~= "string" or usedBy == "" then
        return true
    end
    if not npcSeatOccupiedOnTable(usedBy) then
        return false
    end
    return true
end

--- World XZ around a table segment (seat arc), from C.Tables layout data.
--- Segment indices in `playerToPositionMap` are 1-based (same as rotational-seat-layout).
--- @param cfg table
--- @param segmentIndex1Based number
--- @return Vector|nil
local function worldPositionForTableSegment(cfg, segmentIndex1Based)
    if type(cfg) ~= "table" or type(segmentIndex1Based) ~= "number" or cfg.centerPoint == nil then
        return nil
    end
    local cp = Vector(cfg.centerPoint)
    local numSegments = cfg.numSegments or 10
    if numSegments < 1 then
        numSegments = 10
    end
    local angleSegmentOne = tonumber(cfg.angleSegmentOne) or 0
    local thetaDeg = angleSegmentOne + (segmentIndex1Based - 1) * (360 / numSegments)
    local angleRad = math.rad(thetaDeg)
    local radius = 12
    if cfg.referenceHandPosition ~= nil then
        radius = U.HorizontalDistance(cp, Vector(cfg.referenceHandPosition))
    elseif cfg.activePosition ~= nil then
        radius = U.HorizontalDistance(cp, Vector(cfg.activePosition))
    end
    if radius < 1 then
        radius = 12
    end
    return Vector(
        cp.x + math.sin(angleRad) * radius,
        cp.y,
        cp.z + math.cos(angleRad) * radius
    )
end

--- Playfield world XZ → shared map u,v (via STAGE_BOARD), for CONTROL_BOARD marker placement.
--- @param tableKey string
--- @return number|nil u, number|nil v
local function mapUvForTableCenter(tableKey)
    local cfg = tableConfig(tableKey)
    if cfg == nil or cfg.centerPoint == nil then
        return nil, nil
    end
    return normalizedUvFromWorld(Vector(cfg.centerPoint))
end

--- World-space XZ extents from `getBounds` (minimap marker scale ratios only — not UV math).
--- @param board Object
--- @return number sx, number sz
local function boardMapExtents(board)
    local sx = 1
    local sz = 1
    if isGameObject(board) and board.getBounds ~= nil then
        local b = board.getBounds()
        if b ~= nil and b.size ~= nil then
            sx = b.size.x or b.size[1] or sx
            sz = b.size.z or b.size[3] or sz
        end
    end
    if sx < 0.01 then
        sx = 0.01
    end
    if sz < 0.01 then
        sz = 0.01
    end
    return sx, sz
end

--- Stage vs control minimap scale divisors from board XZ bounds (e.g. ~40 when stage is 800×400 and control is 20×10).
--- Third return is a uniform divisor for marker scale on all axes (do not use board transform Y — both boards are Y scale 1).
--- @return number|nil ratioX, number|nil ratioZ, number|nil uniformRatio
function Gameboard.minimapScaleRatios()
    local stage = getStageBoard()
    local control = getControlBoard()
    if not isGameObject(stage) or not isGameObject(control) then
        return nil, nil, nil
    end
    local stageSx, stageSz = boardMapExtents(stage)
    local controlSx, controlSz = boardMapExtents(control)
    local ratioX = stageSx / controlSx
    local ratioZ = stageSz / controlSz
    return ratioX, ratioZ, (ratioX + ratioZ) * 0.5
end

--- @param source Object|nil
--- @return Vector|nil
local function objectScaleVector(source)
    if not isGameObject(source) or source.getScale == nil then
        return nil
    end
    local s = source.getScale()
    if type(s) ~= "table" then
        return nil
    end
    return Vector(s.x or 1, s.y or 1, s.z or 1)
end

--- Minimap marker scale:
--- - X/Z: source playfield object scale ÷ live STAGE:CONTROL board axis ratios.
--- - Y: source scale ÷ MINIMAP_SCALE_DIVISOR (fixed vertical lift control only).
--- @param marker Object
--- @param source Object|nil Playfield table, leaf, or seat chair being mimicked
local function applyMinimapMarkerScale(marker, source)
    if not isGameObject(marker) or marker.setScale == nil then
        return
    end
    local src = objectScaleVector(source)
    if src == nil then
        return
    end
    local ratioX, ratioZ, uniformRatio = Gameboard.minimapScaleRatios()
    local xDivisor = tonumber(ratioX) or tonumber(uniformRatio) or 40
    local zDivisor = tonumber(ratioZ) or tonumber(uniformRatio) or 40
    local yDivisor = tonumber(DATA.MINIMAP_SCALE_DIVISOR) or 40
    if xDivisor < 0.01 then xDivisor = 0.01 end
    if yDivisor < 0.01 then yDivisor = 0.01 end
    if zDivisor < 0.01 then zDivisor = 0.01 end
    marker.setScale({
        x = src.x / xDivisor,
        y = src.y / yDivisor,
        z = src.z / zDivisor,
    })
end

--- Minimap marker rotation = playfield source euler + CONTROL_BOARD euler (per axis).
--- @param marker Object
--- @param board Object
--- @param source Object|nil
local function applyMinimapMarkerRotation(marker, board, source)
    if not isGameObject(marker) or marker.setRotation == nil or not isGameObject(board) then
        return
    end
    local boardRot = board.getRotation and board.getRotation() or nil
    local bx = 0
    local by = 0
    local bz = 0
    if boardRot ~= nil then
        bx = boardRot.x or 0
        by = boardRot.y or 0
        bz = boardRot.z or 0
    end
    local sx = 0
    local sy = 0
    local sz = 0
    if isGameObject(source) and source.getRotation ~= nil then
        local srcRot = source.getRotation()
        if type(srcRot) == "table" then
            sx = srcRot.x or 0
            sy = srcRot.y or 0
            sz = srcRot.z or 0
        end
    end
    marker.setRotation(Vector(sx + bx, sy + by, sz + bz))
end

--- @param tableKey string
--- @return Object|nil
local function sourceObjectForTable(tableKey)
    local cfg = tableConfig(tableKey)
    if cfg == nil or type(cfg.guid) ~= "string" or cfg.guid == "" then
        return nil
    end
    return objectFromGuid(cfg.guid)
end

--- Playfield seat chair for minimap scale (SEAT_CHAIR_* via G.GetThroneGUID), not arbitrary *Object tags.
--- @param seatKey string PC color or NPC1–NPC4
--- @return Object|nil
local function sourceObjectForSeat(seatKey)
    if type(seatKey) ~= "string" or seatKey == "" then
        return nil
    end
    local guid = G.GetThroneGUID(seatKey)
    if type(guid) == "string" and guid ~= "" then
        return objectFromGuid(guid)
    end
    return nil
end

--- Deep copy plain tables (nested `snapGroups` entries).
--- @param src table
--- @return table
local function deepCopyPlainTable(src)
    if type(src) ~= "table" then
        return {}
    end
    local copy = {}
    for k, v in pairs(src) do
        if type(v) == "table" then
            copy[k] = deepCopyPlainTable(v)
        else
            copy[k] = v
        end
    end
    return copy
end

--- Working copy for validate/install — never return `DATA.CONTROL_BOARD_SNAP` by reference.
--- @param config table|nil
--- @return table
local function resolveControlBoardSnapConfig(config)
    local src = type(config) == "table" and config or (DATA.CONTROL_BOARD_SNAP or {})
    return deepCopyPlainTable(src)
end

--- @param group table|nil snapGroups ring entry
--- @return string|nil OFF|STANDARD when set
local function snapGroupDefaultLightMode(group)
    if type(group) ~= "table" then
        return nil
    end
    local raw = group.defaultLightMode
    if type(raw) ~= "string" or raw == "" then
        return nil
    end
    local mode = string.upper(raw)
    if mode == "OFF" or mode == "STANDARD" then
        return mode
    end
    return nil
end

--- @param cfg table
--- @return table cfg, number rings
local function validateControlBoardSnapConfig(cfg)
    if type(cfg) ~= "table" then
        error("CONTROL_BOARD_SNAP config must be a table")
    end
    local origin = cfg.origin
    if type(origin) ~= "table" or type(origin.u) ~= "number" or type(origin.v) ~= "number" then
        error("CONTROL_BOARD_SNAP.origin must be { u = number, v = number }")
    end
    local innerRingMaxU = tonumber(cfg.innerRingMaxU)
    local innerRingMaxV = tonumber(cfg.innerRingMaxV)
    local outerRingMaxU = tonumber(cfg.outerRingMaxU)
    local outerRingMaxV = tonumber(cfg.outerRingMaxV)
    local hasGlobalRingMax = innerRingMaxU ~= nil
        and innerRingMaxV ~= nil
        and outerRingMaxU ~= nil
        and outerRingMaxV ~= nil
    local legacyRays = tonumber(cfg.rays)
    local snapGroups = cfg.snapGroups
    if type(snapGroups) ~= "table" or #snapGroups < 1 then
        error("CONTROL_BOARD_SNAP.snapGroups must be a non-empty array (one entry per ring)")
    end
    local rings = #snapGroups
    local legacyRings = tonumber(cfg.rings)
    if legacyRings ~= nil then
        if legacyRings < 1 or math.floor(legacyRings) ~= legacyRings then
            error("CONTROL_BOARD_SNAP.rings must be an integer >= 1 when set")
        end
        if math.floor(legacyRings) ~= rings then
            error("CONTROL_BOARD_SNAP.rings must match #CONTROL_BOARD_SNAP.snapGroups when set")
        end
    end
    for ringIndex = 1, rings do
        local group = snapGroups[ringIndex]
        if type(group) ~= "table" then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "] must be a table")
        end
        local num = tonumber(group.num)
        if num == nil or num < 1 or math.floor(num) ~= num then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "].num must be an integer >= 1")
        end
        if tonumber(group.angleDelta) == nil then
            error("CONTROL_BOARD_SNAP.snapGroups[" .. tostring(ringIndex) .. "].angleDelta must be a number")
        end
        local rays = tonumber(group.rays)
        if rays == nil and legacyRays ~= nil then
            rays = legacyRays
        end
        if rays == nil or rays < 1 or math.floor(rays) ~= rays then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].rays must be an integer >= 1 (or set legacy top-level rays)"
            )
        end
        group.rays = math.floor(rays)
        local ringMaxU = tonumber(group.maxU)
        local ringMaxV = tonumber(group.maxV)
        if group.maxU ~= nil and ringMaxU == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].maxU must be a number when set"
            )
        end
        if group.maxV ~= nil and ringMaxV == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].maxV must be a number when set"
            )
        end
        if (ringMaxU ~= nil) ~= (ringMaxV ~= nil) then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "] must set both maxU and maxV together"
            )
        end
        local ringOrigin = group.origin
        if ringOrigin ~= nil then
            if type(ringOrigin) ~= "table" then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].origin must be { u = number, v = number } when set"
                )
            end
            local ringOriginU = tonumber(ringOrigin.u)
            local ringOriginV = tonumber(ringOrigin.v)
            if (ringOriginU ~= nil) ~= (ringOriginV ~= nil) then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].origin must set both u and v together"
                )
            end
            if ringOriginU == nil or ringOriginV == nil then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].origin must be { u = number, v = number } when set"
                )
            end
        end
        if group.snapYawOffsetDeg ~= nil and tonumber(group.snapYawOffsetDeg) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].snapYawOffsetDeg must be a number when set"
            )
        end
        if group.defaultLightMode ~= nil and snapGroupDefaultLightMode(group) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].defaultLightMode must be \"OFF\" or \"STANDARD\" when set"
            )
        end
        if group.groundLevel ~= nil and tonumber(group.groundLevel) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].groundLevel must be a number when set"
            )
        end
        if group.radialStagger ~= nil and tonumber(group.radialStagger) == nil then
            error(
                "CONTROL_BOARD_SNAP.snapGroups["
                    .. tostring(ringIndex)
                    .. "].radialStagger must be a number when set"
            )
        end
        local validSnaps = group.validSnaps
        if validSnaps ~= nil then
            if type(validSnaps) ~= "table" then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].validSnaps must be { minU, maxU, minV, maxV } when set"
                )
            end
            local minU = tonumber(validSnaps.minU)
            local maxU = tonumber(validSnaps.maxU)
            local minV = tonumber(validSnaps.minV)
            local maxV = tonumber(validSnaps.maxV)
            if minU == nil or maxU == nil or minV == nil or maxV == nil then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].validSnaps requires minU, maxU, minV, maxV numbers"
                )
            end
            if minU > maxU or minV > maxV then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].validSnaps min must be <= max"
                )
            end
        end
    end
    if not hasGlobalRingMax then
        for ringIndex = 1, rings do
            local group = snapGroups[ringIndex]
            if tonumber(group.maxU) == nil or tonumber(group.maxV) == nil then
                error(
                    "CONTROL_BOARD_SNAP.snapGroups["
                        .. tostring(ringIndex)
                        .. "].maxU/maxV required when inner/outer ring max omitted"
                )
            end
        end
    end
    return cfg, rings
end

--- Absolute world Y for figurines on a ring when `snapGroups[ring].groundLevel` is set.
--- @param group table
--- @return number|nil
local function resolveSnapGroupGroundLevel(group)
    if type(group) == "table" and tonumber(group.groundLevel) ~= nil then
        return tonumber(group.groundLevel)
    end
    return nil
end

--- Absolute board maxU/maxV for ring index (1 = innermost).
--- Per-ring `snapGroups[ringIndex].maxU/maxV` override inner→outer interpolation when set.
--- @param cfg table
--- @param ringIndex number
--- @param rings number
--- @return number maxU, number maxV
local function ringMaxUvForIndex(cfg, ringIndex, rings)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[ringIndex] or nil
    if type(group) == "table" then
        local maxU = tonumber(group.maxU)
        local maxV = tonumber(group.maxV)
        if maxU ~= nil and maxV ~= nil then
            return maxU, maxV
        end
    end
    local innerRingMaxU = tonumber(cfg.innerRingMaxU)
    local innerRingMaxV = tonumber(cfg.innerRingMaxV)
    local outerRingMaxU = tonumber(cfg.outerRingMaxU)
    local outerRingMaxV = tonumber(cfg.outerRingMaxV)
    if innerRingMaxU == nil or innerRingMaxV == nil or outerRingMaxU == nil or outerRingMaxV == nil then
        error(
            "CONTROL_BOARD_SNAP ring "
                .. tostring(ringIndex)
                .. " needs snapGroups.maxU/maxV or top-level inner/outer ring max"
        )
    end
    local t = 0
    if rings > 1 then
        t = (ringIndex - 1) / (rings - 1)
    end
    local maxU = innerRingMaxU + t * (outerRingMaxU - innerRingMaxU)
    local maxV = innerRingMaxV + t * (outerRingMaxV - innerRingMaxV)
    return maxU, maxV
end

--- Ring-local origin in board u/v, defaulting to top-level config origin.
--- @param cfg table
--- @param ringIndex number
--- @return number originU, number originV
local function ringOriginUvForIndex(cfg, ringIndex)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[ringIndex] or nil
    if type(group) == "table" and type(group.origin) == "table" then
        local ringOriginU = tonumber(group.origin.u)
        local ringOriginV = tonumber(group.origin.v)
        if ringOriginU ~= nil and ringOriginV ~= nil then
            return ringOriginU, ringOriginV
        end
    end
    return cfg.origin.u, cfg.origin.v
end

--- True when this ring's polar origin is not the config master origin (satellite / outskirts rings).
--- @param cfg table
--- @param ringIndex number
--- @return boolean
local function ringOriginDiffersFromMaster(cfg, ringIndex)
    local ringU, ringV = ringOriginUvForIndex(cfg, ringIndex)
    local masterU = tonumber(cfg.origin and cfg.origin.u) or 0.5
    local masterV = tonumber(cfg.origin and cfg.origin.v) or 0.5
    local eps = 1e-4
    return math.abs(ringU - masterU) > eps or math.abs(ringV - masterV) > eps
end

--- Board u/v bearing from (fromU,fromV) toward (toU,toV); 0° = +u, 90° = +v (matches `uvOnEllipse`).
--- @param fromU number
--- @param fromV number
--- @param toU number
--- @param toV number
--- @return number degrees
local function bearingUvDeg(fromU, fromV, toU, toV)
    local du = toU - fromU
    local dv = toV - fromV
    return math.deg(math.atan2(dv, du))
end

--- Family angle on the ring ellipse: master-origin rings use ray anchors; satellite rings rotate so k=0 faces master.
--- @param cfg table
--- @param ringIndex number
--- @param rayIndex number 0-based
--- @param familyK number
--- @param angleDelta number
--- @param rays number
--- @return number angleDeg
local function familyAngleDegForSnap(cfg, ringIndex, rayIndex, familyK, angleDelta, rays)
    local anchorDeg = (rayIndex / rays) * 360
    if not ringOriginDiffersFromMaster(cfg, ringIndex) then
        return anchorDeg + familyK * angleDelta
    end
    local ringOriginU, ringOriginV = ringOriginUvForIndex(cfg, ringIndex)
    local masterU = tonumber(cfg.origin and cfg.origin.u) or 0.5
    local masterV = tonumber(cfg.origin and cfg.origin.v) or 0.5
    local towardMasterDeg = bearingUvDeg(ringOriginU, ringOriginV, masterU, masterV)
    return towardMasterDeg + anchorDeg + familyK * angleDelta
end

--- Board u/v on an axis-aligned ellipse: at angleDeg, u reaches maxU on +u axis and v reaches maxV on +v axis.
--- @param originU number
--- @param originV number
--- @param angleDeg number
--- @param maxU number absolute board u at theta=0
--- @param maxV number absolute board v at theta=90
--- @return number u, number v
local function uvOnEllipse(originU, originV, angleDeg, maxU, maxV)
    local theta = math.rad(angleDeg)
    local u = originU + math.cos(theta) * (maxU - originU)
    local v = originV + math.sin(theta) * (maxV - originV)
    return u, v
end

--- True when normalized board u/v lies on the minimap tile (inclusive 0–1).
--- @param u number
--- @param v number
--- @return boolean
local function snapUvOnBoard(u, v)
    if type(u) ~= "number" or type(v) ~= "number" then
        return false
    end
    return u >= 0 and u <= 1 and v >= 0 and v <= 1
end

--- Per-ring optional `validSnaps` box: all four bounds must pass (inclusive).
--- @param group table snapGroups entry
--- @param u number
--- @param v number
--- @return boolean
local function snapUvPassesValidSnaps(group, u, v)
    if type(group) ~= "table" then
        return true
    end
    local box = group.validSnaps
    if type(box) ~= "table" then
        return true
    end
    local minU = tonumber(box.minU)
    local maxU = tonumber(box.maxU)
    local minV = tonumber(box.minV)
    local maxV = tonumber(box.maxV)
    if minU == nil or maxU == nil or minV == nil or maxV == nil then
        return false
    end
    return u >= minU and u <= maxU and v >= minV and v <= maxV
end

--- Push snap u/v outward from polar origin by `abs(familyK) * radialStagger` along STAGE world XZ.
--- Anchor (`familyK == 0`) is unchanged. Units are STAGE_BOARD / playfield world inches (not CONTROL_BOARD minimap inches).
--- @param originU number
--- @param originV number
--- @param familyK number
--- @param radialStagger number world XZ inches on STAGE_BOARD per family step from anchor
--- @param u number
--- @param v number
--- @return number u, number v
local function applyRadialStaggerUv(originU, originV, familyK, radialStagger, u, v)
    local k = tonumber(familyK) or 0
    local staggerStep = tonumber(radialStagger) or 0
    if k == 0 or staggerStep == 0 then
        return u, v
    end
    local du = u - originU
    local dv = v - originV
    local stage = getStageBoard()
    if not isGameObject(stage) then
        local ext = defaultStageWorld()
        local x0 = ext.centerX + (originU - 0.5) * 2 * ext.halfWidthX
        local z0 = ext.centerZ + (originV - 0.5) * 2 * ext.halfDepthZ
        local x1 = ext.centerX + (u - 0.5) * 2 * ext.halfWidthX
        local z1 = ext.centerZ + (v - 0.5) * 2 * ext.halfDepthZ
        local dx = x1 - x0
        local dz = z1 - z0
        local worldDist = math.sqrt(dx * dx + dz * dz)
        if worldDist < 1e-6 then
            return u, v
        end
        local scale = (worldDist + math.abs(k) * staggerStep) / worldDist
        return originU + du * scale, originV + dv * scale
    end
    local originLp = boardLocalFromUv(stage, originU, originV)
    local snapLp = boardLocalFromUv(stage, u, v)
    local originWp = boardLocalToWorld(stage, originLp)
    local snapWp = boardLocalToWorld(stage, snapLp)
    local dx = snapWp.x - originWp.x
    local dz = snapWp.z - originWp.z
    local worldDist = math.sqrt(dx * dx + dz * dz)
    if worldDist < 1e-6 then
        return u, v
    end
    local scale = (worldDist + math.abs(k) * staggerStep) / worldDist
    local newWp = Vector(originWp.x + dx * scale, snapWp.y, originWp.z + dz * scale)
    local newLp = boardWorldToLocal(stage, newWp)
    if newLp == nil then
        return u, v
    end
    -- Unclamped u/v so off-board stagger candidates are pruned by snapUvOnBoard (not pinned to edges).
    return uvFromBoardLocal(stage, newLp)
end

--- Ellipse u/v + optional radial stagger for one family member; nil when off the minimap tile.
--- @param board Object|nil Used for snap local position on CONTROL_BOARD (stagger uses STAGE_BOARD)
--- @param cfg table
--- @param rings number
--- @param ringIndex number
--- @param rayIndex number 0-based
--- @param familyK number
--- @return number|nil u, number|nil v, Vector|nil localPos
local function controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, familyK)
    local group = cfg.snapGroups[ringIndex]
    local rays = tonumber(group.rays)
    local angleDelta = tonumber(group.angleDelta) or 0
    local radialStagger = tonumber(group.radialStagger) or 0
    local maxU, maxV = ringMaxUvForIndex(cfg, ringIndex, rings)
    local ringOriginU, ringOriginV = ringOriginUvForIndex(cfg, ringIndex)
    local angleDeg = familyAngleDegForSnap(cfg, ringIndex, rayIndex, familyK, angleDelta, rays)
    local u, v = uvOnEllipse(ringOriginU, ringOriginV, angleDeg, maxU, maxV)
    if radialStagger ~= 0 and familyK ~= 0 then
        u, v = applyRadialStaggerUv(ringOriginU, ringOriginV, familyK, radialStagger, u, v)
    end
    if not snapUvOnBoard(u, v) then
        return nil, nil, nil
    end
    if not snapUvPassesValidSnaps(group, u, v) then
        return nil, nil, nil
    end
    local lp = nil
    if isGameObject(board) then
        lp = boardLocalFromUv(board, u, v)
    end
    return u, v, lp
end

--- Pick the ring whose ellipse best matches normalized board u/v (same geometry as snap generation).
--- @param cfg table
--- @param u number
--- @param v number
--- @param rings number
--- @return number ringIndex 1-based
local function resolveRingIndexForUv(cfg, u, v, rings)
    local bestRing = 1
    local bestDist = math.huge
    for ringIndex = 1, rings do
        local ringOriginU, ringOriginV = ringOriginUvForIndex(cfg, ringIndex)
        local du = u - ringOriginU
        local dv = v - ringOriginV
        local angleDeg = math.deg(math.atan2(dv, du))
        local maxU, maxV = ringMaxUvForIndex(cfg, ringIndex, rings)
        local eu, ev = uvOnEllipse(ringOriginU, ringOriginV, angleDeg, maxU, maxV)
        local dist = (u - eu) * (u - eu) + (v - ev) * (v - ev)
        if dist < bestDist then
            bestDist = dist
            bestRing = ringIndex
        end
    end
    return bestRing
end

--- Yaw in board-local space so snapped tokens face the polar origin.
--- @param board Object
--- @param u number
--- @param v number
--- @param originU number
--- @param originV number
--- @return number yawDeg
local function snapYawTowardOriginDeg(board, u, v, originU, originV)
    local snapLp = boardLocalFromUv(board, u, v)
    local originLp = boardLocalFromUv(board, originU, originV)
    local dx = originLp.x - snapLp.x
    local dz = originLp.z - snapLp.z
    return math.deg(math.atan2(dx, dz))
end

--- @return table|nil
local function resolveControlBoardSeatRowConfig()
    local row = DATA.CONTROL_BOARD_SEAT_ROW
    if type(row) ~= "table" or type(row.columns) ~= "table" or #row.columns < 1 then
        return nil
    end
    return row
end

--- @param col table|nil
--- @return boolean
isNpcSeatRowColumn = function(col)
    return type(col) == "table" and col.kind == "npc" and U.isIn(col.seatKey, C.NPCSeats or {})
end

--- Seat-row catalog entries appended after polar rings (TOR-180).
--- @param board Object
--- @param polarCount number snaps already in catalog
--- @return table[]
local function buildSeatRowSnapEntries(board, polarCount)
    local seatCfg = resolveControlBoardSeatRowConfig()
    if seatCfg == nil or not isGameObject(board) then
        return {}
    end
    local columns = seatCfg.columns
    local n = #columns
    local v = tonumber(seatCfg.v) or 0.15
    local uMin = tonumber(seatCfg.uMin) or 0.35
    local uMax = tonumber(seatCfg.uMax) or 0.65
    if uMax < uMin then
        uMin, uMax = uMax, uMin
    end
    -- Seat-row: fixed board-local yaw (offsets CONTROL_BOARD world Y=180°); PC columns add Z flip.
    local yawDeg = ((tonumber(seatCfg.snapYawOffsetDeg) or 0) % 360 + 360) % 360
    local pcSnapZDeg = ((tonumber(seatCfg.pcSnapZDeg) or 0) % 360 + 360) % 360
    local entries = {}
    for i = 1, n do
        local col = columns[i]
        local kind = col.kind or "pc"
        local snapZDeg = kind == "pc" and pcSnapZDeg or 0
        local u = (uMin + uMax) * 0.5
        if n > 1 then
            u = uMin + (i - 1) * (uMax - uMin) / (n - 1)
        end
        local lp = boardLocalFromUv(board, u, v)
        entries[#entries + 1] = {
            snapKind = SNAP_KIND_SEAT,
            seatKey = col.seatKey,
            columnKind = kind,
            u = u,
            v = v,
            yawDeg = yawDeg,
            snapZDeg = snapZDeg,
            localPos = lp,
            worldPos = boardLocalToWorld(board, lp),
            groundLevel = nil,
            defaultLightMode = nil,
            isAnchor = false,
            snapIndex = polarCount + #entries + 1,
        }
    end
    return entries
end

--- @param catalog table[]
--- @return table<string, table> npc seatKey -> catalog entry
local function seatRowCatalogByNpcSeatKey(catalog)
    local out = {}
    for _, entry in ipairs(catalog) do
        if entry.snapKind == SNAP_KIND_SEAT and isNpcSeatRowColumn({ seatKey = entry.seatKey, kind = "npc" }) then
            out[entry.seatKey] = entry
        end
    end
    return out
end

--- Rich snap catalog entry (install order matches TTS getSnapPoints indices).
--- @param board Object
--- @param cfg table validated CONTROL_BOARD_SNAP config
--- @param rings number
--- @return table[]
local function buildControlBoardSnapEntries(board, cfg, rings)
    local entries = {}
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local ringGroundLevel = resolveSnapGroupGroundLevel(group)
        local ringYawOffsetDeg = tonumber(group.snapYawOffsetDeg)
        if ringYawOffsetDeg == nil then
            ringYawOffsetDeg = tonumber(cfg.snapYawOffsetDeg) or 0
        end
        local half = math.floor(num / 2)
        for rayIndex = 0, rays - 1 do
            local familyId = tostring(ringIndex) .. ":" .. tostring(rayIndex)
            for k = -half, half do
                local u, v, lp = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil and lp ~= nil then
                    --- ringGroundLevel (when set) is absolute world Y for figurines on Apply — catalog metadata only; snaps stay on tile surface.
                    local yawDeg = ((snapYawTowardOriginDeg(board, u, v, cfg.origin.u, cfg.origin.v) + ringYawOffsetDeg) % 360 + 360) % 360
                    entries[#entries + 1] = {
                        snapIndex = #entries + 1,
                        ringIndex = ringIndex,
                        rayIndex = rayIndex,
                        familyId = familyId,
                        familyK = k,
                        isAnchor = (k == 0),
                        u = u,
                        v = v,
                        yawDeg = yawDeg,
                        localPos = lp,
                        worldPos = boardLocalToWorld(board, lp),
                        groundLevel = ringGroundLevel,
                        defaultLightMode = snapGroupDefaultLightMode(group),
                    }
                end
            end
        end
    end
    local seatEntries = buildSeatRowSnapEntries(board, #entries)
    for i = 1, #seatEntries do
        seatEntries[i].snapIndex = #entries + i
        entries[#entries + 1] = seatEntries[i]
    end
    return entries
end

--- @param config table|nil
--- @return number total, table perRingCounts indexed by ring
function Gameboard.countControlBoardSnapPoints(config)
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local board = getControlBoard()
    local perRing = {}
    local total = 0
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local half = math.floor(num / 2)
        local ringTotal = 0
        for rayIndex = 0, rays - 1 do
            for k = -half, half do
                local u, _, _ = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil then
                    ringTotal = ringTotal + 1
                end
            end
        end
        perRing[ringIndex] = ringTotal
        total = total + ringTotal
    end
    local seatCfg = resolveControlBoardSeatRowConfig()
    if seatCfg ~= nil then
        total = total + #(seatCfg.columns or {})
    end
    return total, perRing
end

local SNAP_FAMILY_ROLE_BY_K = {
    [-2] = "farLeft",
    [-1] = "nearLeft",
    [0] = "center",
    [1] = "nearRight",
    [2] = "farRight",
}

--- @param familyK number
--- @return string
local function familyRoleLabelForK(familyK)
    local label = SNAP_FAMILY_ROLE_BY_K[familyK]
    if label ~= nil then
        return label
    end
    return "k" .. tostring(familyK)
end

--- Collect on-board snap positions grouped by family role (farLeft … center … farRight).
--- World X/Z use STAGE_BOARD via `worldFromUv`; Y omitted from each point.
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @param options table|nil `{ useInterpolatedRings?: boolean }` when true, ignore per-ring maxU/maxV and interpolate inner→outer
--- @return table<string, table[]> roleName → `{ { x, z, u, v, ringIndex, rayIndex, familyK }, ... }`
function Gameboard.exportSnapFamiliesByRole(config, options)
    options = type(options) == "table" and options or {}
    local cfg = resolveControlBoardSnapConfig(config)
    if options.useInterpolatedRings == true then
        local ringCount = #(cfg.snapGroups or {})
        local firstGroup = type(cfg.snapGroups) == "table" and cfg.snapGroups[1] or nil
        local lastGroup = type(cfg.snapGroups) == "table" and cfg.snapGroups[ringCount] or nil
        if cfg.innerRingMaxU == nil and type(firstGroup) == "table" then
            cfg.innerRingMaxU = firstGroup.maxU
        end
        if cfg.innerRingMaxV == nil and type(firstGroup) == "table" then
            cfg.innerRingMaxV = firstGroup.maxV
        end
        if cfg.outerRingMaxU == nil and type(lastGroup) == "table" then
            cfg.outerRingMaxU = lastGroup.maxU
        end
        if cfg.outerRingMaxV == nil and type(lastGroup) == "table" then
            cfg.outerRingMaxV = lastGroup.maxV
        end
        for ringIndex = 1, #(cfg.snapGroups or {}) do
            local group = cfg.snapGroups[ringIndex]
            if type(group) == "table" then
                group.maxU = nil
                group.maxV = nil
            end
        end
    end
    local rings
    cfg, rings = validateControlBoardSnapConfig(cfg)
    local board = getControlBoard()
    local byRole = {}
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        local num = tonumber(group.num)
        local rays = tonumber(group.rays)
        local ringGroundLevel = resolveSnapGroupGroundLevel(group)
        local half = math.floor(num / 2)
        for rayIndex = 0, rays - 1 do
            for k = -half, half do
                local u, v = controlBoardSnapCandidate(board, cfg, rings, ringIndex, rayIndex, k)
                if u ~= nil then
                    local wp = Gameboard.worldFromUv(u, v, { groundLevel = ringGroundLevel })
                    local role = familyRoleLabelForK(k)
                    local bucket = byRole[role]
                    if bucket == nil then
                        bucket = {}
                        byRole[role] = bucket
                    end
                    bucket[#bucket + 1] = {
                        x = wp.x,
                        z = wp.z,
                        u = u,
                        v = v,
                        ringIndex = ringIndex,
                        rayIndex = rayIndex,
                        familyK = k,
                    }
                end
            end
        end
    end
    return byRole
end

--- Serialize `exportSnapFamiliesByRole` output as a Lua table literal (1-based slot indices per role).
--- @param byRole table
--- @return string
function Gameboard.formatSnapFamiliesLua(byRole)
    if type(byRole) ~= "table" then
        return "return {}"
    end
    local roleNames = {}
    for roleName, _ in pairs(byRole) do
        roleNames[#roleNames + 1] = roleName
    end
    table.sort(roleNames)
    local lines = { "return {" }
    for _, roleName in ipairs(roleNames) do
        lines[#lines + 1] = "  " .. roleName .. " = {"
        local points = byRole[roleName]
        if type(points) == "table" then
            for slotIndex, pt in ipairs(points) do
                if type(pt) == "table" and type(pt.x) == "number" and type(pt.z) == "number" then
                    lines[#lines + 1] = string.format(
                        "    [%d] = { x = %.6f, z = %.6f },",
                        slotIndex,
                        pt.x,
                        pt.z
                    )
                end
            end
        end
        lines[#lines + 1] = "  },"
    end
    lines[#lines + 1] = "}"
    return table.concat(lines, "\n")
end

--- Serialize `exportSnapFamiliesByRole` as CSV: area, slot, x, z (area = family role name).
--- @param byRole table
--- @return string
function Gameboard.formatSnapFamiliesCsv(byRole)
    if type(byRole) ~= "table" then
        return "area,slot,x,z"
    end
    local roleNames = {}
    for roleName, _ in pairs(byRole) do
        roleNames[#roleNames + 1] = roleName
    end
    table.sort(roleNames)
    local lines = { "area,slot,x,z" }
    for _, roleName in ipairs(roleNames) do
        local points = byRole[roleName]
        if type(points) == "table" then
            for slotIndex, pt in ipairs(points) do
                if type(pt) == "table" and type(pt.x) == "number" and type(pt.z) == "number" then
                    lines[#lines + 1] = string.format(
                        "%s,%d,%.6f,%.6f",
                        roleName,
                        slotIndex,
                        pt.x,
                        pt.z
                    )
                end
            end
        end
    end
    return table.concat(lines, "\n")
end

--- Snap catalog with family metadata (anchor = familyK 0 at each ray).
--- Default config (config nil) is cached by board fingerprint; explicit config always rebuilds.
--- @param board Object
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table[]
function Gameboard.buildControlBoardSnapCatalog(board, config)
    if not isGameObject(board) then
        error("Gameboard.buildControlBoardSnapCatalog: board object required")
    end
    if config ~= nil then
        if type(activeInteractionProfile) == "table" then
            activeInteractionProfile.catalog_builds = (activeInteractionProfile.catalog_builds or 0) + 1
        end
        local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
        return buildControlBoardSnapEntries(board, cfg, rings)
    end
    local fp = controlBoardSnapFingerprintFor(board, nil)
    local cacheKey = tostring(board.getGUID()) .. ":" .. fp
    local cached = defaultSnapCatalogCache[cacheKey]
    if type(cached) == "table" then
        return cached
    end
    if type(activeInteractionProfile) == "table" then
        activeInteractionProfile.catalog_builds = (activeInteractionProfile.catalog_builds or 0) + 1
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(nil))
    local catalog = buildControlBoardSnapEntries(board, cfg, rings)
    defaultSnapCatalogCache[cacheKey] = catalog
    return catalog
end

--- Build TTS snap points in board-local space (combined ray + family angles per ring).
--- @param board Object
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table[]
function Gameboard.buildControlBoardSnapPoints(board, config)
    if not isGameObject(board) then
        error("Gameboard.buildControlBoardSnapPoints: board object required")
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local entries = buildControlBoardSnapEntries(board, cfg, rings)
    local points = {}
    for _, entry in ipairs(entries) do
        local snapZ = tonumber(entry.snapZDeg) or 0
        points[#points + 1] = {
            position = { entry.localPos.x, entry.localPos.y, entry.localPos.z },
            rotation = { 0, entry.yawDeg, snapZ },
            rotation_snap = true,
            tags = CONTROL_BOARD_SNAP_TAGS,
        }
    end
    return points
end

--- @param board Object
--- @param config table|nil
--- @return string
controlBoardSnapFingerprintFor = function(board, config)
    local cfg = resolveControlBoardSnapConfig(config)
    local sx, sz = boardMapExtents(board)
    local parts = {
        tostring(board.getGUID()),
        string.format("%.3f,%.3f", sx, sz),
        string.format("%.4f,%.4f", cfg.origin.u, cfg.origin.v),
        tostring(#(cfg.snapGroups or {})),
        table.concat({
            tostring(cfg.innerRingMaxU or ""),
            tostring(cfg.innerRingMaxV or ""),
            tostring(cfg.outerRingMaxU or ""),
            tostring(cfg.outerRingMaxV or ""),
        }, ","),
    }
    local rings = #(cfg.snapGroups or {})
    for ringIndex = 1, rings do
        local group = cfg.snapGroups[ringIndex]
        if type(group) == "table" then
            parts[#parts + 1] = tostring(group.num)
                .. ":"
                .. tostring(group.angleDelta)
                .. ":"
                .. tostring(group.rays)
                .. ":"
                .. tostring(group.groundLevel or "")
                .. ":"
                .. tostring(group.radialStagger or "")
                .. ":"
                .. tostring(group.maxU or "")
                .. ":"
                .. tostring(group.maxV or "")
                .. ":"
                .. tostring(type(group.origin) == "table" and group.origin.u or "")
                .. ":"
                .. tostring(type(group.origin) == "table" and group.origin.v or "")
                .. ":"
                .. tostring(group.snapYawOffsetDeg or "")
                .. ":"
                .. tostring(group.defaultLightMode or "")
        end
    end
    parts[#parts + 1] = "snapTag:" .. TAG_TOKEN
    parts[#parts + 1] = "yawOff:" .. tostring(tonumber(cfg.snapYawOffsetDeg) or 0)
    local seatCfg = resolveControlBoardSeatRowConfig()
    if seatCfg ~= nil then
        parts[#parts + 1] = "seatRow:v:" .. tostring(seatCfg.v)
        parts[#parts + 1] = "seatRow:yaw:" .. tostring(tonumber(seatCfg.snapYawOffsetDeg) or 0)
        parts[#parts + 1] = "seatRow:pcZ:" .. tostring(tonumber(seatCfg.pcSnapZDeg) or 0)
        for i = 1, #(seatCfg.columns or {}) do
            local col = seatCfg.columns[i]
            parts[#parts + 1] = "seatCol:" .. tostring(i) .. "=" .. tostring(col.seatKey) .. ":" .. tostring(col.kind)
        end
    end
    return table.concat(parts, ":")
end

--- @return boolean True unless `sessionScene.npcWorld.controlBoardSnapsEnabled` is explicitly false.
function Gameboard.areControlBoardSnapsEnabled()
    local S = stateModule()
    if type(S) ~= "table" or type(S.getStateVal) ~= "function" then
        return true
    end
    local nw = S.getStateVal("sessionScene", "npcWorld")
    if type(nw) == "table" and nw.controlBoardSnapsEnabled == false then
        return false
    end
    return true
end

--- Enable or disable CONTROL_BOARD polar snaps (persists in `sessionScene.npcWorld`).
--- @param enabled boolean
--- @param options table|nil `{ board?: Object }`
--- @return boolean enabled after call
function Gameboard.setControlBoardSnapsEnabled(enabled, options)
    options = type(options) == "table" and options or {}
    local S = stateModule()
    if type(S) == "table" and type(S.setStateVal) == "function" then
        S.setStateVal(enabled ~= false, "sessionScene", "npcWorld", "controlBoardSnapsEnabled")
    end
    local board = options.board or getControlBoard()
    if not isGameObject(board) or board.setSnapPoints == nil then
        return enabled ~= false
    end
    if enabled == false then
        board.setSnapPoints({})
        polarSnapInstallFingerprint = nil
        installedPolarSnapConfig = nil
        invalidateDefaultSnapCatalogCache(board)
        print("[Gameboard] Control-board snaps disabled (cleared on " .. tostring(board.getGUID()) .. ")")
        return false
    end
    Gameboard.installPolarSnaps(board, { force = true })
    return true
end

--- Flip CONTROL_BOARD snap grid on/off.
--- @param options table|nil `{ board?: Object }`
--- @return boolean enabled after toggle
function Gameboard.toggleControlBoardSnaps(options)
    local nextEnabled = not Gameboard.areControlBoardSnapsEnabled()
    return Gameboard.setControlBoardSnapsEnabled(nextEnabled, options)
end

--- Install CONTROL_BOARD snap points (idempotent; safe from Global reconcile).
--- @param board Object|nil Defaults to G.GUIDS.CONTROL_BOARD
--- @param options table|nil { force?: boolean, config?: table }
--- @return boolean installed
function Gameboard.installPolarSnaps(board, options)
    options = type(options) == "table" and options or {}
    board = board or getControlBoard()
    if not isGameObject(board) or board.setSnapPoints == nil then
        print("[Gameboard] installPolarSnaps: CONTROL_BOARD missing or has no setSnapPoints")
        return false
    end
    if Gameboard.areControlBoardSnapsEnabled() ~= true then
        if #board.getSnapPoints() > 0 then
            board.setSnapPoints({})
            polarSnapInstallFingerprint = nil
            installedPolarSnapConfig = nil
            invalidateDefaultSnapCatalogCache(board)
        end
        return true
    end
    local cfg = resolveControlBoardSnapConfig(options.config)
    local fp = controlBoardSnapFingerprintFor(board, cfg)
    if options.force ~= true and polarSnapInstallFingerprint == fp then
        return true
    end
    boardUvHalfExtentsCache = {}
    invalidateDefaultSnapCatalogCache(board)
    local points = Gameboard.buildControlBoardSnapPoints(board, cfg)
    if #points < 1 then
        print("[Gameboard] installPolarSnaps: no snap points built")
        return false
    end
    local ok = board.setSnapPoints(points)
    if ok then
        polarSnapInstallFingerprint = fp
        installedPolarSnapConfig = resolveControlBoardSnapConfig(cfg)
        Gameboard.buildControlBoardSnapCatalog(board, nil)
        print(
            U.loadElapsedPrefix()
                .. "[Gameboard] Control-board snaps installed ("
                .. tostring(#points)
                .. " points on "
                .. tostring(board.getGUID())
                .. ")"
        )
    else
        print("[Gameboard] installPolarSnaps: setSnapPoints returned false on " .. tostring(board.getGUID()))
    end
    return ok == true
end

--- Alias for installPolarSnaps (same behavior).
Gameboard.installControlBoardSnaps = Gameboard.installPolarSnaps

--- Last installed CONTROL_BOARD snap config, captured from installPolarSnaps.
--- @return table|nil
function Gameboard.getInstalledControlBoardSnapConfig()
    if type(installedPolarSnapConfig) ~= "table" then
        return nil
    end
    return resolveControlBoardSnapConfig(installedPolarSnapConfig)
end

--- Anchor ray angle (degrees) for a catalog entry.
--- @param cfg table
--- @param entry table
--- @return number
local function anchorDegForSnapEntry(cfg, entry)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[entry.ringIndex] or nil
    local rays = tonumber(group and group.rays) or 1
    if rays < 1 then
        rays = 1
    end
    local anchorDeg = (entry.rayIndex / rays) * 360
    if not ringOriginDiffersFromMaster(cfg, entry.ringIndex) then
        return anchorDeg
    end
    local ringOriginU, ringOriginV = ringOriginUvForIndex(cfg, entry.ringIndex)
    local masterU = tonumber(cfg.origin and cfg.origin.u) or 0.5
    local masterV = tonumber(cfg.origin and cfg.origin.v) or 0.5
    return bearingUvDeg(ringOriginU, ringOriginV, masterU, masterV) + anchorDeg
end

--- Family spread offset (degrees) = familyK * angleDelta on that ring.
--- @param cfg table
--- @param entry table
--- @return number
local function spreadOffsetForSnapEntry(cfg, entry)
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[entry.ringIndex] or nil
    local angleDelta = tonumber(group and group.angleDelta) or 0
    return (entry.familyK or 0) * angleDelta
end

--- @param a number degrees
--- @param b number degrees
--- @return number shortest arc distance in [0, 180]
local function angularDeltaDeg(a, b)
    local d = ((a - b) % 360 + 360) % 360
    if d > 180 then
        d = 360 - d
    end
    return d
end

--- Best snap on `ringIndex` matching spread offset, then anchor ray.
--- @param catalog table[]
--- @param cfg table
--- @param ringIndex number
--- @param targetSpread number
--- @param targetAnchor number
--- @return table|nil
local function findBestCatalogEntryOnRing(catalog, cfg, ringIndex, targetSpread, targetAnchor)
    local best = nil
    local bestSpreadDiff = math.huge
    local bestAnchorDiff = math.huge
    for _, entry in ipairs(catalog) do
        if entry.ringIndex == ringIndex then
            local spreadDiff = math.abs(spreadOffsetForSnapEntry(cfg, entry) - targetSpread)
            local anchorDiff = angularDeltaDeg(anchorDegForSnapEntry(cfg, entry), targetAnchor)
            if spreadDiff < bestSpreadDiff
                or (spreadDiff == bestSpreadDiff and anchorDiff < bestAnchorDiff) then
                bestSpreadDiff = spreadDiff
                bestAnchorDiff = anchorDiff
                best = entry
            end
        end
    end
    return best
end

--- Park one token on its palette grid cell when `buildTokenSnapAssignments` has a slot.
--- @param token Object
--- @param characterKey string
--- @return boolean
local function parkNpcTokenOnPalette(token, characterKey)
    local palette = getControlBoardPalette()
    if not isGameObject(palette) or not isGameObject(token) or type(characterKey) ~= "string" then
        return false
    end
    local assignments = Palette.buildTokenSnapAssignments()
    local wantIndex = assignments[characterKey]
    if type(wantIndex) ~= "number" then
        return false
    end
    local wp = Palette.worldPositionForSnapIndex(palette, wantIndex)
    if wp == nil then
        return false
    end
    token.setPosition(wp)
    ensureDefaultNpcControlTokenScale(token)
    Palette.applyPaletteParkingRotation(palette, token)
    if token.setInvisibleTo ~= nil then
        token.setInvisibleTo(C.PlayerColors or {})
    end
    return true
end

--- Park NPC control tokens removed from the seat row (off minimap / in the air).
--- @param characterKeys string[]
--- @param board Object|nil
--- @return number moved
parkVacatedNpcControlTokensToPalette = function(characterKeys, board)
    if type(characterKeys) ~= "table" or #characterKeys < 1 then
        return 0
    end
    board = board or getControlBoard()
    local byChar = buildTokenByCharacterKey()
    local moved = 0
    for i = 1, #characterKeys do
        local ck = characterKeys[i]
        local token = type(ck) == "string" and byChar[ck] or nil
        if isGameObject(token) and (not isGameObject(board) or not isTokenOnMinimapTokenSurface(board, token)) then
            if parkNpcTokenOnPalette(token, ck) then
                moved = moved + 1
            end
        end
    end
    if moved > 0 then
        print("[Gameboard] Apply: parked " .. tostring(moved) .. " vacated token(s) on palette")
    end
    return moved
end

--- Log each NPC token on CONTROL_BOARD (not palette) with ring from snap catalog match.
--- @param board Object|nil
--- @param config table|nil Snap config used to build the catalog for matching
--- @return table[] rows { characterKey, ringIndex?, rayIndex?, familyK?, spreadOffset?, anchorDeg?, reason? }
function Gameboard.logControlBoardTokenSnapRings(board, config)
    board = board or getControlBoard()
    local cfg = resolveControlBoardSnapConfig(config)
    local fuzziness = isGameObject(board) and snapMatchFuzzinessForBoard(board) or CONTROL_BOARD_SNAP_MATCH_FUZZINESS
    local rows = {}
    if not isGameObject(board) then
        print("[Gameboard] logControlBoardTokenSnapRings: CONTROL_BOARD missing")
        return rows
    end
    for _, token in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if isGameObject(token) then
            local characterKey = resolveTokenCharacterKey(token)
            if type(characterKey) == "string" and characterKey ~= "" then
                local palette = getControlBoardPalette()
                if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
                    rows[#rows + 1] = { characterKey = characterKey, reason = "on_palette" }
                    print("[Gameboard] token " .. characterKey .. ": on palette (skipped)")
                else
                    local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, cfg)
                    if entry ~= nil then
                        local spread = spreadOffsetForSnapEntry(cfg, entry)
                        local anchor = anchorDegForSnapEntry(cfg, entry)
                        rows[#rows + 1] = {
                            characterKey = characterKey,
                            ringIndex = entry.ringIndex,
                            rayIndex = entry.rayIndex,
                            familyK = entry.familyK,
                            spreadOffset = spread,
                            anchorDeg = anchor,
                        }
                        print(
                            "[Gameboard] token "
                                .. characterKey
                                .. ": ring "
                                .. tostring(entry.ringIndex)
                                .. " ray "
                                .. tostring(entry.rayIndex)
                                .. " familyK "
                                .. tostring(entry.familyK)
                                .. " spreadOffset "
                                .. string.format("%.2f", spread)
                                .. " anchorDeg "
                                .. string.format("%.1f", anchor)
                        )
                    else
                        rows[#rows + 1] = { characterKey = characterKey, reason = "no_snap_match" }
                        print("[Gameboard] token " .. characterKey .. ": no snap match")
                    end
                end
            end
        end
    end
    return rows
end

--- Install a new CONTROL_BOARD snap grid and remap tokens + placements to the nearest snap on each ring (by spread offset).
--- Tokens on a ring that no longer exists are parked on CONTROL_BOARD_PALETTE and removed from placements.
--- @param oldConfig table|nil Config that matches current token positions (default DATA.CONTROL_BOARD_SNAP)
--- @param newConfig table New CONTROL_BOARD_SNAP table to install
--- @param options table|nil `{ skipSync?: boolean }`
--- @return table stats
function Gameboard.remapControlBoardSnapsToConfig(oldConfig, newConfig, options)
    options = type(options) == "table" and options or {}
    local board = getControlBoard()
    local stats = {
        logged = 0,
        remapped = 0,
        palette = 0,
        skipped = 0,
    }
    if not isGameObject(board) then
        print("[Gameboard] remapControlBoardSnapsToConfig: CONTROL_BOARD missing")
        return stats
    end
    if type(newConfig) ~= "table" then
        error("remapControlBoardSnapsToConfig: newConfig table required")
    end
    local oldCfg = type(oldConfig) == "table"
        and resolveControlBoardSnapConfig(oldConfig)
        or Gameboard.getInstalledControlBoardSnapConfig()
        or resolveControlBoardSnapConfig(DATA.CONTROL_BOARD_SNAP)
    local newCfg, newRings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(newConfig))
    local fuzziness = snapMatchFuzzinessForBoard(board)

    print("[Gameboard] remap: logging token rings (old snap config)")
    local tokenPlans = {}
    for _, token in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if isGameObject(token) then
            local characterKey = resolveTokenCharacterKey(token)
            if type(characterKey) == "string" and characterKey ~= "" then
                local palette = getControlBoardPalette()
                if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
                    stats.skipped = stats.skipped + 1
                else
                    stats.logged = stats.logged + 1
                    local oldEntry = resolveTokenSnapCatalogEntry(board, token, fuzziness, oldCfg)
                    tokenPlans[#tokenPlans + 1] = {
                        token = token,
                        characterKey = characterKey,
                        oldEntry = oldEntry,
                        npcLightMode = tokenLightModeFromFlip(token),
                    }
                    if oldEntry ~= nil then
                        print(
                            "[Gameboard] remap log "
                                .. characterKey
                                .. ": ring "
                                .. tostring(oldEntry.ringIndex)
                        )
                    else
                        print("[Gameboard] remap log " .. characterKey .. ": no snap match (old config)")
                    end
                end
            end
        end
    end

    Gameboard.installPolarSnaps(board, { force = true, config = newCfg })
    local newCatalog = Gameboard.buildControlBoardSnapCatalog(board, newCfg)
    local placements = {}
    local existing = stateModule().getStateVal("sessionScene", "npcWorld", "placements")
    if type(existing) == "table" then
        for ck, row in pairs(existing) do
            if type(ck) == "string" and type(row) == "table" then
                placements[ck] = row
            end
        end
    end
    local boardYaw = objectYawDeg(board)

    for _, plan in ipairs(tokenPlans) do
        local token = plan.token
        local characterKey = plan.characterKey
        local oldEntry = plan.oldEntry
        if oldEntry == nil then
            placements[characterKey] = nil
            stats.skipped = stats.skipped + 1
        elseif oldEntry.snapKind == SNAP_KIND_SEAT then
            stats.skipped = stats.skipped + 1
        elseif oldEntry.ringIndex > newRings then
            placements[characterKey] = nil
            if parkNpcTokenOnPalette(token, characterKey) then
                stats.palette = stats.palette + 1
            else
                stats.skipped = stats.skipped + 1
            end
            print(
                "[Gameboard] remap "
                    .. characterKey
                    .. ": ring "
                    .. tostring(oldEntry.ringIndex)
                    .. " removed → palette"
            )
        else
            local targetSpread = spreadOffsetForSnapEntry(oldCfg, oldEntry)
            local targetAnchor = anchorDegForSnapEntry(oldCfg, oldEntry)
            local newEntry = findBestCatalogEntryOnRing(
                newCatalog,
                newCfg,
                oldEntry.ringIndex,
                targetSpread,
                targetAnchor
            )
            if newEntry == nil then
                placements[characterKey] = nil
                stats.skipped = stats.skipped + 1
                print("[Gameboard] remap " .. characterKey .. ": no target snap on ring " .. tostring(oldEntry.ringIndex))
            else
                placeTokenOnControlBoardSnap(token, newEntry, board, boardYaw)
                local row = {
                    u = newEntry.u,
                    v = newEntry.v,
                    yaw = newEntry.yawDeg,
                    npcLightMode = plan.npcLightMode,
                }
                if newEntry.groundLevel ~= nil then
                    row.groundLevel = newEntry.groundLevel
                end
                placements[characterKey] = row
                stats.remapped = stats.remapped + 1
                print(
                    "[Gameboard] remap "
                        .. characterKey
                        .. ": ring "
                        .. tostring(oldEntry.ringIndex)
                        .. " → ray "
                        .. tostring(newEntry.rayIndex)
                        .. " familyK "
                        .. tostring(newEntry.familyK)
                )
            end
        end
    end

    stateModule().setStateVal(placements, "sessionScene", "npcWorld", "placements")
    local palette = getControlBoardPalette()
    if isGameObject(palette) then
        Palette.syncTokensToPalette(palette)
    end

    if options.skipSync ~= true then
        local Sync = require("core.sync")
        Sync.npcs({
            reason = "gameboard_snap_remap",
            force = true,
            onlySteps = { 1, 5 },
            deferUiRefresh = true,
            skipPreloadPopulate = true,
        })
    end

    print(
        "[Gameboard] remap complete: logged="
            .. tostring(stats.logged)
            .. " remapped="
            .. tostring(stats.remapped)
            .. " palette="
            .. tostring(stats.palette)
            .. " skipped="
            .. tostring(stats.skipped)
    )
    return stats
end

--- Absolute world Y for a normalized u/v on the control-board snap grid (from matching ring `groundLevel`).
--- When the ring omits `groundLevel`, returns nil and `worldFromUv` uses STAGE_BOARD surface world Y at u,v.
--- @param u number
--- @param v number
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return number|nil
function Gameboard.groundLevelForSnapUv(u, v, config)
    u = tonumber(u)
    v = tonumber(v)
    local seatCfg = resolveControlBoardSeatRowConfig()
    if seatCfg ~= nil and u ~= nil and v ~= nil then
        local seatV = tonumber(seatCfg.v) or 0.15
        if math.abs(v - seatV) < 0.02 then
            return nil
        end
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local ringIndex = resolveRingIndexForUv(cfg, u, v, rings)
    local group = cfg.snapGroups[ringIndex]
    return resolveSnapGroupGroundLevel(group)
end

--- @param u number
--- @param v number
--- @param config table|nil
--- @return number ringIndex 1-based
function Gameboard.resolveSnapRingIndexForUv(u, v, config)
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    return resolveRingIndexForUv(cfg, u, v, rings)
end

--- Board-relative Y yaw for a placement at u,v: face the config master `origin` (token Y is cosmetic; figurines use the same math).
--- @param u number
--- @param v number
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return number yawDeg 0–360 board-local
function Gameboard.placementBoardRelYawDeg(u, v, config)
    u = tonumber(u)
    v = tonumber(v)
    if u == nil or v == nil then
        return 0
    end
    local board = getControlBoard()
    if not isGameObject(board) then
        return 0
    end
    local cfg, rings = validateControlBoardSnapConfig(resolveControlBoardSnapConfig(config))
    local originU = tonumber(cfg.origin.u) or 0.5
    local originV = tonumber(cfg.origin.v) or 0.5
    local ringIndex = resolveRingIndexForUv(cfg, u, v, rings)
    local group = cfg.snapGroups[ringIndex]
    local ringYawOffsetDeg = tonumber(group.snapYawOffsetDeg)
    if ringYawOffsetDeg == nil then
        ringYawOffsetDeg = tonumber(cfg.snapYawOffsetDeg) or 0
    end
    local towardOrigin = snapYawTowardOriginDeg(board, u, v, originU, originV)
    return ((towardOrigin + ringYawOffsetDeg) % 360 + 360) % 360
end

--- @param catalog table[]
--- @param familyId string
--- @return table|nil anchor catalog entry (`familyK == 0`)
local function anchorCatalogEntryForFamilyId(catalog, familyId)
    if type(catalog) ~= "table" or type(familyId) ~= "string" or familyId == "" then
        return nil
    end
    for _, entry in ipairs(catalog) do
        if entry.familyId == familyId and entry.isAnchor == true then
            return entry
        end
    end
    return nil
end

--- @param board Object
--- @param anchorEntry table catalog entry with `worldPos`
--- @param cfg table CONTROL_BOARD_SNAP config
--- @return number distance in CONTROL_BOARD world XZ from master origin to anchor
local function anchorWorldDistanceFromMasterOrigin(board, anchorEntry, cfg)
    if type(anchorEntry) ~= "table" or anchorEntry.worldPos == nil then
        return math.huge
    end
    local originU = tonumber(cfg.origin.u) or 0.5
    local originV = tonumber(cfg.origin.v) or 0.35
    local originLp = boardLocalFromUv(board, originU, originV)
    local originWorld = boardLocalToWorld(board, originLp)
    local ap = anchorEntry.worldPos
    local odx = (ap.x or 0) - (originWorld.x or 0)
    local odz = (ap.z or 0) - (originWorld.z or 0)
    return math.sqrt(odx * odx + odz * odz)
end

--- Resolve a persisted placement u/v to the same anchor-family catalog row used by anchor spread.
--- Prefers board u/v match; falls back to STAGE world XZ nearest snap when scan drift exceeds tolerance.
--- @param u number normalized placement u
--- @param v number normalized placement v
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table|nil catalog entry with `familyId`, `familyK`, `isAnchor`, …
function Gameboard.resolvePlacementSnapCatalogEntry(u, v, config)
    u = tonumber(u)
    v = tonumber(v)
    if u == nil or v == nil then
        return nil
    end
    local board = getControlBoard()
    if not isGameObject(board) then
        return nil
    end
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, config)
    local bestUv = nil
    local bestUvDist2 = math.huge
    for _, entry in ipairs(catalog) do
        if entry.snapKind ~= SNAP_KIND_SEAT and entry.u ~= nil and entry.v ~= nil then
            local du = u - entry.u
            local dv = v - entry.v
            local d2 = du * du + dv * dv
            if d2 < bestUvDist2 then
                bestUvDist2 = d2
                bestUv = entry
            end
        end
    end
    local uvTol = 0.02
    if bestUv ~= nil and bestUvDist2 <= uvTol * uvTol then
        return bestUv
    end
    local targetWorld = Gameboard.worldFromUv(u, v, {
        groundLevel = Gameboard.groundLevelForSnapUv(u, v, config),
    })
    local bestWorld = nil
    local bestWorldDist2 = math.huge
    for _, entry in ipairs(catalog) do
        if entry.snapKind ~= SNAP_KIND_SEAT and entry.worldPos ~= nil then
            local wp = entry.worldPos
            local dx = (wp.x or 0) - targetWorld.x
            local dz = (wp.z or 0) - targetWorld.z
            local d2 = dx * dx + dz * dz
            if d2 < bestWorldDist2 then
                bestWorldDist2 = d2
                bestWorld = entry
            end
        end
    end
    return bestWorld or bestUv
end

--- Sort key for stage lerp anchor-family batches: center-out on destination anchor; tie-break by anchor travel.
--- @param srcEntry table|nil catalog entry at move start
--- @param destEntry table|nil catalog entry at move end
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return number lower = earlier in orchestrator
function Gameboard.stageLerpFamilyGroupSortKey(srcEntry, destEntry, config)
    if type(destEntry) ~= "table" then
        return math.huge
    end
    local board = getControlBoard()
    if not isGameObject(board) then
        return math.huge
    end
    local cfg = resolveControlBoardSnapConfig(config)
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, config)
    local destFamilyId = destEntry.familyId
    local destAnchor = anchorCatalogEntryForFamilyId(catalog, destFamilyId) or destEntry
    local destDist = anchorWorldDistanceFromMasterOrigin(board, destAnchor, cfg)
    local travel = 0
    if type(srcEntry) == "table" and type(srcEntry.familyId) == "string" then
        local srcAnchor = anchorCatalogEntryForFamilyId(catalog, srcEntry.familyId) or srcEntry
        if type(srcAnchor) == "table" and srcAnchor.worldPos ~= nil and destAnchor.worldPos ~= nil then
            local sp = srcAnchor.worldPos
            local dp = destAnchor.worldPos
            local tdx = (dp.x or 0) - (sp.x or 0)
            local tdz = (dp.z or 0) - (sp.z or 0)
            travel = math.sqrt(tdx * tdx + tdz * tdz)
        end
    end
    return destDist + travel * 0.001
end

--- Destination anchor-family for stage lerp batching (TOR-173): same `familyId` grouping as anchor spread.
--- @param u number normalized placement u
--- @param v number normalized placement v
--- @param config table|nil Defaults to DATA.CONTROL_BOARD_SNAP
--- @return table|nil `{ areaKey: string, sortKey: number, familyId: string, snapEntry: table }`
function Gameboard.stageAreaGroupForPlacement(u, v, config)
    local entry = Gameboard.resolvePlacementSnapCatalogEntry(u, v, config)
    if entry == nil then
        return nil
    end
    local familyId = entry.familyId or (tostring(entry.ringIndex) .. ":" .. tostring(entry.rayIndex))
    return {
        areaKey = familyId,
        sortKey = Gameboard.stageLerpFamilyGroupSortKey(nil, entry, config),
        familyId = familyId,
        snapEntry = entry,
    }
end

--- Minimal object Lua when the save has no bundled CONTROL_BOARD script (GUID bea29a).
--- 3D/XmlUI buttons call `click_*` on the board object; Global reconcile installs buttons but cannot define handlers without this.
local CONTROL_BOARD_FALLBACK_LUA_SCRIPT = [=[--- Toronto Rising — CONTROL_BOARD fallback (Global-injected when save LuaScript is empty).
--- Persist a bundled script: `.tts/objects/CONTROL_BOARD.*.ttslua` → require("objects.npc_control_board") → Save & Play.

local function resolveControlBoardClickColor(arg1, arg2)
    if arg1 ~= nil and type(arg1.color) == "string" and arg1.color ~= "" then
        return arg1.color
    end
    if type(arg2) == "string" and arg2 ~= "" then
        return arg2
    end
    return nil
end

function onLoad()
    if Global ~= nil and type(Global.call) == "function" then
        Global.call("GlobalGameboardSyncSnapsToggleLabel", { boardGuid = self.getGUID() })
    end
end

function click_apply(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    Global.call("GlobalGameboardApply", {})
end

function click_clear(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    Global.call("GlobalGameboardClearClick", { player_color = player_color })
end

function click_snaps_toggle(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    local enabled = nil
    if Global ~= nil and type(Global.call) == "function" then
        enabled = Global.call("GlobalGameboardToggleControlBoardSnaps", { boardGuid = self.getGUID() })
    end
    if broadcastToColor ~= nil then
        local msg = enabled and "Control-board snap points enabled." or "Control-board snap points disabled."
        broadcastToColor(msg, player_color, { 0, 1, 1 })
    end
end

function click_read_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Read: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end

function click_lock_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Lock: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end

function click_load_stub(player, value, id)
    local player_color = resolveControlBoardClickColor(player, value)
    if player_color ~= "Black" then
        return
    end
    if broadcastToColor ~= nil then
        broadcastToColor("Load: Phase B (not wired yet).", player_color, { 1, 0.8, 0.4 })
    end
end
]=]

--- @param script string|nil
--- @return boolean
local function controlBoardScriptDefinesClickApply(script)
    return type(script) == "string"
        and script:find("function click_apply", 1, true) ~= nil
        and script:find("resolveControlBoardClickColor", 1, true) ~= nil
end

--- Inject `click_*` handlers when the workshop save has empty CONTROL_BOARD LuaScript.
--- @param board Object|nil
--- @return boolean true when handlers are present (already or after inject)
function Gameboard.ensureControlBoardObjectCallbacks(board)
    board = board or getControlBoard()
    if not isGameObject(board) or board.getLuaScript == nil or board.setLuaScript == nil then
        return false
    end
    local existing = board.getLuaScript() or ""
    if controlBoardScriptDefinesClickApply(existing) then
        return true
    end
    local ok = board.setLuaScript(CONTROL_BOARD_FALLBACK_LUA_SCRIPT)
    if ok ~= true then
        print(
            "[Gameboard] ensureControlBoardObjectCallbacks: setLuaScript failed on "
                .. tostring(board.getGUID())
        )
        return false
    end
    print(
        "[Gameboard] installed CONTROL_BOARD click_* fallback on "
            .. tostring(board.getGUID())
            .. " — Save & Play with require(\"objects.npc_control_board\") to persist the full bundle"
    )
    return true
end

--- Install Apply/Clear/Read/Lock/Load 3D buttons when the save has no object script on CONTROL_BOARD yet.
--- @param board Object|nil
function Gameboard.ensureControlBoardObjectUi(board)
    board = board or getControlBoard()
    if not isGameObject(board) then
        return
    end
    local BoardUi = require("objects.npc_control_board_ui")
    BoardUi.installObjectButtons(board)
end

--- Refresh XmlUI `gb_snaps` toolbar label from `sessionScene.npcWorld.controlBoardSnapsEnabled`.
--- @param board Object|nil
function Gameboard.syncControlBoardSnapsToggleLabel(board)
    board = board or getControlBoard()
    if not isGameObject(board) or board.UI == nil or type(board.UI.setAttributes) ~= "function" then
        return
    end
    local enabled = Gameboard.areControlBoardSnapsEnabled()
    local label = enabled and "Snaps On" or "Snaps Off"
    local colors = enabled and "#336644|#448855|#55AA66|#333333" or "#555566|#666677|#777788|#333333"
    board.UI.setAttributes("gb_snaps", { text = label, colors = colors, textColor = "#FFFFFF" })
end

--- Static minimap markers (not npc_control_token): locked so physics does not shove them apart.
--- @param marker Object|nil
local function lockControlBoardMarker(marker)
    if not isGameObject(marker) or marker.setLock == nil then
        return
    end
    marker.setLock(true)
end

--- Park empty / inactive NPC seat markers off the play surface (locked).
--- @param marker Object
--- @param npcSeatKey string|nil Used to spread stash X slightly per slot
local function stashNpcSeatMarker(marker, npcSeatKey)
    if not isGameObject(marker) or marker.setPosition == nil then
        return
    end
    local stashY = tonumber(DATA.MARKER_STASH_WORLD_Y) or -200
    local pos = marker.getPosition()
    local offsetX = 0
    if type(npcSeatKey) == "string" then
        for i = 1, #(C.NPCSeats or {}) do
            if C.NPCSeats[i] == npcSeatKey then
                offsetX = (i - 1) * 0.75
                break
            end
        end
    end
    marker.setPosition(Vector({ x = pos.x + offsetX, y = stashY, z = pos.z }))
    lockControlBoardMarker(marker)
end

--- Park inactive table-component markers off the control surface (locked).
--- @param marker Object
--- @param componentName string|nil Used to spread stash X slightly per component
local function stashTableComponentMarker(marker, componentName)
    if not isGameObject(marker) or marker.setPosition == nil then
        return
    end
    local stashY = tonumber(DATA.MARKER_STASH_WORLD_Y) or -200
    local pos = marker.getPosition()
    local offsetX = 0
    if type(componentName) == "string" then
        offsetX = (string.byte(componentName, 1) or 0) * 0.01
    end
    marker.setPosition(Vector({ x = pos.x + offsetX, y = stashY, z = pos.z }))
    lockControlBoardMarker(marker)
end

--- Park inactive table minimap markers off the control surface (locked).
--- @param marker Object
--- @param tableKey string|nil Used to spread stash X slightly per table
local function stashTableMarker(marker, tableKey)
    if not isGameObject(marker) or marker.setPosition == nil then
        return
    end
    local stashY = tonumber(DATA.MARKER_STASH_WORLD_Y) or -200
    local pos = marker.getPosition()
    local offsetX = 0
    if type(tableKey) == "string" then
        offsetX = (string.byte(tableKey, 1) or 0) * 0.02
    end
    marker.setPosition(Vector({ x = pos.x + offsetX, y = stashY, z = pos.z }))
    lockControlBoardMarker(marker)
end

--- Build diagnostics for a control-board table-component marker.
--- @param marker Object
--- @param activeTable string|nil
--- @return table
local function describeTableComponentMarker(marker, activeTable)
    local row = {
        markerGuid = isGameObject(marker) and marker.getGUID and marker.getGUID() or nil,
        markerName = isGameObject(marker) and marker.getName and marker.getName() or nil,
        activeTable = activeTable,
        show = false,
        reasons = {},
    }
    local compKey = readMarkerKey(marker, DATA.MARKER_COMPONENT_PREFIX)
    row.compKey = compKey
    local parentTable, componentName = parseComponentMarkerKey(compKey)
    row.parentTable = parentTable
    row.componentName = componentName
    if type(parentTable) ~= "string" or parentTable == "" then
        row.reasons[#row.reasons + 1] = "missing_parent_table"
    end
    if type(componentName) ~= "string" or componentName == "" then
        row.reasons[#row.reasons + 1] = "missing_component_name"
    end
    local cfg = tableConfig(parentTable)
    row.tableExists = type(cfg) == "table"
    if row.tableExists ~= true then
        row.reasons[#row.reasons + 1] = "table_cfg_missing"
    end
    local comp = nil
    if row.tableExists and type(cfg.components) == "table" then
        comp = cfg.components[componentName]
    end
    row.componentExists = type(comp) == "table"
    if row.componentExists ~= true then
        row.reasons[#row.reasons + 1] = "component_cfg_missing"
    end
    local usedBy = row.componentExists and comp.usedBy or nil
    row.usedBy = usedBy
    local usedByOccupied = nil
    if type(usedBy) == "string" and usedBy ~= "" then
        usedByOccupied = npcSeatOccupiedOnTable(usedBy)
    end
    row.usedByOccupied = usedByOccupied
    if usedByOccupied == false then
        row.reasons[#row.reasons + 1] = "used_by_seat_empty"
    end
    local show = parentTable == activeTable
        and type(componentName) == "string"
        and componentName ~= ""
        and tableComponentActiveForOccupiedSlots(parentTable, componentName)
    row.show = show
    if parentTable ~= activeTable then
        row.reasons[#row.reasons + 1] = "inactive_table"
    end
    local tableU, tableV = nil, nil
    if type(parentTable) == "string" then
        tableU, tableV = mapUvForTableCenter(parentTable)
    end
    row.tableU = tableU
    row.tableV = tableV
    row.targetU = tableU
    row.targetV = tableV
    row.placementMode = "table_transform"
    if show and (tableU == nil or tableV == nil) then
        row.reasons[#row.reasons + 1] = "table_uv_mapping_failed"
    end
    local tableSource = sourceObjectForTable(parentTable)
    row.tableSourceExists = isGameObject(tableSource)
    row.tableSourceGuid = row.tableSourceExists and tableSource.getGUID and tableSource.getGUID() or nil
    if show and row.tableSourceExists ~= true then
        row.reasons[#row.reasons + 1] = "table_source_missing"
    end
    if isGameObject(marker) and marker.getPosition ~= nil then
        row.markerPosition = marker.getPosition()
    end
    return row
end

--- Print one-line diagnostics for a component marker.
--- @param row table
local function printTableComponentMarkerRow(row)
    local reasons = table.concat(row.reasons or {}, ",")
    if reasons == "" then
        reasons = "none"
    end
    print(
        "[Gameboard] component marker "
            .. tostring(row.componentName or row.compKey or "<unknown>")
            .. " guid=" .. tostring(row.markerGuid or "")
            .. " table=" .. tostring(row.parentTable or "")
            .. " activeTable=" .. tostring(row.activeTable or "")
            .. " show=" .. tostring(row.show == true)
            .. " usedBy=" .. tostring(row.usedBy or "")
            .. " occupied=" .. tostring(row.usedByOccupied)
            .. " uv=(" .. tostring(row.targetU) .. "," .. tostring(row.targetV) .. ")"
            .. " tableSource=" .. tostring(row.tableSourceGuid or "")
            .. " mode=" .. tostring(row.placementMode or "")
            .. " reasons=" .. reasons
    )
end

--- @param marker Object
--- @param board Object
--- @param u number|nil
--- @param v number|nil
--- @param source Object|nil Playfield object this minimap piece mimics (scale + rotation)
--- @param options table|nil { extraLocalY?: number }
local function placeControlBoardMarker(marker, board, u, v, source, options)
    local opts = options or {}
    if u ~= nil and v ~= nil then
        marker.setPosition(Gameboard.worldOnControlBoard(board, u, v, {
            extraLocalY = opts.extraLocalY,
        }))
    end
    if isGameObject(source) then
        applyMinimapMarkerScale(marker, source)
    end
    applyMinimapMarkerRotation(marker, board, source)
    lockControlBoardMarker(marker)
end

--- Active table-leaf markers use the parent table's CONTROL_BOARD transform (models are authored table-relative).
--- @param marker Object
--- @param board Object
--- @param parentTable string
--- @return boolean placed
local function placeActiveTableComponentMarker(marker, board, parentTable)
    local u, v = mapUvForTableCenter(parentTable)
    if u == nil or v == nil then
        return false
    end
    local tableSource = sourceObjectForTable(parentTable)
    placeControlBoardMarker(
        marker,
        board,
        u,
        v,
        tableSource,
        {
            extraLocalY = tonumber(DATA.MINIMAP_TABLE_EXTRA_LOCAL_Y) or 0.06,
        }
    )
    return true
end

--- @return table<string, Object>
buildTokenByCharacterKey = function()
    local byKey = {}
    local tagged = getObjectsWithTag(TAG_TOKEN) or {}
    for _, tok in ipairs(tagged) do
        if isGameObject(tok) then
            local ck = resolveTokenCharacterKey(tok)
            if type(ck) == "string" and ck ~= "" and byKey[ck] == nil then
                byKey[ck] = tok
            end
        end
    end
    return byKey
end

--- After Clear: park stage tokens but return homeland assignments to the seat-row snap (TOR-180).
--- @param board Object|nil
function Gameboard.relocateHomelandSeatTokensAfterClear(board)
    board = board or getControlBoard()
    if not isGameObject(board) then
        return
    end
    local NPCS = require("core.npcs")
    local seatCatalog = seatRowCatalogByNpcSeatKey(Gameboard.buildControlBoardSnapCatalog(board, nil))
    local occupied = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(occupied) ~= "table" then
        return
    end
    local byChar = buildTokenByCharacterKey()
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        local ck = occupied[seatKey]
        if type(ck) == "string" and ck ~= "" then
            local entry = seatCatalog[seatKey]
            local token = byChar[ck]
            if entry ~= nil and isGameObject(token) then
                local present = true
                if type(NPCS.resolveSeatNarrativePresence) == "function" then
                    present = NPCS.resolveSeatNarrativePresence(seatKey) == true
                end
                mirrorSeatRowControlToken(token, board, entry, present)
            end
        end
    end
end

--- Move one control token to exact placement u,v on CONTROL_BOARD (from palette or elsewhere).
--- @param token Object
--- @param board Object
--- @param row table `{ u, v, npcLightMode? }`
local function mirrorControlTokenToPlacementRow(token, board, row)
    if not isGameObject(token) or not isGameObject(board) or type(row) ~= "table" then
        return
    end
    local u = tonumber(row.u)
    local v = tonumber(row.v)
    if u == nil or v == nil then
        return
    end
    token.setPosition(Gameboard.worldOnControlBoard(board, u, v))
    local boardYaw = objectYawDeg(board)
    local relYaw = Gameboard.placementBoardRelYawDeg(u, v)
    local faceUp = row.npcLightMode ~= "OFF"
    ensureDefaultNpcControlTokenScale(token)
    token.setRotation(rotationForNpcControlToken(boardYaw, relYaw, faceUp))
    Gameboard.setHiddenFromPlayerColors(token)
end

--- Horizontal hit radius for NPC control token dropped on a Storyteller dice bag (TOR-174).
local ST_DICE_BAG_TOKEN_DROP_RADIUS = 3
local storytellerDiceBagDropEntries = nil

--- @return table[] { kind: string, guid: string }
local function storytellerDiceBagDropEntriesList()
    if storytellerDiceBagDropEntries ~= nil then
        return storytellerDiceBagDropEntries
    end
    storytellerDiceBagDropEntries = {}
    local bags = G.GetAllStorytellerDiceBagGUIDs()
    for kind, guid in pairs(bags) do
        if type(kind) == "string" and type(guid) == "string" and guid ~= "" then
            storytellerDiceBagDropEntries[#storytellerDiceBagDropEntries + 1] = {
                kind = kind,
                guid = guid,
            }
        end
    end
    return storytellerDiceBagDropEntries
end

--- @param pos Vector|table|nil
--- @return string|nil bag pool key (`normal`, `hunger`, …) when within hit radius
local function dieKindNearStorytellerDiceBag(pos)
    if pos == nil then
        return nil
    end
    local bestKind = nil
    local bestDist = ST_DICE_BAG_TOKEN_DROP_RADIUS
    for _, entry in ipairs(storytellerDiceBagDropEntriesList()) do
        local bag = getObjectFromGUID(entry.guid)
        if U.isGameObject(bag) and bag.getPosition ~= nil then
            local dist = U.HorizontalDistance(pos, bag.getPosition())
            if dist < bestDist then
                bestDist = dist
                bestKind = entry.kind
            end
        end
    end
    return bestKind
end

--- @param characterKey string
--- @return string|nil homeland NPC seat key when assigned
local function homelandSeatForCharacterKey(characterKey)
    if type(characterKey) ~= "string" or characterKey == "" then
        return nil
    end
    local occupied = stateModule().getStateVal("seatLayout", "occupiedNPCSlots")
    if type(occupied) ~= "table" then
        return nil
    end
    for _, seatKey in ipairs(C.NPCSeats or {}) do
        if occupied[seatKey] == characterKey then
            return seatKey
        end
    end
    return nil
end

--- @param characterKey string
--- @return string|nil NPC full name for ST roll label
local function npcDisplayNameForCharacterKey(characterKey)
    if type(characterKey) ~= "string" or characterKey == "" then
        return nil
    end
    local def = type(NPCS_DATA.characters) == "table" and NPCS_DATA.characters[characterKey] or nil
    if type(def) == "table" then
        local display = def.fullName or def.name
        if type(display) == "string" and display ~= "" then
            return display
        end
    end
    return characterKey
end

--- Re-apply committed token home from state (stage placement, homeland seat row, or palette).
--- @param token Object
--- @param characterKey string|nil
--- @return boolean restored
local function restoreNpcControlTokenHome(token, characterKey)
    if not isNpcControlToken(token) then
        return false
    end
    characterKey = characterKey or resolveTokenCharacterKey(token)
    if type(characterKey) ~= "string" or characterKey == "" then
        return false
    end
    local guid = tostring(token.getGUID() or "")
    if guid ~= "" then
        tokenPickedUpFromPaletteGuid[guid] = nil
    end

    local placements = stateModule().getStateVal("sessionScene", "npcWorld", "placements")
    local placementRow = type(placements) == "table" and normalizePlacementRow(placements[characterKey]) or nil
    if placementRow ~= nil then
        local board = getControlBoard()
        if isGameObject(board) then
            mirrorControlTokenToPlacementRow(token, board, placementRow)
            return true
        end
    end

    local seatKey = homelandSeatForCharacterKey(characterKey)
    if type(seatKey) == "string" and seatKey ~= "" then
        local board = getControlBoard()
        if isGameObject(board) then
            local seatCatalog = seatRowCatalogByNpcSeatKey(Gameboard.buildControlBoardSnapCatalog(board, nil))
            local entry = seatCatalog[seatKey]
            if type(entry) == "table" then
                local NPCS = require("core.npcs")
                local present = true
                if type(NPCS.resolveSeatNarrativePresence) == "function" then
                    present = NPCS.resolveSeatNarrativePresence(seatKey) == true
                end
                mirrorSeatRowControlToken(token, board, entry, present)
                return true
            end
        end
    end

    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.parkTokenAtAssignedSnap(palette, token, characterKey) then
        ensureDefaultNpcControlTokenScale(token)
        return true
    end
    return false
end

--- Storyteller drops NPC control token on a dice bag → restore home from state + initiate NPC roll (TOR-174).
--- @param token Object
--- @param playerColor string|nil
--- @return boolean true when drop was consumed (hit an ST bag)
local function tryNpcControlTokenDroppedOnStorytellerDiceBag(token, playerColor)
    if not isNpcControlToken(token) then
        return false
    end
    if playerColor ~= "Black" and playerColor ~= "Host" then
        return false
    end
    if token.getPosition == nil then
        return false
    end
    local board = getControlBoard()
    if isGameObject(board) and isTokenOnMinimapTokenSurface(board, token) then
        return false
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, token) then
        return false
    end
    local bagKind = dieKindNearStorytellerDiceBag(token.getPosition())
    if bagKind == nil then
        return false
    end
    local characterKey = resolveTokenCharacterKey(token)
    if type(characterKey) ~= "string" or characterKey == "" then
        return false
    end
    local label = npcDisplayNameForCharacterKey(characterKey)
    if type(label) ~= "string" or label == "" then
        return false
    end

    restoreNpcControlTokenHome(token, characterKey)

    local dieKind = bagKind
    if dieKind ~= DK.KIND_NORMAL
        and dieKind ~= DK.KIND_HUNGER
        and dieKind ~= DK.KIND_ROUSE
        and dieKind ~= DK.KIND_OBLIV_ROUSE
        and dieKind ~= DK.KIND_WEREWOLF
        and dieKind ~= DK.KIND_RAGE then
        dieKind = DK.KIND_NORMAL
    end

    local STR = require("core.storyteller_rolls")
    local ok = STR.initiateFromBagLabel(label, dieKind)
    if ok ~= true then
        print(
            "[Gameboard] ST dice-bag token drop: roll not started for "
                .. label
                .. " ("
                .. tostring(dieKind)
                .. ")"
        )
    end
    return true
end

Gameboard.restoreNpcControlTokenHome = restoreNpcControlTokenHome
Gameboard.tryNpcControlTokenDroppedOnStorytellerDiceBag = tryNpcControlTokenDroppedOnStorytellerDiceBag

--- Position static table/seat markers for active table.
--- @param opts table|nil `{ force?: boolean }`
function Gameboard.reconcileControlBoardFromState(opts)
    opts = type(opts) == "table" and opts or {}
    local S = stateModule()
    if type(S) ~= "table" or type(S.getStateVal) ~= "function" then
        print("[Gameboard] reconcileControlBoardFromState: core.state unavailable")
        return
    end
    local board = getControlBoard()
    if not isGameObject(board) then
        return
    end
    Gameboard.installPolarSnaps(board)
    Gameboard.ensureControlBoardObjectCallbacks(board)
    Gameboard.ensureControlBoardObjectUi(board)
    Gameboard.syncControlBoardSnapsToggleLabel(board)
    Gameboard.installPaletteSnaps(nil, { force = opts.force == true })

    local npcWorld = S.getStateVal("sessionScene", "npcWorld")
    local activeTable = S.getStateVal("seatLayout", "currentTableKey")
    local layoutLocked = type(npcWorld) == "table" and npcWorld.layoutLock == true
    local placements = {}
    if type(npcWorld) == "table" and type(npcWorld.placements) == "table" then
        placements = npcWorld.placements
    end
    local mirrorFp = controlBoardMirrorFingerprint(activeTable, layoutLocked, placements)
    if opts.force ~= true and mirrorFp == lastControlBoardMirrorFingerprint then
        rebuildAnchorDropEligibilityCache(board)
        return
    end
    boardUvHalfExtentsCache = {}
    lastControlBoardMirrorFingerprint = mirrorFp
    local allMarkers = getObjectsWithTag(TAG_TABLE) or {}
    for _, tag in ipairs({ TAG_PC, TAG_NPC_SEAT, TAG_COMPONENT }) do
        local extra = getObjectsWithTag(tag) or {}
        for i = 1, #extra do
            allMarkers[#allMarkers + 1] = extra[i]
        end
    end

    for _, obj in ipairs(allMarkers) do
        if isGameObject(obj) then
            lockControlBoardMarker(obj)
            local tableKey = readMarkerKey(obj, DATA.MARKER_TABLE_PREFIX)
            local compKey = readMarkerKey(obj, DATA.MARKER_COMPONENT_PREFIX)
            local pcSeat = readMarkerKey(obj, DATA.MARKER_PC_SEAT_PREFIX)
            local npcSeat = readMarkerKey(obj, DATA.MARKER_NPC_SEAT_PREFIX)

            if tableKey ~= nil then
                local show = tableKey == activeTable
                setMarkerVisible(obj, show)
                if show then
                    local u, v = mapUvForTableCenter(tableKey)
                    placeControlBoardMarker(
                        obj,
                        board,
                        u,
                        v,
                        sourceObjectForTable(tableKey),
                        {
                            extraLocalY = tonumber(DATA.MINIMAP_TABLE_EXTRA_LOCAL_Y) or 0.06,
                        }
                    )
                else
                    stashTableMarker(obj, tableKey)
                end
            elseif compKey ~= nil then
                local markerRow = describeTableComponentMarker(obj, activeTable)
                local parentTable = markerRow.parentTable
                local componentName = markerRow.componentName
                local show = markerRow.show == true
                setMarkerVisible(obj, show)
                if opts.debugComponentMarkers == true then
                    printTableComponentMarkerRow(markerRow)
                end
                if show and parentTable ~= nil then
                    if not placeActiveTableComponentMarker(obj, board, parentTable) then
                        print(
                            "[Gameboard] component marker "
                                .. tostring(componentName)
                                .. " active on "
                                .. tostring(parentTable)
                                .. " but table minimap placement failed"
                        )
                        stashTableComponentMarker(obj, componentName)
                    end
                else
                    stashTableComponentMarker(obj, componentName)
                end
            elseif pcSeat ~= nil then
                local show = activeTable ~= nil
                setMarkerVisible(obj, show)
                local u, v = nil, nil
                local seg = nil
                if show then
                    local cfg = tableConfig(activeTable)
                    seg = cfg and cfg.playerToPositionMap and cfg.playerToPositionMap[pcSeat]
                    if type(seg) == "number" then
                        local worldSeat = worldPositionForTableSegment(cfg, seg)
                        u, v = normalizedUvFromWorld(worldSeat)
                        placeControlBoardMarker(
                            obj,
                            board,
                            u,
                            v,
                            sourceObjectForSeat(pcSeat)
                        )
                    end
                end
            elseif npcSeat ~= nil then
                setMarkerVisible(obj, false)
                local cfg = tableConfig(activeTable)
                local seg = cfg and cfg.playerToPositionMap and cfg.playerToPositionMap[npcSeat]
                local show = activeTable ~= nil
                    and type(seg) == "number"
                    and npcSeatOccupiedOnTable(npcSeat)
                local u, v = nil, nil
                if show then
                    local worldSeat = worldPositionForTableSegment(cfg, seg)
                    if worldSeat ~= nil then
                        u, v = normalizedUvFromWorld(worldSeat)
                        placeControlBoardMarker(
                            obj,
                            board,
                            u,
                            v,
                            sourceObjectForSeat(npcSeat)
                        )
                    end
                else
                    stashNpcSeatMarker(obj, npcSeat)
                end
            end
        end
    end

    --- Mirror NPC tokens from placements (skip when layout locked — manual board edits preserved).
    if not layoutLocked then
        local byChar = buildTokenByCharacterKey()
        local NPCS = require("core.npcs")
        local seatCatalog = seatRowCatalogByNpcSeatKey(Gameboard.buildControlBoardSnapCatalog(board, nil))
        local occupied = S.getStateVal("seatLayout", "occupiedNPCSlots")
        if type(occupied) == "table" then
            for _, seatKey in ipairs(C.NPCSeats or {}) do
                local ck = occupied[seatKey]
                if type(ck) == "string" and ck ~= "" then
                    local entry = seatCatalog[seatKey]
                    local token = byChar[ck]
                    if entry ~= nil and isGameObject(token) and isTokenOnMinimapTokenSurface(board, token) then
                        local present = true
                        if type(NPCS.resolveSeatNarrativePresence) == "function" then
                            present = NPCS.resolveSeatNarrativePresence(seatKey) == true
                        end
                        mirrorSeatRowControlToken(token, board, entry, present)
                    end
                end
            end
        end
        for characterKey, row in pairs(placements) do
            if type(row) == "table" and type(row.u) == "number" and type(row.v) == "number" then
                local token = byChar[characterKey]
                if isGameObject(token) and isTokenOnMinimapTokenSurface(board, token) then
                    mirrorControlTokenToPlacementRow(token, board, row)
                end
            end
        end
    end

    applyControlBoardComponentPlayerInvisibility()
    rebuildAnchorDropEligibilityCache(board)
end

--- Inspect control-board table-component markers and print placement decisions.
--- @param options table|nil `{ includeTagless?: boolean }`
--- @return table
function Gameboard.debugDescribeControlBoardTableComponents(options)
    options = type(options) == "table" and options or {}
    local activeTable = stateModule().getStateVal("seatLayout", "currentTableKey")
    local rows = {}
    local markers = getObjectsWithTag(TAG_COMPONENT) or {}
    if options.includeTagless == true then
        local all = getAllObjects() or {}
        for _, obj in ipairs(all) do
            if isGameObject(obj) then
                local hasTag = obj.hasTag ~= nil and obj.hasTag(TAG_COMPONENT) == true
                if not hasTag then
                    local compKey = readMarkerKey(obj, DATA.MARKER_COMPONENT_PREFIX)
                    if compKey ~= nil then
                        markers[#markers + 1] = obj
                    end
                end
            end
        end
    end
    print(
        "[Gameboard] component marker scan: activeTable="
            .. tostring(activeTable)
            .. " markerCount="
            .. tostring(#markers)
    )
    for _, marker in ipairs(markers) do
        if isGameObject(marker) then
            local row = describeTableComponentMarker(marker, activeTable)
            rows[#rows + 1] = row
            printTableComponentMarkerRow(row)
        end
    end
    return {
        activeTable = activeTable,
        count = #rows,
        rows = rows,
    }
end

--- Nearest installed snap catalog entry for a token on CONTROL_BOARD (world XZ within fuzziness).
--- @param board Object
--- @param token Object
--- @param fuzziness number|nil
--- @param config table|nil
--- @return table|nil catalog entry with snapIndex, isAnchor, familyK, worldPos, …
resolveTokenSnapCatalogEntry = function(board, token, fuzziness, config)
    if not isGameObject(board) or not isGameObject(token) then
        return nil
    end
    fuzziness = tonumber(fuzziness) or snapMatchFuzzinessForBoard(board)
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, config)
    if #catalog == 0 then
        return nil
    end
    local pos = token.getPosition()
    if pos == nil then
        return nil
    end
    local fuzzSq = fuzziness * fuzziness
    local best = nil
    local bestDistSq = math.huge
    for _, entry in ipairs(catalog) do
        local wp = entry.worldPos
        if wp ~= nil then
            local dx = (pos.x or 0) - (wp.x or 0)
            local dz = (pos.z or 0) - (wp.z or 0)
            local distSq = dx * dx + dz * dz
            if distSq <= fuzzSq and distSq < bestDistSq then
                bestDistSq = distSq
                best = entry
            end
        end
    end
    return best
end

--- @param board Object
--- @param token Object
--- @param fuzziness number|nil
--- @return number|nil snapIndex 1-based in installed getSnapPoints order
local function resolveTokenSnapSlot(board, token, fuzziness)
    local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, nil)
    return entry and entry.snapIndex or nil
end

--- @param result table
local function logAnchorSpreadResult(result)
    if type(result) ~= "table" or result.reason == "suppressed" then
        return
    end
    if (result.placed or 0) > 0 then
        print(
            "[Gameboard] anchor spread: placed "
                .. tostring(result.placed)
                .. " token(s) for group "
                .. tostring(result.groupId)
        )
        return
    end
    local detail = tostring(result.reason or "unknown")
    if type(result.groupId) == "string" and result.groupId ~= "" then
        detail = detail .. " (group=" .. result.groupId .. ")"
    end
    if result.matchedSnapIndex ~= nil then
        detail = detail
            .. " snap="
            .. tostring(result.matchedSnapIndex)
            .. " familyK="
            .. tostring(result.familyK)
    end
    print("[Gameboard] anchor spread skipped: " .. detail)
end

--- Build fast lookup for drop events: only group-leading (slotIndex 1) tokens that are currently off CONTROL_BOARD.
--- @param board Object|nil
rebuildAnchorDropEligibilityCache = function(board)
    anchorDropEligibleByTokenGuid = {}
    if not isGameObject(board) then
        return
    end
    local byKey = buildTokenByCharacterKey()
    for characterKey, token in pairs(byKey) do
        if isGameObject(token) and not isTokenOnControlBoardSurface(board, token) then
            local _, slotIndex = Palette.resolveGroupForCharacterKey(characterKey)
            if tonumber(slotIndex) == 1 then
                anchorDropEligibleByTokenGuid[tostring(token.getGUID())] = true
            end
        end
    end
end

--- @param board Object
--- @param worldPos Vector|table
--- @param fuzziness number
--- @param ignoreToken Object|nil
--- @return Object|nil
local function findOccupyingTokenAtSnapWorld(board, worldPos, fuzziness, ignoreToken)
    if worldPos == nil then
        return nil
    end
    local singleSnap = { { position = worldPos } }
    for _, tok in ipairs(objectsOnControlBoard(board, TAG_TOKEN)) do
        if tok ~= ignoreToken and isGameObject(tok) then
            local slot = U.findSnapPoint(singleSnap, tok.getPosition(), fuzziness)
            if slot ~= nil then
                return tok
            end
        end
    end
    return nil
end

--- @param token Object
--- @param snapEntry table
--- @param board Object
--- @param boardYaw number
local function placeTokenOnControlBoardSnap(token, snapEntry, board, boardYaw)
    token.setPosition(snapEntry.worldPos)
    local faceUp = tokenRotationIsFaceUp(token)
    if type(snapEntry) == "table" and snapEntry.snapKind == SNAP_KIND_SEAT then
        applySeatRowNpcControlTokenScale(token)
    else
        ensureDefaultNpcControlTokenScale(token)
    end
    token.setRotation(rotationForNpcControlToken(boardYaw, snapEntry.yawDeg, faceUp))
    Gameboard.setHiddenFromPlayerColors(token)
end

--- XZ distance from anchor snap on CONTROL_BOARD (board-local when board exists).
--- @param entry table catalog entry with `worldPos`
--- @param anchorEntry table anchor catalog entry
--- @param board Object|nil CONTROL_BOARD
--- @return number
local function familySnapRadialDistFromAnchor(entry, anchorEntry, board)
    local wp = entry and entry.worldPos
    local ap = anchorEntry and anchorEntry.worldPos
    if wp == nil or ap == nil then
        return math.huge
    end
    if isGameObject(board) then
        local eLp = boardWorldToLocal(board, wp)
        local aLp = boardWorldToLocal(board, ap)
        if eLp ~= nil and aLp ~= nil then
            local dx = (eLp.x or 0) - (aLp.x or 0)
            local dz = (eLp.z or 0) - (aLp.z or 0)
            return math.sqrt(dx * dx + dz * dz)
        end
    end
    local dx = (wp.x or 0) - (ap.x or 0)
    local dz = (wp.z or 0) - (ap.z or 0)
    return math.sqrt(dx * dx + dz * dz)
end

--- Signed lateral offset on the minimap tile (board-local X when possible; lower = screen-left).
--- @param entry table
--- @param anchorEntry table
--- @param board Object|nil
--- @return number
local function familySnapLateralFromAnchor(entry, anchorEntry, board)
    local wp = entry and entry.worldPos
    local ap = anchorEntry and anchorEntry.worldPos
    if wp == nil or ap == nil then
        return 0
    end
    if isGameObject(board) then
        local eLp = boardWorldToLocal(board, wp)
        local aLp = boardWorldToLocal(board, ap)
        if eLp ~= nil and aLp ~= nil then
            return (eLp.x or 0) - (aLp.x or 0)
        end
    end
    return (wp.x or 0) - (ap.x or 0)
end

--- Compare sibling snaps for spread: nearest ring first, then screen-left before screen-right (not raw familyK sign).
--- @param a table catalog entry
--- @param b table catalog entry
--- @param anchorEntry table anchor catalog entry
--- @param board Object|nil CONTROL_BOARD
--- @return boolean
local function compareFamilySnapCenterOutAlternating(a, b, anchorEntry, board)
    local distA = familySnapRadialDistFromAnchor(a, anchorEntry, board)
    local distB = familySnapRadialDistFromAnchor(b, anchorEntry, board)
    if math.abs(distA - distB) > 0.001 then
        return distA < distB
    end
    local latA = familySnapLateralFromAnchor(a, anchorEntry, board)
    local latB = familySnapLateralFromAnchor(b, anchorEntry, board)
    if math.abs(latA - latB) > 0.001 then
        return latA < latB
    end
    return (tonumber(a.snapIndex) or 0) < (tonumber(b.snapIndex) or 0)
end

--- Sort non-anchor family catalog entries for anchor-group spread (mutates list).
--- @param entries table[] catalog rows with `worldPos`
--- @param anchorEntry table|nil anchor row (required for spatial center-out)
--- @param board Object|nil CONTROL_BOARD
function Gameboard.orderFamilySnapsForAnchorSpread(entries, anchorEntry, board)
    if type(entries) ~= "table" then
        return
    end
    if type(anchorEntry) ~= "table" or anchorEntry.worldPos == nil then
        table.sort(entries, function(a, b)
            local ka = tonumber(a.familyK) or 0
            local kb = tonumber(b.familyK) or 0
            local magA = math.abs(ka)
            local magB = math.abs(kb)
            if magA ~= magB then
                return magA < magB
            end
            if ka ~= kb then
                return ka < kb
            end
            return (tonumber(a.snapIndex) or 0) < (tonumber(b.snapIndex) or 0)
        end)
        return
    end
    table.sort(entries, function(a, b)
        return compareFamilySnapCenterOutAlternating(a, b, anchorEntry, board)
    end)
end

--- @return boolean true — anchor spread assigns snaps in center-out alternating order (TOR-175).
function Gameboard.anchorSpreadUsesCenterOutOrdering()
    return true
end

--- Apply ring `defaultLightMode` flip + optional stage light preview for a token on a catalog snap.
--- @param token Object
--- @param entry table catalog entry (`ringIndex`, `yawDeg`)
--- @param board Object
--- @param cfg table|nil CONTROL_BOARD_SNAP config
--- @return table { applied: boolean, reason: string, defaultLightMode?: string, ringIndex?: number }
local function applySnapGroupDefaultLightAtEntry(token, entry, board, cfg)
    local result = { applied = false, reason = "invalid_token" }
    if not isNpcControlToken(token) or type(entry) ~= "table" then
        return result
    end
    if entry.snapKind == SNAP_KIND_SEAT then
        result.reason = "seat_snap"
        return result
    end
    ensureDefaultNpcControlTokenScale(token)
    if type(cfg) ~= "table" then
        cfg = resolveControlBoardSnapConfig(nil)
    end
    local group = type(cfg.snapGroups) == "table" and cfg.snapGroups[entry.ringIndex] or nil
    local mode = snapGroupDefaultLightMode(group)
    if mode == nil then
        result.reason = "no_default_mode"
        return result
    end

    local boardYaw = objectYawDeg(board)
    local faceUp = mode == "STANDARD"
    if token.setRotation ~= nil then
        local rot = rotationForNpcControlToken(boardYaw, entry.yawDeg, faceUp)
        token.setRotation(rot)
        U.delay(function()
            if not isGameObject(token) or not isTokenOnControlBoardSurface(board, token) then
                return
            end
            if tokenRotationIsFaceUp(token) ~= faceUp then
                token.setRotation(rot)
            end
        end, 0.05)
    end
    Gameboard.setHiddenFromPlayerColors(token)

    local characterKey = resolveTokenCharacterKey(token)
    if type(characterKey) == "string" and characterKey ~= "" then
        local NPCS = require("core.npcs")
        if type(NPCS.applyControlTokenLightMode) == "function" then
            NPCS.applyControlTokenLightMode(characterKey, mode)
        end
    end

    result.applied = true
    result.reason = "ok"
    result.defaultLightMode = mode
    result.ringIndex = entry.ringIndex
    return result
end

--- When an anchor snap receives a grouped token and the rest of the family is empty,
--- park remaining group members on sibling snaps (lowest slotIndex first; snaps center-out alternating).
--- @param droppedToken Object
--- @return table result { placed: number, reason?: string, groupId?: string }
function Gameboard.tryAnchorFamilyGroupSpread(droppedToken)
    if anchorFamilySpreadDepth > 0 then
        return { placed = 0, reason = "suppressed" }
    end
    local board = getControlBoard()
    if not isGameObject(board) or not isNpcControlToken(droppedToken) then
        return { placed = 0, reason = "invalid_token" }
    end
    if not isTokenOnControlBoardSurface(board, droppedToken) then
        return { placed = 0, reason = "not_on_board" }
    end
    local palette = getControlBoardPalette()
    if isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, droppedToken) then
        return { placed = 0, reason = "on_palette" }
    end
    local characterKey = resolveTokenCharacterKey(droppedToken)
    if type(characterKey) ~= "string" or characterKey == "" then
        return { placed = 0, reason = "no_character_key" }
    end
    local groupId, _ = Palette.resolveGroupForCharacterKey(characterKey)
    if groupId == nil then
        return { placed = 0, reason = "no_group" }
    end
    if board.getSnapPoints == nil then
        return { placed = 0, reason = "no_snaps" }
    end
    local installedSnaps = board.getSnapPoints()
    if type(installedSnaps) ~= "table" or #installedSnaps == 0 then
        return { placed = 0, reason = "no_snaps" }
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    local catalog = Gameboard.buildControlBoardSnapCatalog(board, nil)
    if #catalog ~= #installedSnaps then
        print(
            "[Gameboard] anchor spread: snap catalog mismatch (installed="
                .. tostring(#installedSnaps)
                .. " catalog="
                .. tostring(#catalog)
                .. "); Save & Play or Sync.npcs to reinstall snaps"
        )
    end
    local anchorEntry = resolveTokenSnapCatalogEntry(board, droppedToken, fuzziness, nil)
    if anchorEntry == nil then
        return { placed = 0, reason = "no_snap_match" }
    end
    if anchorEntry.isAnchor ~= true then
        return {
            placed = 0,
            reason = "not_anchor",
            matchedSnapIndex = anchorEntry.snapIndex,
            familyK = anchorEntry.familyK,
        }
    end
    for _, entry in ipairs(catalog) do
        if entry.familyId == anchorEntry.familyId and entry.isAnchor ~= true then
            local occupant = findOccupyingTokenAtSnapWorld(
                board,
                entry.worldPos,
                fuzziness,
                droppedToken
            )
            if occupant ~= nil then
                return { placed = 0, reason = "family_not_empty", groupId = groupId }
            end
        end
    end
    local members = Palette.getSortedGroupMembers(groupId)
    local byKey = buildTokenByCharacterKey()
    local NPCS = require("core.npcs")
    local toPlace = {}
    for _, member in ipairs(members) do
        if type(NPCS.isCharacterSeatedAtTable) == "function"
            and NPCS.isCharacterSeatedAtTable(member.characterKey) then
            -- TOR-76: seated table NPCs stay put during family anchor spread.
        else
            local tok = byKey[member.characterKey]
            if tok ~= nil and tok ~= droppedToken and not isTokenOnControlBoardSurface(board, tok) then
                toPlace[#toPlace + 1] = {
                    token = tok,
                    slotIndex = member.slotIndex,
                }
            end
        end
    end
    table.sort(toPlace, function(a, b)
        if a.slotIndex == b.slotIndex then
            return tostring(a.token.getGUID()) < tostring(b.token.getGUID())
        end
        return a.slotIndex < b.slotIndex
    end)
    local emptyFamilySnaps = {}
    for _, entry in ipairs(catalog) do
        if entry.familyId == anchorEntry.familyId and entry.isAnchor ~= true then
            emptyFamilySnaps[#emptyFamilySnaps + 1] = entry
        end
    end
    Gameboard.orderFamilySnapsForAnchorSpread(emptyFamilySnaps, anchorEntry, board)
    if #toPlace == 0 then
        return { placed = 0, reason = "nothing_to_place", groupId = groupId }
    end
    if #emptyFamilySnaps == 0 then
        return { placed = 0, reason = "family_has_no_sibling_snaps", groupId = groupId }
    end
    local boardYaw = objectYawDeg(board)
    local snapCfg = Gameboard.getInstalledControlBoardSnapConfig()
    if type(snapCfg) ~= "table" then
        snapCfg = resolveControlBoardSnapConfig(nil)
    end
    anchorFamilySpreadDepth = anchorFamilySpreadDepth + 1
    local placed = 0
    local limit = math.min(#toPlace, #emptyFamilySnaps)
    for i = 1, limit do
        local tok = toPlace[i].token
        local snapEntry = emptyFamilySnaps[i]
        local fromPalette = isGameObject(palette) and Palette.isTokenOnPaletteBoard(palette, tok)
        placeTokenOnControlBoardSnap(tok, snapEntry, board, boardYaw)
        if fromPalette then
            local lightResult = applySnapGroupDefaultLightAtEntry(tok, snapEntry, board, snapCfg)
            if lightResult.applied == true then
                print(
                    "[Gameboard] anchor spread palette light: "
                        .. tostring(resolveTokenCharacterKey(tok))
                        .. " ring "
                        .. tostring(lightResult.ringIndex)
                        .. " "
                        .. tostring(lightResult.defaultLightMode)
                )
            end
        end
        placed = placed + 1
    end
    anchorFamilySpreadDepth = anchorFamilySpreadDepth - 1
    return { placed = placed, reason = "ok", groupId = groupId }
end

--- Record palette origin on pick-up; revert seat-row scale when leaving the board (TOR-199).
--- @param token Object|nil
function Gameboard.onNpcControlTokenPickUp(token)
    if not isNpcControlToken(token) then
        return
    end
    ensureDefaultNpcControlTokenScale(token)
    local palette = getControlBoardPalette()
    if not isGameObject(palette) then
        return
    end
    if Palette.isTokenOnPaletteBoard(palette, token) then
        local guid = tostring(token.getGUID() or "")
        if guid ~= "" then
            tokenPickedUpFromPaletteGuid[guid] = true
        end
    end
end

--- Apply per-ring `defaultLightMode` when a token is dropped from the palette onto CONTROL_BOARD (not ring-to-ring).
--- @param token Object|nil
--- @return table { applied: boolean, reason: string, defaultLightMode?: string, ringIndex?: number }
function Gameboard.applySnapGroupDefaultLightOnPaletteDrop(token)
    local result = { applied = false, reason = "invalid_token" }
    if not isNpcControlToken(token) then
        return result
    end
    local guid = tostring(token.getGUID() or "")
    if guid == "" or tokenPickedUpFromPaletteGuid[guid] ~= true then
        result.reason = "not_palette_drop"
        return result
    end
    tokenPickedUpFromPaletteGuid[guid] = nil

    local board = getControlBoard()
    if not isGameObject(board) or not isTokenOnControlBoardSurface(board, token) then
        result.reason = "not_on_board"
        return result
    end

    local cfg = Gameboard.getInstalledControlBoardSnapConfig()
    if type(cfg) ~= "table" then
        cfg = resolveControlBoardSnapConfig(nil)
    end
    local fuzziness = snapMatchFuzzinessForBoard(board)
    local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, cfg)
    if entry == nil then
        result.reason = "no_snap"
        return result
    end

    return applySnapGroupDefaultLightAtEntry(token, entry, board, cfg)
end

--- Global onObjectDrop hook: seat-row scale, palette defaultLightMode, anchor-family spread.
--- @param token Object
--- @param playerColor string|nil
function Gameboard.onNpcControlTokenDropped(token, playerColor)
    if playerColor ~= "Black" and playerColor ~= "Host" then
        return
    end
    if not isNpcControlToken(token) then
        return
    end
    beginInteractionProfile("token_drop")
    local t0 = os.clock()
    local board = getControlBoard()
    if not isGameObject(board) then
        finishInteractionProfile(t0)
        return
    end
    if not isTokenOnControlBoardSurface(board, token) then
        ensureDefaultNpcControlTokenScale(token)
        finishInteractionProfile(t0)
        return
    end

    local tokenGuid = tostring(token.getGUID() or "")
    local wantPaletteLight = tokenGuid ~= "" and tokenPickedUpFromPaletteGuid[tokenGuid] == true
    local wantAnchorSpread = tokenGuid ~= "" and anchorDropEligibleByTokenGuid[tokenGuid] == true
    local u, v = uvFromWorldOnBoard(board, token.getPosition())
    -- Seat-row scale only; rotation comes from snap points. Skip waitForCondition when palette/anchor
    -- flags are false — b16f26b entered wait with wantSeatRow alone and timed out up to 1s.
    if isNearSeatRowUv(board, u, v) then
        applySeatRowNpcControlTokenScale(token)
    else
        ensureDefaultNpcControlTokenScale(token)
    end
    if not wantPaletteLight and not wantAnchorSpread then
        finishInteractionProfile(t0)
        return
    end

    local fuzziness = snapMatchFuzzinessForBoard(board)
    U.waitForCondition(
        function()
            if wantPaletteLight then
                local lightResult = Gameboard.applySnapGroupDefaultLightOnPaletteDrop(token)
                if lightResult.applied == true then
                    print(
                        "[Gameboard] palette drop: ring "
                            .. tostring(lightResult.ringIndex)
                            .. " defaultLightMode "
                            .. tostring(lightResult.defaultLightMode)
                    )
                elseif lightResult.reason ~= "not_palette_drop" then
                    print("[Gameboard] palette drop defaultLightMode skipped: " .. tostring(lightResult.reason))
                end
            end
            if wantAnchorSpread then
                logAnchorSpreadResult(Gameboard.tryAnchorFamilyGroupSpread(token))
            end
        end,
        function()
            if not isGameObject(token) then
                return true
            end
            if not isTokenOnControlBoardSurface(board, token) then
                return false
            end
            local entry = resolveTokenSnapCatalogEntry(board, token, fuzziness, nil)
            if entry == nil then
                return false
            end
            if wantAnchorSpread and entry.isAnchor ~= true then
                return false
            end
            return true
        end,
        1.0
    )
    finishInteractionProfile(t0)
end

--- @param placements table|nil
function Gameboard.populateControlBoardFromPlacements(placements)
    placements = type(placements) == "table" and placements or stateModule().getStateVal("sessionScene", "npcWorld", "placements")
    if type(placements) ~= "table" then
        placements = {}
    end
    stateModule().setStateVal(placements, "sessionScene", "npcWorld", "placements")
    Gameboard.reconcileControlBoardFromState()
end

return Gameboard