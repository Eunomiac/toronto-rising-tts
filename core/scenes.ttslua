--[[
    Scene Preset System Module (core/scenes.ttslua)

    Manages scene presets for immersive VTM5E gameplay. Each scene preset defines:
    - Ambient lighting (global table lighting)
    - Individual light object modes (spotlights, etc.)
    - Optional background music
    - Scene-specific atmosphere settings

    Scene transitions can be instant or smooth (with fade/duration).

    Pattern: Combines lighting module patterns with ambient lighting control.
    Integration: `U.applyLightingPreset` for ambient + `spotlights`; `L.SetLightMode` for legacy `lights` list.

    Agent guidance: .dev/TESTING.md (scene tests); .dev/AVAILABLE_FUNCTIONS.md.
]]

local Scenes = {}
local U = require("lib.util")
local S = require("core.state")
local C = require("lib.constants")
local G = require("lib.guids")
local L = require("core.lighting")
local Soundscape = require("core.soundscape")
local SceneLibrary = require("core.scene_library")
local RSL = require("lib.rotational-seat-layout")
local ChronicleWeather = require("lib.chronicle_weather")

--- Default table when no live library scene is on the table (TOR-151).
Scenes.DEFAULT_NO_SCENE_TABLE_KEY = "Table B"

--- Last scene+transition fingerprint successfully applied to the live world (incremental sync skips when unchanged).
local lastSceneReconcileFingerprint = nil
local lastTopFogReconcileFingerprint = nil
local lastSkyboxReconcileFingerprint = nil

-- ============================================================================
-- CONFIGURATION
-- ============================================================================

-- Default transition time for scene changes (in seconds)
local DefaultTransitionTime = 2.0

-- ============================================================================
-- SCENE PRESET DEFINITIONS
-- ============================================================================

--- Scene Preset Structure
--
-- Each scene preset contains:
--   ambient: Table with global lighting + optional `spotlights` (see `C.LightModes`, `U.applyLightingPreset`)
--   lights: Table of {name, mode} pairs for legacy per-light entries (non-seat refs preferred)
--   musicTrack, musicMood, soundscapeContext, description (optional)

Scenes.SCENES = {
    -- Default/neutral scene (uses DARK mode)
    default = {
        ambient = C.LightModes.DARK,
        lights = {},
        description = "Default dark lighting"
