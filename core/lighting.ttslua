-- Ensure HUNGRY seat-light modes are fully actionable even when defined as partial
-- overrides (for example color-only). Without this, switching OFF -> HUNGRY can stay
-- visually dark because angle/intensity remain zero from OFF.
for lightRef, lData in pairs(L.LIGHTMODES) do
    if type(lightRef) == "string"
        and type(lData) == "table"
        and U.lightRefIsSeatSpotlight(lightRef)
        and type(lData.HUNGRY) == "table"
        and type(lData.STANDARD) == "table"
    then
        local enrichedHungry = U.clone(lData.HUNGRY, true)
        for k, v in pairs(lData.STANDARD) do
            if enrichedHungry[k] == nil then
                enrichedHungry[k] = type(v) == "table" and U.clone(v, true) or v
            end
        end
        lData.HUNGRY = enrichedHungry
    end
end

-- ============================================================================
-- INTERNAL HELPER FUNCTIONS
-- ============================================================================

--- True if this component behaves like a Unity spotlight (avoids wrong index / non-Light components).
--- @param comp Component|nil
--- @return boolean
local function isRealLightComponent(comp)
    if comp == nil or comp.get == nil then
        return false
    end
    local spotAngle = comp.get("spotAngle")
    local range = comp.get("range")
    local intensity = comp.get("intensity")
    return type(spotAngle) == "number" and type(range) == "number" and type(intensity) == "number"
end

--- Gets the Light component from a TTS spotlight root object.
--- Resolution order matches core/light_test.ttslua (inspect/spawn helpers that behave correctly in-game):
--- 1) getComponentInChildren("Light")  2) enumerate getComponentsInChildren("Light"), first spotlight-like
--- 3) nested child[1].child[2].components[2] only if its .name is "Light" (same as LightTest fallback).
--- @param light Object The light object
--- @param isSilent boolean If true, returns nil on error instead of throwing
--- @return Component|nil The Light component, or nil if not found/error
local function getLightComponent(light, isSilent)
    if light == nil then
        if isSilent then
            return nil
        end
        U.Val("getLightComponent", light, false, "nil light")
    end

    -- 1) Same primary API as LightTest.testInspectLight / testSpawnLight
    local singleComp = nil
    local getSingle = light.getComponentInChildren
    if type(getSingle) == "function" then
        singleComp = getSingle("Light")
    end
    if singleComp ~= nil then
        local nm = singleComp.name
        if nm == "Light" or isRealLightComponent(singleComp) then
            return singleComp
        end
    end

    -- 2) Every "Light" component (depth-first list); prefer one that looks like a spotlight
    local lights = nil
    local getChildrenComponents = light.getComponentsInChildren
    if type(getChildrenComponents) == "function" then
        lights = getChildrenComponents("Light")
    end
    if lights and #lights > 0 then
        for _, comp in ipairs(lights) do
            if isRealLightComponent(comp) then
                return comp
            end
        end
    end

    -- 3) Nested object path — test fixtures may expose Light as components[2] without a spotlight probe
    local getChildrenFn = light.getChildren
    local children = type(getChildrenFn) == "function" and getChildrenFn() or nil
    local child1 = children and children[1] or nil
    local child1GetChildren = child1 and child1.getChildren or nil
    local grandchildren = type(child1GetChildren) == "function" and child1GetChildren() or nil
    local grandchild2 = grandchildren and grandchildren[2] or nil
    local getComponentsFn = grandchild2 and grandchild2.getComponents or nil
    local components = type(getComponentsFn) == "function" and getComponentsFn() or nil
    local lComp = components and components[2] or nil
    if lComp ~= nil and lComp.name == "Light" then
        return lComp
    end

    if isSilent then
        return nil
    end

    U.Val("getLightComponent", light, U.isGameObject(light), "Invalid Light Object")
---@diagnostic disable-next-line: need-check-nil, undefined-field
    local children = light.getChildren()
    U.Val("getLightComponent", { light = light, children = children }, #children > 0, "Light has no Children")
    local grandchildren = children[1].getChildren()
    U.Val(
        "getLightComponent",
        { light = light, grandchildren = grandchildren },
        #grandchildren > 1,
        "Light has too few Grandchildren"
    )
    local components = grandchildren[2].getComponents()
    U.Val("getLightComponent", { light = light, components = components }, #components > 1, "Light has too few components")
    U.Val(
        "getLightComponent",
        { light = light, comp = components[2] },
        components[2] and components[2].name == "Light",
        "Can't find 'Light' component"
    )
    return components[2]
end

--- Finds a light object by GUID
-- GUID is required for all lights - throws error if GUID is not defined in light data.
-- @param lightName string The light name to search for (must exist in L.LIGHTMODES)
-- @param isSilent boolean If true, returns nil on error instead of throwing
-- @return Object|nil The light object, or nil if not found
local function getLight(lightName, isSilent)
    local lData = L.LIGHTMODES[lightName]
    if not lData then
        if isSilent then
            return nil
        else
            U.Val("getLight", lightName, false, "Light mode not found: " .. tostring(lightName))
        end
    end

    -- GUID is required for all lights
    if not lData.guid then
        if isSilent then
            return nil
        else
            error("getLight: Light '" .. tostring(lightName) .. "' must have a GUID defined in LIGHTMODES")
        end
    end

    local light = getObjectFromGUID(lData.guid)
    if light == nil then
        if isSilent then
            return nil
        else
            U.Val("getLight", {lightName, guid = lData.guid}, false, "Light object not found for GUID: " .. tostring(lData.guid))
        end
    end
    return light
end

--- TTS object GUIDs in this project are six hex characters.
--- @param s string|nil
--- @return boolean
local function isProbablyObjectGuid(s)
    if U.Type(s) ~= "string" then
        return false
    end
    return string.match(s or "", "^%x%x%x%x%x%x$") ~= nil
end

--- Resolve a raw object GUID to its registered LIGHTMODES key when possible.
--- Returns nil when no registered light owns the GUID.
--- @param guid string
--- @return string|nil
local function findRegisteredLightRefByGuid(guid)
    if not isProbablyObjectGuid(guid) then
        return nil
    end
    for refName, modeDef in pairs(L.LIGHTMODES or {}) do
        if U.Type(refName) == "string" and U.Type(modeDef) == "table" and U.Type(modeDef.guid) == "string" then
            if modeDef.guid == guid then
                return refName
            end
        end
    end
    return nil
end

--- JSON-safe shallow copy of a mode table for persistence (raw-GUID / inline modes).
--- @param mt table|nil
--- @return table|nil
local function sanitizeModeForPersistence(mt)
    if U.Type(mt) ~= "table" then
        return nil
    end
    local out = {}
    for k, val in pairs(mt or {}) do
        if U.Type(k) ~= "string" then
        elseif U.isInstance(val, Vector) then
            out[k] = { x = val.x, y = val.y, z = val.z }
        elseif U.isInstance(val, Color) then
            out[k] = { r = val.r or val[1], g = val.g or val[2], b = val.b or val[3] }
        elseif U.Type(val) == "number" or U.Type(val) == "string" or U.Type(val) == "boolean" then
            out[k] = val
        elseif U.Type(val) == "table" and val.x ~= nil and val.y ~= nil and val.z ~= nil then
            out[k] = { x = val.x, y = val.y, z = val.z }
        elseif U.Type(val) == "table" and val.r ~= nil and val.g ~= nil and val.b ~= nil then
            out[k] = { r = val.r, g = val.g, b = val.b }
        end
    end
    return out
end

--- Public: JSON-safe shallow copy of an inline spotlight mode table for `gameState` / session bundles.
--- @param mt table|nil
--- @return table|nil
L.sanitizeLightModeTableForPersistence = sanitizeModeForPersistence

--- @param tbl table
--- @return string
local function inlineModeTableFingerprint(tbl)
    local safe = sanitizeModeForPersistence(tbl)
    if safe == nil or next(safe) == nil then
        return ""
    end
    local keys = {}
    for k in pairs(safe) do
        keys[#keys + 1] = k
    end
    table.sort(keys)
    local parts = {}
    for _, k in ipairs(keys) do
        local v = safe[k]
        if U.Type(v) == "table" then
            if v.r ~= nil then
                parts[#parts + 1] = k
                    .. ":"
                    .. tostring(v.r)
                    .. ","
                    .. tostring(v.g)
                    .. ","
                    .. tostring(v.b)
            elseif v.x ~= nil then
                parts[#parts + 1] = k .. ":" .. tostring(v.x) .. "," .. tostring(v.y) .. "," .. tostring(v.z)
            else
                parts[#parts + 1] = k .. ":table"
            end
        else
            parts[#parts + 1] = k .. ":" .. tostring(v)
        end
    end
    return table.concat(parts, "|")
end

--- @param mode string|table|nil
--- @return string|nil
local function reconcileModeFingerprint(mode)
    if U.Type(mode) == "string" then
        return "n:" .. mode
    end
    if U.Type(mode) == "table" then
        local body = inlineModeTableFingerprint(mode)
        if body == "" then
            return "t:empty"
        end
        return "t:" .. body
    end
    return nil
end

--- @param lightRef string
--- @param mode string|table|nil
--- @return boolean
local function reconcileTargetAlreadyApplied(lightRef, mode)
    if U.Type(lightRef) ~= "string" then
        return false
    end
    local fp = reconcileModeFingerprint(mode)
    if fp == nil then
        return false
    end
    return lastReconciledModeByRef[lightRef] == fp
end

--- @param lightRef string
--- @param mode string|table|nil
local function recordReconciledMode(lightRef, mode)
    if U.Type(lightRef) ~= "string" then
        return
    end
    local fp = reconcileModeFingerprint(mode)
    if fp ~= nil then
        lastReconciledModeByRef[lightRef] = fp
    end
end

--- True if `v` is a valid `gameState.lights` value (mode name or inline snapshot).
--- @param v any
--- @return boolean
local function isValidLightsStateValue(v)
    if U.Type(v) == "string" and v ~= "" then
        return true
    end
    if U.Type(v) ~= "table" then
        return false
    end
    return v.enabled ~= nil or v.range ~= nil or v.intensity ~= nil or v.angle ~= nil or v.color ~= nil
        or v.position ~= nil or v.rotation ~= nil
end

--- Resolve spotlight **object** for a registry key, `npcLight_<guid>`, or six-char GUID. Requires usable Light component.
--- @param lightRef string
--- @param silent boolean|nil If false, validate errors throw
--- @return Object|nil
function L.GetLight(lightRef, silent)
    if silent == nil then
        silent = true
    end
    if U.Type(lightRef) ~= "string" then
        if silent then
            return nil
        end
        U.Val("GetLight", lightRef, false, "lightRef must be string")
    end

    local obj
    if L.LIGHTMODES[lightRef] then
        obj = getLight(lightRef, silent)
    elseif string.sub(lightRef, 1, 9) == "npcLight_" then
        local g = string.sub(lightRef, 10)
        obj = getObjectFromGUID(g)
    elseif isProbablyObjectGuid(lightRef) then
        obj = getObjectFromGUID(lightRef)
    else
        if silent then
            return nil
        end
        U.Val("GetLight", lightRef, false, "Unknown light key: " .. tostring(lightRef))
    end

    if obj == nil then
        return nil
    end
    if getLightComponent(obj, true) == nil then
        return nil
    end
    return obj
end

--- Save-time sanitizer for `gameState.lights`:
--- - drops non-string keys
--- - for keys that are six-character object GUIDs: if some `L.LIGHTMODES` entry has the same `guid`,
---   removes that row (canonical persistence is the mode registry key, not the raw GUID); otherwise
---   removes the row if no resolvable light object exists in the world, or if the value is invalid
--- - for all other keys: removes invalid values, then removes rows whose key does not resolve to a
---   live light object (`L.GetLight`)
--- Mutates state via `S.setStateVal`.
function L.sanitizeLightsStateForSave()
    local lights = S.getStateVal("lights")
    if U.Type(lights) ~= "table" then
        return
    end
    local cleaned = U.clone(lights)
    local changed = false

    for k, v in pairs(cleaned) do
        if U.Type(k) ~= "string" then
            cleaned[k] = nil
            changed = true
        elseif isProbablyObjectGuid(k) then
            if findRegisteredLightRefByGuid(k) ~= nil then
                cleaned[k] = nil
                changed = true
            elseif L.GetLight(k, true) == nil then
                cleaned[k] = nil
                changed = true
            elseif not isValidLightsStateValue(v) then
                cleaned[k] = nil
                changed = true
            end
        elseif not isValidLightsStateValue(v) then
            cleaned[k] = nil
            changed = true
        elseif L.GetLight(k, true) == nil then
            cleaned[k] = nil
            changed = true
        end
    end
    if changed then
        S.setStateVal(cleaned, "lights")
    end
end

--- Backward-compatible alias used by existing call sites.
function L.cleanupLightsState()
    L.sanitizeLightsStateForSave()
end

--- Register NPC spotlight modes on `L.LIGHTMODES` (runtime wiring; does not touch save state).
--- Lazy-requires `core.npcs` to avoid load-order issues (npcs already requires this module).
--- @param npcName string
--- @param lightGuid string
function L.registerNpcSpotlightModes(npcName, lightGuid)
    if U.Type(npcName) ~= "string" or U.Type(lightGuid) ~= "string" or lightGuid == "" then
        return
    end
    local NPCS = require("core.npcs")
    local reg = NPCS.lightRegistryName(lightGuid)
    local function makeFn(modeKey)
        return function()
            local t = NPCS.buildResolvedLightModeTable(npcName, modeKey)
            if t == nil then
                return {
                    enabled = false,
                    intensity = 0,
                    angle = 0,
                    range = 10,
                    color = Color(1, 1, 1),
                    position = Vector(0, 20, 0),
                    rotation = Vector(0, 0, 0),
                }
            end
            return t
        end
    end
    L.LIGHTMODES[reg] = {
        guid = lightGuid,
        isSpawned = true,
        default = "STANDARD",
        OFF = makeFn("OFF"),
        STANDARD = makeFn("STANDARD"),
        SPOTLIGHT = makeFn("SPOTLIGHT"),
    }
end

--- Gets all lights matching a tag (or all lights if no tag)
-- @param tag string|nil Optional tag to filter by
-- @return table Array of light objects
local function getAllLights(tag)
    local allObjects = getObjects()
    return U.filter(allObjects, function(obj)
        if obj.getChildren == nil then return false end
        local children = obj.getChildren()
        if #children == 0 then return false end
        if not string.match(children[1].name or "", "^spotlight") then return false end
        if getLightComponent(obj, true) == nil then return false end
        if tag and not obj.hasTag(tag) then return false end
        return true
    end)
end

--- Sets light component property directly (low-level)
local function setEnabled(light, enabled)
    local comp = getLightComponent(light, true)
    if comp then comp.set("enabled", enabled) end
end

local function setRange(light, range)
    local comp = getLightComponent(light, true)
    if comp then comp.set("range", range) end
end

local function setIntensity(light, intensity)
    local comp = getLightComponent(light, true)
    if comp then comp.set("intensity", intensity) end
end

local function setColor(light, color)
    local comp = getLightComponent(light, true)
    if comp then comp.set("color", Color(color)) end
end

local function setAngle(light, angle)
    local comp = getLightComponent(light, true)
    if comp then comp.set("spotAngle", angle) end
end

--- Gets light component property directly (low-level)
local function getEnabled(light)
    local comp = getLightComponent(light, true)
    return comp and comp.get("enabled") or false
end

local function getRange(light)
    local comp = getLightComponent(light, true)
    return comp and comp.get("range") or 0
end

local function getIntensity(light)
    local comp = getLightComponent(light, true)
    return comp and comp.get("intensity") or 0
end

local function getColor(light)
    local comp = getLightComponent(light, true)
    return comp and comp.get("color") or Color.White
end

local function getAngle(light)
    local comp = getLightComponent(light, true)
    return comp and comp.get("spotAngle") or 0
end

-- ============================================================================
-- CORE LIGHTING FUNCTIONS
-- ============================================================================

--- Sets a light to a specific mode with smooth transitions
--
-- This is the main function for controlling lights. It:
--   1. Resolves `lightRef` (registered name, raw object GUID, or nested array of those)
--   2. Finds the light object (via L.LIGHTMODES[ref].guid or getObjectFromGUID(ref))
--   3. Persists to `gameState.lights` after mode resolves (registered: mode key string; raw GUID: sanitized inline table)
--   4. Smoothly transitions using U.Lerp; overlapping calls for the same `lightRef` invalidate prior epochs (last wins)
--
-- Supports per-player lights via seat-scoped mode handlers.
-- Modes can be static tables or dynamic functions that calculate values.
--
-- @param lightRef string|table Registered key in L.LIGHTMODES, or an object GUID string, or an array of either (nested arrays recurse)
-- @param mode string|function|table For registered lights: mode name / resolver. For raw GUID `lightRef`: **must** be a full mode table (enabled, intensity, range, …)
-- @param player Player|string|nil Optional: Player for player-specific lights (registered modes only)
-- @param transitionTime number Optional: Transition duration in seconds (default: 0.5)
-- @return function|nil|table Returns completion function if using coroutines, or nil; batch calls return a table of per-ref results
-- @usage L.SetLightMode("playerLight1Brown", "STANDARD", "Brown", 0.5)
-- @usage L.SetLightMode("playerLight1Brown", "OFF", nil, 1.0)
-- @usage L.SetLightMode("4148ba", { enabled = true, intensity = 5, range = 120, angle = 120 }, nil, 0) -- object GUID, inline mode (not in LIGHTMODES)

-- L.SetLightMode("573771", { enabled = true, intensity = 5, range = 30 }, nil, 0)

function workspaceSandbox()
  L.SetLightMode("playerLight1Brown", "STANDARD", "Brown", 5)
  L.SetLightMode("playerLight1Orange", "STANDARD", "Orange", 5)
  L.SetLightMode("playerLight1Red", "STANDARD", "Red", 5)
  L.SetLightMode("playerLight1Pink", "STANDARD", "Pink", 5)
  L.SetLightMode("playerLight1Brown", "STANDARD", "Brown", 5)

  L.SetLightMode("playerLight1Brown", "OFF", "Brown", 0.5)
  L.SetLightMode("playerLight1Orange", "OFF", "Orange", 0.5)
  L.SetLightMode("playerLight1Red", "OFF", "Red", 0.5)
  L.SetLightMode("playerLight1Pink", "OFF", "Pink", 0.5)
  L.SetLightMode("playerLight1Brown", "OFF", "Brown", 0.5)

  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_BROWN, { enabled = true,
  color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_ORANGE, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_RED, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_PINK, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_PURPLE, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
end

local NPC_LIGHT_TO_SEAT = {
    npcLight2NPC1 = "NPC1",
    npcLight2NPC2 = "NPC2",
    npcLight2NPC3 = "NPC3",
    npcLight2NPC4 = "NPC4",
    npcLight1NPC1 = "NPC1",
    npcLight1NPC2 = "NPC2",
    npcLight1NPC3 = "NPC3",
    npcLight1NPC4 = "NPC4",
}

local NPC_LIGHT_ROLE_BY_REF = {
    npcLight2NPC1 = "SEAT_LIGHT_2",
    npcLight2NPC2 = "SEAT_LIGHT_2",
    npcLight2NPC3 = "SEAT_LIGHT_2",
    npcLight2NPC4 = "SEAT_LIGHT_2",
    npcLight1NPC1 = "SEAT_LIGHT_1",
    npcLight1NPC2 = "SEAT_LIGHT_1",
    npcLight1NPC3 = "SEAT_LIGHT_1",
    npcLight1NPC4 = "SEAT_LIGHT_1",
}

--- @param lightRef string
--- @param seatKey string
--- @return boolean
local function lightRefMatchesSeatColor(lightRef, seatKey)
    if U.Type(lightRef) ~= "string" or U.Type(seatKey) ~= "string" then
        return false
    end
    return string.sub(lightRef, -#seatKey) == seatKey
end

--- @param seatKey string
--- @return boolean
local function isPlayerSeatKey(seatKey)
    return U.isIn(seatKey, C.PlayerColors or {})
end

--- @param playerColor string
--- @param drawerOpen boolean
local function setPlayerRollingState(playerColor, drawerOpen)
    if U.Type(playerColor) ~= "string" then
        return
    end
    local playerID = S.getPlayerID(playerColor)
    if U.Type(playerID) ~= "string" then
        return
    end
    S.setStateVal(drawerOpen == true, "playerData", playerID, "lighting", "isRolling")
end

--- @param playerColor string
--- @return boolean
local function getPlayerRollingState(playerColor)
    if U.Type(playerColor) ~= "string" then
        return false
    end
    local playerID = S.getPlayerID(playerColor)
    if U.Type(playerID) ~= "string" then
        return false
    end
    return S.getStateVal("playerData", playerID, "lighting", "isRolling") == true
end

--- Seat narrative presence + table membership (see `sessionScene.seatPresent` + `C.Tables` maps).
--- Exported for HUD map pin relocation; keep semantics aligned with seat-light enforcement.
--- @param seatKey string Brown | Orange | …
--- @return boolean
function L.isPlayerPresentInActiveSeatLayout(seatKey)
    if U.Type(seatKey) ~= "string" then
        return false
    end
    local currentTableKey = S.getStateVal("seatLayout", "currentTableKey")
    if U.Type(currentTableKey) ~= "string" or currentTableKey == "" then
        -- No table filter active: do not force seats OFF.
        return true
    end
    local tableCfg = C.Tables[currentTableKey]
    if U.Type(tableCfg) ~= "table" then
        return true
    end
    ---@diagnostic disable-next-line: undefined-field
    local map = tableCfg.playerToPositionMap
    if U.Type(map) ~= "table" then
        return true
    end
    local atTable = map[seatKey] ~= nil
    local sp = S.getStateVal("sessionScene", "seatPresent")
    if U.Type(sp) == "table" then
        local narrative = sp[seatKey]
        if narrative == false then
            return false
        end
        if narrative == true then
            return atTable
        end
    end
    return atTable
end

--- @param lightRef string
--- @param playerColor string
--- @return string|nil
local function getConditionLightOverrideMode(lightRef, playerColor)
    local playerID = S.getPlayerID(playerColor)
    if U.Type(playerID) ~= "string" then
        return nil
    end
    local Conditions = require("core.conditions")
    local resolved = Conditions.resolveForPlayer(playerID)
    if U.Type(resolved.lightingModes) ~= "table" then
        return nil
    end
    return resolved.lightingModes[lightRef]
end

--- @param lightRef string
--- @return any|nil value from `sessionScene.lightingSeatSpotlightPreset` for this ref
local function getSessionSeatSpotlightPreset(lightRef)
    local m = S.getStateVal("sessionScene", "lightingSeatSpotlightPreset")
    if U.Type(m) ~= "table" then
        return nil
    end
    return m[lightRef]
end

--- High-priority seat spotlight modes (rolling, absent seat, conditions, hunger).
--- @param lightRef string
--- @param seatKey string
--- @return string|nil mode name when an override applies; nil to use scene seat preset / defaults
local function computeSeatSpotlightPriorityOverride(lightRef, seatKey)
    local lData = L.LIGHTMODES[lightRef]
    if U.Type(lData) ~= "table" then
        return nil
    end

    local isPlayerSeat = isPlayerSeatKey(seatKey)

    if isPlayerSeat and getPlayerRollingState(seatKey) and lData.ROLLING ~= nil then
        return "ROLLING"
    end

    local seatPresenceOff = not L.isPlayerPresentInActiveSeatLayout(seatKey)
    if seatPresenceOff and lData.OFF ~= nil then
        return "OFF"
    end

    if isPlayerSeat then
        local conditionMode = getConditionLightOverrideMode(lightRef, seatKey)
        if U.Type(conditionMode) == "string" and lData[conditionMode] ~= nil then
            return conditionMode
        end

        local hunger = tonumber(S.getPlayerVal(seatKey, "hunger")) or 0
        if hunger >= 4 and lData.HUNGRY ~= nil then
            return "HUNGRY"
        end
    end

    return nil
end

--- Resolves desired apply for a seat-matched registered light: override, scene `C.LightModes` seat preset, or default.
--- @param lightRef string
--- @param seatKey string
--- @return table|nil `{ kind = "named", mode = string }` or `{ kind = "inline", patch = table }`, or nil when no apply
local function computeDesiredSeatLightResolution(lightRef, seatKey)
    local lData = L.LIGHTMODES[lightRef]
    if U.Type(lData) ~= "table" then
        return nil
    end

    local ovr = computeSeatSpotlightPriorityOverride(lightRef, seatKey)
    if U.Type(ovr) == "string" and ovr ~= "" and lData[ovr] ~= nil then
        return { kind = "named", mode = ovr }
    end

    local preset = getSessionSeatSpotlightPreset(lightRef)
    if U.Type(preset) == "string" and preset ~= "" and lData[preset] ~= nil then
        return { kind = "named", mode = preset }
    end
    if U.Type(preset) == "table" and next(preset) ~= nil then
        return { kind = "inline", patch = preset }
    end

    if lData.STANDARD ~= nil then
        return { kind = "named", mode = "STANDARD" }
    end
    if U.Type(lData.default) == "string" and lData[lData.default] ~= nil then
        return { kind = "named", mode = lData.default }
    end
    if lData.OFF ~= nil then
        return { kind = "named", mode = "OFF" }
    end
    return nil
end

--- Clears runtime reconcile apply cache so the next seat reconcile re-applies live lights (pair with `force` repair).
function L.invalidateReconcileCache()
    lastReconciledModeByRef = {}
end

--- Reconcile one seat's lights against current state-derived priorities.
--- For player seats, this includes rolling/conditions/hunger rules.
--- For NPC seats, this applies scene/presence/default-derived modes.
--- @param seatKey string
--- @param opts table|nil `{ force = boolean? }` when true, skips `lastReconciledModeByRef` short-circuit
function L.reconcileForPlayer(seatKey, opts)
    if U.Type(seatKey) ~= "string" then
        return
    end
    opts = type(opts) == "table" and opts or {}
    local force = opts.force == true
    local transitionTime = L.DEFAULT_RECONCILE_LERP_SECONDS
    if opts.bootstrap == true then
        transitionTime = 0
    elseif type(opts.transitionTime) == "number" then
        transitionTime = opts.transitionTime
    end
    for lightRef, lData in pairs(L.LIGHTMODES or {}) do
        if U.Type(lightRef) == "string"
            and U.Type(lData) == "table"
            and lightRefMatchesSeatColor(lightRef, seatKey)
        then
            local res = computeDesiredSeatLightResolution(lightRef, seatKey)
            if U.Type(res) == "table" and res.kind == "named" and U.Type(res.mode) == "string" then
                S.setStateVal(res.mode, "lights", lightRef)
                local lit = getLight(lightRef, true)
                if lit ~= nil and (force or not reconcileTargetAlreadyApplied(lightRef, res.mode)) then
                    L.SetLightMode(lightRef, res.mode, seatKey, transitionTime)
                end
            elseif U.Type(res) == "table" and res.kind == "inline" and U.Type(res.patch) == "table" then
                local lit = getLight(lightRef, true)
                if lit ~= nil and (force or not reconcileTargetAlreadyApplied(lightRef, res.patch)) then
                    L.SetLightMode(lightRef, res.patch, seatKey, transitionTime)
                end
            end
        end
    end
end

--- Reconcile all player lights from state.
--- @param opts table|nil forwarded to `L.reconcileForPlayer`; `skipNpcSeats` skips NPC seat keys
function L.reconcileAllPlayers(opts)
    opts = type(opts) == "table" and opts or {}
    local skipNpc = opts.skipNpcSeats == true
    for _, color in ipairs(C.PlayerColors or {}) do
        L.reconcileForPlayer(color, opts)
    end
    if not skipNpc then
        for _, seatKey in ipairs(C.NPCSeats or {}) do
            L.reconcileForPlayer(seatKey, opts)
        end
    end
end

--- Reconcile one light reference from persisted state (non-player or targeted repairs).
--- @param lightRef string
--- @param transitionTime number|nil
--- @param opts table|nil `{ force = boolean? }`
function L.reconcileLightRef(lightRef, transitionTime, opts)
    if U.Type(lightRef) ~= "string" or lightRef == "" then
        return true
    end
    opts = type(opts) == "table" and opts or {}
    local force = opts.force == true

    local lData = L.LIGHTMODES[lightRef]
    if U.Type(lData) ~= "table" then
        return true
    end

    if L.GetLight(lightRef, true) == nil then
        return false
    end

    local desiredMode = S.getStateVal("lights", lightRef)
    if desiredMode == nil then
        if lData.OFF ~= nil then
            desiredMode = "OFF"
            S.setStateVal(desiredMode, "lights", lightRef)
        else
            if warnedMissingOffMode[lightRef] ~= true then
                warnedMissingOffMode[lightRef] = true
                U.AlertGM("Light '" .. tostring(lightRef) .. "' has no saved mode and no OFF mode; forcing enabled=false.")
            end
            local lightObj = L.GetLight(lightRef, true)
            if lightObj ~= nil then
                setEnabled(lightObj, false)
            end
            return true
        end
    end

    if U.Type(desiredMode) ~= "string" and U.Type(desiredMode) ~= "table" then
        return true
    end

    if not force and reconcileTargetAlreadyApplied(lightRef, desiredMode) then
        return true
    end

    L.SetLightMode(lightRef, desiredMode, nil, transitionTime or 0.25)
    return true
end

--- Toggle rolling context and immediately reconcile this player's lights.
--- @param playerColor string
--- @param drawerOpen boolean
function L.onDiceDrawerStateChanged(playerColor, drawerOpen)
    setPlayerRollingState(playerColor, drawerOpen == true)
    L.reconcileForPlayer(playerColor)
end

--- @param lightRef string
--- @return string|nil
local function resolveNpcSeatLightGuid(lightRef)
    local seatKey = NPC_LIGHT_TO_SEAT[lightRef]
    local roleName = NPC_LIGHT_ROLE_BY_REF[lightRef]
    if U.Type(seatKey) ~= "string" or U.Type(roleName) ~= "string" then
        return nil
    end
    ---@diagnostic disable-next-line: undefined-global
    local tagged = getObjectsWithTag(seatKey .. "Object")
    if U.Type(tagged) ~= "table" then
        return nil
    end
    local roleNeedle = roleName .. "_" .. seatKey
    for _, obj in ipairs(tagged) do
        if U.isGameObject(obj) and obj.getGUID ~= nil then
            local objName = string.upper(tostring(obj.getName() or ""))
            local objNick = string.upper(tostring(obj.getNickname() or ""))
            local matchByRole = string.find(objName, roleNeedle, 1, true)
                or string.find(objName, roleName, 1, true)
                or string.find(objNick, roleNeedle, 1, true)
                or string.find(objNick, roleName, 1, true)
            if matchByRole then
                local guid = obj.getGUID()
                if U.Type(guid) == "string" and guid ~= "" then
                    return guid
                end
            end
        end
    end
    return nil
end

--- @param lightRef string
--- @return boolean
local function isNpcSeatLightActive(lightRef)
    local seatKey = NPC_LIGHT_TO_SEAT[lightRef]
    if U.Type(seatKey) ~= "string" then
        return true
    end
    local occupied = S.getStateVal("seatLayout", "occupiedNPCSlots")
    if U.Type(occupied) ~= "table" then
        return false
    end
    local occupant = occupied[seatKey]
    if occupant == nil or occupant == false then
        return false
    end
    local currentTableKey = S.getStateVal("seatLayout", "currentTableKey")
    local tableCfg = U.Type(currentTableKey) == "string" and C.Tables[currentTableKey] or nil
    ---@diagnostic disable-next-line: undefined-field
    local tableMap = U.Type(tableCfg) == "table" and tableCfg.playerToPositionMap or nil
    if U.Type(tableMap) ~= "table" or tableMap[seatKey] == nil then
        return false
    end
    return true
end


function L.SetLightMode(lightRef, mode, player, transitionTime)
    if transitionTime == nil then
        transitionTime = DefaultTransitionTime
    end

    -- Array of refs: recurse so nested arrays flatten to per-string calls
    if U.Type(lightRef) == "table" then
        return U.map(lightRef, function(ref)
            return L.SetLightMode(ref, mode, player, transitionTime)
        end)
    end

    U.Val("SetLightMode", lightRef, U.Type(lightRef) == "string", "lightRef must be a string or table of strings")

    local aliasedRef = lightRef
    local lData = L.LIGHTMODES[aliasedRef]
    if lData == nil and isProbablyObjectGuid(aliasedRef) then
        local mappedRef = findRegisteredLightRefByGuid(aliasedRef)
        if U.Type(mappedRef) == "string" and mappedRef ~= "" then
            aliasedRef = mappedRef
            lData = L.LIGHTMODES[aliasedRef]
        end
    end
    lightRef = aliasedRef
    local light
    local isSpawned = false
    local modeDef

    if lData ~= nil then
        if U.Type(lData.guid) ~= "string" or lData.guid == "" then
            local resolvedGuid = resolveNpcSeatLightGuid(lightRef)
            if U.Type(resolvedGuid) == "string" and resolvedGuid ~= "" then
                lData.guid = resolvedGuid
            end
        end
        if U.Type(lData.guid) ~= "string" or lData.guid == "" then
            if NPC_LIGHT_TO_SEAT[lightRef] ~= nil then
                return nil
            end
        end
        if not isNpcSeatLightActive(lightRef) then
            mode = "OFF"
        end
        isSpawned = lData.isSpawned or false

        light = getLight(lightRef, true)
        if light == nil and isSpawned then
            return U.waitUntil(function()
                return L.SetLightMode(lightRef, mode, player, transitionTime)
            end, function()
                return getLight(lightRef, true) ~= nil
            end, false)
        end

        light = U.ExpectGameObject("SetLightMode", light, "No light found: " .. U.ToString(lightRef))

        local modeData = mode
        if U.Type(modeData) == "function" then
            modeData = modeData(player)
        elseif U.Type(modeData) == "string" and modeData == "default" then
            modeData = lData.default or "OFF"
        end

        if U.Type(modeData) == "table" then
            modeDef = U.clone(modeData)
            local safePersist = sanitizeModeForPersistence(modeDef)
            if safePersist and next(safePersist) ~= nil then
                S.setStateVal(safePersist, "lights", lightRef)
            end
        else
            U.Val("SetLightMode", modeData,
                U.Type(modeData) == "string" and lData[modeData] ~= nil,
                "No such mode '" .. U.ToString(modeData) .. "' for light '" .. U.ToString(lightRef) .. "'")

            modeDef = lData[modeData]
            if U.Type(modeDef) == "function" then
                modeDef = modeDef(player)
            end
            if U.Type(modeDef) == "table" then
                modeDef = U.clone(modeDef)
            end

            S.setStateVal(modeData, "lights", lightRef)
        end
    else
        light = getObjectFromGUID(lightRef)
        U.Val("SetLightMode", lightRef, U.isGameObject(light),
            "lightRef not in L.LIGHTMODES and not a valid object GUID: " .. U.ToString(lightRef))

        U.Val("SetLightMode", { lightRef, mode }, U.Type(mode) == "table",
            "When lightRef is a raw object GUID, mode must be a full lighting mode table")

        modeDef = U.clone(mode)
        local safePersist = sanitizeModeForPersistence(modeDef)
        if safePersist and next(safePersist) ~= nil then
            S.setStateVal(safePersist, "lights", lightRef)
        end
    end

    local fingerprintMode = mode
    local savedMode = S.getStateVal("lights", lightRef)
    if U.Type(savedMode) == "string" or U.Type(savedMode) == "table" then
        fingerprintMode = savedMode
    elseif U.Type(modeDef) == "table" then
        fingerprintMode = modeDef
    end
    if reconcileTargetAlreadyApplied(lightRef, fingerprintMode) then
        return nil
    end

    transitionEpoch[lightRef] = (transitionEpoch[lightRef] or 0) + 1
    local myEpoch = transitionEpoch[lightRef]
    recordReconciledMode(lightRef, fingerprintMode)

    -- Apply the light mode with smooth transitions
    local function activateLight()
        if transitionEpoch[lightRef] ~= myEpoch then
            return function()
                return true
            end
        end

        local afterVals = {}

        -- Handle enabled state (special case: animate on/off).
        -- Mid-transition lights can report enabled/intensity inconsistently; avoid clearing
        -- `modeDef.enabled` from a naive getEnabled() check alone or NPC toggles miss setup.
        local MIN_VISIBLE_INTENSITY = 0.05
        if modeDef.enabled ~= nil then
            local compOn = getEnabled(light)
            local curI = getIntensity(light)
            if modeDef.enabled == true then
                if (not compOn) or (curI < MIN_VISIBLE_INTENSITY) then
                    setIntensity(light, 0)
                    setAngle(light, 0)
                    setEnabled(light, true)
                else
                    modeDef.enabled = nil
                end
            elseif modeDef.enabled == false then
                if compOn then
                    afterVals.intensity = curI
                    afterVals.angle = getAngle(light)
                    modeDef.intensity = 0
                    modeDef.angle = 0
                else
                    modeDef.enabled = nil
                end
            end
        end

        -- Instant apply: skip RunSequence/waitUntil coroutines entirely. Overlapping async steps
        -- from prior SetLightMode calls could otherwise run finalize/lerps out of order and leave
        -- the light disabled.
        if transitionTime <= 0 then
            if transitionEpoch[lightRef] ~= myEpoch then
                return function()
                    return true
                end
            end
            local function applyRotationPos()
                if modeDef.rotation ~= nil then
                    light.setRotation(OP.mergeRotation(light, modeDef.rotation))
                end
                if modeDef.position ~= nil then
                    light.setPosition(OP.mergePosition(light, modeDef.position))
                end
            end
            if modeDef.enabled == false and afterVals.intensity ~= nil then
                if modeDef.range ~= nil then
                    setRange(light, modeDef.range)
                end
                if modeDef.color ~= nil then
                    setColor(light, Color(modeDef.color))
                end
                setIntensity(light, 0)
                setAngle(light, 0)
                applyRotationPos()
                setEnabled(light, false)
                setIntensity(light, afterVals.intensity)
                setAngle(light, afterVals.angle)
            else
                if modeDef.range ~= nil then
                    setRange(light, modeDef.range)
                end
                if modeDef.intensity ~= nil then
                    setIntensity(light, modeDef.intensity)
                end
                if modeDef.angle ~= nil then
                    setAngle(light, modeDef.angle)
                end
                if modeDef.color ~= nil then
                    setColor(light, Color(modeDef.color))
                end
                applyRotationPos()
                if modeDef.enabled == false then
                    setEnabled(light, false)
                end
            end
            return function()
                return true
            end
        end

        -- Create lerp functions for each property that needs transitioning
        return U.RunSequence({
            function()
                local lerpFuncs = {}

                if modeDef.range ~= nil then
                    table.insert(lerpFuncs, U.Lerp(function(range)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        setRange(light, range)
                    end, getRange(light), modeDef.range, transitionTime))
                end

                if modeDef.intensity ~= nil then
                    table.insert(lerpFuncs, U.Lerp(function(intensity)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        setIntensity(light, intensity)
                    end, getIntensity(light), modeDef.intensity, transitionTime))
                end

                if modeDef.angle ~= nil then
                    table.insert(lerpFuncs, U.Lerp(function(angle)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        setAngle(light, angle)
                    end, getAngle(light), modeDef.angle, transitionTime))
                end

                if modeDef.color ~= nil then
                    table.insert(lerpFuncs, U.Lerp(function(color)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        setColor(light, color)
                    end, getColor(light), Color(modeDef.color), transitionTime))
                end

                -- Transform lerps use inline U.Lerp (not U.setPositionSlow) so epoch guards apply every tick.
                if modeDef.rotation ~= nil then
                    local rotEnd = OP.mergeRotation(light, modeDef.rotation)
                    table.insert(lerpFuncs, U.Lerp(function(rot)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        light.setRotation(rot)
                    end, light.getRotation(), rotEnd, transitionTime, true))
                end

                if modeDef.position ~= nil then
                    local posEnd = OP.mergePosition(light, modeDef.position)
                    table.insert(lerpFuncs, U.Lerp(function(pos)
                        if transitionEpoch[lightRef] ~= myEpoch then
                            return
                        end
                        light.setPosition(pos)
                    end, light.getPosition(), posEnd, transitionTime, false))
                end

                return lerpFuncs
            end,
            function()
                if transitionEpoch[lightRef] ~= myEpoch then
                    return
                end
                -- Finalize enabled state if turning off
                if modeDef.enabled == false then
                    setEnabled(light, false)
                    setIntensity(light, afterVals.intensity)
                    setAngle(light, afterVals.angle)
                end
            end
        })
    end

    if light == nil then
        return nil
    end

    -- Wait for light component if needed (Custom_Assetbundle spotlights: object exists before Unity Light is ready).
    -- `U.waitUntil` + `CheckCoroutine` is unreliable from spawn callbacks; `Wait.condition` is the TTS-native queue.
    if isSpawned and getLightComponent(light, true) == nil then
        U.waitForCondition(function()
            activateLight()
        end, function()
            return getLightComponent(light, true) ~= nil
        end)
        return
    end

    return activateLight()
end

--- Apply one entry from `gameState.lights` during load (`transitionT` should be 0).
--- @return boolean true if applied or skipped intentionally; false if deferred (retry later)
local function tryApplySavedLight(lightName, mData, transitionT)
    if U.Type(lightName) ~= "string" then
        return true
    end
    if U.Type(mData) ~= "string" and U.Type(mData) ~= "table" then
        return true
    end

    -- Seat lights are always derived from authoritative gameplay state
    -- (ROLLING/DARK-HUNGRY/STANDARD priorities), not restored from saved
    -- `gameState.lights` snapshots. Applying saved seat-light modes here can
    -- re-stamp stale STANDARD/OFF values during load and fight reconciler output.
    if U.lightRefIsSeatSpotlight(lightName) then
        return true
    end

    if string.sub(lightName, 1, 9) == "npcLight_" and L.LIGHTMODES[lightName] == nil then
        return false
    end

    if L.LIGHTMODES[lightName] ~= nil then
        return L.reconcileLightRef(lightName, transitionT)
    end

    if isProbablyObjectGuid(lightName) and U.Type(mData) == "table" then
        if L.GetLight(lightName, true) == nil then
            return false
        end
        L.SetLightMode(lightName, mData, nil, transitionT)
        return true
    end

    return true
end

--- Stable fingerprint of PC seat-light + layout inputs used by `reconcileForPlayer` (skip redundant presentation passes).
--- @return string
function L.computePcSeatPresentationInputFingerprint()
    local lines = {}
    lines[#lines + 1] = "tableKey:" .. tostring(S.getStateVal("seatLayout", "currentTableKey") or "")
    local preset = S.getStateVal("sessionScene", "lightingSeatSpotlightPreset")
    if U.Type(preset) == "table" then
        local presetKeys = {}
        for lightRef, mode in pairs(preset) do
            if U.Type(lightRef) == "string" then
                presetKeys[#presetKeys + 1] = lightRef .. "=" .. tostring(mode)
            end
        end
        table.sort(presetKeys)
        lines[#lines + 1] = "presets:" .. table.concat(presetKeys, ";")
    end
    for _, seatKey in ipairs(C.PlayerColors or {}) do
        lines[#lines + 1] = "seat:" .. seatKey
        lines[#lines + 1] = "present:" .. tostring(L.isPlayerPresentInActiveSeatLayout(seatKey))
        lines[#lines + 1] = "rolling:" .. tostring(getPlayerRollingState(seatKey))
        lines[#lines + 1] = "hunger:" .. tostring(S.getPlayerVal(seatKey, "hunger"))
        local playerID = S.getPlayerID(seatKey)
        if U.Type(playerID) == "string" then
            local Conditions = require("core.conditions")
            local resolved = Conditions.resolveForPlayer(playerID)
            if U.Type(resolved.lightingModes) == "table" then
                local condKeys = {}
                for lightRef, mode in pairs(resolved.lightingModes) do
                    if U.Type(lightRef) == "string" then
                        condKeys[#condKeys + 1] = lightRef .. "=" .. tostring(mode)
                    end
                end
                table.sort(condKeys)
                if #condKeys > 0 then
                    lines[#lines + 1] = "cond:" .. table.concat(condKeys, ";")
                end
            end
        end
        for lightRef, lData in pairs(L.LIGHTMODES or {}) do
            if U.Type(lightRef) == "string"
                and U.Type(lData) == "table"
                and lightRefMatchesSeatColor(lightRef, seatKey)
            then
                local res = computeDesiredSeatLightResolution(lightRef, seatKey)
                if U.Type(res) == "table" then
                    if res.kind == "named" then
                        lines[#lines + 1] = lightRef .. "=named:" .. tostring(res.mode)
                    elseif res.kind == "inline" and U.Type(res.patch) == "table" then
                        lines[#lines + 1] = lightRef .. "=inline:" .. reconcileModeFingerprint(res.patch)
                    end
                end
            end
        end
    end
    return table.concat(lines, "\n")
end

--- True when every persisted seat spotlight ref in `gameState.lights` resolves to a live object (bootstrap / overlay gate).
--- @return boolean
function L.seatSpotlightsResolvable()
    local savedLights = S.getStateVal("lights")
    if U.Type(savedLights) ~= "table" then
        return true
    end
    for lightRef, _ in pairs(savedLights) do
        if U.Type(lightRef) == "string" and U.lightRefIsSeatSpotlight(lightRef) then
            if L.GetLight(lightRef, true) == nil then
                return false
            end
        end
    end
    return true
end

--- @return boolean
function L.hasPendingInitLightsRetries()
    for _ in pairs(initLightsRetryKeys) do
        return true
    end
    return false
end

--- @return number
function L.countPendingInitLightsRetries()
    local n = 0
    for _ in pairs(initLightsRetryKeys) do
        n = n + 1
    end
    return n
end

--- Loads saved light states: cleanup, apply all keys with instant transitions, record misses for deferred pass.
function L.InitLights()
    L.cleanupLightsState()
    initLightsRetryKeys = {}
    local savedLights = S.getStateVal("lights") or {}

    -- Reconcile all registered non-seat lights through state records.
    -- Missing saved modes default to OFF (or are force-disabled with a GM warning).
    for lightRef, lData in pairs(L.LIGHTMODES or {}) do
        if U.Type(lightRef) == "string"
            and U.Type(lData) == "table"
            and not U.lightRefIsSeatSpotlight(lightRef)
        then
            if not L.reconcileLightRef(lightRef, 0) then
                initLightsRetryKeys[lightRef] = true
            end
        end
    end

    -- Also apply persisted raw-GUID table records, if any exist.
    U.forEach(savedLights, function(mData, lightName)
        if not tryApplySavedLight(lightName, mData, 0) then
            initLightsRetryKeys[lightName] = true
        end
    end)
    L.reconcileAllPlayers()
end

--- Second pass after load (late-spawned objects). Call from `U.delay` in global onLoad.
function L.InitLightsDeferred()
    L.cleanupLightsState()
    local savedLights = S.getStateVal("lights") or {}
    local remaining = {}
    for lightName, _ in pairs(initLightsRetryKeys) do
        if L.LIGHTMODES[lightName] ~= nil then
            if not L.reconcileLightRef(lightName, 0) then
                remaining[lightName] = true
            end
        else
            local mData = savedLights[lightName]
            if mData ~= nil and not tryApplySavedLight(lightName, mData, 0) then
                remaining[lightName] = true
            end
        end
    end
    initLightsRetryKeys = remaining
    L.reconcileAllPlayers()
end

--- Resets all lights to their default/off states
-- Useful for cleanup or game reset.
-- @usage L.ResetLights() -- Cleanup after game ends
function L.ResetLights()
    U.forEach(L.LIGHTMODES, function(modes, name)
        if modes.loadRotation then
            local light = getLight(name)
            if light then
                local comp = getLightComponent(light, true)
                if comp then
                    comp.set("enabled", false)
                    light.setRotation(Vector(180, 0, 0))
                end
            end
        end
    end)
end

--- Applies a mode to multiple lights at once
-- Convenience function for batch operations.
-- @param lightNames string|table Light name(s) to affect (string or array)
-- @param lightMode string Mode to apply (default: "default")
-- @param transitionTime number Transition duration (default: 3.0)
-- @param playerRef Player|string|nil Optional: Player for player-specific lights
-- @return number The transition time (for chaining)
-- @usage L.LoadLights({"playerLight1Brown", "playerLight1Orange"}, "STANDARD", 2.0)
function L.LoadLights(lightNames, lightMode, transitionTime, playerRef)
    if U.Type(lightNames) == "string" then
        lightNames = {lightNames}
    end
    if lightMode == nil then
        lightMode = "default"
    end
    if transitionTime == nil then
        transitionTime = 3.0
    end

    -- Filter to only lights that exist in LIGHTMODES
    local validLights = U.filter(L.LIGHTMODES, function(_, name)
        return U.isIn(name, lightNames)
    end)

    U.forEach(validLights, function(modes, name)
        if modes[lightMode] == nil then
            U.AlertGM("No Such Mode: " .. U.ToString(lightMode) .. " for light '" .. U.ToString(name) .. "'")
            return
        end

        if lightMode == "default" and U.Type(modes.default) == "string" then
            L.SetLightMode(name, modes.default, playerRef, transitionTime)
        else
            L.SetLightMode(name, lightMode, playerRef, transitionTime)
        end
    end)

    return transitionTime
end

--- Removes a dynamic entry from L.LIGHTMODES (e.g. despawned NPC spotlight).
-- Does not destroy the object; caller destroys objects and clears gameState.lights separately.
-- @param lightName string Registry key such as "npcLight_abc123"
function L.unregisterLightModeEntry(lightName)
    if U.Type(lightName) ~= "string" or lightName == "" then
        return
    end
    L.LIGHTMODES[lightName] = nil
end

-- ============================================================================
-- PUBLIC API EXPORTS
-- ============================================================================

-- Low-level property setters (for direct control without modes)
L.SetIntensity = setIntensity
L.SetAngle = setAngle
L.SetColor = setColor
L.SetRange = setRange
L.GetIntensity = getIntensity
L.GetAngle = getAngle
L.GetColor = getColor
L.GetRange = getRange

return L
