---@diagnostic disable: need-check-nil, lowercase-global
--[[
    Lighting Control Module (core/lighting.ttslua)

    Handles dynamic lighting control for TTS light objects with smooth transitions.
    Extracted and adapted from Kings Dilemma lighting module patterns.

    This module provides:
    - Light mode system (predefined lighting configurations)
    - Smooth transitions using coroutine-based interpolation
    - State persistence (saves current light modes)
    - Light object lookup and component access
    - Batch operations (apply modes to multiple lights)

    Light modes are stored in L.LIGHTMODES table and can be defined per-light.
    Mode fields are optional patches: missing fields are left unchanged on apply.
    Common fields are: enabled, color, range, angle, intensity, rotation, position.
    For `position` and `rotation`, tables (or Vectors) may omit any axis; omitted
    components keep the light object's current world values (see OP.mergePosition / mergeRotation).

    Agent guidance: .dev/NPC Object Spawning & Spotlighting/NPC Object Overview.md (paired spotlights);
    .dev/User Guides/TTS-3D-Positioning-Coordinate-Utilities.md.
]]

local L = {}

--- Default lerp (seconds) for `L.reconcileForPlayer` seat spotlight applies (`gameState.lights`).
L.DEFAULT_RECONCILE_LERP_SECONDS = 2

local U = require("lib.util")
local S = require("core.state")
local C = require("lib.constants")
local G = require("lib.guids")
local OP = require("lib.object_positions")

-- Last-wins: each SetLightMode bumps this; in-flight lerp steps no-op when stale.
local transitionEpoch = {}
--- Last mode fingerprint applied per lightRef; reconcile skips redundant `SetLightMode` lerps.
local lastReconciledModeByRef = {}
-- InitLights first-pass misses (object not ready); deferred pass retries these keys only.
local initLightsRetryKeys = {}
-- Warn each missing-OFF light at most once per session.
local warnedMissingOffMode = {}

-- ============================================================================
-- CONFIGURATION
-- ============================================================================

-- Default transition time for light mode changes (in seconds)
local DefaultTransitionTime = 0.5

-- ============================================================================
-- LIGHT MODE DEFINITIONS
-- ============================================================================

--- Light Mode Definitions Table
--
-- Each light can have multiple modes (e.g., "OFF", "STANDARD", "ambient", "bright", "tension").
-- Modes can be:
--   - Tables: Static mode data {enabled=true, color=Color.White, ...}
--   - Functions: Dynamic modes that calculate values at runtime: function() return {...} end
--   - Strings: Default mode key (e.g., default = "ambient")
--
-- Mode properties (all optional; omitted fields are not changed):
--   - enabled (boolean): Whether light is on/off
--   - color (Color): Light color (Color object or table {r,g,b})
--   - range (number): Light range/radius
--   - angle (number): Spotlight angle (degrees)
--   - intensity (number): Light intensity/brightness
--   - rotation (Vector): Light rotation {x,y,z}
--   - position (Vector): Light position {x,y,z}
--
-- Special properties (at light definition level, not mode level):
--   - default (string): Default mode to use when mode is "default"
--   - isSpawned (boolean): If true, waits for light to spawn before applying
--   - loadRotation (Vector): Initial rotation when light loads
--   - guid (string): Required - GUID of the light object (all lights must have GUID)
--
-- @usage L.LIGHTMODES.playerLight1Brown = {
--     guid = "f251e0",  -- Use GUID lookup instead of tags
--     default = "OFF",
--     OFF = {enabled=false, rotation=Vector(0,-72,0), position=Vector(-36.12,0,-110), ...},
--     STANDARD = {enabled=true, rotation=Vector(0,-72,60), position=Vector(-29.75,22.6,-90), ...}
-- }


function manualPlayerLight2Setup()

  -- These are the "STANDARD" modes for the 2nd player lights
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_BROWN, { enabled = true,
  color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_ORANGE, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_RED, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_PINK, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_PURPLE, { enabled = true, color = Color(255/255, 100/255, 100/255), intensity = 5, range = 80, angle = 90}, nil, 5)

  L.SetLightMode(G.GUIDS.SEAT_LIGHT_1_RED, {position=Vector({0.00, 23.00, -65.00}), rotation=Vector(350, 0, 0)})
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_3_RED, { enabled = true, range = 48.018639, angle = 119.425003, intensity = 1.488999, color = Color(0.525551, 0.525551, 0.525551), position=Vector({0.00, -5, -76.61}), rotation=Vector(180, 0, 0)}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_3_BROWN, { enabled = true, range = 48.018639, angle = 119.425003, intensity = 1.488999, color = Color(0.525551, 0.525551, 0.525551)}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_3_ORANGE, { enabled = true, range = 48.018639, angle = 119.425003, intensity = 1.488999, color = Color(0.525551, 0.525551, 0.525551)}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_3_PINK, { enabled = true, range = 48.018639, angle = 119.425003, intensity = 1.488999, color = Color(0.525551, 0.525551, 0.525551)}, nil, 5)
  L.SetLightMode(G.GUIDS.SEAT_LIGHT_3_PURPLE, { enabled = true, range = 48.018639, angle = 119.425003, intensity = 1.488999, color = Color(0.525551, 0.525551, 0.525551)}, nil, 5)


  L.SetLightMode(G.GUIDS.SEAT_LIGHT_2_PINK,  { enabled = true,
  position = Vector(0.000000, 19.932762, -53.254978), rotation = Vector(77.287727, 180.000000, 180.000000), range = 117.762299, angle = 80.670097, intensity = 1.627504, color = Color(0.819810, 0.689771, 0.583361)},  "Pink", 2)


  -- "OFF" modes should change only by having the angle go to zero.
end
