# Option A: User OAuth client credentials. Open /api/auth/google once after npm start.
PORT=3100
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/callback
OUTPUT_DIR=./output
TS_DIR=./ts
MD_DIR=./md

# Option B: Service account credentials. Share the sheet with the service account email.
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
