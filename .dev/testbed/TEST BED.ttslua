-- #region 4. LIMITED RESOLVE TEST
local function LimitedResolveTest()
  if R == nil then error("Global R is nil. Ensure Global script is loaded.") end
  if C == nil then error("Global C is nil. Ensure Global script is loaded.") end

  local tableKey = TEST_TABLE_KEY
  local t = C.Tables[tableKey]
  if t == nil then
    error("Missing table config: " .. tostring(tableKey))
  end

  -- Keep this intentionally tiny to limit movement/cloning.
  local sourceObjects = {
    player = {
      "SIGNAL_CANDLE", -- seat-specific object
    },
    other = {},
    all = {
      "SEAT_LIGHT_1", -- shared seat object
    },
    relative = {},
    cameraModes = {
      bySeat = {},
      universal = {},
    },
  }

  local computed = R.generateRotationalCoordinates(
    sourceObjects,
    t.centerPoint,
    t.numSegments,
    t.angleSegmentOne,
    t.playerToPositionMap,
    t.referencePlayerColor,
    {
      frameRefsRelativePath = LIMITED_FRAME_REFS_PATH,
      frameRefsVarName = "SEAT_LAYOUT_TEST04",
      currentTableKey = tableKey,
    }
  )

  R.resolveSeatObjects(
    computed,
    sourceObjects,
    {
      guidMapRelativePath = LIMITED_GUIDS_PATH,
      guidMapVarName = "SEAT_LAYOUT_TEST04_GUIDS",
      guidTransformsVarName = "SEAT_LAYOUT_TEST04_TRANSFORMS",
      guidFollowerTransformsVarName = "SEAT_LAYOUT_TEST04_FOLLOWERS",
    }
  )

  writeLog(LIMITED_SUMMARY_PATH, "Limited resolve completed for " .. tableKey)
end
-- #endregion

