--- One-shot: print which NPC seat workshop objects are missing (chair, figure anchor, two seat lights).
--- Optional: warns if `SEAT_FIGURE_NPC*` exists but lacks the `NPC#Object` tag (NPCS.resolveSeatFigurineObject uses tags).
function checkNpcSeatWorldObjects()
  local rows = {
    { seatKey = "NPC1", tag = "NPC1Object", chair = "75aa53", figure = "df88fd", light1 = "ca058d", light2 = "dad7c0" },
    { seatKey = "NPC2", tag = "NPC2Object", chair = "3d6084", figure = "43e314", light1 = "813c68", light2 = "a7b80b" },
    { seatKey = "NPC3", tag = "NPC3Object", chair = "bae868", figure = "16316e", light1 = "af7e58", light2 = "f0d6b5" },
    { seatKey = "NPC4", tag = "NPC4Object", chair = "6bcded", figure = "977ba7", light1 = "e1f9b6", light2 = "bc9f58" },
  }

  local function hasTag(obj, want)
    if obj == nil or obj.getTags == nil then
      return false
    end
    local tags = obj.getTags() or {}
    for i = 1, #tags do
      if tags[i] == want then
        return true
      end
    end
    return false
  end

  local function line(kind, seatKey, role, guid, extra)
    print(string.format("[npc-seat-check] %-5s %-14s %-18s %s %s", kind, seatKey, role, tostring(guid), extra or ""))
  end

  local missingAny = false
  for r = 1, #rows do
    local row = rows[r]
    local checks = {
      { role = "SEAT_CHAIR", guid = row.chair },
      { role = "SEAT_FIGURE", guid = row.figure },
      { role = "SEAT_LIGHT_1", guid = row.light1 },
      { role = "SEAT_LIGHT_2", guid = row.light2 },
    }
    for i = 1, #checks do
      local c = checks[i]
      local obj = getObjectFromGUID(c.guid)
      if obj == nil then
        missingAny = true
        line("MISS", row.seatKey, c.role, c.guid, "(getObjectFromGUID nil)")
      else
        if c.role == "SEAT_FIGURE" then
          obj.interactable = true
        end
        line("OK  ", row.seatKey, c.role, c.guid, "")
      end
    end
    local fig = getObjectFromGUID(row.figure)
    if fig ~= nil and not hasTag(fig, row.tag) then
      line("WARN", row.seatKey, "SEAT_FIGURE tag", row.figure, "expected tag '" .. row.tag .. "' for NPCS.resolveSeatFigurineObject")
    end
    local tagged = getObjectsWithTag(row.tag)
    if type(tagged) ~= "table" or #tagged == 0 then
      missingAny = true
      line("MISS", row.seatKey, "tagged objects", "", "no objects with tag '" .. row.tag .. "'")
    else
      line("OK  ", row.seatKey, "tagged objects", "", tostring(#tagged) .. " with tag '" .. row.tag .. "'")
    end
  end

  if missingAny then
    print("[npc-seat-check] DONE: one or more required pieces missing (see MISS lines).")
  else
    print("[npc-seat-check] DONE: all GUID checks passed; review WARN lines if any.")
  end
end

