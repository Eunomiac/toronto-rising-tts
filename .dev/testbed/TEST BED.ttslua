-- #region 10. LIGHTING EXPERIMENTATION

--[[
  Seat light tuning (see `.dev/RUNNING TASKLIST.md` — Lighting).
  Apply a Red-authored light `modeTable` to every PC seat `playerLight{index}{Color}`.
  When `modeTable.position` and `modeTable.rotation` are set, copies are rotated about
  `C.Tables[currentTableKey].centerPoint` using the same `(segment - refSegment) * (360/numSegments)`
  yaw step used in `CameraGenerationTest` in this file.
]]
function applyPlayerSeatLightsFromRed(lightIndex, modeTable, transitionSeconds)
  local L = require("core.lighting")
  local C = require("lib.constants")
  local S = require("core.state")
  local U = require("lib.util")
  if type(lightIndex) ~= "number" then
    print("[TestBed_applyPlayerSeatLightsFromRed] lightIndex must be a number")
    return
  end
  local idx = math.floor(lightIndex)
  if idx < 1 or idx > 3 then
    print("[TestBed_applyPlayerSeatLightsFromRed] lightIndex must be 1, 2, or 3")
    return
  end
  if type(modeTable) ~= "table" then
    print("[TestBed_applyPlayerSeatLightsFromRed] modeTable must be a table")
    return
  end
  local tr = transitionSeconds
  if type(tr) ~= "number" then
    tr = 0
  end

  local tk = S.getStateVal("seatLayout", "currentTableKey")
  if type(tk) ~= "string" or tk == "" then
    tk = "Table A"
  end
  local tcfg = C.Tables and C.Tables[tk]
  if type(tcfg) ~= "table" then
    print("[TestBed_applyPlayerSeatLightsFromRed] unknown table key: " .. tostring(tk))
    return
  end

  local map = tcfg.playerToPositionMap or {}
  local refColor = tcfg.referencePlayerColor or "Red"
  local refSeg = map[refColor]
  if type(refSeg) ~= "number" then
    print("[TestBed_applyPlayerSeatLightsFromRed] missing segment for reference color " .. tostring(refColor))
    return
  end
  local nSeg = tonumber(tcfg.numSegments) or 20
  local stepDeg = 360 / nSeg
  local center = Vector(tcfg.centerPoint)

  local basePos = modeTable.position
  local baseRot = modeTable.rotation
  local hasPose = basePos ~= nil and baseRot ~= nil

  for i = 1, #(C.PlayerColors or {}) do
    local col = C.PlayerColors[i]
    local ref = "playerLight" .. tostring(idx) .. col
    local tbl = U.clone(modeTable)
    if hasPose then
      local seg = map[col]
      if type(seg) ~= "number" then
        print("[TestBed_applyPlayerSeatLightsFromRed] skip seat " .. tostring(col) .. ": no segment in map")
      else
        local deltaYaw = (seg - refSeg) * stepDeg
        local frame = {
          position = Vector(basePos),
          rotation = Vector(baseRot),
        }
        local out = U.frameAfterRigidYawAboutCenter(center, frame, deltaYaw)
        tbl.position = Vector(out.position)
        tbl.rotation = Vector(out.rotation)
      end
    end
    L.SetLightMode(ref, tbl, col, tr)
  end
end

function getGlobalLightingValues()
  local data = {
    ambient_intensity = Lighting.ambient_intensity,
    ambient_type = Lighting.ambient_type,
    light_intensity = Lighting.light_intensity,
    lut_contribution = Lighting.lut_contribution,
    lut_index = Lighting.lut_index,
    reflection_intensity = Lighting.reflection_intensity,
    ambientEquatorColor = Lighting.getAmbientEquatorColor(),
    ambientGroundColor = Lighting.getAmbientGroundColor(),
    ambientSkyColor = Lighting.getAmbientSkyColor(),
  }
  return data
end
-- #endregion

-- #region SOUNDSCAPE TESTS

--- Resolve the standard soundscape runtime API.
--- This intentionally uses the same public global loaded by core/global_script.ttslua.
--- @return table Soundscape runtime module
local function RequireSoundscape()
  if SS == nil then
    error("Soundscape runtime global SS is not loaded. Run this after the Global script has loaded.")
  end
  return SS
end

--- Record a soundscape test result in the console and optional workspace log.
--- @param label string Human-readable test label
--- @param ok boolean Whether the tested operation succeeded
--- @param message string|nil Runtime message returned by the soundscape API
local function LogSoundscapeResult(label, ok, message)
  local line = string.format(
    "[soundscape-test] %s: %s -- %s",
    tostring(label),
    ok and "OK" or "FAIL",
    tostring(message or "")
  )
  print(line)
  table.insert(SOUNDSCAPE_TEST_LOG_LINES, line)
  writeLog(SOUNDSCAPE_TEST_LOG_PATH, table.concat(SOUNDSCAPE_TEST_LOG_LINES, "\n"))
end

--- Run a soundscape API call and log its result.
--- @param label string Human-readable test label
--- @param action function Function returning boolean, string
--- @return boolean ok
--- @return string message
local function RunSoundscapeAction(label, action)
  if type(action) ~= "function" then
    error("RunSoundscapeAction requires a function for " .. tostring(label))
  end

  local okCall, okResult, message = pcall(action)
  if not okCall then
    LogSoundscapeResult(label, false, okResult)
    return false, tostring(okResult)
  end

  LogSoundscapeResult(label, okResult == true, message)
  return okResult == true, tostring(message or "")
end

--- Run timed soundscape actions in sequence using the standard TTS Wait API.
--- @param label string Human-readable sequence label
--- @param steps table Array of { label = string, delay = number, action = function }
local function RunSoundscapeSequence(label, steps)
  if type(steps) ~= "table" then
    error("RunSoundscapeSequence requires a steps table.")
  end
  if Wait == nil or type(Wait.time) ~= "function" then
    error("Soundscape sequence tests require the standard TTS Wait.time API.")
  end

  print(string.format("[soundscape-test] Starting sequence: %s", tostring(label)))
  local elapsed = 0
  for index, step in ipairs(steps) do
    local delay = tonumber(step.delay) or 0
    elapsed = elapsed + delay
    Wait.time(function()
      RunSoundscapeAction(string.format("%s step %d: %s", tostring(label), index, tostring(step.label)), step.action)
    end, elapsed)
  end
end

