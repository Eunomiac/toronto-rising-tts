---@diagnostic disable: undefined-global, need-check-nil, undefined-field, lowercase-global
-- =========================
-- Config (edit these first)
-- =========================
local TEST_NAME = "seat_layout_test_camera_generation_apply"
local TEST_TABLE_KEY = "Table A"
local TEST_COLOR = "Red" -- Must be one of: Brown, Orange, Red, Pink, Purple

local LOG_PATH = "debug_logs/" .. TEST_NAME .. ".txt"
local APPLY_BY_SEAT_MODES = true
local APPLY_UNIVERSAL_MODES = true
local TEST_LOG_PREFIX = "debug_logs/seat_layout_test_"
local PREFLIGHT_LOG_PATH = TEST_LOG_PREFIX .. "01_preflight.txt"
local GEOMETRY_FRAME_REFS_PATH = TEST_LOG_PREFIX .. "02_frame_refs.lua"
local GEOMETRY_SUMMARY_PATH = TEST_LOG_PREFIX .. "02_summary.txt"
local REAL_FRAME_REFS_PATH = TEST_LOG_PREFIX .. "03_frame_refs.lua"
local REAL_SUMMARY_PATH = TEST_LOG_PREFIX .. "03_summary.txt"
local LIMITED_FRAME_REFS_PATH = TEST_LOG_PREFIX .. "04_frame_refs.lua"
local LIMITED_GUIDS_PATH = TEST_LOG_PREFIX .. "04_guids.lua"
local LIMITED_SUMMARY_PATH = TEST_LOG_PREFIX .. "04_summary.txt"
local FULL_APPLY_SUMMARY_PATH = TEST_LOG_PREFIX .. "05_full_apply.txt"
local FULL_APPLY_CLEANUP_PATH = TEST_LOG_PREFIX .. "05_cleanup.txt"
local SOURCE_RESOLUTION_SUMMARY_PATH = TEST_LOG_PREFIX .. "06_source_resolution_summary.txt"
local SOUNDSCAPE_TEST_LOG_PATH = "debug_logs/soundscape_test_bed.txt"
local SOUNDSCAPE_TEST_LOG_LINES = {}

-- Soundscape test defaults. These keys must exist in lib/soundscape_catalog.ttslua.
local SOUNDSCAPE_TEST_MOOD = "intrigue"
local SOUNDSCAPE_TEST_LOCATION = "softIndoor"
local SOUNDSCAPE_TEST_LOCATION_MUSIC = "casaLoma"
local SOUNDSCAPE_TEST_FEATURED = "TR_Intro"
local SOUNDSCAPE_TEST_WEATHER = "thunderstorm"
local SOUNDSCAPE_TEST_RAIN = "rainHeavy"
local SOUNDSCAPE_TEST_WIND = "windMed"
local SOUNDSCAPE_TEST_THUNDER = "thunder1"
local SOUNDSCAPE_TEST_SITE = "casaLoma"

-- If true, write generated by-seat modes for TEST_COLOR to storyteller row
-- instead of the TEST_COLOR player's row.
local REDIRECT_TEST_COLOR_TO_STORYTELLER = true

-- Shared file-writer helper for all tests in this file.
local function writeLog(path, content)
  local ok = false

  if sendExternalCommand ~= nil then
    ok = pcall(function()
      sendExternalCommand({
        type = "write",
        name = path,
        content = content,
        format = "none",
      })
    end)
    if not ok then
      ok = pcall(function()
        sendExternalCommand({
          command = "write",
          name = path,
          content = content,
          format = "none",
        })
      end)
    end
  end

  if not ok and DEBUG ~= nil and type(DEBUG.writeWorkspaceFile) == "function" then
    ok = (DEBUG.writeWorkspaceFile(path, content, "none", false) == true)
  end

  if not ok and sendExternalMessage ~= nil then
    ok = pcall(function()
      sendExternalMessage({
        type = "write",
        name = path,
        content = content,
        format = "none",
      })
    end)
  end

  print("[test-bed] writeLog ok=" .. tostring(ok) .. " path=" .. tostring(path))
  return ok
end

-- #region 0. CAMERA GENERATION + STATE-APPLY TEST
local function CameraGenerationTest()
  -- ============================================================================
  -- CAMERA GENERATION + STATE-APPLY TEST (global-only; no require)
  -- ============================================================================

  -- ===================================
  -- Helpers
  -- ===================================
  local function isValidPlayerColor(color)
    for i = 1, #(C.PlayerColors or {}) do
      if C.PlayerColors[i] == color then
        return true
      end
    end
    return false
  end

  local function rigidTransformBetweenCenters(oldCenter, newCenter, frame, deltaYaw)
    local rotated = U.frameAfterRigidYawAboutCenter(oldCenter, frame, deltaYaw)
    local translatedPos = Vector(rotated.position) + (Vector(newCenter) - Vector(oldCenter))
    return {
      position = translatedPos,
      rotation = Vector(rotated.rotation),
    }
  end

  -- Match production camera normalization rules:
  -- yaw in [0,360), pitch clamped [0,90], and exact zero values bumped to 0.1.
  local function normalizeCameraAngles(pitch, yaw, distance)
    local p = tonumber(pitch) or 0
    local y = tonumber(yaw) or 0
    local d = tonumber(distance) or 0

    y = y % 360
    if y < 0 then
      y = y + 360
    end

    if p < 0 then
      p = 0
    elseif p > 90 then
      p = 90
    end

    if p == 0 then p = 0.1 end
    if y == 0 then y = 0.1 end
    if d == 0 then d = 0.1 end

    return p, y, d
  end

  local function ensureStorytellerPlayerDataRow()
    local storytellerID = C.StorytellerID
    local row = S.getStateVal("playerData", storytellerID)
    if type(row) ~= "table" then
      S.setStateVal({
        color = "Black",
        hud = {},
        cameraAngles = {},
      }, "playerData", storytellerID)
      return storytellerID
    end
    if type(row.cameraAngles) ~= "table" then
      S.setStateVal({}, "playerData", storytellerID, "cameraAngles")
    end
    return storytellerID
  end

  local function tryGetPlayerIDByColor(color)
    local ok, result = pcall(function()
      return S.getPlayerID(color)
    end)
    if ok and type(result) == "string" and result ~= "" then
      return result
    end
    return nil
  end

  -- ===================================
  -- Validation
  -- ===================================
  if not isValidPlayerColor(TEST_COLOR) then
    error("Invalid TEST_COLOR '" .. tostring(TEST_COLOR) .. "'. Must be one of C.PlayerColors.")
  end

  local t = C.Tables and C.Tables[TEST_TABLE_KEY]
  if t == nil then
    error("Missing table config: " .. tostring(TEST_TABLE_KEY))
  end

  local map = t.playerToPositionMap or {}
  local refColor = t.referencePlayerColor
  local refSegment = map[refColor]
  if type(refSegment) ~= "number" then
    error("Reference segment missing for table reference color '" .. tostring(refColor) .. "'.")
  end

  -- ===================================
  -- Generate camera outputs
  -- ===================================
  local center = Vector(t.centerPoint)
  local stepDeg = 360 / t.numSegments

  local bySeatOut = {}    -- [playerColor][modeKey] = camera table
  local universalOut = {} -- [modeBase..seatKey] = camera table

  -- by-seat modes
  local bySeatModes = (((C.TableSourceObjects or {}).cameraModes or {}).bySeat) or {}
  for i = 1, #bySeatModes do
    local modeKey = bySeatModes[i]
    local redMode = C.RedCameraAngles and C.RedCameraAngles[modeKey]
    if type(redMode) == "table" and redMode.position ~= nil then
      for j = 1, #(C.PlayerColors or {}) do
        local color = C.PlayerColors[j]
        local seg = map[color]
        if type(seg) == "number" then
          local deltaYaw = (seg - refSegment) * stepDeg
          local transformed = rigidTransformBetweenCenters(
            center,
            center,
            {
              position = Vector(redMode.position),
              rotation = Vector({ redMode.pitch or 0, redMode.yaw or 0, 0 }),
            },
            deltaYaw
          )

          bySeatOut[color] = bySeatOut[color] or {}
          local pitch, yaw, distance = normalizeCameraAngles(
            transformed.rotation.x,
            transformed.rotation.y,
            redMode.distance or 0
          )
          bySeatOut[color][modeKey] = {
            cameraMode = redMode.cameraMode or "FirstPerson",
            position = Vector(transformed.position),
            pitch = pitch,
            yaw = yaw,
            distance = distance,
          }
        end
      end
    end
  end

  -- universal modes
  local universalModes = (((C.TableSourceObjects or {}).cameraModes or {}).universal) or {}
  for i = 1, #universalModes do
    local modeBase = universalModes[i]
    local sourceKey = modeBase .. refColor
    local redMode = C.RedCameraAngles and C.RedCameraAngles.forUniversal and C.RedCameraAngles.forUniversal[sourceKey]
    if type(redMode) == "table" and redMode.position ~= nil then
      for seatKey, seg in pairs(map) do
        if type(seatKey) == "string" and type(seg) == "number" then
          local deltaYaw = (seg - refSegment) * stepDeg
          local transformed = rigidTransformBetweenCenters(
            center,
            center,
            {
              position = Vector(redMode.position),
              rotation = Vector({ redMode.pitch or 0, redMode.yaw or 0, 0 }),
            },
            deltaYaw
          )
          local generatedKey = modeBase .. seatKey
          local pitch, yaw, distance = normalizeCameraAngles(
            transformed.rotation.x,
            transformed.rotation.y,
            redMode.distance or 0
          )
          universalOut[generatedKey] = {
            cameraMode = redMode.cameraMode or "FirstPerson",
            position = Vector(transformed.position),
            pitch = pitch,
            yaw = yaw,
            distance = distance,
          }
        end
      end
    end
  end

  -- ===================================
  -- Apply to state (real write path)
  -- ===================================
  local storytellerID = ensureStorytellerPlayerDataRow()
  local appliedCount = 0
  local redirectedCount = 0
  local skippedCount = 0

  if APPLY_BY_SEAT_MODES then
    for color, modeMap in pairs(bySeatOut) do
      local targetPlayerID = nil
      local redirected = false

      if REDIRECT_TEST_COLOR_TO_STORYTELLER and color == TEST_COLOR then
        targetPlayerID = storytellerID
        redirected = true
      else
        targetPlayerID = tryGetPlayerIDByColor(color)
      end

      if targetPlayerID ~= nil then
        for modeKey, modeVal in pairs(modeMap) do
          S.setStateVal(modeVal, "playerData", targetPlayerID, "cameraAngles", modeKey)
          appliedCount = appliedCount + 1
          if redirected then
            redirectedCount = redirectedCount + 1
          end
        end
      else
        for _modeKey, _ in pairs(modeMap) do
          skippedCount = skippedCount + 1
        end
      end
    end
  end

  if APPLY_UNIVERSAL_MODES then
    S.setStateVal(universalOut, "seatLayout", "universalCameraAngles")
  end

  -- ===================================
  -- Log output
  -- ===================================
  local lines = {}
  table.insert(lines, "=== Camera Generation + Apply Test ===")
  table.insert(lines, "os.time=" .. tostring(os.time()))
  table.insert(lines, "TEST_TABLE_KEY=" .. tostring(TEST_TABLE_KEY))
  table.insert(lines, "TEST_COLOR=" .. tostring(TEST_COLOR))
  table.insert(lines, "REDIRECT_TEST_COLOR_TO_STORYTELLER=" .. tostring(REDIRECT_TEST_COLOR_TO_STORYTELLER))
  table.insert(lines, "storytellerID=" .. tostring(storytellerID))
  table.insert(lines, "")

  table.insert(lines, "referenceColor=" .. tostring(refColor))
  table.insert(lines, "referenceSegment=" .. tostring(refSegment))
  table.insert(lines, "numSegments=" .. tostring(t.numSegments))
  table.insert(lines, "angleSegmentOne=" .. tostring(t.angleSegmentOne))
  table.insert(lines, "")

  table.insert(lines, "appliedBySeatCount=" .. tostring(appliedCount))
  table.insert(lines, "redirectedToStorytellerCount=" .. tostring(redirectedCount))
  table.insert(lines, "skippedBySeatCount=" .. tostring(skippedCount))
  table.insert(lines, "appliedUniversalCount=" .. tostring((function()
    local c = 0
    for _k, _v in pairs(universalOut) do
      c = c + 1
    end
    return c
  end)()))
  table.insert(lines, "")

  table.insert(lines, "--- BY_SEAT_GENERATED ---")
  table.insert(lines, JSON.encode_pretty(bySeatOut))
  table.insert(lines, "")
  table.insert(lines, "--- UNIVERSAL_GENERATED ---")
  table.insert(lines, JSON.encode_pretty(universalOut))
  table.insert(lines, "")

  table.insert(lines, "--- STORYTELLER_CAMERA_ANGLES_AFTER_APPLY ---")
  table.insert(lines, JSON.encode_pretty(S.getStateVal("playerData", storytellerID, "cameraAngles") or {}))
  table.insert(lines, "")

  writeLog(LOG_PATH, table.concat(lines, "\n"))
  print("[camera-test] complete")
end
-- #endregion

-- #region 1. PREFLIGHT
local function PreflightTest()
  if C == nil then error("Global C is nil. Ensure Global script is loaded.") end
  if S == nil then error("Global S is nil. Ensure Global script is loaded.") end

  local lines = {}
  table.insert(lines, "=== Seat Layout Preflight ===")
  table.insert(lines, "os.time=" .. tostring(os.time()))
  table.insert(lines, "currentTableKey=" .. tostring(S.getStateVal("seatLayout", "currentTableKey")))

  for tableKey, cfg in pairs(C.Tables or {}) do
    local seatCount = 0
    for _k, _v in pairs(cfg.playerToPositionMap or {}) do
      seatCount = seatCount + 1
    end
    table.insert(lines, string.format(
      "table=%s guid=%s segments=%s seats=%d ref=%s",
      tostring(tableKey),
      tostring(cfg.guid),
      tostring(cfg.numSegments),
      seatCount,
      tostring(cfg.referencePlayerColor)
    ))
  end

  writeLog(PREFLIGHT_LOG_PATH, table.concat(lines, "\n"))
end
-- #endregion

-- #region 2. GEOMETRY-ONLY DRY RUN
local function GeometryDryRunTest()
  if R == nil then error("Global R is nil. Ensure Global script is loaded.") end
  if C == nil then error("Global C is nil. Ensure Global script is loaded.") end

  local tableKey = TEST_TABLE_KEY
  local t = C.Tables[tableKey]
  if t == nil then
    error("Missing table config: " .. tostring(tableKey))
  end

  -- Pure frame entries: ROLE_SUFFIX naming still required.
  local sourceObjects = {
    player = {
      { Name = "TEST_ANCHOR_RED", position = Vector({ 0, 3, -20 }), rotation = Vector({ 0, 0, 0 }) },
      { Name = "TEST_SECOND_RED", position = Vector({ 5, 3, -22 }), rotation = Vector({ 0, 15, 0 }) },
    },
    other = {},
    all = {},
    relative = {},
  }

  local computed = R.generateRotationalCoordinates(
    sourceObjects,
    t.centerPoint,
    t.numSegments,
    t.angleSegmentOne,
    t.playerToPositionMap,
    t.referencePlayerColor,
    {
      frameRefsRelativePath = GEOMETRY_FRAME_REFS_PATH,
      frameRefsVarName = "SEAT_LAYOUT_TEST02",
    }
  )

  local lines = {}
  table.insert(lines, "=== Geometry Dry Run ===")
  table.insert(lines, "table=" .. tableKey)
  table.insert(lines, "radius(inferred)=" .. tostring(computed.inferredRadius))
  table.insert(lines, "radius(used)=" .. tostring(computed.radius))

  for seatKey, pack in pairs(computed.byColor or {}) do
    local slotCount = (pack and pack.slots and #pack.slots) or 0
    table.insert(lines, string.format("seat=%s slots=%d", tostring(seatKey), slotCount))
  end

  writeLog(GEOMETRY_SUMMARY_PATH, table.concat(lines, "\n"))
end
-- #endregion

