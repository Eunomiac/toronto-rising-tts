--- Simulate changing to a site by applying the site's configured soundscape.
--- @param site string Key in C.Sites.
local function SoundscapeSiteTest(site)
  local Soundscape = RequireSoundscape()
  if type(site) ~= "string" then
    error("SoundscapeSiteTest requires a site key string.")
  end
  if C == nil or type(C.Sites) ~= "table" then
    error("SoundscapeSiteTest requires global C.Sites to be loaded.")
  end

  local siteData = C.Sites[site]
  if siteData == nil then
    error(string.format("Unknown site key for SoundscapeSiteTest: %s", tostring(site)))
  end

  local context = {
    isIndoors = siteData.isIndoors == true,
  }
  if type(siteData.soundscape) == "table" then
    if type(siteData.soundscape.backgroundMusic) == "table" then
      context.locationMusic = siteData.soundscape.backgroundMusic.playlist
    end
    if type(siteData.soundscape.location) == "table" then
      context.locationAudio = siteData.soundscape.location.track
    end
  end

  RunSoundscapeAction(string.format("site %s", site), function()
    local result = Soundscape.applyContext(context)
    return result.ok == true, table.concat({
      string.format("siteName=%s", tostring(siteData.name or site)),
      tostring(result.message or ""),
      Soundscape.getSummaryText(),
    }, " | ")
  end)
end

