-- #region UNLOCKING FUNCTIONS
local function ToggleChairs()
  local thrones = {
    G.GUIDS.SEAT_CHAIR_BROWN,
    G.GUIDS.SEAT_CHAIR_ORANGE,
    G.GUIDS.SEAT_CHAIR_RED,
    G.GUIDS.SEAT_CHAIR_PINK,
    G.GUIDS.SEAT_CHAIR_PURPLE
  };

  for _, throneGuid in ipairs(thrones) do
    local throne = getObjectFromGUID(throneGuid)
    if throne ~= nil then
      throne.interactable = not throne.interactable
    end
  end
end

local function ToggleFigures()
  local figures = {
    G.GUIDS.SEAT_FIGURE_BROWN,
    G.GUIDS.SEAT_FIGURE_ORANGE,
    G.GUIDS.SEAT_FIGURE_RED,
    G.GUIDS.SEAT_FIGURE_PINK,
    G.GUIDS.SEAT_FIGURE_PURPLE
  };

  for _, figureGuid in ipairs(figures) do
    local figure = getObjectFromGUID(figureGuid)
    if figure ~= nil then
      figure.interactable = not figure.interactable
    end
  end
end

local function ToggleSoundEmitters(override)

  local function isVisible(emitter)
    return emitter.getPosition().y > 0
  end

  local soundEmitters = {
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_MUSIC_A),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_MUSIC_B),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_FEATURED_A),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_FEATURED_B),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_LOCATION_A),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_LOCATION_B),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_WEATHER_RAIN),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_WEATHER_WIND),
    getObjectFromGUID(G.GUIDS.SOUNDSCAPE_WEATHER_THUNDER),
  }

  for _, soundEmitter in ipairs(soundEmitters) do
    local toggleState = not isVisible(soundEmitter)
    if override ~= nil then
      toggleState = override
    end
    if toggleState then
      soundEmitter.setPosition(Vector({soundEmitter.getPosition().x, 5, soundEmitter.getPosition().z}))
    else
      soundEmitter.setPosition(Vector({soundEmitter.getPosition().x, -100, soundEmitter.getPosition().z}))
    end
  end
end
-- #endregion

-- #region THRONE FUNCTIONS
local function ToggleThrone(throneGuid, overrideState)
  local throne = getObjectFromGUID(throneGuid)
  local thronePos = throne.getPosition()
  -- If overrideState is true or false, set the throne to that state
  if overrideState ~= nil then
    if thronePos.y > 100 and overrideState == true then
      throne.setPosition(throne.getPosition():sub(Vector({0, 100, 0})))
    elseif thronePos.y < 100 and overrideState == false then
      throne.setPosition(throne.getPosition():add(Vector({0, 100, 0})))
    end
    return
  end

  -- If throne y-position is over 100, add 100 to it
  -- Otherwise, subtract 100 from it
  if thronePos.y > 100 then
    throne.setPosition(throne.getPosition():add(Vector({0, 100, 0})))
  else
    throne.setPosition(throne.getPosition():sub(Vector({0, 100, 0})))
  end
end

local function SwapThrone(throneGuid, newThroneGuid, newScale)

  local throne = getObjectFromGUID(throneGuid)
  local newThrone = getObjectFromGUID(newThroneGuid)
  local thronePos = throne.getPosition()
  local throneRot = throne.getRotation()

  ToggleThrone(throneGuid, false)

  newThrone.setPosition(thronePos)
  newThrone.setRotation(throneRot)
  if newScale ~= nil then
    newThrone.setScale(newScale)
  end
end
-- #endregion

-- #region DATA RETRIEVAL FUNCTIONS

--- Best-effort XML pretty-printer (2-space indent). Not a validating parser.
--- @param rawXml string
--- @return string
local function prettyPrintXml(rawXml)
  if type(rawXml) ~= "string" or rawXml == "" then
    return rawXml or ""
  end

  local xml = string.gsub(rawXml, "\r\n", "\n")
  xml = string.gsub(xml, ">%s+<", "><")

  local tokens = {}
  local pos = 1
  while pos <= #xml do
    local lt = string.find(xml, "<", pos, true)
    if lt == nil then
      local tail = string.sub(xml, pos)
      if string.match(tail, "%S") then
        table.insert(tokens, tail)
      end
      break
    end
    if lt > pos then
      local text = string.sub(xml, pos, lt - 1)
      if string.match(text, "%S") then
        table.insert(tokens, text)
      end
    end
    local gt = string.find(xml, ">", lt, true)
    if gt == nil then
      table.insert(tokens, string.sub(xml, lt))
      break
    end
    table.insert(tokens, string.sub(xml, lt, gt))
    pos = gt + 1
  end

  local indent = 0
  local lines = {}
  for t = 1, #tokens do
    local token = tokens[t]
    if string.sub(token, 1, 1) == "<" then
      local tag = token
      local isClosing = string.match(tag, "^</") ~= nil
      local isSelfClosing = string.match(tag, "/>$") ~= nil
      local isDeclaration = string.match(tag, "^<%?") ~= nil or string.match(tag, "^<!") ~= nil

      if isClosing then
        indent = math.max(0, indent - 1)
      end
      table.insert(lines, string.rep("  ", indent) .. tag)
      if not isClosing and not isSelfClosing and not isDeclaration then
        local openName = string.match(tag, "^<([%w_%-]+)")
        if openName ~= nil and string.match(tag, "</" .. openName .. ">$") == nil then
          indent = indent + 1
        end
      end
    else
      local text = string.gsub(token, "^%s+", "")
      text = string.gsub(text, "%s+$", "")
      if text ~= "" then
        table.insert(lines, string.rep("  ", indent) .. text)
      end
    end
  end

  return table.concat(lines, "\n")
end

--- Label for dump headers: scripted name, saved Name, or Nickname.
--- @param obj Object
--- @return string
local function objectDisplayName(obj)
  if obj == nil then
    return "(nil object)"
  end
  local scripted = obj.getName and obj.getName() or ""
  if type(scripted) == "string" and scripted ~= "" then
    return scripted
  end
  local data = (obj.getData and obj.getData()) or {}
  if type(data.Name) == "string" and data.Name ~= "" then
    return data.Name
  end
  if type(data.Nickname) == "string" and data.Nickname ~= "" then
    return data.Nickname
  end
  return "(unnamed)"
end

--- Read an object's **runtime** UI XML (`object.UI.getXml()`), pretty-print, write under `.dev/.debug/`.
--- This is the live UI tree in-game, not necessarily the editor `.xml` source (which may be only `<Include ...>`).
--- Requires TTS Tools / bridge on 39998 for file write (same as `writeLog` / `getObjectsByName`).
--- @param objectGuid string Object GUID
--- @param relativePath string|nil e.g. `debug_logs/csheet_page4_pink.xml` (default includes guid + os.time())
--- @return boolean ok True when XML was non-empty and write was attempted
function dumpObjectXmlToFile(objectGuid, relativePath)
  if type(objectGuid) ~= "string" or objectGuid == "" then
    print("dumpObjectXmlToFile: objectGuid must be a non-empty string")
    return false
  end

  relativePath = relativePath
    or ("debug_logs/object_xml_" .. string.gsub(objectGuid, "[^%w]", "_") .. "_" .. tostring(os.time()) .. ".xml")

  local obj = getObjectFromGUID(objectGuid)
  if obj == nil then
    print("dumpObjectXmlToFile: no object for guid=" .. tostring(objectGuid))
    return false
  end

  if obj.UI == nil or type(obj.UI.getXml) ~= "function" then
    print("dumpObjectXmlToFile: object has no UI.getXml (guid=" .. tostring(objectGuid) .. ")")
    return false
  end

  local rawXml = obj.UI.getXml()
  if type(rawXml) ~= "string" then
    print("dumpObjectXmlToFile: getXml() did not return a string (guid=" .. tostring(objectGuid) .. ")")
    return false
  end
  if rawXml == "" then
    print("dumpObjectXmlToFile: getXml() returned empty string (guid=" .. tostring(objectGuid) .. ")")
    return false
  end

  local header = table.concat({
    "<!--",
    "  dumpObjectXmlToFile",
    "  os.time=" .. tostring(os.time()),
    "  guid=" .. tostring(objectGuid),
    "  name=" .. objectDisplayName(obj),
    "  note=Runtime UI from object.UI.getXml(); editor source may differ.",
    "-->",
    "",
  }, "\n")

  local body = prettyPrintXml(rawXml)
  local ok = writeLog(relativePath, header .. body)
  print(
    string.format(
      "dumpObjectXmlToFile: chars=%d ok=%s -> .dev/.debug/%s",
      #body,
      tostring(ok),
      relativePath
    )
  )
  return ok
end

--- Case-sensitive substring search over all spawned objects; writes GUID lines to the workspace debug folder.
--- @param substring string Non-empty substring (plain text, not a Lua pattern).
--- @param relativePath string|nil Optional path under .dev/.debug (default: debug_logs/objects_by_name_<time>.lua).
function getObjectsByName(substring, relativePath)
  if type(substring) ~= "string" or substring == "" then
    print("getObjectsByName: substring must be a non-empty string")
    return
  end

  relativePath = relativePath
    or ("debug_logs/objects_by_name_" .. tostring(os.time()) .. ".lua")

  --- Prefer scripted name, then saved Name, then Nickname.
  --- @param obj Object
  --- @return string
  local function objectFullName(obj)
    if obj == nil then
      return ""
    end
    local scripted = obj.getName and obj.getName() or ""
    if type(scripted) == "string" and scripted ~= "" then
      return scripted
    end
    local data = (obj.getData and obj.getData()) or {}
    if type(data.Name) == "string" and data.Name ~= "" then
      return data.Name
    end
    if type(data.Nickname) == "string" and data.Nickname ~= "" then
      return data.Nickname
    end
    return "(unnamed)"
  end

  local matches = {}
  for _, obj in ipairs(getAllObjects() or {}) do
    local fullName = objectFullName(obj)
    if string.find(fullName, substring, 1, true) ~= nil then
      local guid = (obj.getGUID and obj.getGUID()) or "?"
      table.insert(matches, { guid = guid, name = fullName })
    end
  end

  table.sort(matches, function(a, b)
    if a.name == b.name then
      return a.guid < b.guid
    end
    return a.name < b.name
  end)

  local lines = {}
  for i = 1, #matches do
    local row = matches[i]
    local safeName = string.gsub(row.name, "[\r\n]", " ")
    table.insert(lines, string.format('  "%s", -- %s', row.guid, safeName))
  end

  local body = table.concat(lines, "\n")
  if body ~= "" then
    body = body .. "\n"
  end

  if DEBUG == nil or type(DEBUG.writeWorkspaceFile) ~= "function" then
    print(body)
    print("getObjectsByName: DEBUG.writeWorkspaceFile missing; output printed above")
    return
  end

  local ok = DEBUG.writeWorkspaceFile(relativePath, body, "none", false) == true
  print(
    string.format(
      "getObjectsByName: matches=%d ok=%s -> .dev/.debug/%s",
      #matches,
      tostring(ok),
      relativePath
    )
  )
end

-- #endregion

--- One-shot cleanup: all NPC figurines + paired lights in the world, then clear NPC instance state.
--- Run from External Editor console:  lua destroyAllNpcWorldObjects()
function destroyAllNpcWorldObjects()
  local TAG_FIG = "npc_figurine"
  local TAG_LIT = "npc_light"
  local destroyed = { figurines = 0, lights = 0 }
  local seenGuids = {}

  local function destroyOne(obj, bucket)
      if obj == nil or obj.destruct == nil then
          return
      end
      local guid = obj.getGUID ~= nil and obj.getGUID() or nil
      if guid ~= nil and guid ~= "" then
          if seenGuids[guid] then
              return
          end
          seenGuids[guid] = true
      end
      if obj.getLock ~= nil and obj.getLock() then
          obj.setLock(false)
      end
      obj.destruct()
      destroyed[bucket] = destroyed[bucket] + 1
  end

  for _, obj in ipairs(getObjectsWithTag(TAG_FIG) or {}) do
      destroyOne(obj, "figurines")
  end
  for _, obj in ipairs(getObjectsWithTag(TAG_LIT) or {}) do
      destroyOne(obj, "lights")
  end

  -- Clear state so restored GUIDs / instances do not reference deleted objects.
  -- local S = require("core.state")
  S.setStateVal({}, "npcs", "instances")

  local lights = S.getStateVal("lights") or {}
  for regName, _ in pairs(lights) do
      if type(regName) == "string" and string.sub(regName, 1, 9) == "npcLight_" then
          lights[regName] = nil
      end
  end
  S.setStateVal(lights, "lights")
  S.setStateVal({}, "seatLayout", "occupiedNPCSlots")

  print(string.format(
      "[TR] destroyAllNpcWorldObjects: figurines=%d lights=%d (state cleared)",
      destroyed.figurines,
      destroyed.lights
  ))
  return destroyed
end

