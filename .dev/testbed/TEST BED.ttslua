-- #region 6. TABLE SWITCH SEQUENCE (PRODUCTION ENTRYPOINT)
local function TableSwitchSequenceTest()
  if R == nil then error("Global R is nil. Ensure Global script is loaded.") end
  if C == nil then error("Global C is nil. Ensure Global script is loaded.") end
  if S == nil then error("Global S is nil. Ensure Global script is loaded.") end

  local targetTableKey = TEST_TABLE_KEY
  local beforeTableKey = S.getStateVal("seatLayout", "currentTableKey")
  local occupiedNPCSlots = S.getStateVal("seatLayout", "occupiedNPCSlots") or {}

  R.SetTableTo(targetTableKey)
  local afterTableKey = S.getStateVal("seatLayout", "currentTableKey")

  local lines = {}
  table.insert(lines, "=== Table Switch Sequence Test ===")
  table.insert(lines, "os.time=" .. tostring(os.time()))
  table.insert(lines, "targetTableKey=" .. tostring(targetTableKey))
  table.insert(lines, "before.currentTableKey=" .. tostring(beforeTableKey))
  table.insert(lines, "after.currentTableKey=" .. tostring(afterTableKey))
  table.insert(lines, "occupiedNPCSlots=" .. JSON.encode(occupiedNPCSlots))
  table.insert(lines, "note=This test calls R.SetTableTo(), the production table-switch entrypoint.")

  writeLog(FULL_APPLY_SUMMARY_PATH, table.concat(lines, "\n"))
end
-- #endregion

-- #region 7. SOURCE OBJECT RESOLUTION DIAGNOSTIC
local function SourceResolutionDiagnosticTest()
  if C == nil then error("Global C is nil. Ensure Global script is loaded.") end
  if U == nil then error("Global U is nil. Ensure Global script is loaded.") end

  local tableCfg = C.Tables and C.Tables[TEST_TABLE_KEY]
  if tableCfg == nil then
    error("Missing table config: " .. tostring(TEST_TABLE_KEY))
  end
  local referenceColor = tableCfg.referencePlayerColor
  if type(referenceColor) ~= "string" or referenceColor == "" then
    error("Missing referencePlayerColor for table: " .. tostring(TEST_TABLE_KEY))
  end
  local refUpper = string.upper(referenceColor)

  local function findObjectByDisplayName(displayName)
    if type(displayName) ~= "string" or displayName == "" then
      return nil
    end
    local target = string.upper(displayName)
    for _, obj in ipairs(getAllObjects() or {}) do
      if obj ~= nil then
        local objName = string.upper((obj.getName and obj.getName()) or "")
        if objName == target then
          return obj
        end
        local data = obj.getData and obj.getData() or {}
        local nickname = string.upper(data.Nickname or "")
        if nickname == target then
          return obj
        end
      end
    end
    return nil
  end

  local function describeRef(ref)
    if type(ref) == "string" then
      return ref
    end
    if type(ref) == "table" then
      if ref.guid ~= nil then
        return "table{guid=" .. tostring(ref.guid) .. "}"
      end
      return "table"
    end
    return tostring(ref)
  end

  local function checkGroup(groupName, refs)
    local missing = {}
    local total = 0
    refs = refs or {}
    for i = 1, #refs do
      total = total + 1
      local ref = refs[i]
      local resolvedObj = U.getObject(ref, true)
      if resolvedObj == nil then
        if type(ref) == "string" then
          local expectedDisplayName = ref .. "_" .. refUpper
          resolvedObj = findObjectByDisplayName(expectedDisplayName)
          if resolvedObj == nil then
            table.insert(
              missing,
              string.format(
                "[%s:%d] ref='%s' expectedDisplayName='%s'",
                groupName,
                i,
                describeRef(ref),
                expectedDisplayName
              )
            )
          end
        else
          table.insert(
            missing,
            string.format("[%s:%d] ref='%s'", groupName, i, describeRef(ref))
          )
        end
      end
    end
    return total, missing
  end

  local tso = C.TableSourceObjects or {}
  local pTotal, pMissing = checkGroup("player", tso.player)
  local oTotal, oMissing = checkGroup("other", tso.other)
  local aTotal, aMissing = checkGroup("all", tso.all)
  local rTotal, rMissing = checkGroup("relative", tso.relative)

  local lines = {}
  table.insert(lines, "=== Seat Source Resolution Diagnostic ===")
  table.insert(lines, "os.time=" .. tostring(os.time()))
  table.insert(lines, "TEST_TABLE_KEY=" .. tostring(TEST_TABLE_KEY))
  table.insert(lines, "referenceColor=" .. tostring(referenceColor))
  table.insert(lines, "")
  table.insert(lines, string.format("player: total=%d missing=%d", pTotal, #pMissing))
  table.insert(lines, string.format("other: total=%d missing=%d", oTotal, #oMissing))
  table.insert(lines, string.format("all: total=%d missing=%d", aTotal, #aMissing))
  table.insert(lines, string.format("relative: total=%d missing=%d", rTotal, #rMissing))
  table.insert(lines, "")
  table.insert(lines, "--- MISSING ENTRIES ---")
  if #pMissing + #oMissing + #aMissing + #rMissing == 0 then
    table.insert(lines, "None. All source refs resolved for this table/reference color.")
  else
    for _, row in ipairs(pMissing) do table.insert(lines, row) end
    for _, row in ipairs(oMissing) do table.insert(lines, row) end
    for _, row in ipairs(aMissing) do table.insert(lines, row) end
    for _, row in ipairs(rMissing) do table.insert(lines, row) end
  end

  writeLog(SOURCE_RESOLUTION_SUMMARY_PATH, table.concat(lines, "\n"))
end
-- #endregion

-- #region 8. INITIALIZE ALL TABLES TO HIDDEN
local function InitializeAllTablesToHidden()
  -- Hide all configured table objects and table components from all player layers.
  -- Includes player colors plus White/Grey.
  do
    local ALL_LAYER_COLORS = { "Brown", "Orange", "Pink", "Purple", "Red", "White", "Grey" }

    if C == nil then
      error("Global C is nil. Ensure Global script is loaded.")
    end

    local function hideByGuid(guid, label)
      if type(guid) ~= "string" or guid == "" then
        print("[table-hide] Skipping " .. tostring(label) .. ": invalid GUID")
        return
      end

      local obj = getObjectFromGUID(guid)
      if obj == nil then
        print("[table-hide] Missing object for " .. tostring(label) .. " guid=" .. tostring(guid))
        return
      end

      obj.setInvisibleTo(ALL_LAYER_COLORS)
      print("[table-hide] Hidden " .. tostring(label) .. " guid=" .. tostring(guid))
    end

    local tables = C.Tables or {}
    for tableKey, tableCfg in pairs(tables) do
      if type(tableCfg) == "table" then
        hideByGuid(tableCfg.guid, "table:" .. tostring(tableKey))

        local components = tableCfg.components
        if type(components) == "table" then
          for componentName, componentCfg in pairs(components) do
            if type(componentCfg) == "table" then
              hideByGuid(componentCfg.guid, "component:" .. tostring(tableKey) .. ":" .. tostring(componentName))
            end
          end
        end
      end
    end

    print("[table-hide] Done.")
  end
end
-- #endregion

-- #region 9. CAMERA EXPERIMENTATION
local function GetIntermediateCameraData(cameraData)
  local intermediateCameraData = U.clone(cameraData)
  if (intermediateCameraData.pitch > 45) then
    intermediateCameraData.pitch = intermediateCameraData.pitch - 2
  else
    intermediateCameraData.pitch = intermediateCameraData.pitch + 2
  end
  if (intermediateCameraData.distance > 15) then
    intermediateCameraData.distance = intermediateCameraData.distance - 2
  else
    intermediateCameraData.distance = intermediateCameraData.distance + 2
  end
  return intermediateCameraData
end

local function DoubleSetLookAt(cameraData, cameraMode, playerColor)

  if playerColor == nil then
    playerColor = "Black"
  end
  if cameraMode == nil then
    cameraMode = "ThirdPerson"
  end

  local player = Player[playerColor]
  if player == nil then
    error("Player " .. tostring(cameraMode) .. " not found")
  end

  -- Generate a second set of camera data distinct from the first, which will be set initially as a brief reset before applying the final lookAt
  local intermediateCameraData = GetIntermediateCameraData(cameraData)

  U.RunSequence({
    function()
      player.lookAt(intermediateCameraData)
      return 0.15
    end,
    function()
      player.lookAt(cameraData)
      return 0.5
    end,
    function()
      player.setCameraMode(cameraMode)
    end
  })
end

