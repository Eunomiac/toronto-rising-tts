<!-- Right Sidebar reference layer template (cloned per player color via @@color@@) -->
<Panel id="playerHud_referenceLayer_@@color@@" visibility="@@color@@">
  <Image id="playerHud_refPanel_princesCourt_@@color@@" active="false" class="popupImage" image="refPanel_PrincesCourt" />
  <Image id="playerHud_refPanel_chronicleTenets_@@color@@" active="false" class="popupImage" image="refPanel_ChronicleTenets" />
  <Image id="playerHud_refPanel_rolls_@@color@@" active="false" class="popupImage" image="refPanel_Rolls" />
