      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image class="imageBorder" image="hud-border-silver-bottom" />
  </VerticalLayout>

  <!-- Hover overlay layer -->
  <VerticalLayout class="storyteller_sidebarLayout">
    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_core_map_@@color@@_hover" image="toggle_CorePanel_Map_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_core_sheet_@@color@@_hover" image="toggle_CorePanel_Sheet_hover" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_ref_princesCourt_@@color@@_hover" image="toggle_PrincesCourt_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_coteries_@@color@@_hover" image="toggle_Coteries_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_chronicleTenets_@@color@@_hover" image="toggle_ChronicleTenets_hover" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_ref_rolls_@@color@@_hover" image="toggle_Rolls_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_socialCombat_@@color@@_hover" image="toggle_SocialCombat_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_physicalCombat_@@color@@_hover" image="toggle_PhysicalCombat_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_frenzy_@@color@@_hover" image="toggle_Frenzy_hover" active="false" />
