<!-- Right Sidebar buttons template (cloned per player color via @@color@@) -->
<Panel
  id="playerHud_rightSidebar_@@color@@"
  visibility="@@color@@"
  rectAlignment="UpperRight"
  height="420"
  width="125"
  offsetXY="0 -100"
>
  <!-- Base layer -->
  <VerticalLayout class="storyteller_sidebarLayout" childAlignment="UpperCenter">
    <Image class="imageBorder" image="hud-border-silver-top" />

    <Image
      id="playerHud_RSidebarBtn_core_map_@@color@@"
      image="toggle_CorePanel_Map_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_core_sheet_@@color@@"
      image="toggle_CorePanel_Sheet_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image
      id="playerHud_RSidebarBtn_ref_princesCourt_@@color@@"
      image="toggle_PrincesCourt_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_coteries_@@color@@"
      image="toggle_Coteries_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_chronicleTenets_@@color@@"
      image="toggle_ChronicleTenets_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image
      id="playerHud_RSidebarBtn_ref_rolls_@@color@@"
      image="toggle_Rolls_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_socialCombat_@@color@@"
      image="toggle_SocialCombat_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_physicalCombat_@@color@@"
      image="toggle_PhysicalCombat_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
