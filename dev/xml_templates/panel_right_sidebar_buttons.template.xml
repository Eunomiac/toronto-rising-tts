      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image
      id="playerHud_RSidebarBtn_ref_experience_@@color@@"
      image="toggle_Experience_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_projects_@@color@@"
      image="toggle_Projects_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
