    <Image id="playerHud_RSidebarBtn_ref_experience_@@color@@_hover" image="toggle_Experience_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_advantages_@@color@@_hover" image="toggle_Advantages_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_projects_@@color@@_hover" image="toggle_Projects_hover" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_memoriam_@@color@@_hover" image="toggle_Memoriam_hover" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" color="clear" />
  </VerticalLayout>

  <!-- Active overlay layer -->
  <VerticalLayout class="playerHud_sidebarLayout">
    <Image class="imageBorder" image="hud-border-silver-top" color="clear" />
    <Image id="playerHud_RSidebarBtn_core_sheet_@@color@@_active" class="long_active" image="toggle_CorePanel_Sheet_active" active="false" />
    <Image id="playerHud_RSidebarBtn_core_map_@@color@@_active" class="long_active" image="toggle_CorePanel_Map_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_princesCourt_@@color@@_active" class="long_active" image="toggle_PrincesCourt_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_coteries_@@color@@_active" class="long_active" image="toggle_Coteries_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_chronicleTenets_@@color@@_active" image="toggle_ChronicleTenets_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" color="clear" />

    <Image class="imageBorder" image="hud-border-silver-top" color="clear" />
    <Image id="playerHud_RSidebarBtn_ref_rolls_@@color@@_active" image="toggle_Rolls_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_socialCombat_@@color@@_active" image="toggle_SocialCombat_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_physicalCombat_@@color@@_active" image="toggle_PhysicalCombat_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_frenzy_@@color@@_active" image="toggle_Frenzy_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_recovery_@@color@@_active" image="toggle_Recovery_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_resonance_@@color@@_active" image="toggle_Resonance_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" color="clear" />

    <Image class="imageBorder" image="hud-border-silver-top" color="clear" />
    <Image id="playerHud_RSidebarBtn_ref_experience_@@color@@_active" image="toggle_Experience_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_advantages_@@color@@_active" image="toggle_Advantages_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_projects_@@color@@_active" image="toggle_Projects_active" active="false" />
