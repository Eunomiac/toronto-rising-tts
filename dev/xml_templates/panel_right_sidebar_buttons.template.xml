<!-- Right Sidebar buttons template (cloned per player color via @@color@@) -->
<Panel
  id="playerHud_rightSidebar_@@color@@"
  visibility="@@color@@"
  class="playerHud_rightSidebar"
>
  <!-- Base layer -->
  <VerticalLayout class="playerHud_sidebarLayout">
    <Image class="imageBorder" image="hud-border-silver-top" />

    <Image
      id="playerHud_RSidebarBtn_core_sheet_@@color@@"
      image="toggle_CorePanel_Sheet_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_core_map_@@color@@"
      image="toggle_CorePanel_Map_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_princesCourt_@@color@@"
      image="toggle_PrincesCourt_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
      onMouseExit="HUD_playerRightSidebar_hoverOff"
    />
    <Image
      id="playerHud_RSidebarBtn_ref_coteries_@@color@@"
      image="toggle_Coteries_inactive"
      raycastTarget="true"
      onMouseDown="HUD_playerRightSidebar_mouseDown"
      onMouseUp="HUD_playerRightSidebar_mouseUp"
      onMouseEnter="HUD_playerRightSidebar_hoverOn"
