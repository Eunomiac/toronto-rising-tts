    <Image id="playerHud_RSidebarBtn_ref_memoriam_@@color@@_hover" image="toggle_Memoriam_hover" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />
  </VerticalLayout>

  <!-- Active overlay layer -->
  <VerticalLayout class="storyteller_sidebarLayout">
    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_core_map_@@color@@_active" image="toggle_CorePanel_Map_active" active="false" />
    <Image id="playerHud_RSidebarBtn_core_sheet_@@color@@_active" image="toggle_CorePanel_Sheet_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_ref_princesCourt_@@color@@_active" image="toggle_PrincesCourt_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_coteries_@@color@@_active" image="toggle_Coteries_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_chronicleTenets_@@color@@_active" image="toggle_ChronicleTenets_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_ref_rolls_@@color@@_active" image="toggle_Rolls_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_socialCombat_@@color@@_active" image="toggle_SocialCombat_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_physicalCombat_@@color@@_active" image="toggle_PhysicalCombat_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_frenzy_@@color@@_active" image="toggle_Frenzy_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="playerHud_RSidebarBtn_ref_experience_@@color@@_active" image="toggle_Experience_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_projects_@@color@@_active" image="toggle_Projects_active" active="false" />
    <Image id="playerHud_RSidebarBtn_ref_memoriam_@@color@@_active" image="toggle_Memoriam_active" active="false" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />
  </VerticalLayout>
</Panel>

