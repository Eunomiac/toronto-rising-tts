    "convictions": [
      {
        "description": "My Soldiers Must Be Able To Handle Anything",
        "notes": [
          "Chief Keira Vaughn is the chief of Toronto's police department who, after briefly catching a Masquerade breach before it was scrubbed (one of Mara's dramatic murders of a political official), has been investigating what she believes is a conspiracy of criminals who can commit impossible feats of strength and speed operating in the city.",
          "Caesar admires her for how many lieutenants she's been able to bring into the fold and convince them fully.",
          "Her stern leadership reminds him of his days as a ship captain."
        ],
        "touchstone": {
          "name": "Keira Vaughan",
          "description": "Police Chief, Toronto Police",
          "notes": [
            "Chief of Toronto's police department; briefly caught a Masquerade breach before it was scrubbed (one of Mara's dramatic murders of a political official).",
            "Has been investigating what she believes is a conspiracy of criminals capable of impossible feats of strength and speed in the city.",
            "Caesar admires how many lieutenants she's brought into the fold and convinced fully.",
            "Her stern leadership reminds him of his days as a ship captain."
          ]
        }
      },
      {
        "description": "The Captain Always Saves Himself First"
      },
      {
        "description": "Reward Success, Excoriate Failure",
        "notes": [
          "Retained from Black Caesar's days following the Path of Power and the Inner Voice during his tenure as a member of the Sabbat.",
          "Slightly more likely to result in Stains when violated, compared to other Convictions."
        ]
      }
    ],
