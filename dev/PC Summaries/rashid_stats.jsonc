    "bloodline": {
      "name": "Descendant of Ur-Shulgi",
      "description": "Ur-Shulgi is spoken of as something worse than an elder: an ancient Assamite horror from the oldest wars, entombed beneath Alamut for centuries before rising as the Black Shepherd. When he woke, he judged his clan, culled the unworthy, and shattered the Tremere's centuries-old blood curse with sheer will. Those who carry his lineage inherit heat that does not fear flame, patience for plans measured in centuries, and the certainty that obedience is taken, not requested.",
      "merits": [
        {
          "name": "The Silent King",
          "value": 1,
          "description": "A sliver of Ur-Shulgi's domineering presence lives in your Blood.",
          "rules": "Once per session, when you attempt to command deference from a vampire whose applicable Status is lower than yours, you may re-roll one die.",
          "notes": "",
          "purchased": true
        },
        {
          "name": "Veins Ablaze",
          "value": 2,
          "description": "You carry an inner heat that refuses to panic before flame.",
          "rules": "Reduce the Difficulty of rolls to resist frenzy triggered by fire by 2 (minimum Difficulty 1).",
          "notes": "",
          "purchased": false
        },
        {
          "name": "Architect of Eternity",
          "value": 3,
          "description": "You think in centuries, laying foundations whose harvest may not be yours.",
          "rules": "Once per story, when you Launch a Project during a Memoriam, the Launch Roll automatically succeeds. In the present, when spending Goal dots to reduce that Project Die, you may treat your Goal dots as doubled for that purpose.",
          "notes": "",
          "purchased": true
        },
        {
          "name": "Herald of Destruction",
          "value": 4,
          "description": "Ur-Shulgi's infamous wrath can flare through you at the perfect moment.",
          "rules": "Once per session, after rolling, you may set one Hunger die to 10 if doing so would produce a Messy Critical.",
          "notes": "",
          "purchased": false
        },
        {
          "name": "Breaker of Chains",
          "value": 5,
          "description": "Your Blood remembers how to unmake bindings other Kindred accept as inevitable.",
          "rules": "Gain the Unbondable Merit. Additionally, if you feed a thrall a full Rouse Check's worth of vitae, it immediately breaks their regnant's Blood Bond. You cannot create Blood Bonds of your own.",
          "notes": "",
          "purchased": false
        }
      ]
    },
    "loresheet": {
      "name": "Nephilim",
      "description": "The Nephilim are a modern cult fixated on the Dream of Constantinople: a vampire “utopia” once upheld by a Trinity of philosophers (Michael, the Dracon, and Antonius) before crusade-era catastrophe and corruption tore it apart. Nephilim seek perfection as a path to rebuilding that idealized city, either as true believers preparing a new Trinity or as wary observers watching a dangerous movement gather momentum.",
      "merits": [
        {
          "name": "To Build the Dream",
          "value": 1,
          "description": "You study the people and politics required to raise a new Constantinople.",
          "rules": "Gain the Persuasion (Camarilla) and Politics (Camarilla) Specialties.",
          "notes": "",
          "purchased": true
        },
        {
          "name": "The Architect's Wisdom",
          "value": 2,
          "description": "You've absorbed Antonius' lessons on governance and the structures that hold a domain together.",
          "rules": "Add 2 dice to Politics pools involving domain governance. Once per story, you may decisively mediate a court dispute, defusing escalation and quashing imminent violence through action or authority.",
          "notes": "Corrected to 2-dot merit per PDF.",
          "purchased": true
        },
        {
          "name": "The Angel's Grace",
          "value": 3,
          "description": "You carry the spark of Michael's ability to inspire and steady others against the Beast.",
          "rules": "Add 1 die to Insight rolls to gauge another's Beast. Once per story, spend 1 Willpower to let another vampire re-roll up to 3 dice when resisting frenzy.",
          "notes": "",
          "purchased": false
        },
        {
          "name": "The Dragon's Disciple",
          "value": 4,
          "description": "You count yourself among the Dracon's disciples and know how his surviving shadow might be found.",
          "rules": "The Dracon functions as a 5-dot Mawla, aiding you with mediation, compromise, and the work of forging a “new Constantinople.”",
          "notes": "",
          "purchased": false
        },
        {
          "name": "The Trinity Reborn",
          "value": 5,
          "description": "You believe prophecy names you as part of the new Trinity that will rebuild the Dream, whatever it costs.",
          "rules": "Once per story, before making a Remorse test, you may remove up to 5 Stains earned in pursuit of bringing about the new Trinity.",
          "notes": "",
          "purchased": false
        }
      ]
    },
    "timeline": [
      {
        "era": "Pre-Embrace",
        "startYear": 1774,
        "endYear": 1811,
        "affiliation": "nil",
        "details": "In life, a former Sufi involved in the rise of Wahabism and the ensuing Ottoman-Wahabi war.",
        "locations": [
          "Diriyah, Ottoman Empire"
        ]
      },
      {
        "era": "A Time of Violence",
        "startYear": 1811,
        "endYear": 1839,
        "affiliation": "independent",
        "details": "Embraced directly into the Web of Knives as a Warrior Caste spy.\n\nThrough total luck, he impulsively seized opportunity to assassinate a powerful Kindred enemy: the Ventrue Prince of Diriyah, Ibrahim Kethüda.\n\nUnintended consequences abounded: the Prince's many agreements and negotiations keeping Diriyah's enemies at bay died with the Prince, and the city burned within a fortnight.\n\nIn this, Rashid was forced to face the scope of the suffering he could wreak with a single careless act, and began to question his role in his clan and the responsibility of power.\n\nRashid still keeps the ring he lifted out of the ashes that remained after he staked the Prince and left him to face the Sun, as a reminder of a mistake he will never make again.\n\nHis sire, who would become the Piece-Taker, was equally devastated; it was here that she took her famous vow of silence and began her path towards becoming the militantly isolationist autarkis of Toronto.\n\n(Dark Secret: if this ever gets out, it would invalidate his entire professed worldview.)",
        "locations": [
          "Diriyah, Ottoman Empire",
          "Alamut, Afghanistan"
        ]
      },
      {
        "era": "A Time of Faith",
        "startYear": 1839,
        "endYear": 1893,
        "affiliation": "independent",
        "details": "After spending twenty years at Alamut trying to reconcile his clan's teachings with the disaster of Diriyah, Rashid became so disillusioned with Clan Assamite that he abandoned Alamut in search of a better path forward.\n\nHaving learned about the Dream of Constantinople in the great library at Alamut, and hearing of the Tanzimat Reforms currently underway in Constantinople, the city of Michael's Dream became his next destination in his quest to find a way to exist without being an avatar of destruction.\n\nRashid's interest in the Dream did not go unnoticed, and he was approached by Sofia Mavridì, a Nephilim of Clan Toreador and a descendant of Michael the Archangel himself.\n\nFirst, she was an asset in Rashid's investigations into Constantinople's history, but the more time they spent together, the more convinced Rashid became that the Nephilim was the very path forward he was looking for: a path of creation, not destruction; a promise to build instead of to ruin.\n\nSofia was more than happy to induct him into the followers of Michael's Dream.",
        "locations": [
          "Alamut, Afghanistan",
          "Constantinople, Ottoman Empire"
        ]
      },
      {
        "era": "A Time of Sorcery",
        "startYear": 1893,
        "endYear": 1922,
        "affiliation": "independent",
        "details": "Devoted to pursuing Michael's Dream as a member of the Nephilim, when Rashid discovered that Sofia was a descendant of Michael himself, he recalled writings in the library at Alamut relating to travelling through ancestral blood memories.\n\nReturning to Alamut, he suffered the presence of his despised clan to study the sorcerous teachings he needed to help Sofia unlock the memories in her blood.\n\nReturning to Constantinople, armed with new magic, he was successful, more than successful; in a Blood Sorcery ritual, he and Sofia encountered a memory, or reflection of Michael.\n\nThe Archangel revealed the monstrous truth of Rashid's ancestor, Ur-Shulgi, but delivered a prophecy: for everything that Ur-Shulgi would destroy upon his awakening, Rashid would rebuild.\n\nWhen he awoke from the ritual trance, the ring from Diriyah glowed a deep red, and Michael had given it its name: \"Ur-Shulgi's Promise\". With this realization, it seared his flesh and blackened his finger, binding permanently to his hand.",
        "locations": [
          "Alamut, Afghanistan",
          "Constantinople, Ottoman Empire"
        ]
      },
      {
        "era": "A Time of Lineage",
        "startYear": 1922,
        "endYear": 1998,
        "affiliation": "independent",
        "details": "Having discovered the truth of his lineage, and armed with the prophecy of the Archangel, Rashid had been searching for his sire for three decades.\n\nBut Laleh bint Saif had not been seen for over a century, and the trail had long gone cold.\n\nFinally, Rashid learned of a mysterious autarkis in Toronto, Canada, the Piece-Taker, whose description and activities were very familiar to him.\n\nWielding the same ritual that he used with Sofia, Rashid was able to confirm that this was indeed his sire, and so, he finally set sail across the Atlantic.\n\nHis sire took him in and sheltered him within her protected domain, where he found many of the answers he was looking for.",
        "locations": [
          "Various Locations, Europe",
          "Toronto, Canada"
        ]
      },
      {
        "era": "A Time of Dominion",
        "startYear": 1998,
        "endYear": 2025,
        "affiliation": "camarilla",
        "details": "Rashid felt it immediately when Ur-Shulgi rose: the ring spasmed, blazed with light, and from then on he could hear the whispers of the blood god always in the back of his mind.\n\nKnowing that this was the time that Michael's prophecy spoke of, he left the shelter of his sire's domain and quietly began planning how he could become the force for order that Michael said would balance every act of Ur-Shulgi's chaos.\n\nAfter cultivating contacts and informants, he learned of the now-Banu Haqim's plan to join the Camarilla, and travelled to Denmark to assist in the forging of the Odense Pact.\n\nRashid returned to Toronto with a singular purpose: to finally realize Michael's Dream in the city he had claimed as his own.",
        "locations": [
          "Toronto, Canada",
          "Odense, Denmark"
        ]
      }
    ]
  }
}