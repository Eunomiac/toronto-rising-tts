    <Text id="rollPanel_type_Brown"
      fontSize="14"
      fontStyle="Bold"
      color="#C9A84C"
      alignment="MiddleCenter"
      text="" />

    <Text id="rollPanel_phase_Brown"
      fontSize="12"
      color="#CCCCCC"
      alignment="MiddleCenter"
      text="Awaiting Storyteller..." />

    <HorizontalLayout spacing="16" childAlignment="MiddleCenter">
      <!-- Pool: white diamonds for normal dice, red for hunger dice -->
      <HorizontalLayout spacing="2" childAlignment="MiddleCenter" childForceExpandWidth="false">
        <Text id="rollPanel_pool_normal_Brown" fontSize="14" color="#FFFFFF" text="" />
        <Text id="rollPanel_pool_hunger_Brown" fontSize="14" color="#CC3333" text="" />
      </HorizontalLayout>
      <Text id="rollPanel_diff_Brown"
        fontSize="12"
        color="#AAAAAA"
        text="Difficulty: —" />
    </HorizontalLayout>

    <!-- Die face image row: 15 slots activated+image-set per-roll by refreshDiceImages() -->
    <HorizontalLayout spacing="2" childAlignment="MiddleCenter"
      childForceExpandWidth="false" childForceExpandHeight="false"
      minHeight="48" preferredHeight="48">
      <Image id="rollPanel_die_1_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_2_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_3_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
