<!-- 3. RESULT BROADCAST PANEL                                                     -->
<!-- Visible to ALL players (no visibility filter). Shown briefly when a roll     -->
<!-- resolves; auto-hides after 12 seconds. Can be manually hidden by RUI.        -->
<!-- Positioned upper-center over the play area.                                  -->
<!-- ============================================================================ -->
<Panel id="rollResult_panel" class="rollPanel_result">

  <VerticalLayout class="rollPanel_result_content">

    <!-- Roller name + roll type label -->
    <Text id="rollResult_name"
      fontSize="16"
      fontStyle="Bold"
      color="#C9A84C"
      alignment="MiddleCenter"
      text="" />

    <!-- Die face image row: 15 slots activated+image-set by refreshDiceImages() -->
    <HorizontalLayout spacing="2" childAlignment="MiddleCenter"
      childForceExpandWidth="false" childForceExpandHeight="false"
      minHeight="54" preferredHeight="54">
      <Image id="rollResult_die_1"  active="False" preferredWidth="34" preserveAspect="True" />
      <Image id="rollResult_die_2"  active="False" preferredWidth="34" preserveAspect="True" />
