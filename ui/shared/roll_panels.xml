<!-- Roll System Panels (ui/shared/roll_panels.xml) -->
<!-- Included from ui/Global.xml at root level (outside HUD_PANEL_BLACK/PLAYER). -->
<!-- Contains three surfaces:                                                       -->
<!--   1. ST Roll Dashboard (rollDash_ST)          — Black|Host only               -->
<!--   2. Player Roll Panels (rollPanel_<Color>)   — per-player, per-color          -->
<!--   3. Result Broadcast (rollResult_panel)      — no visibility filter (all)    -->
<!-- Agent guidance: .dev/Dice System/Dice System Outline.md §8, §10               -->

<Defaults>

<Panel class="rollPanel_ST"
  visibility="Black|Host"
  active="False"
  rectAlignment="LowerRight"
  offsetXY="0 0"
  padding="10 10 10 10"
  width="520" />

<Panel class="rollPanel_player"
  active="False"
  rectAlignment="LowerCenter"
  offsetXY="0 80"
  width="480"
  padding="12 10 12 10"
  childAlignment="LowerCenter"
  childForceExpandHeight="false" />

<VerticalLayout class="rollPanel_player_content"
  spacing="6"
  childAlignment="LowerCenter"
  childForceExpandWidth="true"
  childForceExpandHeight="false"
  color="#000000" />

<Panel class="rollPanel_result"
  active="False"
  rectAlignment="UpperCenter"
  childAlignment="UpperCenter"
  childForceExpandWidth="true"
  childForceExpandHeight="false"
  offsetXY="0 -60"
  width="560"
  padding="16 12 16 12" />

<VerticalLayout class="rollPanel_result_content"
  spacing="8"
  childAlignment="UpperCenter"
  childForceExpandWidth="true"
  childForceExpandHeight="false"
  color="#000000" />

</Defaults>


<!-- ============================================================================ -->
<!-- 1. ST ROLL DASHBOARD                                                          -->
<!-- Shows all active player rolls. ST can set difficulty and open/confirm each.   -->
<!-- Positioned lower-right to avoid overlapping core HUD areas.                  -->
<!-- ============================================================================ -->
<Panel id="rollDash_ST" class="rollPanel_ST">

  <VerticalLayout spacing="4" childAlignment="UpperLeft" childForceExpandHeight="false" childForceExpandWidth="true">

    <!-- Header -->
    <Panel color="#000000" padding="5 5 5 5" flexibleWidth="1">
    <Text
      fontSize="14"
      fontStyle="Bold"
      color="#C9A84C"
      text="ACTIVE ROLLS"
      alignment="MiddleRight"
      preferredHeight="20"
      minHeight="20"
      flexibleHeight="0"
      flexibleWidth="1" />
    </Panel>

    <!-- One row per player color; shown/hidden by RUI.refreshSTDashboard() -->

    <!-- Brown row -->
    <Panel id="rollDash_row_Brown"
      active="False"
      flexibleWidth="1"
      padding="0 0 0 0"
      childForceExpandWidth="true" >
      <HorizontalLayout color="#654321" spacing="6" childAlignment="MiddleLeft" flexibleWidth="1" padding="5 5 5 5">
        <Text id="rollDash_name_Brown"  fontSize="12" color="#FFFFFF" flexibleWidth="1"  text="Brown" />
        <Text id="rollDash_type_Brown"  fontSize="11" color="#AAAAAA" flexibleWidth="1" text="" />
        <Text id="rollDash_phase_Brown" fontSize="11" color="#CCCCCC" flexibleWidth="1"  text="" />
        <Text id="rollDash_pool_Brown"  fontSize="11" color="#CCCCCC" flexibleWidth="1"  text="" />
        <InputField id="rollDash_difficulty_Brown"
          fontSize="12"
          flexibleWidth="1"
          preferredWidth="50"
          minWidth="50"
          text=""
          placeholder="Diff"
          onValueChanged="HUD_rollSetDifficulty" />
        <Button id="rollDash_opts_Brown"
          fontSize="10"
          preferredWidth="44"
          flexibleWidth="0"
          onClick="HUD_rollOptsOpen"
          text="Opts" />
        <Button id="rollDash_btn_Brown"
          fontSize="11"
          preferredWidth="60"
          flexibleWidth="0"
          onClick="HUD_rollSTAction"
          text="OPEN" />
        <Button id="rollDash_cancel_Brown"
          fontSize="11"
          preferredWidth="24"
          flexibleWidth="0"
          color="rgba(0.6,0.1,0.1,1)"
          onClick="HUD_rollCancel"
          text="X" />
      </HorizontalLayout>
    </Panel>

    <!-- Orange row -->
    <Panel id="rollDash_row_Orange"
      active="False"
      color="rgba(180,90,20,0.5)"
      padding="5 5 5 5">
      <HorizontalLayout spacing="6" childAlignment="MiddleLeft">
        <Text id="rollDash_name_Orange"  fontSize="12" color="#FFFFFF" preferredWidth="70"  text="Orange" />
        <Text id="rollDash_type_Orange"  fontSize="11" color="#AAAAAA" preferredWidth="110" text="" />
        <Text id="rollDash_phase_Orange" fontSize="11" color="#CCCCCC" preferredWidth="70"  text="" />
        <Text id="rollDash_pool_Orange"  fontSize="11" color="#CCCCCC" preferredWidth="50"  text="" />
        <InputField id="rollDash_difficulty_Orange"
          fontSize="12"
          preferredWidth="40"
          preferredHeight="24"
          text=""
          placeholder="Diff"
          onValueChanged="HUD_rollSetDifficulty" />
        <Button id="rollDash_opts_Orange"
