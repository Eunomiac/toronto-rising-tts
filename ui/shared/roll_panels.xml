        color="#CCCCCC"
        text="" />
      <Text id="rollPanel_margin_Brown"
        fontSize="12"
        color="#AAAAAA"
        text="" />
    </HorizontalLayout>

    <HorizontalLayout spacing="8" childAlignment="MiddleCenter">
      <Button id="rollPanel_btnRoll_Brown"
        active="False"
