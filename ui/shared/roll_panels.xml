      <Image id="rollResult_die_6"  active="False" preferredWidth="34" preserveAspect="True" />
      <Image id="rollResult_die_7"  active="False" preferredWidth="34" preserveAspect="True" />
      <Image id="rollResult_die_8"  active="False" preferredWidth="34" preserveAspect="True" />
      <Image id="rollResult_die_9"  active="False" preferredWidth="34" preserveAspect="True" />
