      <Image id="rollPanel_die_7_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_8_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_9_Brown"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_10_Brown" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_11_Brown" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_12_Brown" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_13_Brown" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_14_Brown" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_15_Brown" active="False" preferredWidth="30" preserveAspect="True" />
    </HorizontalLayout>

    <Text id="rollPanel_result_Brown"
      fontSize="18"
      fontStyle="Bold"
      color="#FFD700"
      alignment="MiddleCenter"
      text="" />

    <HorizontalLayout spacing="10" childAlignment="MiddleCenter">
