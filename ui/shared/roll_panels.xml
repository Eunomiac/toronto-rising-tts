<!-- Roll System Panels (ui/shared/roll_panels.xml) -->
<!-- Included from ui/Global.xml at root level (outside HUD_PANEL_BLACK/PLAYER). -->
<!-- Contains three surfaces:                                                       -->
<!--   1. ST Roll Dashboard (rollDash_ST)          — Black|Host only               -->
<!--   2. Player Roll Panels — PC: ui/player/panel_roll_controls.xml (generated)   -->
<!--      ST live roll: rollPanel_Black in this file                               -->
<!--   3. Result Broadcast (rollRes_panel)         — ui/shared/panel_roll_results.xml -->
<!-- Agent guidance: .dev/Dice System/Dice System Outline.md §8, §10               -->

<Defaults>

  <Panel class="rollPanel_ST"
    visibility="Black|Host"
    active="False"
    rectAlignment="LowerRight"
    offsetXY="0 0"
    padding="10 10 10 10"
    width="730" />

  <Panel class="rollPanel_player"
    active="False"
    rectAlignment="MiddleRight"
    offsetXY="40 0"
    width="480"
    padding="12 10 12 10"
    childAlignment="MiddleRight"
    childForceExpandHeight="false" />

  <VerticalLayout class="rollPanel_player_content"
    spacing="6"
    childAlignment="MiddleRight"
    childForceExpandWidth="true"
    childForceExpandHeight="false"
    color="#000000" />

</Defaults>


<!-- ============================================================================ -->
<!-- 1. ST ROLL DASHBOARD                                                          -->
<!-- Shows all active player rolls. ST can set difficulty and open/confirm each.   -->
<!-- Body rows: generated ui/shared/roll_dash_generated.xml (TOR-218)              -->
<!-- ============================================================================ -->
<Panel id="rollDash_ST" class="rollPanel_ST">
  <Include src="roll_dash_generated.xml" />
</Panel>

<!-- ============================================================================ -->
<!-- 2. PLAYER ROLL PANELS (PC) — generated: ui/player/panel_roll_controls.xml -->
<!--    Template: ui/.templates/panel_roll_controls.xml. ST live roll: rollPanel_Black below. -->
<!-- ============================================================================ -->


<!-- Black (Storyteller) — live NPC/Werewolf roll controls (Host sees all player panels too) -->
<Panel id="rollPanel_Black"
  visibility="Black|Host"
  class="rollPanel_player">
  <VerticalLayout class="rollPanel_player_content">
    <Text id="rollPanel_type_Black"   fontSize="14" fontStyle="Bold" color="#C9A84C" alignment="MiddleCenter" text="" />
    <Text id="rollPanel_phase_Black"  fontSize="12" color="#CCCCCC" alignment="MiddleCenter" text="" />
    <HorizontalLayout spacing="16" childAlignment="MiddleCenter">
      <HorizontalLayout spacing="6" childAlignment="MiddleCenter" childForceExpandWidth="false">
        <Text id="rollPanel_pool_rouse_Black" fontSize="14" color="#8B1A1A" text="" />
        <HorizontalLayout spacing="2" childAlignment="MiddleCenter" childForceExpandWidth="false">
          <Text id="rollPanel_pool_normal_Black" fontSize="14" color="#FFFFFF" text="" />
          <Text id="rollPanel_pool_hunger_Black" fontSize="14" color="#CC3333" text="" />
          <Text id="rollPanel_pool_obliv_Black" fontSize="14" color="#5C2D7A" text="" />
          <Text id="rollPanel_pool_werewolf_Black" fontSize="14" color="#9ACD32" text="" />
          <Text id="rollPanel_pool_rage_Black" fontSize="14" color="#FF8C00" text="" />
        </HorizontalLayout>
      </HorizontalLayout>
      <Text id="rollPanel_diff_Black" fontSize="12" color="#AAAAAA" text="Difficulty: —" />
    </HorizontalLayout>
    <HorizontalLayout spacing="2" childAlignment="MiddleCenter" childForceExpandWidth="false" childForceExpandHeight="false" minHeight="48" preferredHeight="48">
      <Image id="rollPanel_die_1_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_2_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_3_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_4_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_5_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_6_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_7_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_8_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_9_Black"  active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_10_Black" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_11_Black" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_12_Black" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_13_Black" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_14_Black" active="False" preferredWidth="30" preserveAspect="True" />
      <Image id="rollPanel_die_15_Black" active="False" preferredWidth="30" preserveAspect="True" />
    </HorizontalLayout>
    <Text id="rollPanel_result_Black"    fontSize="18" fontStyle="Bold" color="#FFD700" alignment="MiddleCenter" text="" />
    <HorizontalLayout spacing="10" childAlignment="MiddleCenter">
      <Text id="rollPanel_successes_Black" fontSize="12" color="#CCCCCC" text="" />
      <Text id="rollPanel_margin_Black"    fontSize="12" color="#AAAAAA" text="" />
    </HorizontalLayout>
    <HorizontalLayout spacing="8" childAlignment="MiddleCenter">
      <Button id="rollPanel_btnRoll_Black"    active="False" fontSize="13" preferredWidth="90"  preferredHeight="30" color="rgba(0.1,0.4,0.1,1)" onClick="HUD_rollRollButton" text="ROLL" />
      <Button id="rollPanel_btnHalf_Black"    active="False" fontSize="11" preferredWidth="100" preferredHeight="30" color="rgba(0.2,0.2,0.5,1)" onClick="HUD_rollTakeHalf"   text="TAKE HALF" />
      <Button id="rollPanel_btnWP_Black"      active="False" fontSize="11" preferredWidth="140" preferredHeight="30" color="rgba(0.4,0.1,0.1,1)" onClick="HUD_rollSpendWP"      text="SPEND WILLPOWER" />
      <Button id="rollPanel_btnRecalc_Black"  active="False" fontSize="11" preferredWidth="110" preferredHeight="30" color="rgba(0.25,0.25,0.35,1)" onClick="HUD_rollRecalculate" text="RECALCULATE" />
      <Button id="rollPanel_btnConfirm_Black" active="False" fontSize="13" preferredWidth="90"  preferredHeight="30" color="rgba(0.1,0.4,0.1,1)" onClick="HUD_rollConfirm"    text="CONFIRM" />
      <Button id="rollPanel_btnCancel_Black"  active="True"  fontSize="11" preferredWidth="70"  preferredHeight="30" color="rgba(0.5,0.1,0.1,1)" onClick="HUD_rollCancel"     text="CANCEL" />
      <Button id="rollPanel_btnOblivHunger_Black" active="False" fontSize="10" preferredWidth="130" preferredHeight="28" color="rgba(0.3,0.2,0.5,1)" onClick="HUD_rollConfirmOblivChoice" text="CONFIRM — HUNGER" />
      <Button id="rollPanel_btnOblivStain_Black"  active="False" fontSize="10" preferredWidth="120" preferredHeight="28" color="rgba(0.35,0.15,0.35,1)" onClick="HUD_rollConfirmOblivChoice" text="CONFIRM — STAIN" />
      <Button id="rollPanel_btnBrutalFail_Black"  active="False" fontSize="10" preferredWidth="110" preferredHeight="28" color="rgba(0.4,0.15,0.1,1)" onClick="HUD_rollConfirmBrutalChoice" text="CONFIRM FAIL" />
      <Button id="rollPanel_btnBrutalViolence_Black" active="False" fontSize="10" preferredWidth="130" preferredHeight="28" color="rgba(0.5,0.1,0.1,1)" onClick="HUD_rollConfirmBrutalChoice" text="CONFIRM VIOLENCE" />
    </HorizontalLayout>
  </VerticalLayout>
</Panel>

<!-- ============================================================================ -->
<!-- 3. RESULT BROADCAST PANEL (panel_roll_results.xml)                  -->
<!-- Visible to ALL players (no visibility filter). Shown briefly when a roll     -->
<!-- resolves; auto-hides after C.ROLL_RESULT_BROADCAST_SECONDS.                  -->
<!-- ============================================================================ -->
<Include src="panel_roll_results.xml" />

<!-- Storyteller roll name modal (bag click without live roll) -->
<Panel id="rollStName_modal" active="False" visibility="Black|Host"
  rectAlignment="MiddleCenter" width="400" padding="16 16 16 16" color="#1a1a1a">
  <VerticalLayout spacing="10" childAlignment="MiddleCenter">
    <Text fontSize="14" fontStyle="Bold" color="#C9A84C" text="Storyteller Roll Name" />
    <InputField id="rollStName_input" class="hud_storyteller_input" fontSize="14"
      preferredWidth="360" minWidth="360" preferredHeight="34" minHeight="34"
      flexibleWidth="1" lineType="SingleLine" text=""
      onValueChanged="HUD_rollStNameInputChanged" onEndEdit="HUD_rollStNameInputChanged"
      placeholder="Character / NPC name" />
    <HorizontalLayout spacing="12" childAlignment="MiddleCenter">
      <Button id="rollStName_btnApply" fontSize="12" preferredWidth="100" preferredHeight="28"
        onClick="HUD_rollStNameApply" text="START ROLL" />
      <Button id="rollStName_btnCancel" fontSize="12" preferredWidth="80" preferredHeight="28"
        onClick="HUD_rollStNameCancel" text="CANCEL" />
    </HorizontalLayout>
  </VerticalLayout>
</Panel>

<!-- ============================================================================ -->
<!-- ASSET PRELOAD PANEL                                                           -->
<!-- References all 7 die face image asset names so TTS loads them into memory    -->
<!-- at game start. The panel is permanently hidden; its content is never shown.  -->
<!-- This ensures image attribute swaps in refreshDiceImages() are instant.        -->
<!-- ============================================================================ -->
<Panel active="False" color="#00000000" preferredWidth="1" preferredHeight="1">
  <HorizontalLayout>
    <Image image="dieFace_normal_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_normal_ankh"  preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_normal_crit"  preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_hunger_skull" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_hunger_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_hunger_ankh"  preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_hunger_crit"  preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rouse_fang" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rouse_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_oblivRouse_fang" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_oblivRouse_fangStain" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_oblivRouse_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_oblivRouse_stain" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_werewolf_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_werewolf_scratch" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_werewolf_crit" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rage_jaws" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rage_blank" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rage_scratch" preferredWidth="1" preserveAspect="True" />
    <Image image="dieFace_rage_crit" preferredWidth="1" preserveAspect="True" />
  </HorizontalLayout>
</Panel>
