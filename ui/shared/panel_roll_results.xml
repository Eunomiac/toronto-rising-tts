<!-- Roll Result Broadcast Panel (all players). Use UI.show/UI.hide on rollRes_panel for fade animations. -->

<Defaults>

  <Panel class="rollRes_screen"
    color = "rgba(0, 0, 0, 0.97)"
    width = "100%"
    height = "100%" rectAlignment="MiddleCenter" offsetXY="0 0" showAnimation = "FadeIn" hideAnimation = "FadeOut" animationDuration = "0.5" showAnimationDelay = "0.5" />

  <Panel class="rollRes_screen_content_spacer" flexibleWidth="1" flexibleHeight="1" />

  <Panel class="rollRes_screen_content"
    height = "100%"
    width = "900" rectAlignment="MiddleCenter" />

  <Image class="rollRes_image" preserveAspect="true" rectAlignment = "MiddleCenter" />

  <Image class="rollRes_image_background" height = "550" width = "1200" offsetXY = "0 -15" preserveAspect = "false" />

  <Image class="rollRes_image_figure"
    height = "900" rectAlignment = "UpperCenter" showAnimation = "FadeIn" animationDelay = "2" />

  <Image class="rollRes_image_border"
    width = "100%" />

  <Image class="rollRes_image_border_top"  />

  <Image class="rollRes_image_border_bottom" />

  <Panel class="rollRes_rousePanel" height = "40" />
  <Image class="rollRes_rouseDie" rectAlignment = "UpperLeft" width = "40" height = "60" outline = "#000000" outlineSize = "-1 1" preserveAspect = "true" />


  <Text class = "rollRes_rouseText" rectAlignment = "UpperLeft" fontSize = "32" color = "#FF0000" alignment = "MiddleLeft" fontStyle = "BoldAndItalic" horizontalOverflow = "overflow" shadow = "#000000" shadowDistance = "3 -3" outline = "#000000" outlineSize = "2 -2"/>

  <Text class = "rollRes_rollType" rectAlignment = "MiddleCenter" fontSize = "18" color = "#b39542" alignment = "MiddleLeft" fontStyle = "BoldAndItalic" horizontalOverflow = "overflow" shadow = "#000000" shadowDistance = "3 -3" outline = "#000000" outlineSize = "2 -2"/>
  <Text class = "rollRes_rollIntro" rectAlignment = "MiddleCenter" fontSize = "32" color = "#ffe59d" alignment = "MiddleLeft" fontStyle = "Bold" horizontalOverflow = "overflow" shadow = "#000000" shadowDistance = "3 -3" outline = "#000000" outlineSize = "2 -2"/>

  <Image class="rollRes_die"  preferredWidth = "0" minWidth = "80" preserveAspect = "true" />


  <HorizontalLayout class="rollRes_diceContainer" height = "120" width = "2000" childAlignment = "MiddleCenter" childForceExpandWidth = "false" />

  <HorizontalLayout class="rollRes_successesContainer" childAlignment = "MiddleRight" childForceExpandWidth="false" preferredWidth="0" spacing="20" preferredHeight="44" minHeight="44" flexibleHeight="0"/>

  <Text class="rollRes_successes"
    fontSize = "60"
    color = "#ffffff"
    outline = "#000000"
    outlineSize = "5 5"
    alignment = "MiddleRight"
    fontStyle = "Bold"
    horizontalOverflow = "overflow"
    shadow = "#000000"
     flexibleWidth="0"
    shadowDistance = "3 -3" />

  <Text class="rollRes_successesPhrase"
    fontSize = "32"
    color = "#ffffff"
    alignment = "MiddleRight"
    fontStyle = "Bold"
    horizontalOverflow = "overflow"
    shadow = "#000000"
     flexibleWidth="0"
    shadowDistance = "3 -3" />
  <HorizontalLayout class="rollRes_difficultyDisplayContainer" spacing="15" />
  <Text class="rollRes_difficultyVS"
    fontSize = "32"
    color = "#990000"
    alignment = "MiddleRight"
    fontStyle = "Bold"
    horizontalOverflow = "overflow"
    shadow = "#000000"
     flexibleWidth="0"
    shadowDistance = "3 -3" />

  <Text class="rollRes_difficulty"
    fontSize = "60"
    color = "#FF0000"
    outline = "#000000"
    outlineSize = "5 5"
    alignment = "MiddleRight"
    fontStyle = "Bold"
    horizontalOverflow = "overflow"
    shadow = "#000000"
     flexibleWidth="0"
    shadowDistance = "3 -3" />

  <Text class="rollRes_resultDisplay"
    fontSize = "100"
    color = "#ffffff"
    outline = "#000000"
    outlineSize = "3 3"
    alignment = "MiddleRight"
    fontStyle = "Bold"
    horizontalOverflow = "overflow"
    shadow = "#000000"
    shadowDistance = "3 -3" />

  <Text class="rollRes_result_win" color="#c8c8c8" />
  <Text class="rollRes_result_failure" color="#ff0000" />
  <Text class="rollRes_result_totalFailure" color="#000000" outline="#990000" outlineSize="5 5" alignment="MiddleCenter" />
  <Text class="rollRes_result_criticalWin" color="#ffffff" outline="#FFDD00" outlineSize="2 2" alignment="MiddleCenter" />
  <Text class="rollRes_result_messyCritical" color="#ffffff" outline="#FF0000" outlineSize="3 3" alignment="MiddleCenter" />
  <Text class="rollRes_result_bestialFailure" color="#990000" outline="#FF0000" outlineSize="2 2" alignment="MiddleCenter" />
  <Text class="rollRes_result_totalBestialFailure" color="#440000" outline="#FF0000" outlineSize="5 5" alignment="MiddleCenter" fontSize = "80" />
  <Text class="rollRes_result_brutalFailure" outline="#ff7300" outlineSize="5 5" color="#990000" alignment="MiddleCenter" />
  <Text class="rollRes_result_brutalOutcome" color="#ff9100" outline="#ff0000" outlineSize="2 2" alignment="MiddleCenter" />

</Defaults>

<Panel id="rollRes_panel" class="rollRes_screen" active="false">

  <Panel class="rollRes_screen_content">
    <Image id="rollRes_screen_content_background" class="rollRes_image rollRes_image_background" image="resultsBG" />
    <Image id="rollRes_screen_content_figure" class="rollRes_image rollRes_image_figure" image="" />

    <Image class="rollRes_image rollRes_image_border rollRes_image_border_top" image="resultsBorder" offsetXY = "0 350" />
    <Image id="rollRes_screen_content_border_bottom" class="rollRes_image rollRes_image_border rollRes_image_border_bottom" image="resultsBorderBottom" offsetXY = "0 -200" />

    <Panel class="rollRes_body_container">

      <Panel id="rollRes_rousePanel_2" class="rollRes_rousePanel" offsetXY = "-250 350" scale="0.75" active="false">
        <Image id="rollRes_rouseDie_2_5" class="rollRes_rouseDie" image="" active="false" offsetXY = "0 20" />
        <Image id="rollRes_rouseDie_2_4" class="rollRes_rouseDie" image="" active="false" offsetXY = "30 20" />
        <Image id="rollRes_rouseDie_2_3" class="rollRes_rouseDie" image="" active="false" offsetXY = "60 20" />
        <Image id="rollRes_rouseDie_2_2" class="rollRes_rouseDie" image="" active="false" offsetXY = "90 20" />
        <Image id="rollRes_rouseDie_2_1" class="rollRes_rouseDie" image="" active="false" offsetXY = "120 20" />
        <Text id="rollRes_rouseText_2" class="rollRes_rouseText" text = "" active="true" offsetXY = "160 5"/>
      </Panel>

      <Panel id="rollRes_rousePanel_1" class="rollRes_rousePanel" offsetXY = "-250 310" scale="0.75" active="false">
        <Image id="rollRes_rouseDie_1_5" class="rollRes_rouseDie" image="" active="false"  offsetXY = "0 20" />
        <Image id="rollRes_rouseDie_1_4" class="rollRes_rouseDie" image="" active="false" offsetXY = "30 20"/>
        <Image id="rollRes_rouseDie_1_3" class="rollRes_rouseDie" image="" active="false" offsetXY = "60 20"/>
        <Image id="rollRes_rouseDie_1_2" class="rollRes_rouseDie" image="" active="false" offsetXY = "90 20"/>
        <Image id="rollRes_rouseDie_1_1" class="rollRes_rouseDie" image="" active="false" offsetXY = "120 20"/>
        <Text id="rollRes_rouseText_1" class="rollRes_rouseText" text = "" active="true" offsetXY = "160 5"/>
      </Panel>

      <Text id="rollRes_rollType" class="rollRes_rollType" text="" offsetXY = "0 280" />
      <Text id="rollRes_rollIntro" class="rollRes_rollIntro" text="" offsetXY = "0 230" />

      <HorizontalLayout class="rollRes_diceContainer" offsetXY = "0 140">
        <Image id="rollRes_die_1" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_2" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_3" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_4" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_5" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_6" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_7" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_8" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_9" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_10" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_11" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_12" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_13" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_14" class="rollRes_die" image="" active="false" />
        <Image id="rollRes_die_15" class="rollRes_die" image="" active="false" />
      </HorizontalLayout>
      <HorizontalLayout id="rollRes_successesContainer" class="rollRes_successesContainer" offsetXY = "0 40" active="false">

        <Text id="rollRes_successes" class="roll_text rollRes_successes" text="" />
        <Text id="rollRes_successesPhrase" class="roll_text rollRes_successesPhrase" text="" />
        <HorizontalLayout id="rollRes_difficultyDisplay" class="rollRes_difficultyDisplayContainer" spacing="15" active="false">
          <Text class="roll_text rollRes_difficultyVS" text="vs." />
          <Text id="rollRes_difficulty" class="roll_text rollRes_difficulty" text="" />
        </HorizontalLayout>
      </HorizontalLayout>

      <Text id="rollRes_resultDisplay" class="roll_text rollRes_resultDisplay" text="" offsetXY = "0 -50"/>

    </Panel>
  </Panel>

</Panel>
