<!-- CONTROL_BOARD (bea29a) object XmlUI — Apply/Clear call click_* on objects/npc_control_board.ttslua -->
<Panel id="npc_control_board_panel" width="200" height="360" rectAlignment="UpperLeft" offsetXY="8 -8">
  <VerticalLayout spacing="6" padding="8 8 8 8" childAlignment="MiddleCenter" childForceExpandHeight="false">
    <Text fontSize="13" color="#CCCCCC" alignment="MiddleCenter">NPC gameboard</Text>
    <Button id="gb_apply" onClick="click_apply" fontSize="14" preferredHeight="44" minHeight="40"
      colors="#336644|#448855|#55AA66|#333333" textColor="#FFFFFF">Apply</Button>
    <Button id="gb_clear" onClick="click_clear" fontSize="14" preferredHeight="44" minHeight="40"
      colors="#663333|#884444|#AA5555|#333333" textColor="#FFFFFF">Clear</Button>
    <Button id="gb_read" onClick="click_read_stub" fontSize="12" preferredHeight="36" minHeight="32"
      colors="#444455|#555566|#666677|#333333" textColor="#DDDDDD">Read</Button>
    <Button id="gb_lock" onClick="click_lock_stub" fontSize="12" preferredHeight="36" minHeight="32"
      colors="#444455|#555566|#666677|#333333" textColor="#DDDDDD">Lock</Button>
    <Button id="gb_load" onClick="click_load_stub" fontSize="12" preferredHeight="36" minHeight="32"
      colors="#444455|#555566|#666677|#333333" textColor="#DDDDDD">Load</Button>
  </VerticalLayout>
</Panel>
