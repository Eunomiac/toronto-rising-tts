<!-- Parameters:
@@COLOR@@ - Title-case seat suffix for divider_flaws image (e.g. "Purple")
@@BACKGROUNDS_COLUMN_1@@ - concatenated bg_block renders
@@BACKGROUNDS_COLUMN_2@@
@@BACKGROUNDS_COLUMN_3@@
@@MERITS_COLUMN_1@@ - concatenated merit_block renders
@@MERITS_COLUMN_2@@
@@MERITS_COLUMN_3@@
@@FLAWS_COLUMN_1@@ - concatenated flaw_block renders
@@FLAWS_COLUMN_2@@
@@FLAWS_COLUMN_3@@
-->

<Panel id="paper_root" class="page_root padded_border" height="2150" padding="10 10 140 100">

  <Button id="pageBack" class="page_navigation page_back" />

  <VerticalLayout id="page3_container" class="vertical_section_container">
    <Panel id="page3_top_spacer" class="spacer" preferredHeight="150" flexibleHeight="0" minHeight="150" />

    <HorizontalLayout class="box_column_container">
      <VerticalLayout class="box_column">@@BACKGROUNDS_COLUMN_1@@</VerticalLayout>
      <VerticalLayout class="box_column">@@BACKGROUNDS_COLUMN_2@@</VerticalLayout>
      <VerticalLayout class="box_column">@@BACKGROUNDS_COLUMN_3@@</VerticalLayout>
    </HorizontalLayout>

    <Image id="divider_merits" image="divider_merits" class="divider_image" />

    <HorizontalLayout class="box_column_container">
      <VerticalLayout class="box_column">@@MERITS_COLUMN_1@@</VerticalLayout>
      <VerticalLayout class="box_column">@@MERITS_COLUMN_2@@</VerticalLayout>
      <VerticalLayout class="box_column">@@MERITS_COLUMN_3@@</VerticalLayout>
    </HorizontalLayout>

    <Image id="divider_flaws" image="divider_flaws_@@COLOR@@" class="divider_flaws_image" />

    <HorizontalLayout class="box_column_container">
      <VerticalLayout class="box_column">@@FLAWS_COLUMN_1@@</VerticalLayout>
      <VerticalLayout class="box_column">@@FLAWS_COLUMN_2@@</VerticalLayout>
      <VerticalLayout class="box_column">@@FLAWS_COLUMN_3@@</VerticalLayout>
    </HorizontalLayout>

  </VerticalLayout>

    <!-- Status overlays (sheetDisplay:false): single Images, LTR base/temp + grey disabled from the right. -->
     <Defaults>
        <Image class="dot_status" height="80" width="80" ignoreLayout="true" rectAlignment="UpperLeft" active="false" />
     </Defaults>

    <Image id="dot_statusCamarilla_1" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusCamarilla_2" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusCamarilla_3" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusCamarilla_4" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusCamarilla_5" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />

    <Image id="dot_statusClan_1" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_2" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_3" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_4" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
    <Image id="dot_statusClan_5" image="" class="dot dot_standard dot_status" offsetXY="286 -226" />
</Panel>
