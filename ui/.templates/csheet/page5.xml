<!-- Parameters:
@@PROJECT_BLOCKS@@ - Concatenated project_block renders
@@GEAR_BLOCKS@@ - Concatenated gear_block renders
@@HAS_BOONS@@ - set true when there exist any boons to render
@@BOONS_COLUMN_1@@ .. @@BOONS_COLUMN_3@@ - concatenated boon_block renders
-->

<Include src="csheet_defaults.xml" />

<Panel id="paper_root" class="page_root">

  <Button id="pageBack" class="page_navigation page_back" />
  <Button id="pageInner" class="page_navigation page_inner_right" />
  <!-- === ATTRIBUTES === -->

  <VerticalLayout class="vertical_project_container"  >

    @@PROJECT_BLOCKS@@

  </VerticalLayout>

  <VerticalLayout class="vertical_gear_container" >

    @@GEAR_BLOCKS@@

  </VerticalLayout>

  ##IF @@HAS_BOONS@@##
  <Image id="divider_boonsFavors" image="divider_boonsFavors" class="divider_image" />

  <HorizontalLayout class="box_column_container">
    <VerticalLayout class="box_column">@@BOONS_COLUMN_1@@</VerticalLayout>
    <VerticalLayout class="box_column">@@BOONS_COLUMN_2@@</VerticalLayout>
    <VerticalLayout class="box_column">@@BOONS_COLUMN_3@@</VerticalLayout>
  </HorizontalLayout>

  ##ENDIF##

</Panel>
