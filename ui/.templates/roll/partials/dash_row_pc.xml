<!-- @@COLOR@@ @@ROW_BG@@ — PC active-roll dashboard row (absolute pixel layout) -->
<Panel id="rollDash_row_@@COLOR@@"
  active="False"
  width="520"
  height="34"
  rectAlignment="UpperLeft"
  offsetXY="0 @@ROW_OFFSET_Y@@"
  color="@@ROW_BG@@">
  <Text id="rollDash_name_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="5 8"
    preferredWidth="70"
    preferredHeight="18"
    fontSize="12"
    color="#FFFFFF"
    text="@@COLOR@@" />
  <Text id="rollDash_type_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="81 9"
    preferredWidth="110"
    preferredHeight="16"
    fontSize="11"
    color="#AAAAAA"
    text="" />
  <Text id="rollDash_phase_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="197 9"
    preferredWidth="70"
    preferredHeight="16"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <Text id="rollDash_pool_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="273 9"
    preferredWidth="50"
    preferredHeight="16"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <InputField id="rollDash_difficulty_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="329 5"
    preferredWidth="40"
    preferredHeight="24"
    fontSize="12"
    text=""
    placeholder="Diff"
    onValueChanged="HUD_rollSetDifficulty" />
  ##IF @@SHOW_OPTS@@##
  <Button id="rollDash_opts_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="375 5"
    preferredWidth="44"
    preferredHeight="24"
    fontSize="10"
    onClick="HUD_rollOptsOpen"
    text="Opts" />
  ##ENDIF##
  <Button id="rollDash_btn_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="425 5"
    preferredWidth="70"
    preferredHeight="24"
    fontSize="11"
    onClick="HUD_rollSTAction"
    text="OPEN" />
  <Button id="rollDash_cancel_@@COLOR@@"
    rectAlignment="UpperLeft"
    offsetXY="501 5"
    preferredWidth="24"
    preferredHeight="24"
    fontSize="11"
    color="rgba(0.6,0.1,0.1,1)"
    onClick="HUD_rollCancel"
    text="X" />
</Panel>
