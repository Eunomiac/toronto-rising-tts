<!-- @@COLOR@@ @@ROW_BG@@ — PC active-roll dashboard row (absolute pixel layout) -->
<Panel id="rollDash_row_@@COLOR@@"
  active="False"
  preferredWidth="@@DASH_WIDTH@@"
  preferredHeight="34"
  color="@@ROW_BG@@">
  <Text id="rollDash_name_@@COLOR@@"
    rectAlignment="MiddleLeft"
    alignment = "MiddleLeft"
    offsetXY="5 0"
    width="70"
    height="34"
    fontSize="12"
    fontStyle="Bold"
    color="#FFFFFF"
    text="@@COLOR@@" />
  <Text id="rollDash_type_@@COLOR@@"
    rectAlignment="UpperLeft"
    alignment = "UpperCenter"
    offsetXY="75 -5"
    width="80"
    height="16"
    fontSize="11"
    color="#AAAAAA"
    text="" />
  <Text id="rollDash_phase_@@COLOR@@"
    rectAlignment="LowerLeft"
    alignment = "LowerCenter"
    offsetXY="75 5"
    width="80"
    height="16"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <Text id="rollDash_pool_@@COLOR@@"
    rectAlignment="MiddleLeft"
    alignment = "MiddleLeft"
    offsetXY="160 0"
    width="50"
    height="34"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <GridLayout id="gridStrip_rollDash@@COLOR@@_difficulty" class="grid_strip_design grid_strip_difficulty" active="true">
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_0" class="grid_strip_cell_design grid_strip_cell_difficulty" />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_1" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_2" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_3" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_4" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_5" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_6" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_7" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_8" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_9" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
    <Panel id="gridStrip_rollDash@@COLOR@@_difficulty_10" class="grid_strip_cell_design grid_strip_cell_difficulty"  />
  </GridLayout>
  ##IF @@SHOW_OPTS@@##
  <Button id="rollDash_opts_@@COLOR@@"
    rectAlignment="MiddleRight"
    offsetXY="-40 0"
    width="24"
    height="24"
    fontSize="14"
    fontStyle = "Bold"
    onClick="HUD_rollOptsOpen"
    outline="#FFFFFF"
    outlineSize = "2 -2"
    text="O" />
  ##ENDIF##

  <!--
  UI.setAttributes("rollDash_cancel_Brown", {offsetXY = "-10 0", height="24", outline="#FFFFFF", outlineSize = "2 -2", fontStyle = "Bold", textColor = "#FFFFFF", fontSize = "14"})
  -->
  <Button id="rollDash_cancel_@@COLOR@@"
    rectAlignment="MiddleRight"
    offsetXY="-10 0"
    width="24"
    height="24"
    fontSize="14"
    color="rgba(0.6,0.1,0.1,1)"
    onClick="HUD_rollCancel"
    outline="#FFFFFF"
    outlineSize = "2 -2"
    fontStyle = "Bold"
    textColor = "#FFFFFF"
    text="X" />
</Panel>
