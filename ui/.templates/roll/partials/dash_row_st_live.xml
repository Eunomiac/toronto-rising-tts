<!-- Storyteller (Black) NPC / Werewolf live-roll dashboard row (absolute pixel layout) -->
<Panel id="rollDash_row_Black"
  active="False"
  width="730"
  height="34"
  rectAlignment="UpperLeft"
  offsetXY="0 @@ROW_OFFSET_Y@@"
  color="#333333">
  <Text id="rollDash_name_Black"
    rectAlignment="UpperLeft"
    offsetXY="5 8"
    preferredWidth="90"
    preferredHeight="18"
    fontSize="12"
    color="#FFFFFF"
    text="ST Roll" />
  <Text id="rollDash_type_Black"
    rectAlignment="UpperLeft"
    offsetXY="99 9"
    preferredWidth="90"
    preferredHeight="16"
    fontSize="11"
    color="#AAAAAA"
    text="" />
  <Text id="rollDash_phase_Black"
    rectAlignment="UpperLeft"
    offsetXY="193 9"
    preferredWidth="60"
    preferredHeight="16"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <Text id="rollDash_pool_Black"
    rectAlignment="UpperLeft"
    offsetXY="257 9"
    preferredWidth="50"
    preferredHeight="16"
    fontSize="11"
    color="#CCCCCC"
    text="" />
  <InputField id="rollDash_difficulty_Black"
    rectAlignment="UpperLeft"
    offsetXY="311 5"
    preferredWidth="40"
    preferredHeight="24"
    fontSize="12"
    text=""
    placeholder="Diff"
    onValueChanged="HUD_rollSetDifficulty" />
  <Button id="rollDash_btn_Black"
    rectAlignment="UpperLeft"
    offsetXY="355 5"
    preferredWidth="64"
    preferredHeight="24"
    fontSize="10"
    onClick="HUD_rollSTAction"
    text="OPEN" />
  ##IF @@SHOW_OBLIV_BUTTONS@@##
  <Button id="rollDash_btnOblivHunger_Black"
    active="False"
    rectAlignment="UpperLeft"
    offsetXY="423 5"
    preferredWidth="72"
    preferredHeight="24"
    fontSize="9"
    onClick="HUD_rollConfirmOblivChoice"
    text="HUNGER" />
  <Button id="rollDash_btnOblivStain_Black"
    active="False"
    rectAlignment="UpperLeft"
    offsetXY="499 5"
    preferredWidth="64"
    preferredHeight="24"
    fontSize="9"
    onClick="HUD_rollConfirmOblivChoice"
    text="STAIN" />
  ##ENDIF##
  ##IF @@SHOW_BRUTAL_BUTTONS@@##
  <Button id="rollDash_btnBrutalFail_Black"
    active="False"
    rectAlignment="UpperLeft"
    offsetXY="567 5"
    preferredWidth="56"
    preferredHeight="24"
    fontSize="9"
    onClick="HUD_rollConfirmBrutalChoice"
    text="FAIL" />
  <Button id="rollDash_btnBrutalViolence_Black"
    active="False"
    rectAlignment="UpperLeft"
    offsetXY="627 5"
    preferredWidth="72"
    preferredHeight="24"
    fontSize="9"
    onClick="HUD_rollConfirmBrutalChoice"
    text="VIOLENCE" />
  ##ENDIF##
  <Button id="rollDash_cancel_Black"
    rectAlignment="UpperLeft"
    offsetXY="703 5"
    preferredWidth="24"
    preferredHeight="24"
    fontSize="11"
    color="rgba(0.6,0.1,0.1,1)"
    onClick="HUD_rollCancel"
    text="X" />
</Panel>
