<!-- @@SLOT_INDEX@@ — one ST drawer slot summary row -->
<Panel id="rollDash_stRow_@@SLOT_INDEX@@"
  active="False"
  preferredWidth="@@DASH_WIDTH@@"
  preferredHeight="30"
  color="#2a2a2a">
  <Text id="rollDash_stLabel_@@SLOT_INDEX@@"
    rectAlignment="UpperLeft"
    offsetXY="4 7"
    width="120"
    height="16"
    fontSize="11"
    color="#FFFFFF"
    text="" />
  <Text id="rollDash_stPhase_@@SLOT_INDEX@@"
    rectAlignment="UpperLeft"
    offsetXY="130 8"
    width="70"
    height="14"
    fontSize="10"
    color="#CCCCCC"
    text="" />
  <Text id="rollDash_stLive_@@SLOT_INDEX@@"
    rectAlignment="UpperLeft"
    offsetXY="206 8"
    width="36"
    height="14"
    fontSize="10"
    color="#C9A84C"
    text="" />
  <Button id="rollDash_stCancel_@@SLOT_INDEX@@"
    rectAlignment="UpperLeft"
    offsetXY="248 4"
    width="50"
    height="22"
    fontSize="10"
    onClick="HUD_rollCancel"
    text="CLEAR" />
</Panel>
