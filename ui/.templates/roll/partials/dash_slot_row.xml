<!-- @@SLOT_INDEX@@ — one ST drawer slot summary row -->
<Panel id="rollDash_stRow_@@SLOT_INDEX@@"
  active="False"
  preferredWidth="@@DASH_WIDTH@@"
  preferredHeight="30"
  color="#2a2a2a">

<!--
  UI.setAttributes("rollDash_stLabel_1", {fontSize = "12", fontStyle = "Bold", color = "#FFFFFF", width = "120", offsetXY = "4 0", rectAlignment = "MiddleLeft", horizontalOverflow = "overflow", alignment = "MiddleLeft", height = "30"})
  UI.setAttributes("rollDash_stPhase_1", {height = "30", fontSize = "12", fontStyle = "Italic", color = "#CCCCCC", width = "70", offsetXY = "260 0"})
  UI.setAttributes("rollDash_stLive_1", {fontStyle = "Bold",height = "30", fontSize = "10", color = "#C9A84C", width = "36", offsetXY = "226 0"})
  UI.setAttributes("rollDash_stCancel_1", {fontSize = "10", width = "50", offsetXY = "248 4"})
-->

  <Text id="rollDash_stLabel_@@SLOT_INDEX@@"
    rectAlignment="MiddleLeft"
    offsetXY="4 0"
    width="120"
    height="30"
    fontSize="12"
    fontStyle = "Bold"
    color="#FFFFFF"
    horizontalOverflow = "overflow"
    alignment = "MiddleLeft"
    text="" />
  <Text id="rollDash_stPhase_@@SLOT_INDEX@@"
    rectAlignment="MiddleLeft"
    offsetXY="160 0"
    width="70"
    height="30"
    fontSize="12"
    fontStyle = "Italic"
    color="#CCCCCC"
    horizontalOverflow = "overflow"
    alignment = "MiddleLeft"
    text="" />

    <!--
    UI.setAttributes("rollDash_stLive_1", {text = "Live Roll", height = "30", fontSize = "10", color = "#C9A84C", width = "36", offsetXY = "226 0"})
    -->
  <Text id="rollDash_stLive_@@SLOT_INDEX@@"
    rectAlignment="MiddleLeft"
    offsetXY="226 0"
    width="36"
    height="30"
    fontSize="10"
    color="#C9A84C"
    text="" />

  <Button id="rollDash_stBroadcast_@@SLOT_INDEX@@"

    rectAlignment="MiddleRight"
    offsetXY="-10 0"
    width="24"
    height="24"
    fontSize="14"
    color="#00ffd5"
    outline="#FFFFFF"
    outlineSize = "2 -2"
    fontStyle = "Bold"
    textColor = "#FFFFFF"
    text="B"
    onClick="HUD_rollBroadcast" />

  <Button id="rollDash_stCancel_@@SLOT_INDEX@@"

    rectAlignment="MiddleRight"
    offsetXY="-10 0"
    width="24"
    height="24"
    fontSize="14"
    color="rgba(0.6,0.1,0.1,1)"
    outline="#FFFFFF"
    outlineSize = "2 -2"
    fontStyle = "Bold"
    textColor = "#FFFFFF"
    text="X"
    onClick="HUD_rollCancel" />
</Panel>
