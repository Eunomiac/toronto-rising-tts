<!-- TARGET: ui/player/panel_roll_controls.xml -->
<!-- Agent guidance: .dev/TTS_BUNDLING_SETUP.md (generator); .dev/HUDs & Overlays/Player HUD Overview.md (map panels). -->
<!-- Visibility: TTS `UI.show` / `UI.hide` play showAnimation/hideAnimation (tts-api UI API/Attributes.md). -->

<Panel id="rollControl_root_@@color@@" class="rollControl_root" visibility="@@color@@" active="false">
<!-- ACTIVATE for open roll -->
  <VerticalLayout class="rollControl_container">
    <HorizontalLayout class="rollControl_headerContainer">
      <Text id="rollControl_rollType_@@color@@" class="roll_text roll_header_text roll_type_text" text="" />
      <!-- The type of roll, in title case, e.g. "Standard Roll", "Frenzy Roll" -->
      <Panel class="rollControl_spacer" />
      <Text id="rollControl_rollInstructions_@@color@@" class="roll_text roll_body_text" text="" />
      <!-- Instructions for next step, in title case, e.g. "Result Ready — 'CONFIRM' When Done" -->
    </HorizontalLayout>

    <HorizontalLayout class="rollControl_rollAssembly">
      <HorizontalLayout class="rollControl_dicePoolDisplay">
        <Text id="rollControl_oblivRouseDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_oblivRouseDiceText" text=""/>
        <!-- One '◆' character per Oblivion Rouse Die in pool (empty string for none) -->
        <Text id="rollControl_rouseDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_rouseDiceText" text="" />
        <!-- One '◆' character per (non-Blood Surge) Rouse Die in pool (empty string for none) -->
        <Text id="rollControl_bloodSurgeRouseDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_bloodSurgeRouseDiceText" text="" />
        <!-- One '◆' character per Blood Surge Rouse Die in pool (empty string for none) -->
        <Panel class="rollControl_spacer rollControl_rouseSpacer" />
        <HorizontalLayout class="rollControl_standardDicePoolDisplay">
          <Text id="rollControl_hungerDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_hungerDiceText" text=""/>
          <!-- One '◆' character per Hunger Die in pool (empty string for none) -->
          <Text id="rollControl_rageDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_rageDiceText" text=""/>
          <!-- One '◆' character per Rage Die in pool (empty string for none) -->
          <Text id="rollControl_standardDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_standardDiceText" text=""/>
          <!-- One '◆' character per Normal Die in pool (empty string for none) -->
          <Text id="rollControl_wwDice_@@color@@" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_wwDiceText" text=""/>
          <!-- One '◆' character per Werewolf Die in pool (empty string for none) -->
        </HorizontalLayout>
        <!-- A whitespace should be introduced after every fifth die, TOTAL, displayed in the 'standardDicePoolDisplay'-->
        <Panel class="rollControl_spacer" />
      </HorizontalLayout>
    </HorizontalLayout>

    <HorizontalLayout class="rollControl_diceImageDisplayStrip">
      <HorizontalLayout id="rollControl_rouseDiceContainer_@@color@@" class="rollControl_diceContainer rollControl_diceContainer_small" active="false">
      <!-- ACTIVATE if Oblivion-Rouse or Rouse Dice in pool, DEACTIVATE if not -->
        <Image id="rollControl_rouseDie_1_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_rouseDie_2_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_rouseDie_3_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_rouseDie_4_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_rouseDie_5_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
      </HorizontalLayout>

      <HorizontalLayout id="rollControl_bloodSurgeRouseDiceContainer_@@color@@" class="rollControl_diceContainer rollControl_diceContainer_small" active="false">
      <!-- ACTIVATE if Blood Surge Rouse Dice in pool, DEACTIVATE if not -->
        <Image id="rollControl_bloodSurgeRouseDie_1_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_bloodSurgeRouseDie_2_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_bloodSurgeRouseDie_3_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_bloodSurgeRouseDie_4_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_bloodSurgeRouseDie_5_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
      </HorizontalLayout>

      <HorizontalLayout class="rollControl_diceContainer">
        <Image id="rollControl_die_1_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_2_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_3_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_4_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_5_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_6_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_7_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_8_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_9_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_10_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_11_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_12_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_13_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_14_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
        <Image id="rollControl_die_15_@@color@@" class="rollControl_die" active="false" />
        <!-- ACTIVATE and set image, DEACTIVATE if no die -->
      </HorizontalLayout>
    </HorizontalLayout>

    <HorizontalLayout id="rollControl_successesContainer_@@color@@" class="rollControl_successesContainer" active="false">
    <!-- ACTIVATE when successes are available to report, DEACTIVATE otherwise -->
      <Panel class="rollControl_spacer" />
      <Text id="rollControl_successes_@@color@@" class="roll_text rollControl_successes" text="" />
      <!-- Number of successes rolled, as a number -->
      <Text id="rollControl_successesPhrase_@@color@@" class="roll_text rollControl_successesPhrase" text="" />
      <!-- Set to "Success" if 1 success, "Successes" otherwise  -->
      <HorizontalLayout id="rollControl_difficultyDisplay_@@color@@" class="rollControl_difficultyDisplayContainer" spacing = "15" active="true">
      <!-- DEACTIVATE if no Difficulty -->
        <Text class="roll_text rollControl_difficultyVS" text="vs. Difficulty" />
        <Text id="rollControl_difficulty_@@color@@" class="roll_text rollControl_difficulty" text="" />
        <!-- Difficulty, as a number -->
      </HorizontalLayout>
      <Panel class="rollControl_spacer" />
    </HorizontalLayout>

    <HorizontalLayout id="rollControl_resultDisplayContainer_@@color@@" class="rollControl_resultDisplayContainer" active="false">
    <!-- ACTIVATE if a result is available to display, deactivate otherwise -->
      <Panel class="rollControl_spacer" />
      <Text id="rollControl_resultDisplay_@@color@@" class="roll_text rollControl_resultDisplay" text="" />
      <!-- Result in ALL CAPS followed by margin (if any) as a signed integer. Class should be set via `UI.setClass` to "`roll_text rollControl_resultDisplay rollControl_result<resultClass>`". Margin should use actual minus sign for negative numbers, i.e. '−' not '-'  -->
      <Panel class="rollControl_spacer" />
    </HorizontalLayout>

    <Panel class="rollControl_verticalSpacer" />

    <HorizontalLayout class="rollControl_buttonContainer">      <!-- Activate/Deactivate buttons as they become available to the player -->
      <Button id="rollControl_btnRoll_@@color@@" class="rollControl_button rollControl_btnRoll" onClick="HUD_rollRollButton" text="ROLL" active="true" />
      <Button id="rollControl_btnHalf_@@color@@" class="rollControl_button rollControl_btnHalf" onClick="HUD_rollTakeHalf" text="TAKE HALF" active="false" />
      <Button id="rollControl_btnWP_@@color@@" class="rollControl_button rollControl_btnWP" onClick="HUD_rollSpendWP" text="SPEND WP" active="false" />
      <Button id="rollControl_btnConfirm_@@color@@" class="rollControl_button rollControl_btnConfirm" onClick="HUD_rollConfirm" text="CONFIRM" active="false" />
      <Button id="rollControl_btnOblivHunger_@@color@@" class="rollControl_button rollControl_btnOblivHunger" onClick="HUD_rollConfirmOblivChoice" text="HUNGER" active="false" />
      <Button id="rollControl_btnOblivStain_@@color@@" class="rollControl_button rollControl_btnOblivStain" onClick="HUD_rollConfirmOblivChoice" text="STAIN" active="false" />
      <Button id="rollControl_btnBrutalFail_@@color@@" class="rollControl_button rollControl_btnBrutalFail" onClick="HUD_rollConfirmBrutalChoice" text="FAILURE" active="false" />
      <Button id="rollControl_btnBrutalViolence_@@color@@" class="rollControl_button rollControl_btnBrutalViolence" onClick="HUD_rollConfirmBrutalChoice" text="VIOLENCE" active="false" />
      <Button id="rollControl_btnCancel_@@color@@" class="rollControl_button rollControl_btnCancel" onClick="HUD_rollCancel" text="CANCEL" active="true" />
    </HorizontalLayout>

  </VerticalLayout>

</Panel>
