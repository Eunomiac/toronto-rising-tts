<!-- KD Debug Panel (Black) -->
<!-- Agent guidance: dev/EXTRACTABLE_FUNCTIONS_INDEX.md; dev/TESTING.md. -->
<!-- Debug buttons and state display panel -->

<HorizontalLayout class="kd_buttonPanel kd_debugButtonPanel" visibility="Black">
  <Button id="kd_toggleElem_kd_debugControls" class="kd_button kd_buttonPanelToggle">&#9658;</Button>
  <VerticalLayout id="kd_debugControls" class="kd_buttonBar" active="False">
    <Button id="kd_debug_logState" class="kd_button">Log State</Button>
    <Button id="kd_debug_resetState" class="kd_button">Reset State</Button>
    <Button id="kd_debug_resetPlayers" class="kd_button">Reset Players</Button>
    <Text class="spacer_10"></Text>
    <Button id="kd_debug_setArrows" class="kd_button">Light Arrows</Button>
    <Button id="kd_debug_primeLights" class="kd_button">Reset Lights</Button>
    <Button id="kd_debug_setLight" class="kd_button">Set Light</Button>
    <Text class="spacer_10"></Text>
    <Button id="kd_debug_testFunc1" class="kd_button">Test Func 1</Button>
    <Button id="kd_debug_testFunc2" class="kd_button">Test Func 2</Button>
    <Button id="kd_debug_testFunc3" class="kd_button">Test Func 3</Button>
    <Button id="kd_debug_testFunc4" class="kd_button">Test Func 4</Button>
    <Button id="kd_debug_testFunc5" class="kd_button">Test Func 5</Button>
    <Text class="spacer_10"></Text>
    <Button id="kd_prompt_assignHouseName" class="kd_button">Name House</Button>
    <Text class="spacer_5"></Text>
    <Button id="kd_prompt_simClick" class="kd_button">Sim Click</Button>
  </VerticalLayout>
</HorizontalLayout>

<HorizontalLayout class="kd_debugDisplayPanel" visibility="Black">
  <Button id="kd_toggleElem_kd_stateDisplayPanel" class="kd_button kd_buttonPanelToggle">&#9658;</Button>
  <Panel id="kd_stateDisplayPanel" class="kd_codeDisplayPanel" active="False">
    <Text id="kd_stateDisplay" class="kd_codeDisplay"></Text>
  </Panel>
</HorizontalLayout>
