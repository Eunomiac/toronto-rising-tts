<!-- KD Admin Panel (Black) -->
<!-- Game flow controls: preflight, session init, game status, admin tools -->

<VerticalLayout class="kd_adminContainer" visibility="Black">
  <HorizontalLayout id="kd_preflightDisplay" class="kd_gameStatusDisplay" active="False">
    <Text class="kd_gameStatusDisplay" color="White">Initialize:</Text>
    <Button id="kd_initPreflight" class="kd_button">Preflight</Button>
  </HorizontalLayout>

  <HorizontalLayout id="kd_sessionInitDisplay" class="kd_gameStatusDisplay" active="False">
    <Text class="kd_gameStatusDisplay" color="White">Initialize:</Text>
    <Button id="kd_initSession" class="kd_button">Session</Button>
  </HorizontalLayout>

  <HorizontalLayout id="kd_gameStatusDisplay" class="kd_gameStatusDisplay" active="False">
    <Text class="kd_gameStatusDisplay" color="White">Current:</Text>
    <Text id="kd_currentGameModeDisplay" class="kd_gameStatusDisplay"></Text>
    <HorizontalLayout id="kd_currentGamePhaseContainer" class="kd_gameStatusDisplay" active="False">
      <Text class="kd_gameStatusDisplay" color="White"> &#9830; </Text>
      <Text id="kd_currentGamePhaseDisplay" class="kd_gameStatusDisplay"></Text>
    </HorizontalLayout>
    <Button id="kd_advanceGamePhase" class="kd_button">Advance To &#9658;</Button>
    <Text id="kd_nextGameModeDisplay" class="kd_gameStatusDisplay"></Text>
    <HorizontalLayout id="kd_nextGamePhaseContainer" class="kd_gameStatusDisplay" active="False">
      <Text class="kd_gameStatusDisplay" color="White"> &#9830; </Text>
      <Text id="kd_nextGamePhaseDisplay" class="kd_gameStatusDisplay"></Text>
    </HorizontalLayout>
  </HorizontalLayout>

  <HorizontalLayout class="kd_buttonPanel">
    <Button id="kd_toggleElem_kd_adminControls" class="kd_button kd_buttonPanelToggle">&#9658;</Button>
    <VerticalLayout id="kd_adminControls" class="kd_buttonBar" active="False">
      <Button id="kd_clearPlayers" class="kd_button">Clear Players</Button>
      <Button id="kd_resetTable" class="kd_button">Reset Table</Button>
      <Text class="spacer_10"></Text>
      <Button id="kd_setChronicleType" class="kd_button">Set Chronicle</Button>
    </VerticalLayout>
  </HorizontalLayout>
</VerticalLayout>
