<!-- King's Dilemma Area-Specific Defaults -->
<!-- Agent guidance: dev/EXTRACTABLE_FUNCTIONS_INDEX.md; dev/tts-api/UI API/Defaults.md. -->
<!-- All classes use kd_ prefix to avoid collisions with Heritage/shared classes. -->

<!-- ========================== -->
<!-- Generic KD Text Styles     -->
<!-- ========================== -->
<Defaults>
  <Text class="kd_header"
    font="Fonts/Title"
    rectAlignment="UpperCenter"
    fontSize="60"
    alignment="UpperCenter" />
  <Text class="kd_bold" fontStyle="Bold" />
  <Text class="kd_smallcaps" font="Fonts/FrizSC" />
</Defaults>

<!-- ========================== -->
<!-- Generic KD Button Styles   -->
<!-- ========================== -->
<Defaults>
  <Button class="kd_button"
    colors="#888888|#AAAAAA|#FFFFFF|rgba(0.5, 0.5, 0.5, 0.5)"
    height="25"
    width="100"
    preferredHeight="25"
    preferredWidth="100"
    flexibleWidth="0"
    flexibleHeight="0"
    padding="0 0 0 0"
    onClick="KD_Click"
    textAlignment="MiddleCenter"
    rectAlignment="UpperLeft"
    font="Fonts/FrizB" />

  <Button class="kd_buttonPanelToggle"
    preferredWidth="25"
    offsetXY="50 -15" />
</Defaults>

<!-- ========================== -->
<!-- Admin Panel Classes        -->
<!-- ========================== -->
<Defaults>
  <VerticalLayout class="kd_adminContainer"
    width="800"
    spacing="0"
    padding="5 0 0 0"
    rectAlignment="UpperLeft"
    offsetXY="40 -10" />

  <HorizontalLayout class="kd_gameStatusDisplay"
    childAlignment="MiddleLeft"
    preferredHeight="25"
    flexibleHeight="0"
    spacing="10"
    padding="0 0 0 0" />

  <Text class="kd_gameStatusDisplay"
    color="Yellow"
    alignment="MiddleCenter"
    fontSize="14"
    outline="Black"
    preferredHeight="25"
    font="Fonts/FrizB" />

  <HorizontalLayout class="kd_buttonPanel"
    padding="0 0 0 0"
    spacing="0" />

  <VerticalLayout class="kd_buttonBar"
    spacing="3"
    padding="0 0 0 0"
    childAlignment="UpperLeft" />
</Defaults>

<!-- ========================== -->
<!-- Debug Panel Classes        -->
<!-- ========================== -->
<Defaults>
  <HorizontalLayout class="kd_debugDisplayPanel"
    rectAlignment="UpperRight"
    height="1500"
    width="250" />

  <HorizontalLayout class="kd_debugButtonPanel"
    offsetXY="0 -350" />

  <Panel class="kd_codeDisplayPanel"
    color="rgba(0, 0, 0, 0.5)"
    padding="5 5 5 5"
    height="1500"
    width="250" />

  <Text class="kd_codeDisplay"
    fontSize="8"
    alignment="UpperLeft" />
</Defaults>

<!-- ========================== -->
<!-- Turn HUD Classes           -->
<!-- ========================== -->
<Defaults>
  <Panel class="kd_turnContainer"
    height="250"
    width="2000"
    rectAlignment="LowerCenter"
    offsetXY="0 0"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="0.5" />

  <Panel class="kd_turnPanel"
    preferredHeight="60" flexibleHeight="0"
    preferredWidth="300" flexibleWidth="0"
    showAnimation=""
    hideAnimation=""
    animationDuration="0" />

  <Image class="kd_turnBorderTop"
    ignoreLayout="true"
    height="270"
    width="2000"
    rectAlignment="UpperCenter"
    offsetXY="0 20"
    image="splash-border-above" />

  <Text class="kd_turnText"
    alignment="MiddleCenter"
    font="Fonts/Friz"
    rectAlignment="MiddleCenter"
    resizeTextForBestFit="False"
    fontSize="60"
    color="rgba(1, 1, 1, 0.5)"
    shadow="rgba(0, 0, 0, 1)"
    shadowDistance="1 -1"
    verticalOverflow="Overflow"
    horizontalOverflow="Overflow"
    showAnimation=""
    hideAnimation=""
    animationDuration="0" />

  <VerticalLayout class="kd_turnLayout"
    height="400"
    width="2000"
    offsetXY="0 0"
    rectAlignment="UpperCenter"
    childAlignment="MiddleCenter"
    childForceExpandWidth="true"
    childForceExpandHeight="false"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="0.5" />

  <HorizontalLayout class="kd_turnRow"
    preferredHeight="60" flexibleHeight="0"
    padding="10"
    spacing="0"
    childAlignment="UpperCenter"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <Image class="kd_turnButton"
    height="60"
    width="300"
    color="rgba(0.6, 0.47, 0, 0.5)"
    rectAlignment="MiddleCenter"
    image="button-bg"
    raycastTarget="True"
    onMouseDown="KD_Turn_Click"
    onMouseEnter="KD_Turn_HoverOn"
    onMouseExit="KD_Turn_HoverOff" />

  <Image class="kd_turnButtonAye"
    color="rgba(0, 1, 1, 0.5)" />
  <Image class="kd_turnButtonNay"
    color="rgba(1, 0, 0, 0.5)" />

  <Image class="kd_turnIcon"
    height="250"
    width="250"
    scale="0.16 0.16 0.16"
    outline="rgba(0, 0, 0, 1)"
    outlineSize="10"
    color="rgba(1, 0.87, 0, 0.5)"
    rectAlignment="MiddleCenter"
    offsetXY="90 0" />

  <Image class="kd_turnModeratorIcon"
    scale="0.25 0.25 0.25" />

  <Text class="kd_turnButtonText"
    alignment="MiddleCenter"
    font="Fonts/CinzelBB"
    fontSize="25" />

  <Text class="kd_turnTextWithIcon"
    alignment="UpperCenter"
    offsetXY="-15 5" />

  <Text class="kd_turnSmallText"
    alignment="LowerCenter"
    font="Fonts/FrizI"
    fontSize="18"
    offsetXY="-15 -5" />
</Defaults>

<!-- ========================== -->
<!-- Splash Screen Classes      -->
<!-- ========================== -->
<Defaults>
  <Panel class="kd_splashPanel"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="0.5"
    childForceExpandHeight="false"
    childForceExpandWidth="false"
    childAlignment="MiddleCenter"
    padding="5 5 5 5" />

  <VerticalLayout class="kd_splashRoot"
    spacing="0"
    childAlignment="UpperCenter"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    childForceExpandHeight="false"
    childForceExpandWidth="false"
    preferredWidth="650" flexibleWidth="0" minWidth="650"
    padding="0 0 65 65"
    animationDuration="0.5" />

  <VerticalLayout class="kd_splashContent"
    preferredWidth="650" flexibleWidth="0" minWidth="650"
    childAlignment="UpperCenter" />

  <VerticalLayout class="kd_splashImageContainer"
    ignoreLayout="true"
    childAlignment="UpperCenter"
    position="MiddleCenter"
    spacing="-1"
    height="100%"
    width="100%" />

  <Image class="kd_splashBorderTop"
    preferredWidth="650" flexibleWidth="0" minWidth="650"
    preferredHeight="65" flexibleHeight="0" minHeight="65"
    image="splash-border-above" />

  <Image class="kd_splashBorderBottom"
    preferredWidth="650" flexibleWidth="0" minWidth="650"
    preferredHeight="65" flexibleHeight="0" minHeight="65"
    image="splash-border-under" />

  <Image class="kd_splashBg"
    preferredWidth="1000" flexibleWidth="0" minWidth="1000"
    preserveAspect="false"
    image="splash-bg" />

  <Text class="kd_splashText"
    alignment="MiddleCenter"
    font="Fonts/Friz"
    resizeTextForBestFit="false"
    showAnimation=""
    hideAnimation=""
    animationDuration="0"
    color="rgba(1,1,1,1)"
    verticalOverflow="Overflow"
    horizontalOverflow="Wrap"
    fontSize="50"
    preferredHeight="80" minHeight="80" flexibleHeight="0"
    preferredWidth="5000" minWidth="5000" flexibleWidth="0"
    scale="1 1 1" />
</Defaults>

<Defaults>
  <Panel class="kd_splashScreen"
    offsetXY="0 100"
    color="rgba(0, 0, 0, 0.95)"
    scale="1.75 1.75 1.75" />

  <Text class="kd_splashIntro"
    fontSize="87"
    preferredHeight="40" minHeight="40" flexibleHeight="0"
    scale="0.57 0.57 0.57"
    font="Fonts/FrizSC" />

  <Text class="kd_splashIntroSub"
    fontSize="30"
    scale="0.57 0.57 0.57"
    preferredHeight="20" minHeight="20" flexibleHeight="0" />
</Defaults>

<Defaults>
  <Panel class="kd_splashHud"
    offsetXY="0 325" />
</Defaults>

<!-- ========================== -->
<!-- Splash Query Classes       -->
<!-- ========================== -->
<Defaults>
  <Panel class="kd_splashQuery"
    offsetXY="-400 350"
    scale="0.6 0.6 0.6" />

  <HorizontalLayout class="kd_splashQueryRow"
    preferredHeight="110" flexibleHeight="0"
    padding="10"
    spacing="20"
    childAlignment="UpperCenter"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <Panel class="kd_splashOption"
    preferredHeight="80" flexibleHeight="0"
    preferredWidth="400" flexibleWidth="0" />

  <Image class="kd_splashOptionImage"
    preserveAspect="false"
    preferredHeight="80" flexibleHeight="0"
    preferredWidth="400" flexibleWidth="0"
    color="#FFD70011"
    image="button-bg"
    raycastTarget="true"
    onMouseDown="KD_Click"
    onMouseEnter="KD_HoverOn"
    onMouseExit="KD_HoverOff" />

  <Text class="kd_playerPrompt"
    color="#FFFFFF"
    font="Fonts/CinzelBB"
    alignment="UpperCenter"
    shadow="#000000"
    shadowDistance="2 -2"
    fontSize="70" />

  <Text class="kd_splashOptionText"
    color="#FFFFFF44"
    alignment="MiddleCenter"
    font="Fonts/CinzelBB"
    fontSize="25" />

  <Text class="kd_splashQueryPrompt"
    fontSize="40" />
</Defaults>

<!-- ========================== -->
<!-- House Selection Classes    -->
<!-- ========================== -->
<Defaults>
  <Panel class="kd_houseSelectionContainer"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="1" />

  <GridLayout class="kd_houseSelectionGrid"
    width="1260"
    height="580"
    offsetXY="0 50"
    spacing="20 20"
    cellSize="300 180"
    childForceExpandWidth="False"
    childForceExpandHeight="False"
    constraintCount="4" />

  <Text class="kd_houseSelectionHeader"
    offsetXY="0 -100" />

  <Image class="kd_houseFlag"
    color="rgba(0.5, 0.5, 0.5, 1)"
    outlineSize="50" />

  <Image class="kd_houseHover"
    color="rgba(0, 0, 0, 0)"
    raycastTarget="True"
    onMouseDown="KD_Click"
    onMouseEnter="KD_HoverOn"
    onMouseExit="KD_HoverOff" />

  <Panel class="kd_houseInfo"
    rectAlignment="LowerCenter"
    offsetXY="0 25"
    height="250"
    width="750" />

  <Image class="kd_houseInfoImage"
    active="False"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="0.5" />
</Defaults>

<!-- ========================== -->
<!-- Content Fetcher Classes    -->
<!-- ========================== -->
<Defaults>
  <Panel class="kd_fetcherQuery"
    height="100%"
    width="100%"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    animationDuration="0.5"
    childForceExpandHeight="false"
    childAlignment="LowerCenter"
    padding="5 5 5 5"
    offsetXY="0 100" />

  <VerticalLayout class="kd_fetcherLayout"
    childAlignment="UpperCenter" />

  <Image class="kd_fetcherBorderTop"
    preferredHeight="100" flexibleHeight="0" minHeight="100"
    image="splash-border-above" />

  <Image class="kd_fetcherBorderBottom"
    ignoreLayout="true"
    height="100"
    rectAlignment="LowerCenter"
    offsetXY="0 -80"
    preferredHeight="100" flexibleHeight="0" minHeight="100"
    image="splash-border-under" />

  <Image class="kd_fetcherBg"
    ignoreLayout="true"
    preserveAspect="false"
    height="100%"
    width="150%"
    image="splash-bg" />

  <Text class="kd_fetcherText"
    alignment="MiddleCenter"
    font="Fonts/Friz"
    resizeTextForBestFit="false"
    fontSize="40"
    showAnimation=""
    hideAnimation=""
    animationDuration="0"
    preferredWidth="1000" minWidth="1000"
    color="rgba(1,1,1,1)"
    shadow="rgba(0,0,0,1)"
    shadowDistance="1 -1"
    verticalOverflow="Overflow"
    horizontalOverflow="Wrap" />

  <InputField class="kd_fetcherInput"
    colors="#FFFFFF00|#FFFFFF00|#C8C8C800|#BBBBBB00"
    lineType="SingleLine"
    characterValidation="Alphanumeric"
    characterLimit="5"
    font="Fonts/FrizB"
    alignment="MiddleCenter"
    fontSize="70"
    preferredHeight="125" flexibleHeight="0"
    preferredWidth="250" flexibleWidth="0"
    textColor="#000000FF"
    caretColor="#00000000"
    caretWidth="0"
    placeholder=" "
    scale="0.8 1 1" />

  <InputField class="kd_fetcherSticker"
    onEndEdit="KD_Fetcher_Sticker" />
  <InputField class="kd_fetcherEnvelope"
    onEndEdit="KD_Fetcher_Envelope" />

  <Image class="kd_fetcherInputDecor"
    ignoreLayout="true"
    rectAlignment="LowerCenter"
    height="125"
    width="200"
    offsetXY="0 15"
    scale="1 1 1" />

  <Image class="kd_fetcherStickerBg" image="fetch-sticker-bg" color="#FFFFFF33" />
  <Image class="kd_fetcherStickerBorder" image="fetch-sticker-border" />
  <Image class="kd_fetcherStickerIcon" image="fetch-sticker-icon" />
  <Image class="kd_fetcherEnvelopeBg" image="fetch-envelope-bg" color="#FFFFFF33" />
  <Image class="kd_fetcherEnvelopeBorder" image="fetch-envelope-border" />
  <Image class="kd_fetcherEnvelopeIcon" image="fetch-envelope-icon" />
</Defaults>
