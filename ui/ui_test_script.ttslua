---@diagnostic disable: undefined-global

local M = {}

local PIXELS_PER_UNIT = 115
local FACE = "top"
local FACE_SURFACE_OFFSET = 0.05
local FACE_ROTATION = "90 0 0"
local DEBUG = true

local function asPositiveNumber(value, fallback)
  local numberValue = tonumber(value)
  if numberValue == nil or numberValue <= 0 then
    return fallback
  end
  return numberValue
end

local function getFaceDimensions(bounds, faceName)
  if faceName == "top" then
    return asPositiveNumber(bounds.x, 1), asPositiveNumber(bounds.z, 1)
  end
  if faceName == "front" then
    return asPositiveNumber(bounds.x, 1), asPositiveNumber(bounds.y, 1)
  end
  if faceName == "right" then
    return asPositiveNumber(bounds.z, 1), asPositiveNumber(bounds.y, 1)
  end

  return asPositiveNumber(bounds.x, 1), asPositiveNumber(bounds.z, 1)
end

local function getFacePosition(bounds, faceName)
  if faceName == "top" then
    return string.format("0 %.4f 0", (asPositiveNumber(bounds.y, 1) / 2) + FACE_SURFACE_OFFSET)
  end
  if faceName == "front" then
    return string.format("0 0 %.4f", (asPositiveNumber(bounds.z, 1) / 2) + FACE_SURFACE_OFFSET)
  end
  if faceName == "right" then
    return string.format("%.4f 0 0", (asPositiveNumber(bounds.x, 1) / 2) + FACE_SURFACE_OFFSET)
  end

  return "0 0 0"
end

local function applyPaperBoundsToUi(obj)
  if obj == nil or obj.UI == nil then
    return
  end

  if obj.UI.loading then
    Wait.time(function()
      applyPaperBoundsToUi(obj)
    end, 0.1)
    return
  end

  local bounds = obj.getBoundsNormalized()
  if bounds == nil then
    return
  end

  local faceWidthUnits, faceHeightUnits = getFaceDimensions(bounds, FACE)
  local widthPixels = math.max(1, math.floor(faceWidthUnits * PIXELS_PER_UNIT))
  local heightPixels = math.max(1, math.floor(faceHeightUnits * PIXELS_PER_UNIT))
  local panelPosition = getFacePosition(bounds, FACE)

  obj.UI.setAttributes("paper_root", {
    width = tostring(widthPixels),
    height = tostring(heightPixels),
    position = panelPosition,
    rotation = FACE_ROTATION,
    rectAlignment = "MiddleCenter",
    pivot = "0.5 0.5"
  })

  if DEBUG then
    print(string.format(
      "[TABLE B3 XML TEST] face=%s bounds=(%.3f, %.3f, %.3f) panel=%dx%d pos=%s",
      FACE,
      asPositiveNumber(bounds.x, 0),
      asPositiveNumber(bounds.y, 0),
      asPositiveNumber(bounds.z, 0),
      widthPixels,
      heightPixels,
      panelPosition
    ))
  end
end

function M.onLoad(obj)
  if obj == nil then
    return
  end

  obj.interactable = false
  obj.setInvisibleTo({"Brown", "Orange", "Pink", "Purple", "Red", "White", "Grey"})

  Wait.time(function()
    applyPaperBoundsToUi(obj)
  end, 0.2)
end

return M
