<!-- Main HUD - VTM5E Module -->
<!-- Agent guidance: dev/TTS_BUNDLING_SETUP.md (bundling + XML templates); dev/HUD_FUNCTIONS.md; dev/HUDs & Overlays/Player HUD Overview.md; dev/tts-api/UI API/ (XML elements). -->
<!-- Root bundle file; no layout applied here. Include order matters for TTS defaults. -->
<!-- The TTS Tools extension bundles when using "Save and Play"; loaded via UI.setXml() -->

<!-- 1. Tag-based defaults (include first); includes are relative to ui/ -->
<Include src="defaults_tags" />

<!-- 2. General shared classes -->
<Include src="defaults_classes" />

<!-- 3. Storyteller HUD (Black): admin panel + sidebar + camera defaults -->
<Panel id="HUD_PANEL_BLACK" class="hud_root_panel" visibility="Black">
  <!-- 3a. Storyteller HUD defaults -->
  <Include src="storyteller/hud_storyteller_defaults" />
  <Include src="storyteller/panel_pcs_defaults" />

  <!-- 3b. Storyteller HUD -->
  <Include src="storyteller/hud_storyteller" />
</Panel>

<!-- 4. Player HUD (per-color panels) -->
<Panel id="HUD_PANEL_PLAYER" class="hud_root_panel">

  <!-- Defaults -->
  <Include src="player/panel_overlays_defaults.xml" />
  <Include src="player/panel_right_sidebar_defaults.xml" />
  <Include src="player/panel_map_core_defaults.xml" />

  <!-- 4a. Player HUD Overlays -->
  <Include src="player/panel_overlays.xml" />

  <!-- 4a. Player HUD Right Sidebar -->

  <!-- Map panels (generated per player color) -->
  <Include src="player/panel_map_core.xml" />

  <!-- Right sidebar buttons (generated per player color) -->
  <Include src="player/panel_right_sidebar_buttons.xml" />

  <!-- Reference layer (generated per player color) -->
  <Include src="player/panel_right_sidebar_referenceLayer.xml" />


</Panel>
