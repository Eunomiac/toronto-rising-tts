<!-- General Shared Classes -->
<!-- Agent guidance: .dev/TTS_BUNDLING_SETUP.md; .dev/HUDs & Overlays/Player HUD Overview.md; .dev/tts-api/UI API/ (Defaults, Attributes). -->
<!-- Include after defaults_tags; used across storyteller, player, shared. -->

<Defaults>
  <!-- Text Spacers -->
  <Text class="spacer_5" color="clear" fontSize="4" />
  <Text class="spacer_10" color="clear" fontSize="8" />
  <Text class="spacer_15" color="clear" fontSize="16" />
  <Text class="spacer_20" color="clear" fontSize="32" />

  <!-- Panel Styles -->
  <Panel class="panel-base" color="rgba(0, 0, 0, 0.7)" padding="10 10 10 10" />
  <Panel class="panel-dark" color="rgba(0, 0, 0, 0.85)" padding="10 10 10 10" />

  <!-- Button Sizes -->
  <Button class="smallButton"
    minWidth="130"
    preferredWidth="130"
    textColor="#FFFFFF" />

  <Button class="button_icon"
    colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
    textColor="#FFFFFF"
    textAlignment="MiddleCenter"
    fontStyle="Bold"
    ignoreLayout="true"
    padding="0 0 0 0"
    rectAlignment="MiddleLeft"
    fontSize="27"
    height="30"
    width="30" />

  <Button class="button_icon_small"
    scale="0.8" />

  <Button class="red_button_icon"
    colors="#8B0000|#AA0000|#660000|#330000"
  />

  <!-- Debug Panel Styles -->
  <Panel class="debugPanel"
    color="rgba(0,0,0,0.75)"
    height="400"
    width="350"
    padding="5 5 5 5"
    scale="0.75"
    rectAlignment="MiddleLeft"
    offsetXY="250 0" />

  <Text class="debugText"
    preferredWidth="200"
    alignment="UpperLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Hover Button Panel Styles -->


  <Panel class="hover_button_panel_container"
    flexibleWidth="0"
    flexibleHeight="0"
    preferredWidth="150"
    minWidth="150"
    rectAlignment="UpperRight"
  />

  <Panel class="hover_button_panel_container_wide"
    preferredWidth="175"
    minWidth="175"
  />

  <VerticalLayout class="hover_button_panel"
    height="100%"
    spacing="0"
    rectAlignment="UpperLeft"
    childAlignment="UpperLeft"
    childForceExpandHeight="false"
    childForceExpandWidth="false"
  />

  <VerticalLayout class="hover_button_panel_wide" width="175"/>

  <VerticalLayout class="hover_button_panel_right"
    rectAlignment="UpperRight"
    childAlignment="UpperRight"
  />

  <Image class="hover_button_panel_border"
    preferredWidth="150"
    minWidth="150"
    preferredHeight="50"
    minHeight="50"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
  />

  <Image class="hover_button_panel_border_short"
    preferredHeight="30"
    minHeight="30"
  />
  <Image class="hover_button"
    minWidth="150"
    minHeight="25"
    preferredHeight="25"
    preserveAspect="false"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_wide"
    preferredWidth="175"
    minWidth="175"  />

  <Image class="hover_button_thin"
    preferredHeight="20"
    minHeight="20"
    preferredWidth="175"
    minWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_base"
    raycastTarget="true"
  />

  <Image class="hover_button_hover"
    raycastTarget="false"
    color="clear"
  />

  <Image class="hover_button_active"
    raycastTarget="false"
    color="clear"
  />

  <!-- Reminder/Alert Panel Styles -->
  <Panel class="reminderPanel"
    color="Black"
    padding="15 5 5 5"
    scale="0.75"
    outline="#FF0000"
    outlineSize="2 2" />

  <Text class="reminderHeading reminderAction"
    color="#FFFFFF"
    alignment="MiddleLeft"
    outline="#000000"
    outlineSize="1 1"
    flexibleHeight="0" />
  <Text class="reminderAction"
    fontSize="24"
    fontStyle="Bold"
    outline="#550000"
    color="Red" />
  <Text class="reminderHeading"
    fontSize="18"
    fontStyle="Bold"
    outline="#555500"
    color="Yellow" />

  <!-- Image Button Layers (base + overlay for hover highlight pattern) -->
  <Image class="imageButtonBase"
    raycastTarget="true"
    color="rgba(0.5, 0.5, 0.5, 1)" />

  <Image class="imageButtonOverlay"
    color="clear"
    raycastTarget="false" />

  <Image class="imageBorder"
    rectAlignment="MiddleLeft" />

  <!-- Popup Image Styles (hidden fullscreen image popups) -->
  <Image class="popupImage"
    width="90%"
    active="false" />

  <Image class="popupImageNarrow"
    width="60%" />

  <Panel class="popupImageContainer"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- Status Display Styles -->
  <Text class="statusText"
    fontSize="14"
    alignment="MiddleLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statusLabel"
    fontSize="14"
    alignment="MiddleLeft"
    color="#CCCCCC"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Stat Display (Hunger, Willpower, Health - player HUD) -->
  <HorizontalLayout class="statDisplay"
    spacing="10"
    padding="5 5 5 5"
    childAlignment="MiddleLeft"
    childForceExpandWidth="false" />

  <Text class="statLabel"
    fontSize="16"
    alignment="MiddleLeft"
    color="#CCCCCC"
    preferredWidth="100"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statValue"
    fontSize="18"
    alignment="MiddleCenter"
    color="#FFFFFF"
    preferredWidth="50"
    outline="#000000"
    outlineSize="1 1"
    fontStyle="Bold" />

  <!-- Player HUD Container -->
  <Panel class="playerHudPanel"
    width="250"
    height="150"
    color="rgba(0, 0, 0, 0.7)"
    padding="10 10 10 10"
    rectAlignment="UpperRight"
    offsetXY="-10 10" />

  <!-- Stat Display Layout -->
  <VerticalLayout class="playerStats"
    spacing="8"
    padding="5 5 5 5"
    childAlignment="UpperLeft"
    childForceExpandWidth="true" />

  <!-- Roll Results Broadcast Panel -->
  <Panel class="rollBroadcast_root"
    rectAlignment="UpperCenter"
    width = "900"
    height = "500"
    color = "rgba(0.25, 0, 0, 1)"
    outline = "rgba(1, 1, 0, 1)"
    padding = "25 25 25 25"
  />

  <!-- Roll Options Panel Classes -->

  <Panel class="rollOpts_modal"
    visibility="Black|Host"
    active="False"
    rectAlignment="MiddleCenter"
    offsetXY="0 0"
    width="460"
    padding="16 16 16 16"
    childForceExpandHeight="false" />

  <VerticalLayout class="rollOpts_modal_content"
    spacing="10"
    childAlignment="UpperCenter"
    childForceExpandWidth="true"
    color="#1A1A1AE6"
    padding = "10 10 10 10" />

  <Text class="rollOpts_modal_description"
    fontSize="11"
    color="#888888"
    alignment="MiddleCenter" />

  <Text class="rollOpts_modal_title"
   fontSize="18"
   fontStyle="Bold"
   color="#C9A84C"
   alignment="MiddleCenter" />

  <Text class="rollOpts_modal_header"
   fontSize="16"
   fontStyle="Bold"
   color="#CCCCCC"
   alignment="MiddleCenter" />

  <Text class="rollOpts_modal_subheader"
   fontSize="12"
   fontStyle="Bold"
   color="#FFDDCC"
   alignment="MiddleCenter" />

  <HorizontalLayout class="rollOpts_modal_horiz_toggle_container"
    minHeight = "30"
    preferredHeight = "30"
    flexibleHeight = "0"
    childAlignment = "MiddleCenter"
    spacing="4"
    padding="4 0 8 0" />

  <HorizontalLayout class="rollOpts_modal_horiz_input_container"
    minHeight = "30"
    preferredHeight = "30"
    flexibleHeight = "0"
    childAlignment = "MiddleCenter"
    spacing="4"
    padding="4 0 8 0" />

  <Button class="rollOpts_toggle"
    fontSize = "11"
    fontStyle = "Bold" />

  <Button class="rollOpts_toggle_on"
    color = "#00FF00"
    textColor = "#000000" />
  <Button class="rollOpts_toggle_off"
    color = "#999999"
    textColor = "#FFFFFF" />

  <Text class="rollOpts_modal_input_label"
    fontSize="11"
    color="#AAAAAA"
    alignment="MiddleRight" />

  <InputField class="rollOpts_modal_input_field"
    fontSize="13"
    preferredWidth="28"
    minWidth="28"
    flexibleWidth="0"
    minHeight = "28"
    padding = "0 0 0 0"
    fontStyle = "Bold"
    onValueChanged="HUD_rollOptsInputChanged"
    onEndEdit="HUD_rollOptsInputChanged" />

  <HorizontalLayout class="rollOpts_modal_horiz_button_container"
   spacing="12"
   childAlignment="MiddleCenter"
   padding="8 0 0 0" />

  <VerticalLayout class="rollOpts_conditions_column" childForceExpandWidth="true" />

  <Button class="rollOpts_button"
    fontSize="14"
    preferredWidth="120"
    preferredHeight="32"
    textColor = "#FFFFFF"
    fontStyle = "Bold" />
</Defaults>
