<!-- General Shared Classes -->
<!-- Agent guidance: .dev/TTS_BUNDLING_SETUP.md; .dev/HUDs & Overlays/Player HUD Overview.md; .dev/tts-api/UI API/ (Defaults, Attributes). -->
<!-- Include after defaults_tags; used across storyteller, player, shared. -->

<Defaults>
  <!-- Text Spacers -->
  <Text class="spacer_5" color="clear" fontSize="4" />
  <Text class="spacer_10" color="clear" fontSize="8" />
  <Text class="spacer_15" color="clear" fontSize="16" />
  <Text class="spacer_20" color="clear" fontSize="32" />

  <!-- Panel Styles -->
  <Panel class="panel-base" color="rgba(0, 0, 0, 0.7)" padding="10 10 10 10" />
  <Panel class="panel-dark" color="rgba(0, 0, 0, 0.85)" padding="10 10 10 10" />

  <!-- Button Sizes -->
  <Button class="smallButton"
    minWidth="130"
    preferredWidth="130"
    textColor="#FFFFFF" />

  <Button class="button_icon"
    colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
    textColor="#FFFFFF"
    textAlignment="MiddleCenter"
    fontStyle="Bold"
    ignoreLayout="true"
    padding="0 0 0 0"
    rectAlignment="MiddleLeft"
    fontSize="27"
    height="30"
    width="30" />

  <Button class="button_icon_small"
    scale="0.8" />

  <Button class="red_button_icon"
    colors="#8B0000|#AA0000|#660000|#330000"
  />

  <!-- Debug Panel Styles -->
  <Panel class="debugPanel"
    color="rgba(0,0,0,0.75)"
    height="400"
    width="350"
    padding="5 5 5 5"
    scale="0.75"
    rectAlignment="MiddleLeft"
    offsetXY="250 0" />

  <Text class="debugText"
    preferredWidth="200"
    alignment="UpperLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Hover Button Panel Styles -->


  <Panel class="hover_button_panel_container"
    flexibleWidth="0"
    flexibleHeight="0"
    preferredWidth="150"
    minWidth="150"
    rectAlignment="UpperRight"
  />

  <Panel class="hover_button_panel_container_wide"
    preferredWidth="175"
    minWidth="175"
  />

  <VerticalLayout class="hover_button_panel"
    height="100%"
    spacing="0"
    rectAlignment="UpperLeft"
    childAlignment="UpperLeft"
    childForceExpandHeight="false"
    childForceExpandWidth="false"
  />

  <VerticalLayout class="hover_button_panel_wide" width="175"/>

  <VerticalLayout class="hover_button_panel_right"
    rectAlignment="UpperRight"
    childAlignment="UpperRight"
  />

  <Image class="hover_button_panel_border"
    preferredWidth="150"
    minWidth="150"
    preferredHeight="50"
    minHeight="50"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
  />

  <Image class="hover_button_panel_border_short"
    preferredHeight="30"
    minHeight="30"
  />
  <Image class="hover_button"
    minWidth="150"
    minHeight="25"
    preferredHeight="25"
    preserveAspect="false"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_wide"
    preferredWidth="175"
    minWidth="175"  />

  <Image class="hover_button_thin"
    preferredHeight="20"
    minHeight="20"
    preferredWidth="175"
    minWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_base"
    raycastTarget="true"
  />

  <Image class="hover_button_hover"
    raycastTarget="false"
    color="clear"
  />

  <Image class="hover_button_active"
    raycastTarget="false"
    color="clear"
  />

  <!-- Reminder/Alert Panel Styles -->
  <Panel class="reminderPanel"
    color="Black"
    padding="15 5 5 5"
    scale="0.75"
    outline="#FF0000"
    outlineSize="2 2" />

  <Text class="reminderHeading reminderAction"
    color="#FFFFFF"
    alignment="MiddleLeft"
    outline="#000000"
    outlineSize="1 1"
    flexibleHeight="0" />
  <Text class="reminderAction"
    fontSize="24"
    fontStyle="Bold"
    outline="#550000"
    color="Red" />
  <Text class="reminderHeading"
    fontSize="18"
    fontStyle="Bold"
    outline="#555500"
    color="Yellow" />

  <!-- Image Button Layers (base + overlay for hover highlight pattern) -->
  <Image class="imageButtonBase"
    raycastTarget="true"
    color="rgba(0.5, 0.5, 0.5, 1)" />

  <Image class="imageButtonOverlay"
    color="clear"
    raycastTarget="false" />

  <Image class="imageBorder"
    rectAlignment="MiddleLeft" />

  <!-- Popup Image Styles (hidden fullscreen image popups) -->
  <Image class="popupImage"
    width="90%"
    active="false" />

  <Image class="popupImageNarrow"
    width="60%" />

  <Panel class="popupImageContainer"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- Status Display Styles -->
  <Text class="statusText"
    fontSize="14"
    alignment="MiddleLeft"
    color="#FFFFFF"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statusLabel"
    fontSize="14"
    alignment="MiddleLeft"
    color="#CCCCCC"
    outline="#000000"
    outlineSize="1 1" />

  <!-- Stat Display (Hunger, Willpower, Health - player HUD) -->
  <HorizontalLayout class="statDisplay"
    spacing="10"
    padding="5 5 5 5"
    childAlignment="MiddleLeft"
    childForceExpandWidth="false" />

  <Text class="statLabel"
    fontSize="16"
    alignment="MiddleLeft"
    color="#CCCCCC"
    preferredWidth="100"
    outline="#000000"
    outlineSize="1 1" />

  <Text class="statValue"
    fontSize="18"
    alignment="MiddleCenter"
    color="#FFFFFF"
    preferredWidth="50"
    outline="#000000"
    outlineSize="1 1"
    fontStyle="Bold" />

  <!-- Player HUD Container -->
  <Panel class="playerHudPanel"
    width="250"
    height="150"
    color="rgba(0, 0, 0, 0.7)"
    padding="10 10 10 10"
    rectAlignment="UpperRight"
    offsetXY="-10 10" />

  <!-- Stat Display Layout -->
  <VerticalLayout class="playerStats"
    spacing="8"
    padding="5 5 5 5"
    childAlignment="UpperLeft"
    childForceExpandWidth="true" />

  <!-- Roll Results Broadcast Panel -->
  <Panel class="rollBroadcast_root"
    rectAlignment="UpperCenter"
    width = "900"
    height = "500"
    color = "rgba(0.25, 0, 0, 1)"
    outline = "rgba(1, 1, 0, 1)"
    padding = "25 25 25 25"
  />

  <!-- Roll Control Panel -->
    <Panel class="rollControl_root"
    width = "1100"
    height = "500"
    offsetXY = "0 0"
    color = "rgba(0, 0, 0, 1)"
    outline = "rgba(1, 1, 0, 1)"
    padding = "25 25 0 0"
    childForceExpandWidth="true"
    scale = "0.5"
    rectAlignment = "LowerCenter"
    pivot = "0.5 1"
  />

  <VerticalLayout class="rollControl_container"
    childAlignment="UpperCenter"
    childForceExpandHeight="false"
    childForceExpandWidth="true"
    spacing = "-10" />

  <Text class="roll_text"
    fontSize = "32"
    fontStyle = "Bold"
    color = "#FFFFFF"
    />

  <HorizontalLayout class="rollControl_headerContainer"
    childForceExpandWidth = "true"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "0"
    flexibleHeight = "0"
    preferredHeight = "60"
    padding = "0 0 0 0"
  />

  <Text class="roll_header_text"
    color = "#ffdd00"
    fontSize = "36"
    fontStyle = "Bold"
    minHeight = "20"
    alignment = "MiddleLeft" />

  <Text class="roll_body_text"
    alignment = "MiddleRight"
    color = "#ffffff"
    fontSize = "32"
    fontStyle = "Bold"
    minHeight = "20" />

  <HorizontalLayout class="rollControl_rollAssembly"
    childForceExpandWidth = "true"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "0"
    flexibleHeight = "0"
    preferredHeight = "90"
    padding = "50 50 0 0"

  />
  <HorizontalLayout class="rollControl_dicePoolDisplay"
    childForceExpandWidth = "false"
    childForceExpandHeight = "true"
    childAlignment = "UpperLeft"
    preferredWidth = "0"
    spacing = "10"

  />
  <Text class="rollControl_diceText"
    flexibleWidth = "0"
  />

  <Text class="rollControl_diceSymbols"
    flexibleWidth = "0"
    fontSize = "60"
  />
  <Text class="rollControl_oblivRouseDiceText"
    fontSize = "40"
    color="#1900ff"
    outline="#FF0000"
    flexibleHeight = "0"
  />
  <Text class="rollControl_rouseDiceText"
    fontSize = "40"
    color="#550000"
    outline="#FF0000"
    flexibleHeight = "0"
  />
  <Text class="rollControl_bloodSurgeRouseDiceText"
    fontSize = "40"
    color="#550000"
    outline="#FF0000"
    flexibleHeight = "0"
  />
  <Text class="rollControl_hungerDiceText"
    color="#FF0000"
  />
  <Text class="rollControl_standardDiceText"

  />


  <HorizontalLayout class="rollControl_standardDicePoolDisplay"
    rectAlignment="MiddleCenter" ignoreLayout = "true" childForceExpandWidth = "false" childAlignment = "MiddleCenter"
  />

  <HorizontalLayout class="rollControl_difficultyDisplay"
    flexibleWidth = "0"
    spacing = "10"
  />

  <Text class="rollControl_difficultyVS"
    color="#990000"
  />

  <Text class="rollControl_difficulty"
    fontSize = "80"
    color="#FF0000"
  />

  <Panel class="rollControl_spacer" flexibleWidth = "1" />
  <Panel class="rollControl_rouseSpacer" flexibleWidth = "0.15" />
  <Panel class="rollControl_verticalSpacer" flexibleHeight = "0" preferredHeight = "40" />


  <Panel class="diceImageDisplayStrip"
    preferredHeight = "100"
    flexibleHeight = "0"
   />

  <HorizontalLayout class="rollControl_diceImageDisplayStrip"
    spacing = "2"
    childAlignment = "MiddleCenter"
    childForceExpandWidth = "false"
    childForceExpandHeight = "false"
    minHeight = "48"
    preferredHeight = "48"
  />

  <Image class="rollControl_die"
    preferredWidth = "30"
    preserveAspect = "true" />

  <HorizontalLayout class="rollControl_successesContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "20"
    preferredHeight = "90"
    flexibleHeight = "0"
  />

  <Text class="rollControl_successes"
  fontSize = "80"
    flexibleWidth = "0"
  />
  <Text class="rollControl_successesPhrase"
    flexibleWidth = "0"
  />
  <Text class="rollControl_difficultyVS_bottom"
    flexibleWidth = "0"

  />
  <Text class="rollControl_difficulty_bottom"
    flexibleWidth = "0"

  />

  <HorizontalLayout class="rollControl_resultDisplayContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "20"
    preferredHeight = "125"
    flexibleHeight = "0"
  />

  <Text class="rollControl_resultDisplay"
    flexibleWidth = "0"
    fontSize = "100"
  />

  <HorizontalLayout class="rollControl_buttonContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    spacing = "5"
    ignoreLayout = "true"
    rectAlignment = "LowerCenter"
    height = "50"
  />

  <Button class="rollControl_button"
    preferredWidth = "200"
    fontSize = "30"
    fontStyle = "Bold"
  />

  <Button class="rollControl_btnRoll"
    color = "#00FF00"
  />
  <Button class="rollControl_btnHalf"
    color = "#FFDD00"

  />
  <Button class="rollControl_btnWP"
    color = "#86a2ff"

  />
  <Button class="rollControl_btnConfirm"
    color = "#00FF00"
  />
    <Button class="rollControl_btnOblivHunger"
    color = "#330075"
    textColor = "#ff3333"
  />
  <Button class="rollControl_btnOblivStain"
    color = "#330075"
    textColor = "#ffffff"
  />
  <Button class="rollControl_btnBrutalFail"
    color = "#ff8800"
    textColor = "#000000"
  />
  <Button class="rollControl_btnBrutalViolence"
    color = "#990000"
    textColor = "#ff8800"
  />
  <Button class="rollControl_btnCancel"
    color = "#990000"
    textColor = "#FFFFFF"
  />
</Defaults>
