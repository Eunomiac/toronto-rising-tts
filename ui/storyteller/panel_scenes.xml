<!-- Storyteller Scenes: lighting presets, table, seat narrative presence, location keys, clock (see core/storyteller_scenes_panel.ttslua). -->
<Panel id="panel_scenes" active="false">
  <VerticalLayout spacing="6" padding="6 6 6 6" childForceExpandWidth="true" minWidth="600" preferredWidth="600">
    <Text class="hud_storyteller_header">Scenes</Text>
    <Text fontSize="9" color="#AAAAAA">Lighting presets drive `currentScene` / `Scenes.reconcileFromState`. Narrative fields live in `gameState.sessionScene`.</Text>

    <Text class="hud_storyteller_label">Lighting presets</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4">
      <Button id="adminScene_dark" class="hud_storyteller_button" text="DARK" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="adminScene_standard" class="hud_storyteller_button" text="STANDARD" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="adminScene_bright" class="hud_storyteller_button" text="BRIGHT" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Table</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4" childForceExpandWidth="false">
      <Button id="scenes_tbl_TableA" text="Table A" minWidth="72" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB" text="Table B" minWidth="72" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB1" text="B1" minWidth="48" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB2" text="B2" minWidth="48" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB3" text="B3" minWidth="48" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB4" text="B4" minWidth="48" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Seat presence (narrative)</Text>
    <Text fontSize="9" color="#AAAAAA">When `enforceActiveSeatLighting` is on, explicit “off” dims that seat. Neutral leaves layout-only rules.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="3" childForceExpandWidth="false">
      <Button id="scenes_seat_Brown" text="Brown" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Orange" text="Orange" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Red" text="Red" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Pink" text="Pink" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Purple" text="Purple" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="3" childForceExpandWidth="false">
      <Button id="scenes_seat_NPC1" text="NPC1" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC2" text="NPC2" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC3" text="NPC3" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC4" text="NPC4" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Scene location</Text>
    <Text fontSize="9" color="#AAAAAA">Browse districts/sites from `C.Districts` / `C.Sites`. Site browse shows the district bucket matching the District key field plus general sites (no fixed district). Or type keys manually, then Apply.</Text>
    <HorizontalLayout spacing="6" childForceExpandWidth="false" childAlignment="UpperLeft">
      <VerticalLayout spacing="2" minWidth="288" preferredWidth="288" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">District key</Text>
        <InputField id="scenes_districtKey" class="hud_storyteller_input" preferredHeight="30" minHeight="30" minWidth="280" preferredWidth="280" flexibleWidth="0"
          lineType="SingleLine" fontSize="12" textColor="#222222"
          colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)"
          placeholder="DupontByTheCastle" onEndEdit="HUD_scenesPanelInput"></InputField>
      </VerticalLayout>
      <VerticalLayout spacing="2" minWidth="288" preferredWidth="288" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">Site key</Text>
        <InputField id="scenes_siteKey" class="hud_storyteller_input" preferredHeight="30" minHeight="30" minWidth="280" preferredWidth="280" flexibleWidth="0"
          lineType="SingleLine" fontSize="12" textColor="#222222"
          colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)"
          placeholder="CLGrounds" onEndEdit="HUD_scenesPanelInput"></InputField>
      </VerticalLayout>
    </HorizontalLayout>
    <HorizontalLayout spacing="6" childForceExpandWidth="false" childAlignment="UpperLeft">
      <Button id="scenes_openDistrictModal" class="hud_storyteller_button" fontSize="11" minWidth="140" preferredHeight="30" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" text="Browse districts..." onClick="HUD_scenesOpenDistrictModal" />
      <Button id="scenes_openSiteModal" class="hud_storyteller_button" fontSize="11" minWidth="140" preferredHeight="30" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" text="Browse sites..." onClick="HUD_scenesOpenSiteModal" />
    </HorizontalLayout>
    <Button class="hud_storyteller_button" text="Apply location + soundscape" onClick="HUD_scenesApplyLocation" />

    <Text class="hud_storyteller_label">Scene time</Text>
    <Text fontSize="9" color="#AAAAAA">Narrative clock: type numbers in each box (they are fields, not buttons), then click Apply clock.</Text>
    <HorizontalLayout spacing="5" childForceExpandWidth="false" childAlignment="UpperLeft">
      <VerticalLayout spacing="2" flexibleWidth="0"><Text fontSize="9" color="#CCCCCC">Hr</Text><InputField id="scenes_clock_hour" class="hud_storyteller_input" minWidth="46" preferredWidth="46" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" characterValidation="Integer" text="0" onEndEdit="HUD_scenesPanelInput" /></VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0"><Text fontSize="9" color="#CCCCCC">Min</Text><InputField id="scenes_clock_minute" class="hud_storyteller_input" minWidth="46" preferredWidth="46" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" characterValidation="Integer" text="0" onEndEdit="HUD_scenesPanelInput" /></VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0"><Text fontSize="9" color="#CCCCCC">Day</Text><InputField id="scenes_clock_day" class="hud_storyteller_input" minWidth="46" preferredWidth="46" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" characterValidation="Integer" text="1" onEndEdit="HUD_scenesPanelInput" /></VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0"><Text fontSize="9" color="#CCCCCC">Mo</Text><InputField id="scenes_clock_month" class="hud_storyteller_input" minWidth="46" preferredWidth="46" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" characterValidation="Integer" text="1" onEndEdit="HUD_scenesPanelInput" /></VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0"><Text fontSize="9" color="#CCCCCC">Yr</Text><InputField id="scenes_clock_year" class="hud_storyteller_input" minWidth="58" preferredWidth="58" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" characterValidation="Integer" text="2026" onEndEdit="HUD_scenesPanelInput" /></VerticalLayout>
    </HorizontalLayout>
    <Button class="hud_storyteller_button" text="Apply clock" onClick="HUD_scenesApplyClock" />

    <Text class="hud_storyteller_label">Chronicle weather (hourly CSV)</Text>
    <Text fontSize="9" color="#AAAAAA">Uses `TR_Weather.csv` → `lib/tr_weather_schedule.ttslua`. Thunder hour = scheduled one-shots (random strikes). Minute / real-time ticker not used yet.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4" childForceExpandWidth="false">
      <Button id="scenes_chronicle_toggleFollow" text="Follow on clock" minWidth="120" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_chronicle_toggleHold" text="Manual hold" minWidth="100" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_chronicle_applyNow" text="Apply schedule now" minWidth="140" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">NPC role snapshot (stub)</Text>
    <Text fontSize="9" color="#AAAAAA">Stores `sessionScene.npcWorld.lastNote` for future NPC/table tracking hooks.</Text>
    <InputField id="scenes_npcWorldNote" class="hud_storyteller_input" preferredHeight="30" minHeight="30" minWidth="520" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" placeholder="Note (optional)" onEndEdit="HUD_scenesPanelInput" />
    <Button class="hud_storyteller_button" text="Save NPC scene note" onClick="HUD_scenesSaveNpcNote" />
  </VerticalLayout>
</Panel>
