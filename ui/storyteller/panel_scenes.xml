<!-- Storyteller Scenes: lighting presets, table, seat narrative presence, location keys, clock (see core/storyteller_scenes_panel.ttslua). -->
<!-- `active` stays true while parent `panel_scenes_host` controls tab visibility. Width 596 pairs with library column inside 1200px host. -->
<Panel id="panel_scenes" active="true" width="596" minWidth="596" flexibleWidth="0">
  <VerticalLayout class="storyteller_panel_surface" spacing="6" padding="6 6 6 6" childForceExpandWidth="true" minWidth="596" preferredWidth="596" flexibleWidth="0">
    <Text class="hud_storyteller_header">Scenes</Text>
    <Text fontSize="9" color="#AAAAAA">Lighting presets drive `currentScene` / `Scenes.reconcileFromState`. Narrative fields live in `gameState.sessionScene`.</Text>

    <Text class="hud_storyteller_label">Lighting presets</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4">
      <Button id="adminScene_dark" class="hud_storyteller_button" text="DARK" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="adminScene_standard" class="hud_storyteller_button" text="STANDARD" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="adminScene_bright" class="hud_storyteller_button" text="BRIGHT" onClick="HUD_selectAdminLightingScene"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Table</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4" childForceExpandWidth="false">
      <Button id="scenes_tbl_TableA" text="Table A" minWidth="72" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB" text="Table B" minWidth="72" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB0" text="B0" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB1" text="B1" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB2" text="B2" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB3" text="B3" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB4" text="B4" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableB5" text="B5" minWidth="40" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_tbl_TableC" text="Table C" minWidth="72" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Seat presence (narrative)</Text>
    <Text fontSize="9" color="#AAAAAA">Absent seats (grey) turn seat spotlights off. Neutral leaves layout-only presence rules.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="3" childForceExpandWidth="false">
      <Button id="scenes_seat_Brown" text="Brown" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Orange" text="Orange" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Red" text="Red" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Pink" text="Pink" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_Purple" text="Purple" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="3" childForceExpandWidth="false">
      <Button id="scenes_seat_NPC1" text="NPC1" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC2" text="NPC2" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC3" text="NPC3" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="scenes_seat_NPC4" text="NPC4" minWidth="56" onClick="HUD_scenesPanel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text class="hud_storyteller_label">Scene location</Text>
    <Text fontSize="9" color="#AAAAAA">District and site are chosen with the browse modals, then applied to soundscape with the button below.</Text>
    <HorizontalLayout spacing="6" childForceExpandWidth="false" childAlignment="UpperLeft">
      <VerticalLayout spacing="2" minWidth="288" preferredWidth="288" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">District</Text>
        <Text id="scenes_districtNameDisplay" fontSize="12" color="#FFFFFF" preferredHeight="30" minHeight="30" minWidth="280" preferredWidth="280" flexibleWidth="0" text="—" />
      </VerticalLayout>
      <VerticalLayout spacing="2" minWidth="288" preferredWidth="288" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">Site</Text>
        <Text id="scenes_siteNameDisplay" fontSize="12" color="#FFFFFF" preferredHeight="30" minHeight="30" minWidth="280" preferredWidth="280" flexibleWidth="0" text="—" />
      </VerticalLayout>
    </HorizontalLayout>
    <HorizontalLayout spacing="6" childForceExpandWidth="false" childAlignment="UpperLeft">
      <Button id="scenes_openDistrictModal" class="hud_storyteller_button" fontSize="11" minWidth="140" preferredHeight="30" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" text="Browse districts..." onClick="HUD_scenesOpenDistrictModal" />
      <Button id="scenes_openSiteModal" class="hud_storyteller_button" fontSize="11" minWidth="140" preferredHeight="30" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" text="Browse sites..." onClick="HUD_scenesOpenSiteModal" />
    </HorizontalLayout>
    <Button class="hud_storyteller_button" text="Apply location + soundscape" onClick="HUD_scenesApplyLocation" />

    <Text class="hud_storyteller_label">Scene time</Text>
    <Text fontSize="9" color="#AAAAAA">Pick month, enter calendar day and year, time as 12-hour (e.g. 9:05 PM). Set (present day) writes gameState.presentDayClock from the stashed inputs; Apply clock updates the live scene clock. Real-time ON advances the narrative clock each wall second; Speed is a multiplier (1 = one narrative minute per 60 real seconds). Chronicle weather follows the narrative hour when you Apply.</Text>
    <HorizontalLayout spacing="3" childForceExpandWidth="false" childAlignment="UpperLeft">
      <Button id="scenes_month_1" class="hud_storyteller_button" text="Jan" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_2" class="hud_storyteller_button" text="Feb" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_3" class="hud_storyteller_button" text="Mar" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_4" class="hud_storyteller_button" text="Apr" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_5" class="hud_storyteller_button" text="May" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_6" class="hud_storyteller_button" text="Jun" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
    </HorizontalLayout>
    <HorizontalLayout spacing="3" childForceExpandWidth="false" childAlignment="UpperLeft">
      <Button id="scenes_month_7" class="hud_storyteller_button" text="Jul" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_8" class="hud_storyteller_button" text="Aug" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_9" class="hud_storyteller_button" text="Sep" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_10" class="hud_storyteller_button" text="Oct" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_11" class="hud_storyteller_button" text="Nov" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_month_12" class="hud_storyteller_button" text="Dec" minWidth="44" preferredHeight="26" onClick="HUD_scenesMonthPick" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
    </HorizontalLayout>
    <HorizontalLayout spacing="8" childForceExpandWidth="false" childAlignment="UpperLeft">
      <VerticalLayout spacing="2" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">Day</Text>
        <InputField id="scenes_clock_day" class="hud_storyteller_input" minWidth="52" preferredWidth="52" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" characterValidation="Integer" text="1" onValueChanged="HUD_scenesClockFieldChanged" onEndEdit="HUD_scenesClockFieldChanged" />
      </VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">Year</Text>
        <InputField id="scenes_clock_year" class="hud_storyteller_input" minWidth="64" preferredWidth="64" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" characterValidation="Integer" text="2026" onValueChanged="HUD_scenesClockFieldChanged" onEndEdit="HUD_scenesClockFieldChanged" />
      </VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="1">
        <Text fontSize="9" color="#CCCCCC">Time (12h)</Text>
        <InputField id="scenes_clock_time12" class="hud_storyteller_input" minWidth="160" preferredWidth="200" preferredHeight="30" minHeight="30" flexibleWidth="1" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" placeholder="7:05 PM" text="12:00 AM" onValueChanged="HUD_scenesClockFieldChanged" onEndEdit="HUD_scenesClockFieldChanged" />
      </VerticalLayout>
      <VerticalLayout spacing="2" flexibleWidth="0">
        <Text fontSize="9" color="#CCCCCC">Present day</Text>
        <Button id="scenes_clock_setPresentDay" class="hud_storyteller_button" text="Set" minWidth="52" preferredWidth="52" preferredHeight="30" minHeight="30" flexibleWidth="0" fontSize="11" onClick="HUD_scenesSetPresentDayClock" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      </VerticalLayout>
    </HorizontalLayout>
    <HorizontalLayout spacing="8" childForceExpandWidth="false" childAlignment="MiddleLeft">
      <Text fontSize="10" color="#CCCCCC">Real-time clock</Text>
      <Button id="scenes_clock_rtToggle" class="hud_storyteller_button" text="OFF" minWidth="56" preferredHeight="28" onClick="HUD_scenesToggleRealTimeClock" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Text fontSize="10" color="#CCCCCC">Speed (× real time)</Text>
      <InputField id="scenes_clock_speed" class="hud_storyteller_input" minWidth="48" preferredWidth="48" preferredHeight="28" minHeight="28" flexibleWidth="0" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" characterValidation="FloatingPoint" text="1" onValueChanged="HUD_scenesClockFieldChanged" onEndEdit="HUD_scenesClockFieldChanged" />
    </HorizontalLayout>
    <Button id="scenes_clock_apply" class="hud_storyteller_button" text="Apply clock" onClick="HUD_scenesApplyClock" />

    <Text class="hud_storyteller_label">Scene library (constructor)</Text>
    <Text fontSize="9" color="#AAAAAA">Import JSON bundles into `gameState.sceneLibrary` (not activated). Fork snapshots the live `sessionScene` into a new library row and switches the mirror target.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="6" childForceExpandWidth="false">
      <Button id="scenes_ctor_btn_import" class="hud_storyteller_button" text="Import scene…" minWidth="120" onClick="HUD_scenesCtorImportOpen" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="scenes_ctor_btn_fork" class="hud_storyteller_button" text="New scene (fork)…" minWidth="150" onClick="HUD_scenesCtorForkOpen" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
    </HorizontalLayout>

    <Panel id="scenes_ctor_import_modal" active="false" offsetXY="0 0" width="580" minHeight="280" color="rgba(0.05,0.05,0.08,0.95)">
      <VerticalLayout padding="10 10 10 10" spacing="6" childForceExpandWidth="true" childForceExpandHeight="true">
        <Text class="hud_storyteller_label">Import scene (JSON)</Text>
        <Text fontSize="9" color="#AAAAAA">Wrapper: sceneKey, title, sessionScene. Validates here; entry is saved with receivesLiveWrites false (not activated).</Text>
        <InputField id="scenes_ctor_import_json" minHeight="140" preferredHeight="160" flexibleHeight="1" flexibleWidth="1" fontSize="11" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="MultiLineSubmit" characterValidation="None" text="" onValueChanged="HUD_scenesCtorImportJsonChanged" onEndEdit="HUD_scenesCtorImportJsonChanged" />
        <Text id="scenes_ctor_import_err" fontSize="10" color="#AAAAAA" minHeight="40" text="" />
        <HorizontalLayout spacing="8" childForceExpandWidth="false" childAlignment="MiddleLeft">
          <Button id="scenes_ctor_import_confirm" class="hud_storyteller_button" text="Import" minWidth="96" onClick="HUD_scenesCtorImportConfirm" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
          <Button id="scenes_ctor_import_cancel" class="hud_storyteller_button" text="Cancel" minWidth="96" onClick="HUD_scenesCtorImportCancel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
        </HorizontalLayout>
      </VerticalLayout>
    </Panel>

    <Panel id="scenes_ctor_fork_modal" active="false" offsetXY="0 0" width="520" minHeight="200" color="rgba(0.05,0.05,0.08,0.95)">
      <VerticalLayout padding="10 10 10 10" spacing="6" childForceExpandWidth="true">
        <Text class="hud_storyteller_label">Fork scene</Text>
        <Text fontSize="9" color="#AAAAAA">Titles are captured from the fields as you type (TTS InputField contract). Confirm pins the prior active row and starts mirroring the new row.</Text>
        <Text fontSize="9" color="#CCCCCC">New scene title</Text>
        <InputField id="scenes_ctor_fork_title_new" class="hud_storyteller_input" minHeight="28" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" text="" onValueChanged="HUD_scenesCtorForkTitleChanged" onEndEdit="HUD_scenesCtorForkTitleChanged" />
        <Text fontSize="9" color="#CCCCCC">Original scene title (frozen row)</Text>
        <InputField id="scenes_ctor_fork_title_old" class="hud_storyteller_input" minHeight="28" fontSize="12" textColor="#222222" colors="#EEEEEE|#FFFFFF|#DDDDDD|rgba(0.9,0.9,0.9,0.98)" lineType="SingleLine" text="" onValueChanged="HUD_scenesCtorForkTitleChanged" onEndEdit="HUD_scenesCtorForkTitleChanged" />
        <HorizontalLayout spacing="8" childForceExpandWidth="false" childAlignment="MiddleLeft">
          <Button id="scenes_ctor_fork_confirm" class="hud_storyteller_button" text="Fork" minWidth="96" onClick="HUD_scenesCtorForkConfirm" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
          <Button id="scenes_ctor_fork_cancel" class="hud_storyteller_button" text="Cancel" minWidth="96" onClick="HUD_scenesCtorForkCancel" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
        </HorizontalLayout>
      </VerticalLayout>
    </Panel>
  </VerticalLayout>
</Panel>
