<!-- Area NPC row, used to generate panel_npcs.xml

  Placeholders:
    @@area_key@@ — D.areas key (must match wired partials).
    @@npc_key@@ — D.characters key.
    @@npc_name@@ — display name (XML-escaped by the generator).
    @@npc_color_attr@@ — empty, or ` color="#RRGGBB"` from labelColor.
-->

<HorizontalLayout id="npc_occRow_@@area_key@@_@@npc_key@@" class="hud_storyteller_button_row" active="false">
  <Button id="npc_toggle_@@area_key@@_@@npc_key@@" class="button_icon button_icon_small npc_button_icon_small" offsetXY="5 0">⊚</Button>
  <Button id="npc_spot_@@area_key@@_@@npc_key@@" class="button_icon button_icon_small" offsetXY="30 0" onMouseDown="HUD_npcSpotDown" onMouseUp="HUD_npcSpotUp">◎</Button>
  <Text id="npc_occName_@@area_key@@_@@npc_key@@" class="hud_storyteller_label hud_storyteller_row_name npc_row_name"@@npc_color_attr@@>@@npc_name@@</Text>
  <Button id="npc_roll_@@area_key@@_@@npc_key@@" class="button_icon button_icon_small npc_button_icon" offsetXY="-220 0">R</Button>
  <Button id="npc_stats_@@area_key@@_@@npc_key@@" class="button_icon button_icon_small npc_button_icon" offsetXY="-195 0">i</Button>
  <Button id="npc_move_@@area_key@@_@@npc_key@@_centerForward" class="button_icon button_icon_small npc_button_icon" offsetXY="-160 0">▼</Button>
  <Button id="npc_move_@@area_key@@_@@npc_key@@_nearLeft" class="button_icon button_icon_small npc_button_icon" offsetXY="-135 0">◀</Button>
  <Button id="npc_move_@@area_key@@_@@npc_key@@_nearRight" class="button_icon button_icon_small npc_button_icon" offsetXY="-110 0">▶</Button>
  <Button id="npc_move_@@area_key@@_@@npc_key@@_farLeft" class="button_icon button_icon_small npc_button_icon" offsetXY="-85 0">◁</Button>
  <Button id="npc_move_@@area_key@@_@@npc_key@@_farRight" class="button_icon button_icon_small npc_button_icon" offsetXY="-60 0">▷</Button>
  <Button id="npc_remove_@@area_key@@_@@npc_key@@" class="button_icon button_icon_small red_button_icon npc_button_icon" offsetXY="-25 0">✕</Button>
</HorizontalLayout>