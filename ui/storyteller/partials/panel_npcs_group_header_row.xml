<!-- Group header row, used to generate panel_npcs.xml

  Paramters:
    @@group_name@@ - The name of the group (e.g. 'the Regency of the University Chantry')
    @@group_key@@ - The key from the NPCS.groups object that represents the group ('regencyUniversityChantry', 'fiveKeys', 'harpies', 'redFlag').
    @@group_color@@ - Group header bar color as `rgba(r, g, b, a)` with all channels floats in 0..1
        (two significant figures each). Derived from the leader's labelColor with alpha forced to 0.8.
-->

<HorizontalLayout id="npc_groupRow_@@group_key@@" class="hud_storyteller_button_row" active="true" color="@@group_color@@">
  <Button id="npc_groupTwirl_@@group_key@@" class="button_icon" onClick="HUD_npcDispatch">▸</Button>
  <Text id="npc_groupName_@@group_key@@" class="hud_storyteller_label hud_storyteller_row_name npc_group_row_name">@@group_name@@</Text>
  <Button id="npc_group_@@group_key@@_centerForward" class="button_icon npc_button_icon" offsetXY="-140 0">▼</Button>
  <Button id="npc_group_@@group_key@@_nearLeft" class="button_icon npc_button_icon" offsetXY="-110 0">◀</Button>
  <Button id="npc_group_@@group_key@@_nearRight" class="button_icon npc_button_icon" offsetXY="-80 0">▶</Button>
  <Button id="npc_group_@@group_key@@_farLeft" class="button_icon npc_button_icon" offsetXY="-50 0">◁</Button>
  <Button id="npc_group_@@group_key@@_farRight" class="button_icon npc_button_icon" offsetXY="-20 0">▷</Button>
</HorizontalLayout>