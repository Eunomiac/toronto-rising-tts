<!-- Area header row, used at the start of each defined area, used to generate panel_npcs.xml

  Placeholders:
    @@area_name@@ — D.areas `name` (header text); generator falls back to title-cased key if `name` is omitted.
    @@area_key@@ — D.areas table key (ids). `label` stays the triangle/arrow glyph for buttons only.
-->

<HorizontalLayout id="npc_areaHeader_@@area_key@@" class="hud_storyteller_button_row" active="false" padding="10 0 0 0" color="rgba(255, 255, 255, 0.7)">
  <Text id="npc_areaLabel_@@area_key@@" class="hud_storyteller_label hud_storyteller_row_name" color="#000000">@@area_name@@</Text>
  <Button id="npc_moveGroup_@@area_key@@_centerForward" class="button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-180 0">▼</Button>
  <Button id="npc_moveGroup_@@area_key@@_nearLeft" class="button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-150 0">◀</Button>
  <Button id="npc_moveGroup_@@area_key@@_nearRight" class="button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-120 0">▶</Button>
  <Button id="npc_moveGroup_@@area_key@@_farLeft" class="button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-90 0">◁</Button>
  <Button id="npc_moveGroup_@@area_key@@_farRight" class="button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-60 0">▷</Button>
  <Button id="npc_clearArea_@@area_key@@" class="button_icon red_button_icon npc_button_icon" onClick="HUD_npcDispatch" offsetXY="-20 0">✕</Button>
</HorizontalLayout>