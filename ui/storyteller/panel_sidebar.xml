<!-- Sidebar Panel -->
<!-- Right-side reference image toggles for Black -->
<!-- Reproduces Heritage hud.xml sidebar: dual-layer buttons (base + overlay) -->
<!-- Mouse-down shows reference popup, right-click toggles it on -->

<Panel id="hudSidebarHost" class="storyteller_sidebar" visibility="Black">

  <!-- ================================================================ -->
  <!-- Base Layer: toggle button images (grey-tinted, clickable)        -->
  <!-- ================================================================ -->
  <VerticalLayout class="storyteller_sidebarLayout">

    <!-- Battlegrounds Group (silver borders) -->
    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="hudRefBattlegroundsHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-battlegrounds" />
    <Image id="hudRefAncillaeAHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-ancillaeA" />
    <Image id="hudRefAncillaeBHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-ancillaeB" />
    <Image id="hudRefAncillaeCHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-ancillaeC" />
    <Image id="hudRefAncillaeDHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-ancillaeD" />
    <Image id="hudRefAncillaeEHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-ancillaeE" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <!-- Clans Group (gold borders) -->
    <Image class="imageBorder" image="hud-border-gold-top" />
    <Image id="hudRefBrujahHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-clanBrujah" />
    <Image id="hudRefGangrelHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-clanGangrel" />
    <Image id="hudRefLasombraHost"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-clanLasombra" />
    <Image id="hudRefMalkavianHost"
