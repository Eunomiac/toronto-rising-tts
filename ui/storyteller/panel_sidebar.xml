    <Image class="imageBorder" image="hud-border-gold-bottom" />

    <!-- Traits Group (silver borders) -->
    <Image class="imageBorder" image="hud-border-silver-top" />
    <Image id="hudRefTraits1Host"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-traits1" />
    <Image id="hudRefTraits2Host"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-traits2" />
    <Image id="hudRefTraits3Host"
      class="storyteller_refButton imageButtonBase"
      image="hud-toggle-traits3" />
    <Image class="imageBorder" image="hud-border-silver-bottom" />

    <!-- Misc Group (silver borders) -->
    <Image class="imageBorder" image="hud-border-silver-top" />
