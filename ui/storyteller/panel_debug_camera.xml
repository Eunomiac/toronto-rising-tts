<Defaults>
  <HorizontalLayout flexibleHeight="0" />
  <Text flexibleWidth="0" />
  <Button flexibleWidth="0" flexibleHeight="0" />
  <Slider minWidth="300" />
</Defaults>

<!-- Focused camera debug: live lookAt sliders + snapshot (Host). -->
<Panel id="panel_debug_camera_root" active="false" color="rgba(0,0,0,0.82)" padding="10 10 10 10" width="800" scale="0.8" rectAlignment="MiddleRight" offsetXY="-300 0" raycastTarget="true">
  <VerticalLayout spacing="5" childForceExpandWidth="true" childForceExpandHeight="false">
    <Text id="dc_debug_label" fontSize="14" color="#7FE7FF" preferredHeight="32">Debug Camera</Text>

    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">position.x</Text>
      <Slider id="dc_positionX" minValue="-200" maxValue="200" value="0" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>
    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">position.y</Text>
      <Slider id="dc_positionY" minValue="0" maxValue="100" value="0" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>
    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">position.z</Text>
      <Slider id="dc_positionZ" minValue="-100" maxValue="100" value="0" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>
    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">pitch</Text>
      <Slider id="dc_pitch" minValue="0" maxValue="90" value="0" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>
    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">yaw</Text>
      <Slider id="dc_yaw" minValue="0" maxValue="360" value="0" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>
    <HorizontalLayout preferredHeight="30" childForceExpandWidth="true" spacing="6" childAlignment="MiddleLeft">
      <Text preferredWidth="110" fontSize="12" color="#CCCCCC">distance</Text>
      <Slider id="dc_distance" minValue="0" maxValue="200" value="40" flexibleWidth="1" onValueChanged="HUD_debugCameraSlider" />
    </HorizontalLayout>

    <HorizontalLayout preferredHeight="32" spacing="8" childAlignment="MiddleCenter">
      <Button class="smallButton" preferredWidth="120" fontSize="11" onClick="HUD_debugCameraSnapshot">Snapshot</Button>
      <Button class="smallButton" preferredWidth="120" fontSize="11" onClick="HUD_debugCameraDone">Done</Button>
    </HorizontalLayout>

    <HorizontalLayout preferredHeight="32" spacing="8" childForceExpandWidth="false" childAlignment="MiddleCenter">
      <InputField id="dc_mode_input" preferredWidth="240" minWidth="240" preferredHeight="30" minHeight="30" lineType="SingleLine" fontSize="12" textColor="#111111" placeholder="camera mode key (e.g. sheet)" onValueChanged="HUD_debugCameraModeInput" onEndEdit="HUD_debugCameraModeInput"></InputField>
      <Button class="smallButton" preferredWidth="70" fontSize="11" onClick="HUD_debugCameraApplyMode">OK</Button>
    </HorizontalLayout>
  </VerticalLayout>
</Panel>
