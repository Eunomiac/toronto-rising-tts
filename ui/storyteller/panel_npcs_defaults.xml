<!-- Storyteller NPC panel defaults (non-generated). -->
<!-- Keep this file hand-authored; generator composes panel_npcs.xml from ui/storyteller/partials/. -->
<Defaults>
  <Panel class="npc_panel_root" active="false" padding="0 0 0 0" offsetXY="0 -50" color="rgba(0, 0, 0, 0.8)" />

  <VerticalLayout class="npc_panel_layout_root" />

  <VerticalScrollView class="npc_panel_scroll"
      horizontalScrollbarVisibility="AutoHideAndExpandViewport"
      scrollbarBackgroundColor="#440000"
      scrollbarColors="#990000|#AA0000|#CC0000|#333333"
      inertia="false"
      color="rgba(0, 0, 0, 0.7)"
      horizontal="false"
      vertical="true"
      preferredHeight="250"
      minHeight="200"
      flexibleWidth="1"
      flexibleHeight="1"
      childForceExpandWidth="true"
      padding="5 5 5 5"
      spacing="3"
      childForceExpandHeight="true" />

  <HorizontalLayout class="hud_storyteller_button_row"
    padding="10 10 0 0"
    preferredHeight="20"
    minHeight="20"
    flexibleHeight="0"
    childForceExpandWidth="true"
    childForceExpandHeight="true" />

  <HorizontalLayout class="npc_group_member_row"
    padding="24 10 0 0"
    color="rgba(0, 0, 0, 1)" />

  <Text class="npc_group_row_color"
    minWidth="8"
    preferredWidth="8"
    flexibleWidth="0"
    minHeight="20"
    preferredHeight="20"
    flexibleHeight="0"
    color="#444444"
    text="" />

  <!-- <VerticalLayout class="npc_panel_rows_root"
    ignoreLayout="true"
    height="1200"
    width="100%"
    spacing="0"
    childForceExpandWidth="true"
    childForceExpandHeight="true"
    minHeight="1200" /> -->
  <VerticalLayout class="npc_panel_rows_root"
    ignoreLayout="true"
    height="1200"
    width="100%"
    spacing="0"
    childAlignment="UpperLeft"
    childForceExpandWidth="true"
    childForceExpandHeight="false" />

  <Text class="hud_storyteller_row_label"
    minHeight="20"
    flexibleWidth="1"
    fontSize="16"
    fontStyle="Bold"
    color="#FFFFFF"
    alignment="MiddleLeft" />

  <Text class="hud_storyteller_row_name"
    minWidth="180"
    preferredWidth="180"
    flexibleWidth="0"
    minHeight="20"
    preferredHeight="20"
    flexibleHeight="0"
    fontSize="13"
    color="#FFD700"
    alignment="MiddleLeft" />

  <Text class="npc_group_row_name"
    color="#000000"
    fontStyle="Bold"
    ignoreLayout = "true"
    rectAlignment = "MiddleLeft"
    offsetXY = "35 0"
    width = "250" />

  <Text class="npc_row_name"
    fontStyle="Bold"
    ignoreLayout="true"
    rectAlignment="MiddleLeft"
    offsetXY = "70 0"
    width="250" />

  <Text class="seated_npc_slot_name"
    ignoreLayout="true"
    rectAlignment="MiddleLeft"
    textAlignment="MiddleLeft"
    offsetXY = "10 0"
    height="30" />

  <Text class="seated_npc_name"
    ignoreLayout = "true"
    rectAlignment = "MiddleLeft"
    textAlignment = "MiddleLeft"
    height="30"
    offsetXY = "70 0" />

  <Panel class="hud_storyteller_horiz_spacer"
    color="clear"
    flexibleWidth="1"
    minWidth="8"
    preferredWidth="8"
    raycastTarget="false" />

  <Button class="hud_storyteller_button_icon_narrow" width="11" minWidth="11" preferredWidth="11" />

  <Button class="npc_button_icon"
    rectAlignment="MiddleRight"
    onClick="HUD_npcDispatch" />

  <Button class="npc_button_icon_small"
    rectAlignment="MiddleLeft"
    onClick="HUD_npcDispatch" />



</Defaults>
