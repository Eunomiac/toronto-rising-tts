        </HorizontalLayout>
      </HorizontalLayout>

      <HorizontalLayout class="projectEditor_fullFields_row" childAlignment="MiddleLeft">
        <Text class="projectEditor_text_label" text="Increment:" preferredWidth="100" flexibleWidth="0" />
