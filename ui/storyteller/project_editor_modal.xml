
  <Defaults>
    <Panel class="projectEditor_modal" visibility="Black|Host" active="false" rectAlignment="MiddleCenter" offsetXY="0 0" preferredWidth="760" width="760" height="500" preferredHeight="500" color="rgba(0.05,0.05,0.08,0.96)" padding="10 10 10 10" />

    <VerticalLayout class="projectEditor_content" spacing="10" childForceExpandHeight="false" childAlignment="UpperMiddle" />

    <Text class="projectEditor_title" fontSize="16" fontStyle="Bold" color="#FFD700" />

    <HorizontalLayout class="projectEditor_dots_row" spacing="8" preferredHeight="32" childForceExpandWidth="false" childAlignment="MiddleCenter" />

    <Text class="projectEditor_text_label" fontSize="14" fontStyle="Bold" alignment="MiddleRight" color="#CCCCCC" preferredWidth="30" minWidth="50"
      flexibleWidth = "0" />

    <Text class="projectEditor_text_wide" fontSize="14" color="#CCCCCC"
      flexibleWidth = "1" preferredWidth="1000" alignment="MiddleLeft" />

    <InputField class="projectEditor_integer_field" contentType="IntegerNumber" characterLimit="2" alignment="MiddleCenter" preferredWidth="0" preferredHeight="28" minHeight="45" minWidth="45" fontSize="28" fontStyle="Bold" flexibleHeight="0" flexibleWidth="0" onValueChanged="HUD_projectEditorField" onEndEdit="HUD_projectEditorField" placeholder=" "  />

    <VerticalLayout class="projectEditor_fullFields" spacing="10" childForceExpandHeight="false" />

    <HorizontalLayout class="projectEditor_fullFields_row" spacing="6" preferredHeight="30" flexibleHeight="0" />

    <InputField class="projectEditor_text_field" preferredWidth="1000" preferredHeight="30" fontSize="12" onValueChanged="HUD_projectEditorField" onEndEdit="HUD_projectEditorField" flexibleHeight="0" />

    <Dropdown class="projectEditor_dropdown" onValueChanged="HUD_projectDropdown(selectedIndex)" flexibleWidth="1" preferredWidth="140" />

    <HorizontalLayout class="projectEditor_stake_row" spacing="6" preferredHeight="36" />

    <Panel class="spacer" flexibleHeight="1" flexibleWidth="1" />

    <Button class="projectEditor_button_small" preferredWidth="45" preferredHeight="45" minWidth="45" minHeight="45" fontSize="32" fontStyle="Bold" color="#FFFF00" />

    <HorizontalLayout class="projectEditor_button_bar" spacing="8" preferredHeight="36" childAlignment="MiddleCenter" />

    <Button class="projectEditor_confirm_button" preferredWidth="100" preferredHeight="32" fontSize="12" colors="#225522|#336633|#44AA44|rgba(0.1,0.3,0.1,0.5)" textColor="#FFFFFF" onClick="HUD_projectEditorConfirm" text="OK" />

    <Button class="projectEditor_cancel_button" preferredWidth="100" preferredHeight="32" fontSize="12" colors="#333333|#444444|#555555|rgba(0.2,0.2,0.2,0.5)" textColor="#FFFFFF" onClick="HUD_projectEditorCancel" text="Cancel" />

    <Button class="projectEditor_delete_button" preferredWidth="100" preferredHeight="32" fontSize="12" colors="#662222|#883333|#991111|rgba(0.5,0.1,0.1,0.4)" textColor="#FFFFFF" onClick="HUD_projectEditorDelete" text="Delete" />

    <Button class="projectEditor_begin_button" preferredWidth="120" preferredHeight="32" fontSize="12" colors="#224466|#336699|#4488BB|rgba(0.1,0.2,0.4,0.5)" textColor="#FFFFFF" onClick="HUD_projectEditorBegin" text="Lock &amp; Begin" />

    <Button class="projectEditor_complete_button" preferredWidth="100" preferredHeight="32" fontSize="12" colors="#226666|#33AAAA|#119999|rgba(0.1,0.5,0.5,0.4)" textColor="#FFFFFF" onClick="HUD_projectEditorComplete" text="Complete" />
