<!-- Storyteller HUD Defaults -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md; .dev/TTS_BUNDLING_SETUP.md; .dev/tts-api/UI API/Defaults.md. -->
<!-- Admin panel + sidebar + camera classes. Include before hud_storyteller. -->

<Defaults>

  <!-- ================================================================ -->
  <!-- Defaults Classes (shared across all storyteller panels)           -->
  <!-- ================================================================ -->

  <Text class="hud_storyteller_header" fontSize="12" color="#FFDD00" flexibleWidth="1"/>
  <Text class="hud_storyteller_label"	fontSize="11" color="#FFD700"  />

  <Row class="hud_storyteller_button_row" preferredHeight="20" minHeight="20" spacing="0" childForceExpandWidth="false" childForceExpandHeight="false" />
  <HorizontalLayout class="hud_storyteller_button_row" preferredHeight="20" minHeight="20" spacing="0" childForceExpandWidth="false" childForceExpandHeight="false" />

  <Button class="hud_storyteller_button" fontSize="9" height="20" preferredHeight="20" minHeight="20" minWidth="40" flexibleHeight="0" flexibleWidth="0" />
  <Button class="hud_storyteller_button_label" width="40" preferredWidth="40" />
  <Button class="hud_storyteller_button_icon" fontSize="20" width="20" minWidth="20" preferredWidth="20" />
  <Button class="hud_storyteller_button_icon_off" color="#666666" />
  <Button class="hud_storyteller_button_icon_on" color="#FFDD00" />

  <Row class="hud_storyteller_header" height="30" preferredHeight="30" flexibleHeight="0" childForceExpandHeight="false" childForceExpandWidth="true" />
  <Cell class="hud_storyteller_wide" columnSpan="6" childForceExpandWidth="true" />
  <Cell class="hud_storyteller_label" childForceExpandWidth="true" />

  <!-- ================================================================ -->
  <!-- Admin Panel Classes (left-side button controls)                   -->
  <!-- ================================================================ -->

  <!-- Main button column: left-aligned, half-scale, vertically stacked -->
  <VerticalLayout class="storyteller_buttonControls"
    padding="10 10 5 5"
    spacing="5"
    rectAlignment="MiddleLeft"
    childAlignment="UpperLeft"
    width="160"
    offsetXY="0 -90"
    scale="0.5"
    flexibleWidth="0"
    flexibleHeight="0"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <!-- ================================================================ -->
  <!-- Sidebar Classes (right-side reference image toggles)             -->
  <!-- ================================================================ -->

  <!-- Faction icon container (bottom-right, above camera bar) -->
  <HorizontalLayout class="storyteller_factionIconContainer"
    rectAlignment="LowerRight"
    padding="0 400 0 20"
    spacing="0"
    height="150"
    width="800"
    scale="0.7"
    childAlignment="LowerLeft"
    childForceExpandHeight="true"
    childForceExpandWidth="false" />

  <!-- Camera control bar (bottom-right row) -->
  <HorizontalLayout class="storyteller_cameraControls"
    rectAlignment="LowerRight"
    padding="0 0 0 0"
    spacing="0"
    height="28"
    width="800"
    scale="0.7"
    childAlignment="LowerRight"
    childForceExpandHeight="true"
    childForceExpandWidth="false" />

  <!-- Camera button: clickable image with hover handlers -->
  <Image class="storyteller_cameraButton"
    raycastTarget="true"
    onMouseDown="HUD_cameraSet"
    onMouseEnter="HUD_highlight"
    onMouseExit="HUD_dim" />

  <!-- Right sidebar panel container -->
  <Panel class="storyteller_sidebar"
    rectAlignment="LowerRight"
    height="740"
    width="125"
    offsetXY="0 100" />

  <!-- Right sidebar inner vertical layout -->
  <VerticalLayout class="storyteller_sidebarLayout"
    height="100%"
    width="100%"
    spacing="0"
    childAlignment="LowerLeft"
    childForceExpandHeight="false"
    childForceExpandWidth="true" />

  <!-- Reference toggle button: show/hide on mouse events -->
  <Image class="storyteller_refButton"
    onMouseDown="HUD_show"
    onMouseUp="HUD_hide"
    onMouseEnter="HUD_highlight"
    onMouseExit="HUD_dim" />


  <!-- Existing-NPC Controls -->

  <Row class="hud_storyteller_areas" />
  <Cell class="hud_storyteller_areas" childForceExpandHeight="false" />
  <Cell class="hud_storyteller_areas hud_storyteller_header" childForceExpandHeight="false" childForceExpandWidth="false" />
  <HorizontalLayout class="hud_storyteller_areas" childForceExpandHeight="false" childForceExpandWidth="false" />

  <!-- Spawn NPC Controls -->

  <!-- Spawn Individuals -->

  <HorizontalLayout class="hud_storyteller_spawn" />


</Defaults>
