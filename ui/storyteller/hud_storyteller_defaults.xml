<!-- Storyteller HUD Defaults -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md; .dev/TTS_BUNDLING_SETUP.md; .dev/tts-api/UI API/Defaults.md. -->
<!-- Admin panel + sidebar + camera classes. Include before hud_storyteller. -->

<Defaults>

  <!-- ================================================================ -->
  <!-- Defaults Classes (shared across all storyteller panels)           -->
  <!-- ================================================================ -->

  <Text class="hud_storyteller_header" fontSize="12" color="#FFDD00" flexibleWidth="1"/>
  <Text class="hud_storyteller_label"	fontSize="11" color="#FFD700"  />

  <Row class="hud_storyteller_button_row" preferredHeight="20" minHeight="20" spacing="0" childForceExpandWidth="false" childForceExpandHeight="false" />
  <HorizontalLayout class="hud_storyteller_button_row" childAlignment="MiddleCenter" preferredHeight="30" minHeight="30" spacing="0" childForceExpandWidth="true" childForceExpandHeight="true" />


  <!-- <Button class="hud_storyteller_button"
    fontSize="12"
    height="20"
    preferredHeight="20"
    minHeight="20"
    preferredWidth="125"
    minWidth="125"
    flexibleHeight="0"
    flexibleWidth="0"
  /> -->

  <Button class="hud_storyteller_button"
    fontSize="14"
    colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
    textColor="#FFFFFF" />
  <Button class="hud_storyteller_button_label" width="40" preferredWidth="40" />
  <Button class="hud_storyteller_button_icon"
    fontSize="14"
    textColor="#FFFFFF"
    fontStyle="Bold"
    height="20"
    minHeight="20"
    preferredHeight="20"
    flexibleHeight="0"
    width="20"
    minWidth="20"
    preferredWidth="20"
    flexibleWidth="0"
    alignment="MiddleCenter"
  />

  <!-- <HorizontalLayout class="hud_storyteller_control_row" preferredHeight="30" minHeight="30" spacing="4" childForceExpandWidth="true" childForceExpandHeight="true" childAlignment="MiddleLeft" /> -->

  <HorizontalLayout class="hud_storyteller_control_row" />

  <InputField class="hud_storyteller_input"
    fontSize="14"
    lineType="SingleLine"
    textColor = "#000000"
  />

  <InputField class="guid_input"
    characterLimit="6"
    flexibleWidth="0"
    characterValidation="Alphanumeric"
    placeholder="GUID" />


  <Text class="hud_storyteller_header"
    minHeight="20"
    flexibleWidth="1"
    fontSize="18"
    fontStyle="Bold"
    color="#FFFFFF"
    alignment="LowerCenter" />

  <Text class="hud_storyteller_label"
    minHeight="20"
    flexibleWidth="1"
    fontSize="16"
    fontStyle="Bold"
    color="#FFD700"
    alignment="LowerCenter" />

  <Text class="hud_storyteller_row_label"
    fontSize="14"
    alignment="MiddleLeft"
  />

  <Button class="hud_storyteller_row_button"
    minHeight="20"
    fontSize="14"
    fontStyle="Bold"
    color="#FFFFFF"
    alignment="MiddleLeft" />

  <Button class="hud_storyteller_row_button_icon"
    alignment="MiddleCenter"
    width="20"
    preferredWidth="20"
    flexibleWidth="0"
    minWidth="20"
    height="20"
    preferredHeight="20"
    flexibleHeight="0"
    minHeight="20" />

  <Row class="hud_storyteller_header" height="30" preferredHeight="30" flexibleHeight="0" childForceExpandHeight="false" childForceExpandWidth="true" />
  <Cell class="hud_storyteller_wide" columnSpan="6" childForceExpandWidth="true" />
  <Cell class="hud_storyteller_label" childForceExpandWidth="true" />

  <!-- ================================================================ -->
  <!-- Admin Panel Classes (left-side button controls)                   -->
  <!-- ================================================================ -->

  <!-- Debug seat-swap row (bottom-right, left of admin twirl-down) -->
  <Button class="debug_seat_color_button"
    text=""
    width="30"
    height="30"
    minWidth="30"
    minHeight="30"
    preferredWidth="30"
    preferredHeight="30"
    flexibleWidth="0"
    flexibleHeight="0"
    fontSize="1"
    textColor="rgba(0,0,0,0)"
    padding="0 0 0 0"
    alignment="MiddleCenter"
    outline="rgba(0,0,0,0)"
    outlineSize="0 0" />

  <HorizontalLayout class="debug_seat_color_row"
    rectAlignment="LowerRight"
    offsetXY="-34 0"
    width="190"
    height="30"
    spacing="2"
    childAlignment="MiddleRight"
    childForceExpandWidth="false"
    childForceExpandHeight="false"
    ignoreLayout="true" />

  <!-- Main button column: left-aligned, half-scale, vertically stacked (TOR-396: +100 Y) -->
  <VerticalLayout class="storyteller_buttonControls"
    padding="0 0 0 0"
    spacing="1"
    rectAlignment="LowerRight"
    childAlignment="LowerRight"
    width="200"
    height="400"
    offsetXY="-50 130"
    childForceExpandWidth="true"
    childForceExpandHeight="true" />

  <!-- ================================================================ -->
  <!-- Sidebar Classes (right-side reference image toggles)             -->
  <!-- ================================================================ -->

  <!-- Reference toggle button: show/hide on mouse events -->
  <Image class="storyteller_refButton"
    onMouseDown="HUD_show"
    onMouseUp="HUD_hide"
    onMouseEnter="HUD_highlight"
    onMouseExit="HUD_dim" />




  <Panel class="rollST_root"
    rectAlignment="LowerCenter"
    width = "900"
    height = "900"
    color = "rgba(0, 0, 0.25, 1)"
    outline = "rgba(1, 1, 0, 1)"
  />

    <GridLayout class="grid_strip" cellSize = "10 20" height = "20" spacing = "6" startCorner = "UpperLeft" startAxis = "Horizontal" constraint = "FixedRowCount" constraintCount = "1" onMouseExit="HUD_gridStripMouseExit" />
  <Panel class="grid_strip_cell" outline = "#000000" outlineSize = "-1 1" onMouseEnter="HUD_gridStripCellMouseEnter" onMouseDown="HUD_gridStripCellMouseDown" onMouseUp="HUD_gridStripCellMouseUp" />
  <Panel class="grid_strip_cell_hunger" color = "rgba(1, 0, 0, 0.15)" />
  <Panel class="grid_strip_cell_normal" color = "rgba(0.5, 0.5, 0.5, 0.15)" />
  <Panel class="grid_strip_cell_difficulty" color = "rgba(0, 1, 0, 0.15)" />
  <Text class="grid_strip_cell_difficulty_text" fontSize="9" fontStyle="Bold" />
  <Text class="grid_strip_cell_hunger_text" fontSize="9" fontStyle="Bold" />
  <Text class="grid_strip_cell_normal_text" fontSize="9" fontStyle="Bold" />

</Defaults>
