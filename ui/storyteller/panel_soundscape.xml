<!-- Storyteller Soundscape Controls -->
<!-- Agent guidance: .dev/SOUNDSCAPE_UNITY_SETUP.md; .dev/HUD_FUNCTIONS.md. -->

<Panel id="panel_soundscape" active="false">
  <VerticalLayout spacing="4" padding="6 6 6 6" childForceExpandWidth="false" childForceExpandHeight="false">
    <Text class="hud_storyteller_header">Soundscape</Text>
    <Text id="soundscapeSummary" fontSize="10" color="#DDDDDD">Music: mood/general | Featured: none | Location: none | Weather: none | Rain: none | Wind: none | Thunder: false | Indoors: false</Text>

    <Text class="hud_storyteller_label">Music Mood</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4">
      <Button id="soundscapeMood_general" text="General" minWidth="62" preferredWidth="62" onClick="HUD_soundscapeSetMusicMood"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="soundscapeMood_intrigue" text="Intrigue" minWidth="62" preferredWidth="62" onClick="HUD_soundscapeSetMusicMood"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
      <Button id="soundscapeMood_combat" text="Combat" minWidth="62" preferredWidth="62" onClick="HUD_soundscapeSetMusicMood"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" />
    </HorizontalLayout>

    <Text fontSize="9" color="#AAAAAA">Weather and location layers are API/debug controlled until the clock, weather table, and SITES data exist.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4">
      <Button text="Inspect" minWidth="62" preferredWidth="62" onClick="HUD_soundscapeInspect" />
      <Button text="Stop All" minWidth="62" preferredWidth="62" onClick="HUD_soundscapeStopAll" />
    </HorizontalLayout>
  </VerticalLayout>
</Panel>
