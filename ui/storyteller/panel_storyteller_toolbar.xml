<!-- Storyteller bottom-right tool bar + pop-out panels (Black) -->
<!-- Agent guidance: dev/HUD_FUNCTIONS.md; dev/NPC Object Spawning & Spotlighting/NPC Object Overview.md (NPCs toggle). -->
<Panel id="storytellerToolbarRoot" visibility="Black" rectAlignment="UpperLeft" offsetXY="50 200" width="800" height="800">
  <VerticalLayout spacing="4" childAlignment="LowerLeft" height="36">
    <HorizontalLayout rectAlignment="UpperLeft" ignoreLayout="true" spacing="3" childAlignment="MiddleLeft" width="200" height="20" offsetXY="0 20">
      <Button id="toggle_lighting" text="Light" minWidth="16" fontSize="8"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" />
      <Button id="toggle_scenes" text="Scenes" minWidth="16" fontSize="8"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" />
      <Button id="toggle_pcs" text="PCs" minWidth="16" fontSize="8"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" />
      <Button id="toggle_phases" text="Phases" minWidth="16" fontSize="8"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" />
      <Button id="toggle_npcs" text="NPCs" minWidth="16" fontSize="8"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" />
    </HorizontalLayout>

    <!-- padding: Panel acts as layout group (TTS Layout/Grouping). Inner VL uses flexibleHeight so children get real vertical space. -->
    <Panel id="storytellerContentArea" active="false" width="560" minHeight="700" flexibleHeight="0" padding="0 0 0 0">
      <VerticalLayout padding="0" spacing="4" flexibleHeight="1" childForceExpandHeight="true" childForceExpandWidth="true">
        <Panel id="panel_lighting" active="false">
          <Text fontSize="11" color="#AAAAAA">Lighting: use Light Debug panel / scene tools.</Text>
        </Panel>
        <Panel id="panel_scenes" active="false">
          <Text fontSize="11" color="#AAAAAA">Scenes: TBD.</Text>
        </Panel>
        <Include src="panel_pcs" />
        <Panel id="panel_phases" active="false">
          <Text fontSize="11" color="#AAAAAA">Phases: TBD.</Text>
        </Panel>
        <Include src="panel_npcs" />
      </VerticalLayout>
    </Panel>
  </VerticalLayout>
</Panel>
