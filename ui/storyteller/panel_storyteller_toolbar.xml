<!-- Storyteller bottom-right tool bar + pop-out panels (Black) -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md -->

<Panel id="storytellerToolbarRoot" visibility="Host" rectAlignment="UpperLeft" offsetXY="50 00" width="1280" height="800">
  <Button id="toggleElem_storytellerToolbarBody" class="hud_storyteller_button hud_storyteller_button_icon" rectAlignment="UpperLeft" width="30" height="30" onClick="HUD_togglePanel">►</Button>
  <VerticalLayout spacing="4" childAlignment="UpperLeft" rectAlignment="UpperLeft" offsetXY="35 -30">
    <Panel id="storytellerToolbarBody" active="false">
      <VerticalLayout spacing="4" childAlignment="UpperLeft" height="20">
    <HorizontalLayout rectAlignment="UpperLeft" ignoreLayout="true" spacing="3" childAlignment="UpperLeft" width="500" height="30" offsetXY="0 20">
      <Button id="toggle_scenes" text="Scenes" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" textColor="#FFFFFF" />
      <Button id="toggle_soundscape" text="Sound" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" textColor="#FFFFFF" />
      <Button id="toggle_pcs" text="PCs" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" textColor="#FFFFFF" />
      <Button id="toggle_phases" text="Phases" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" textColor="#FFFFFF" />
      <Button id="toggle_stats" text="Stats" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
        onClick="HUD_selectStorytellerPanel" textColor="#FFFFFF" />
    </HorizontalLayout>

    <!-- padding: Panel acts as layout group (TTS Layout/Grouping). Inner VL uses flexibleHeight so children get real vertical space. -->
    <!-- Inner VL width must match `storytellerContentArea` or TTS squeezes multi-column Scenes (`panel_scenes_host`) to a hairline. -->
    <Panel id="storytellerContentArea" active="false" width="1200" minWidth="1200" minHeight="700" flexibleHeight="0" padding="0 0 0 0">
      <VerticalLayout padding="0" spacing="4" flexibleHeight="1" childForceExpandHeight="true" minWidth="1200" preferredWidth="1200" childForceExpandWidth="true">
        <Include src="panel_scenes_host.xml" />
        <Include src="panel_soundscape.xml" />
        <Include src="panel_pcs.xml" />
        <Include src="panel_phases.xml" />
        <Include src="panel_stats.xml" />
      </VerticalLayout>
    </Panel>
      </VerticalLayout>
    </Panel>
  </VerticalLayout>
</Panel>
