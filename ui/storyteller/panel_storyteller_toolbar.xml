<!-- Storyteller bottom-right tool bar + pop-out panels (Black) -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md -->

<Defaults>

  <Panel class="storyteller_panel_root"
    visibility = "Host"
    rectAlignment = "UpperLeft"
    offsetXY = "50 0"
    width = "1500"
    height = "900"
    padding = "0 0 0 0"
    childAlignment = "UpperLeft" />

  <Button class="hud_storyteller_twirldown_button"
    ignoreLayout = "true"
    height = "30"
    width = "30"
    rectAlignment = "UpperLeft" />

  <VerticalLayout class="storyteller_control_container"
    spacing="4"
    childAlignment="UpperLeft"
    childForceExpandWidth = "true"
    childForceExpandHeight = "false" />

  <HorizontalLayout class="storyteller_button_bar"
    padding = "30 800 0 0"
    flexibleHeight = "0"
    spacing= "3" />

  <Button class="storyteller_panel_button"
    colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)"
    onClick="HUD_selectStorytellerPanel"
    textColor="#FFFFFF" />

  <Panel class="storyteller_control_content"
    padding="0 0 0 0"
    childForceExpandHeight = "true"
    flexibleHeight = "1"
    childForceExpandWidth = "true" />

  <HorizontalLayout class="storyteller_three_panel_container"
    spacing="8"
    padding="0 0 0 0"
    color = "rgba(0, 0, 0, 0.85)"
    childAlignment="UpperLeft"
    childForceExpandHeight="true"
    childForceExpandWidth="true" />

  <!-- Storyteller modal panels (Scenes, Sound, Phases, …): shared semi-opaque backdrop -->
  <VerticalLayout class="storyteller_panel_column"
    color="rgba(0, 0, 0, 0.8)"
    spacing="6"
    padding="6 6 6 6"
    childForceExpandWidth="true"
    flexibleWidth = "1"
    minWidth = "0"
    preferredWidth = "0"
  />

  <Text class="body_text"
    fontSize="12"
    color="#AAAAAA"
  />

  <Text class="small_header_text"
   alignment = "MiddleCenter"
   fontStyle = "Bold"
   fontSize = "14"
   preferredWidth = "200"
   flexibleWidth = "1"
  />

  <VerticalLayout class="hud_storyteller_inner_column"
    spacing="6"
    childForceExpandWidth="true"
    childAlignment="UpperMiddle"
    minWidth = "0"
    flexibleWidth = "1"
    preferredWidth = "250" />


</Defaults>

<!-- Master root container -->
<Panel id="storytellerToolbarRoot" class="storyteller_panel_root">

  <!-- Twirl-down Collapsible Button Toggle -->
  <Button id="toggleElem_storytellerToolbarBody" class="hud_storyteller_twirldown_button" onClick="HUD_togglePanel">►</Button>

  <!-- Toggleable full content container -->
  <VerticalLayout id="storytellerToolbarBody" class="storyteller_control_container" active="false" >

    <!-- Top navigation buttons -->
    <HorizontalLayout class="storyteller_button_bar" >
      <Button id="toggle_scenes" text="Scenes" class="storyteller_panel_button"  />
      <Button id="toggle_soundscape" text="Sound" class="storyteller_panel_button" />
      <Button id="toggle_pcs" text="PCs" class="storyteller_panel_button" />
      <Button id="toggle_phases" text="Phases" class="storyteller_panel_button" />
      <Button id="toggle_stats" text="Stats" class="storyteller_panel_button" />
      <Button id="toggle_projects" text="Projects" class="storyteller_panel_button" />
    </HorizontalLayout>

    <!-- Main content panels -->
    <Panel id="storytellerContentArea" class="storyteller_control_content" active="false">

      <!-- Scenes Panel -->
      <HorizontalLayout id="panel_scenes_host" class="storyteller_three_panel_container">
      <!--
      UI.setAttributes("panel_scenes", {})
      UI.setAttributes("panel_scenes_library", {})
      UI.setAttributes("db_third_column", {})
      -->
        <Include src="panel_scenes.xml" />
        <Include src="panel_scenes_library.xml" />
        <Panel id="db_third_column" class="storyteller_panel_column" />
      </HorizontalLayout>

      <Include src="panel_soundscape.xml" />
      <Include src="panel_pcs.xml" />
      <Include src="panel_phases.xml" />
      <Include src="panel_stats.xml" />
      <Include src="panel_projects.xml" />
    </Panel>

  </VerticalLayout>

</Panel>
