<!-- Storyteller Phases: one button per C.Phases value; active = green (sync in global_script). -->
<Panel id="panel_phases" active="false">
  <VerticalLayout class="storyteller_panel_surface" spacing="6" padding="6 6 6 6" childForceExpandWidth="false">
    <Text class="hud_storyteller_header">Session phase</Text>
    <Text fontSize="9" color="#AAAAAA">Sets `gameState.currentPhase`. Future reconcilers can subscribe to transitions.</Text>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4" childForceExpandWidth="false">
      <Button id="phase_SessionStart" text="Start" minWidth="72" preferredWidth="72" onClick="HUD_advancePhase"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="phase_Play" text="Play" minWidth="72" preferredWidth="72" onClick="HUD_advancePhase"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="phase_Downtime" text="Downtime" minWidth="72" preferredWidth="72" onClick="HUD_advancePhase"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
    </HorizontalLayout>
    <HorizontalLayout class="hud_storyteller_button_row" spacing="4" childForceExpandWidth="false">
      <Button id="phase_Memoriam" text="Memoriam" minWidth="72" preferredWidth="72" onClick="HUD_advancePhase"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
      <Button id="phase_SessionEnd" text="End" minWidth="72" preferredWidth="72" onClick="HUD_advancePhase"
        colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)" textColor="#FFFFFF" />
    </HorizontalLayout>
  </VerticalLayout>
</Panel>
