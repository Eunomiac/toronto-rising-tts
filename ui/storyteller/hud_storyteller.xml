<!-- Storyteller HUD Layout -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md; .dev/TTS_BUNDLING_SETUP.md; .dev/TESTING.md. -->
<!-- Visibility: Black (Storyteller/GM) -->
<!-- Left-side game phase controls + debug panels -->
<!-- Also includes sidebar (reference toggles) and camera bar via sub-includes -->

<Panel id="adminControls" visibility="Host">

  <!-- ================================================================ -->
  <!-- Main Button Column (left side): Print State + debug test buttons  -->
  <!-- ================================================================ -->
  <VerticalLayout class="storyteller_buttonControls" visibility="Host" rectAlignment="LowerRight" childAlignment="LowerRight" offsetXY="0 0">
    <Button preferredWidth="125" minWidth="125" onClick="HUD_printState">Print State</Button>
    <HorizontalLayout preferredHeight="30" minHeight="30" spacing="4" childForceExpandWidth="false" childForceExpandHeight="false" childAlignment="MiddleLeft">
      <Button preferredWidth="78" minWidth="78" preferredHeight="30" minHeight="30" flexibleWidth="0" flexibleHeight="0" fontSize="14" onClick="HUD_debugLightActivate">Debug Light</Button>
      <InputField id="dl_guid" preferredWidth="65" minWidth="65" preferredHeight="30" minHeight="30" height="30" flexibleWidth="0" flexibleHeight="0" lineType="SingleLine" fontSize="12" textColor="#111111" placeholder="GUID" onValueChanged="HUD_debugLightGuidInput" onEndEdit="HUD_debugLightGuidInput"></InputField>
    </HorizontalLayout>
    <Text class="spacer_10"></Text>
    <Button id="adminScene_dark" class="smallButton" onClick="HUD_selectAdminLightingScene" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">DARK</Button>
    <Button id="adminScene_standard" class="smallButton" onClick="HUD_selectAdminLightingScene" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">STANDARD</Button>
    <Button id="adminScene_bright" class="smallButton" onClick="HUD_selectAdminLightingScene" colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">BRIGHT</Button>
    <Text class="spacer_15"></Text>
    <Button preferredWidth="125" minWidth="125" onClick="HUD_debugRunTests" color="#AA00AA">Run All Tests</Button>
    <Button class="smallButton" onClick="HUD_debugTestLightingAndSignals" color="#8888FF">Lighting &amp; Signals</Button>
    <Button class="smallButton" onClick="HUD_debugTestEasing" color="#8888FF">Easing</Button>
    <Text class="spacer_15"></Text>
    <Button id="toggle_npcPanelXmlDump" preferredWidth="150" minWidth="150" flexibleWidth="0" flexibleHeight="0" text="NPC XML → IDE (off)" colors="#666666|#555555|#777777|rgba(0.22,0.22,0.22,0.45)" onClick="HUD_toggleNpcPanelXmlDump" />

  </VerticalLayout>

  <!-- ================================================================ -->
  <!-- Debug State Display Panel                                        -->
  <!-- ================================================================ -->
  <Panel id="debugStatePanel" active="false" class="debugPanel">
    <Text id="debugState" class="debugText"></Text>
  </Panel>

  <Include src="panel_debug_light.xml" />

  <!-- ================================================================ -->
  <!-- Sidebar (reference image toggles) and Camera bar                 -->
  <!-- ================================================================ -->
  <Include src="panel_camera.xml" />

</Panel>

<Include src="panel_storyteller_toolbar.xml" />
