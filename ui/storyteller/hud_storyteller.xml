<!-- Storyteller HUD Layout -->
<!-- Agent guidance: .dev/HUD_FUNCTIONS.md; .dev/TTS_BUNDLING_SETUP.md; .dev/TESTING.md. -->
<!-- Visibility: Black (Storyteller/GM) -->
<!-- Left-side game phase controls + debug panels -->
<!-- Also includes sidebar (reference toggles) and camera bar via sub-includes -->

<Panel id="adminControls" visibility="Host">
  <HorizontalLayout class="debug_seat_color_row">
    <Button id="debugSeat_Black" class="debug_seat_color_button" colors="#1A1A1A|#2A2A2A|#0F0F0F|#1A1A1A" onClick="HUD_debugSeatColor" />
    <Button id="debugSeat_Red" class="debug_seat_color_button" colors="#B22222|#C42828|#901818|#B22222" onClick="HUD_debugSeatColor" />
    <Button id="debugSeat_Orange" class="debug_seat_color_button" colors="#E67300|#F08010|#CC6600|#E67300" onClick="HUD_debugSeatColor" />
    <Button id="debugSeat_Brown" class="debug_seat_color_button" colors="#6B4423|#7A5030|#5A3820|#6B4423" onClick="HUD_debugSeatColor" />
    <Button id="debugSeat_Pink" class="debug_seat_color_button" colors="#C71585|#D02090|#B01075|#C71585" onClick="HUD_debugSeatColor" />
    <Button id="debugSeat_Purple" class="debug_seat_color_button" colors="#5E2A7E|#6E358E|#4E2070|#5E2A7E" onClick="HUD_debugSeatColor" />
  </HorizontalLayout>
  <Button id="toggleElem_adminControlsBody" class="hud_storyteller_button hud_storyteller_button_icon" onClick="HUD_togglePanel" rectAlignment="LowerRight" width="30" height="30">►</Button>
  <VerticalLayout class="storyteller_buttonControls" visibility="Host" height="30" childForceExpandHeight="false">
  </VerticalLayout>
  <Panel id="adminControlsBody" active="false">

    <!-- ================================================================ -->
    <!-- Main Button Column (left side): Print State + debug test buttons  -->
    <!-- ================================================================ -->
    <VerticalLayout class="storyteller_buttonControls" visibility="Host" height="300">
      <Text class="hud_storyteller_header">== DEBUG ==</Text>
      <Button class="hud_storyteller_button" onClick="HUD_printState">Print State</Button>
      <Button class="hud_storyteller_button" onClick="HUD_syncAll">Sync All (force)</Button>
      <Button class="hud_storyteller_button" onClick="HUD_updateCoterieData">Update Coterie Data</Button>
      <Button class="hud_storyteller_button" onClick="HUD_clearLoadingOverlay">Clear Loading Overlay</Button>
      <Button class="hud_storyteller_button" onClick="HUD_refreshUi">Refresh UI</Button>
      <Button class="hud_storyteller_button" onClick="HUD_toggleDebugAmbient">Toggle Lights</Button>
      <Button class="hud_storyteller_button" onClick="HUD_toggleAllAnchors">Toggle Anchors</Button>
      <Button class="hud_storyteller_button" onClick="HUD_toggleAllSpotlights">Toggle Spotlights</Button>
      <Button class="hud_storyteller_button" onClick="HUD_debugCameraActivate">Debug Camera</Button>
      <HorizontalLayout class="hud_storyteller_control_row">
        <Button class="hud_storyteller_button" onClick="HUD_debugLightActivate">Debug Light</Button>
        <InputField id="dl_guid" class="hud_storyteller_input guid_input" onValueChanged="HUD_debugLightGuidInput" onEndEdit="HUD_debugLightGuidInput"></InputField>
      </HorizontalLayout>
    </VerticalLayout>

    <Include src="panel_debug_light.xml" />
    <Include src="panel_debug_camera.xml" />

    <!-- ================================================================ -->
    <!-- Sidebar (reference image toggles) and Camera bar                 -->
    <!-- ================================================================ -->
    <Include src="panel_camera.xml" />
  </Panel>

</Panel>

<Include src="panel_storyteller_toolbar.xml" />

<Include src="panel_storyteller_roll_controls.xml" />
