<!-- Storyteller HUD Layout -->
<!-- Visibility: Black (Storyteller/GM) -->
<!-- Reproduces Heritage admin.xml: left-side game phase controls + debug panels -->
<!-- Also includes sidebar (reference toggles) and camera bar via sub-includes -->

<Panel id="adminControls" visibility="Host" active="true">

  <!-- ================================================================ -->
  <!-- Main Button Column (left side): Print State + debug test buttons  -->
  <!-- ================================================================ -->
  <VerticalLayout class="storyteller_buttonControls" visibility="Host" rectAlignment="UpperLeft" offsetXY="50 0">
    <Button onClick="HUD_printState">Print State</Button>
    <Text class="spacer_10"></Text>
    <Button id="adminScene_dark" class="smallButton" onClick="HUD_selectAdminLightingScene"
      colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">DARK</Button>
    <Button id="adminScene_standard" class="smallButton" onClick="HUD_selectAdminLightingScene"
      colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">STANDARD</Button>
    <Button id="adminScene_bright" class="smallButton" onClick="HUD_selectAdminLightingScene"
      colors="#444444|#555555|#666666|rgba(0.3,0.3,0.3,0.5)">BRIGHT</Button>
    <Text class="spacer_15"></Text>
    <Button onClick="HUD_debugRunTests" color="#AA00AA">Run All Tests</Button>
    <Button class="smallButton" onClick="HUD_debugTestLightingAndSignals" color="#8888FF">Lighting &amp; Signals</Button>
    <Button class="smallButton" onClick="HUD_debugTestEasing" color="#8888FF">Easing</Button>
    <Text class="spacer_15"></Text>
    <Button id="toggle_npcPanelXmlDump" class="smallButton" fontSize="9" minHeight="22" preferredHeight="22"
      text="NPC XML → IDE (off)"
      colors="#666666|#555555|#777777|rgba(0.22,0.22,0.22,0.45)"
      onClick="HUD_toggleNpcPanelXmlDump" />
  </VerticalLayout>

  <!-- ================================================================ -->
  <!-- Debug State Display Panel                                        -->
  <!-- ================================================================ -->
  <Panel id="debugStatePanel" active="false" class="debugPanel">
    <Text id="debugState" class="debugText"></Text>
  </Panel>

  <!-- ================================================================ -->
  <!-- Sidebar (reference image toggles) and Camera bar                 -->
  <!-- ================================================================ -->
  <Include src="panel_camera" />

  <Include src="panel_storyteller_toolbar" />

</Panel>
