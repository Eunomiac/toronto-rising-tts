<Defaults>

  <Panel class="rollControl_root"
    width = "1100"
    height = "500"
    offsetXY = "0 0"
    color = "#090909"
    outline = "#000000"
    outlineSize = "30 10"
    padding = "25 25 0 0" childForceExpandWidth="true"
    scale = "0.5"
    rectAlignment = "LowerCenter"
    pivot = "0.5 -0.5" />

  <VerticalLayout class="rollControl_container" childAlignment="UpperCenter" childForceExpandHeight="false" childForceExpandWidth="true"
    spacing = "-10" />

  <Text class="roll_text"
    fontSize = "32"
    fontStyle = "Bold"
    color = "#FFFFFF" />

  <HorizontalLayout class="rollControl_headerContainer"
    childForceExpandWidth = "true"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "0"
    flexibleHeight = "0"
    preferredHeight = "60"
    padding = "0 0 0 0" />

  <Text class="roll_header_text"
    color = "#ffdd00"
    fontSize = "36"
    fontStyle = "Bold"
    minHeight = "20"
    alignment = "MiddleLeft" />

  <Text class="roll_body_text"
    alignment = "MiddleRight"
    color = "#ffffff"
    fontSize = "32"
    fontStyle = "Bold"
    minHeight = "20" />

  <HorizontalLayout class="rollControl_rollAssembly"
    childForceExpandWidth = "true"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "0"
    flexibleHeight = "0"
    preferredHeight = "90"
    padding = "50 50 0 0" />
  <HorizontalLayout class="rollControl_dicePoolDisplay"
    childForceExpandWidth = "false"
    childForceExpandHeight = "true"
    childAlignment = "UpperLeft"
    preferredWidth = "0"
    spacing = "10" />
  <Text class="rollControl_diceText"
    flexibleWidth = "0" />

  <Text class="rollControl_diceSymbols"
    flexibleWidth = "0"
    fontSize = "60" />
  <Text class="rollControl_oblivRouseDiceText"
    fontSize = "40" color="#1900ff" outline="#FF0000"
    flexibleHeight = "0" />
  <Text class="rollControl_rouseDiceText"
    fontSize = "40" color="#550000" outline="#FF0000"
    flexibleHeight = "0" />
  <Text class="rollControl_bloodSurgeRouseDiceText"
    fontSize = "40" color="#550000" outline="#FF0000"
    flexibleHeight = "0" />
  <Text class="rollControl_hungerDiceText" color="#FF0000" />
  <Text class="rollControl_standardDiceText" />


  <HorizontalLayout class="rollControl_standardDicePoolDisplay" rectAlignment="MiddleCenter" ignoreLayout = "true" childForceExpandWidth = "false" childAlignment = "MiddleCenter" />

  <HorizontalLayout class="rollControl_difficultyDisplay"
    flexibleWidth = "0"
    spacing = "10" />

  <Text class="rollControl_difficultyVS" color="#990000" />

  <Text class="rollControl_difficulty"
    fontSize = "80" color="#FF0000" outline="#000000" outlineSize="5 5" />

  <Panel class="rollControl_spacer" flexibleWidth = "1" />
  <Panel class="rollControl_rouseSpacer" flexibleWidth = "0.15" />
  <Panel class="rollControl_verticalSpacer" flexibleHeight = "0" preferredHeight = "40" />


  <Panel class="diceImageDisplayStrip"
    preferredHeight = "100"
    flexibleHeight = "0" />

  <HorizontalLayout class="rollControl_diceImageDisplayStrip"
    spacing = "20"
    childAlignment = "MiddleCenter"
    childForceExpandWidth = "false"
    childForceExpandHeight = "false"
    flexibleHeight = "0"
    minHeight = "90"
    preferredHeight = "90" />

  <HorizontalLayout class="rollControl_diceContainer_small"
   scale = "0.7"
   pivot = "0 1" />

  <Image class="rollControl_die"
    preferredWidth = "60"
    preserveAspect = "true" />

  <HorizontalLayout class="rollControl_successesContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "20"
    preferredHeight = "100"
    minHeight = "100"
    flexibleHeight = "0" />

  <Text class="rollControl_successes"
    fontSize = "80"
    flexibleWidth = "0"
    outline="#000000" outlineSize="5 5" />
  <Text class="rollControl_successesPhrase"
    flexibleWidth = "0" />

  <HorizontalLayout class="rollControl_difficultyDisplayContainer" spacing = "15" />

  <HorizontalLayout class="rollControl_resultDisplayContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    preferredWidth = "0"
    spacing = "20"
    preferredHeight = "125"
    flexibleHeight = "0" />

  <Text class="rollControl_resultDisplay"
    pivot = "0 0.75"
    horizontalOverflow = "Overflow"
    fontSize = "100"
    outline="#000000"
    outlineSize="3 3"
    alignment = "MiddleCenter"
    ignoreLayout = "true"
    rectAlignment = "MiddleCenter" />

  <Text class="rollControl_result_win" color="#c8c8c8" />
  <Text class="rollControl_result_failure" color="#ff0000" />
  <Text class="rollControl_result_totalFailure" color="#000000" outline="#990000" outlineSize="5 5" scale = "0.75 1" offsetXY = "-380 50" />
  <Text class="rollControl_result_criticalWin" color="#ffffff" outline="#FFDD00" outlineSize = "2 2" />
  <Text class="rollControl_result_messyCritical" color="#ffffff" outline="#FF0000" outlineSize = "3 3" />
  <Text class="rollControl_result_bestialFailure" color="#990000" outline="#FF0000" outlineSize = "2 2" scale = "0.75 1"  offsetXY = "-420 50" />
  <Text class="rollControl_result_totalBestialFailure" color="#440000" outline="#FF0000" outlineSize="5 5" scale = "0.75 1" offsetXY = "-545 50" rectAlignment = "MiddleCenter" />
  <Text class="rollControl_result_brutalFailure" outline="#ff7300" outlineSize = "5 5" color="#990000" />
  <Text class="rollControl_result_brutalOutcome" color="#ff9100" outline="#ff0000" outlineSize = "2 2" scale = "0.9 1" />

  <HorizontalLayout class="rollControl_buttonContainer"
    childForceExpandWidth = "false"
    childAlignment = "MiddleCenter"
    spacing = "5"
    ignoreLayout = "true"
    rectAlignment = "LowerCenter"
    height = "50" />

  <Button class="rollControl_button"
    preferredWidth = "200"
    fontSize = "30"
    fontStyle = "Bold" />

  <Button class="rollControl_btnRoll"
    color = "#00FF00" />
  <Button class="rollControl_btnHalf"
    color = "#FFDD00" />
  <Button class="rollControl_btnWP"
    color = "#86a2ff" />
  <Button class="rollControl_btnConfirm"
    color = "#00FF00" />
  <Button class="rollControl_btnOblivHunger"
    color = "#330075"
    textColor = "#ff3333" />
  <Button class="rollControl_btnOblivStain"
    color = "#330075"
    textColor = "#ffffff" />
  <Button class="rollControl_btnBrutalFail"
    color = "#ff8800"
    textColor = "#000000" />
  <Button class="rollControl_btnBrutalViolence"
    color = "#990000"
    textColor = "#ff8800" />
  <Button class="rollControl_btnCancel"
    color = "#990000"
    textColor = "#FFFFFF" />
</Defaults>