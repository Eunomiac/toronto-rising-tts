<!-- Player HUD CorePanel_Map defaults (map layout + toggle stacks + draggable viewport) -->

<Defaults>
  <!-- Core map root layer (visibility per seat color on the generated panel id). -->
  <Panel class="playerHud_coreLayer"
    rectAlignment="LeftCenter"
    width="100%"
    height="200%"
    offsetXY="0 0"
    active="false"
  />

  <HorizontalLayout class="hud_map_parent_container"
    childForceExpandWidth="false"
    childForceExpandHeight="true"
    width="1700"
    height="1000"
    childAlignment="MiddleRight"
    rectAlignment="MiddleLeft"
    offsetXY="0 0"
  />

  <Panel class="hover_button_panel_container"
    flexibleWidth="0"
    childForceExpandHeight="false"
    childAlignment="UpperCenter"
  />

  <VerticalLayout class="hover_button_panel"
    height="150"
    width="150"
  />

  <Image class="hud_map_toggleBorder"
    preferredHeight="50"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="false"
    padding="0 0 0 0"
    raycastTarget="false"
  />

  <Image class="hud_map_toggleBorderSilver"
    preferredHeight="50"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="false"
    padding="0 0 0 0"
    raycastTarget="false"
  />

  <Image class="hover_button"
    preferredHeight="25"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_thin"
    preferredHeight="20"
    preferredWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
  />

  <Image class="hover_button_base"
    raycastTarget="true"
    type="Simple"
  />

  <Image class="hover_button_hover"
    raycastTarget="false"
    color="clear"
  />

  <Image class="hover_button_active"
    raycastTarget="false"
    color="clear"
  />

  <Image class="hover_button_base_overlay"
    onMouseDown="HUD_playerMap_overlayToggle_mouseDown"
    onMouseEnter="HUD_playerMap_overlayToggle_hoverOn"
    onMouseExit="HUD_playerMap_overlayToggle_hoverOff"
  />

  <Image class="hover_button_base_district"
    raycastTarget="true"
    onMouseDown="HUD_playerMap_districtToggle_mouseDown"
    onMouseEnter="HUD_playerMap_districtToggle_hoverOn"
    onMouseExit="HUD_playerMap_districtToggle_hoverOff"
  />

  <Panel class="hud_map_center_container"
    preferredWidth="1900"
    flexibleWidth="0"
    minHeight="2500"
    rectAlignment="MiddleCenter"
    preferredHeight="2500"
    offsetXY="0 -500"
    flexibleHeight="0"
  />

  <Panel class="hud_map_draggable_container"
    allowDragging="true"
    restrictDraggingToParentBounds="true"
    raycastTarget="true"
    onBeginDrag="HUD_playerMap_dragBegin"
    onEndDrag="HUD_playerMap_dragEnd"
    returnToOriginalPositionWhenReleased="false"
  />

  <Image class="hud_map_image"
    height="2000"
    preserveAspect="true"
    rectAlignment="MiddleCenter"
  />

  <Image class="hud_map_image_base"
    raycastTarget="false"
  />

  <!-- Lua uses setTintVisibility (color #FFFFFF vs clear); keep active true so tint applies. -->
  <Image class="hud_map_image_overlay"
    raycastTarget="false"
    active="true"
    color="clear"
    rectAlignment="MiddleCenter"
  />

  <Panel class="hud_map_district_card_container"
    rectAlignment="LowerLeft"
    offsetXY="50 50"
    width="600"
    height="400"
  />

  <Image class="hud_map_district_card"
    width="600"
    preserveAspect="true"
    raycastTarget="false"
    active="true"
    color="clear"
    rectAlignment="UpperLeft"
  />

  <!-- Recenter: fixed in viewport; sibling of draggable map stack. -->
  <Panel class="mapPanel_recenterButton"
    rectAlignment="UpperLeft"
    height="50"
    width="50"
    preferredHeight="50"
    preferredWidth="50"
    flexibleHeight="0"
    flexibleWidth="0"
    offsetXY="40 -40"
    ignoreLayout="true"
  />

  <Panel class="mapPanel_siteCardContainer"
    rectAlignment="UpperLeft"
    flexibleHeight="0"
    flexibleWidth="0"
    preferredWidth="300"
    preferredHeight="200"
  />
</Defaults>
