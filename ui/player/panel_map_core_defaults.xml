<!-- Player HUD CorePanel_Map defaults (map layout + toggle stacks + draggable viewport) -->
<!-- Agent guidance: dev/HUDs & Overlays/Player HUD Overview.md (map panels); dev/TTS_BUNDLING_SETUP.md. -->

<Defaults>
  <!-- Core map root layer (visibility per seat color on the generated panel id). -->
  <Panel class="playerHud_coreLayer"
    rectAlignment="LeftCenter"
    width="100%"
    height="200%"
    offsetXY="0 0"
    active="false"
  />

  <HorizontalLayout class="hud_map_parent_container"
    childForceExpandWidth="false"
    childForceExpandHeight="true"
    width="1550"
    height="50%"
    childAlignment="MiddleLeft"
    rectAlignment="MiddleLeft"
    offsetXY="40 0"
  />

  <Panel class="hud_map_hover_button_panel_wrapper"
    rectAlignment="UpperRight"
    minWidth="150"
   />


  <Panel class="hud_map_center_container"
    preferredWidth="1225"
    flexibleWidth="0"
    minHeight="2100"
    rectAlignment="MiddleCenter"
    preferredHeight="2100"
    offsetXY="0 -500"
    flexibleHeight="0"
    color="rgba(0, 0, 0, 1)"
  />

  <Panel class="hud_map_draggable_container"
    height="1600"
    width="1225"
    allowDragging="false"
    restrictDraggingToParentBounds="true"
    raycastTarget="true"
    returnToOriginalPositionWhenReleased="false"
  />

  <Image class="hud_map_image"
    width="100%"
    preserveAspect="true"
    rectAlignment="MiddleCenter"
    raycastTarget="false"
  />

  <Image class="hud_map_image_base"
    raycastTarget="false"
  />

  <!-- Stacked map overlays: Lua uses setMapStackImageVisibility (inactive when off; on = active + #FFFFFF). Toggle/row chrome uses tint-only. -->
  <Image class="hud_map_image_overlay"
    raycastTarget="false"
    active="true"
    color="clear"
    rectAlignment="MiddleCenter"
  />

  <Image class="hover_button_base_overlay"
    onMouseDown="HUD_playerMap_overlayToggle_mouseDown"
    onMouseEnter="HUD_playerMap_overlayToggle_hoverOn"
    onMouseExit="HUD_playerMap_overlayToggle_hoverOff"
  />

  <Image class="hover_button_base_district"
    raycastTarget="true"
    onMouseDown="HUD_playerMap_districtToggle_mouseDown"
    onMouseEnter="HUD_playerMap_districtToggle_hoverOn"
    onMouseExit="HUD_playerMap_districtToggle_hoverOff"
  />

  <Panel class="hud_map_navigation_panel"
    ignoreLayout="true"
    rectAlignment="UpperLeft"
    offsetXY="150 -20"
    height="200"
    width="100"
  />

  <Image class="hud_map_hover_button_pan"
    preferredHeight="25"
    minHeight="25"
    preserveAspect="true"
    flexibleHeight="0"
    flexibleWidth="0"
    />

<Image class="hud_map_hover_button_recenter"
    preferredHeight="50"
    minHeight="50"
    preserveAspect="true"
    flexibleHeight="0"
    flexibleWidth="0"
    />




  <Panel class="hud_map_district_card_container"
    rectAlignment="LowerLeft"
    offsetXY="-10 10"
    width="800"
    height="400"
    ignoreLayout="true"
  />

  <!-- Stacked cards: Lua uses setMapStackImageVisibility (off = inactive; on = active + #FFFFFF). -->
  <Image class="hud_map_district_card"
    width="800"
    preserveAspect="true"
    raycastTarget="false"
    active="true"
    color="clear"
    rectAlignment="UpperLeft"
  />

  <!-- Recenter: fixed in viewport; sibling of draggable map stack. -->
  <Panel class="mapPanel_recenterButton"
    rectAlignment="UpperLeft"
    height="50"
    width="50"
    preferredHeight="50"
    preferredWidth="50"
    flexibleHeight="0"
    flexibleWidth="0"
    offsetXY="40 -40"
    ignoreLayout="true"
  />

  <Panel class="mapPanel_siteCardContainer"
    rectAlignment="UpperLeft"
    flexibleHeight="0"
    flexibleWidth="0"
    preferredWidth="300"
    preferredHeight="200"
  />
</Defaults>
