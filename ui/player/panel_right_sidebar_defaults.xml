<!-- Agent guidance: .dev/HUDs & Overlays/Player HUD Overview.md; .dev/TTS_BUNDLING_SETUP.md. -->
<Defaults>
  <Panel flexibleWidth="0" flexibleHeight="0" rectAlignment="MiddleCenter" width="100%" height="100%" />
  <VerticalLayout flexibleWidth="0" flexibleHeight="0" spacing="0" childForceExpandWidth="false" childForceExpandHeight="false" />
  <HorizontalLayout flexibleWidth="0" flexibleHeight="0" spacing="0" />

  <!-- Right sidebar column: matches map hover stacks; gold borders are 150×50 (hud_map_toggleBorder from map defaults). -->
  <Panel class="playerHud_rightSidebar"
    rectAlignment="UpperRight"
    height="750"
    width="175"
    offsetXY="0 -100"
    padding="0 0 0 0"
  />

  <Panel class="playerHud_coreLayer"
    rectAlignment="MiddleCenter"
    preferredWidth="1800"
    preferredHeight="100%"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />

  <Panel class="coterie-reference"
    rectAlignment="MiddleCenter"
    preferredWidth="1800"
    preferredHeight="100%"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />
  <VerticalLayout class="coterie-grid"
    rectAlignment="MiddleCenter"
    preferredWidth="1400"
    preferredHeight="640"
    spacing="10"
    childAlignment="UpperCenter"
    flexibleWidth="0"
    flexibleHeight="0"
    childForceExpandWidth="false"
    childForceExpandHeight="false" />
  <HorizontalLayout class="coterie-grid-row"
    preferredHeight="150"
    preferredWidth="1000"
    childAlignment="MiddleCenter"
    flexibleHeight="0"
    flexibleWidth="0" />

  <!-- Sidebar toggle rows: 30px tall; 175px row for sheet/map/princes/coteries active art, 150px for the rest. -->
  <Image class="RSidebar_btn_base_wide"
    preferredHeight="30"
    preferredWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="true"
    type="Simple"
  />
  <Image class="RSidebar_btn_base_narrow"
    preferredHeight="30"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="true"
    type="Simple"
  />
  <Image class="RSidebar_btn_hover_wide"
    preferredHeight="30"
    preferredWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
    color="clear"
  />
  <Image class="RSidebar_btn_hover_narrow"
    preferredHeight="30"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
    color="clear"
  />
  <Image class="RSidebar_btn_active_wide"
    preferredHeight="30"
    preferredWidth="175"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
    color="clear"
  />
  <Image class="RSidebar_btn_active_narrow"
    preferredHeight="30"
    preferredWidth="150"
    flexibleHeight="0"
    flexibleWidth="0"
    preserveAspect="true"
    raycastTarget="false"
    color="clear"
  />
</Defaults>
