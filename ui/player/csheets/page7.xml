<!-- Agent guidance: .dev/HUDs & Overlays/Player HUD Overview.md; lib/json/PCS.json (PC fields). -->
<!-- XML Exact height is 200; 8.5x11 aspect ratio means the width is 154.5

Standard dot images are 6.3x6.3 pixels.
Standard dot-lines are five standard dots wide with 3.4 pixel spacing between them.
Large dot images are 11.3x11.3 pixels.
Large dot-lines are five large dots wide with 6.8 pixel spacing between them.
Standard box images are 8.0x8.0 pixels.
Standard box-lines are ten standard boxes wide with 4.2 pixel spacing between them.

*** PAGE 1 STANDARD DOT LINES *** == ATTRIBUTES ==
9 standard dot-lines in a 3x3 grid.
Grid top-left is at 28.5 -66.8
Row spacing is -7.7 pixels.
Column spacing is 49.7 pixels
Dot images: dot_yellow, dot_white
Dot ids: <dot_image_name>_<attribute_key>_<slot_number>
  E.g. dot_yellow_strength_1, dot_white_dexterity_2, etc.

  == SKILLS ==
27 standard dot-lines in a 3x9 grid.
Grid top-left is at 28.5 -94.0
Row spacing is -7.9 pixels.
Column spacing is 49.7 pixels
Dot images: dot_yellow, dot_white
Dot ids: <dot_image_name>_<skill_key>_<slot_number>
  E.g. dot_yellow_athletics_1, dot_white_animalKen_2, etc.

  == BOX TRACKERS ==
3 standard box-lines in a 2x2 grid, with the bottom-right grid being empty.
Grid top-left is at 108.5 -173.05
Row spacing is -12.1 pixels.
Column spacing is 88.4 pixels.
Box images (first and third grid cells): box_yellow, box_grey, box_red
Box images (second grid cell): box_white, box_black, box_red
Box ids: <box_image_name>_<tracker_key>_<slot_number>
  E.g. box_yellow_health_1, box_grey_willpower_2, etc.

  == BLOOD POTENCY ==
1 large dot-line.
Dot-line top-left is at 103.3 -184.2
Dot images: dot_large_red, dot_large_white
Dot ids: <dot_image_name>_bloodPotency_<slot_number>
  E.g. dot_large_red_bloodPotency_1, dot_large_white_bloodPotency_2, etc.

 -->

<Include src="csheet_defaults.xml" />

<Panel id="paper_root" class="page_root">  <!-- width="1545" height="2000" -->
  <Button id="pageBack" class="page_navigation page_back" />
  <Button id="pageInner" class="page_navigation page_inner_right" />


  <Panel id="rollBroadcast_root" class="rollBroadcast_root">
    <VerticalLayout id="rollBroadcast_container" class="rollBroadcast_container">


    </VerticalLayout>
  </Panel>

  <Panel id="rollControl_root" class="rollControl_root">
    <VerticalLayout id="rollControl_container" class="rollControl_container">
      <HorizontalLayout id="rollControl_headerContainer" class="rollControl_headerContainer">
        <Text id="rollControl_rollType" class="roll_text roll_header_text roll_type_text" text="Standard Roll" /> <!-- @@HEADER_TEXT@@ -->
        <Panel id="rollControl_spacerHeader" class="rollControl_spacer" />
        <Text id="rollControl_rollType" class="roll_text roll_body_text" text="Result Ready — 'CONFIRM' When Done" /> <!-- @@BODY_TEXT@@ -->
      </HorizontalLayout>

      <HorizontalLayout id="rollControl_rollAssembly" class="rollControl_rollAssembly">
        <HorizontalLayout id="rollControl_dicePoolDisplay" class="rollControl_dicePoolDisplay">
          <Text id="rollControl_oblivRouseDice" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_oblivRouseDiceText" text=""/> <!-- @@OBLIV_DICE_STRING@@ -->
          <Text id="rollControl_rouseDice" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_rouseDiceText" text="◆"  /> <!-- @@ROUSE_DICE_STRING@@ -->
          <Text id="rollControl_bloodSurgeRouseDice" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_bloodSurgeRouseDiceText" text=""  /> <!-- @@BLOOD_SURGE_DICE_STRING@@ -->
          <Panel id="rollControl_spacerRouse" class="rollControl_spacer rollControl_rouseSpacer" />
          <HorizontalLayout id="rollControl_standardDicePoolDisplay" class="rollControl_standardDicePoolDisplay" >
            <Text id="rollControl_hungerDice" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_hungerDiceText" text="◆◆◆"/> <!-- @@HUNGER_DICE_STRING@@ -->
            <Text id="rollControl_standardDice" class="roll_text rollControl_diceText rollControl_diceSymbols rollControl_standardDiceText" text="◆◆ ◆◆◆"/> <!-- @@STANDARD_DICE_STRING@@ -->
          </HorizontalLayout>
          <Panel id="rollControl_spacerRightA" class="rollControl_spacer" />
        </HorizontalLayout>
      </HorizontalLayout>

      <HorizontalLayout id="diceImageDisplayStrip" class="rollControl_resultDisplayContainer" />

      <HorizontalLayout class="rollControl_successesContainer">
          <Panel id="rollControl_spacerLeftB" class="rollControl_spacer" />
        <Text id="rollControl_successes" class="roll_text rollControl_successes" text="3" /> <!-- @@SUCCESSES@@ -->
        <Text id="rollControl_successesPhrase" class="roll_text rollControl_successesPhrase" text="Successes" />
        <Text id="rollControl_difficultyVS_bottom" class="roll_text rollControl_difficultyVS" text="vs. Difficulty" />
        <Text id="rollControl_difficulty_bottom" class="roll_text rollControl_difficulty" text="5" /> <!-- @@DIFFICULTY@@ -->
          <Panel id="rollControl_spacerRightB" class="rollControl_spacer" />
      </HorizontalLayout>

      <HorizontalLayout id="rollControl_resultDisplayContainer" class="rollControl_resultDisplayContainer" active="false">
          <Panel id="rollControl_spacerLeftC" class="rollControl_spacer" />
          <Text id="rollControl_resultDisplay" class="roll_text rollControl_resultDisplay" text="CRITICAL WIN" color="#FFFFFF" /> <!-- @@RESULT_DISPLAY@@, @@RESULT_DISPLAY_COLOR@@-->
        <Text id="rollControl_marginDisplay" class="roll_text rollControl_resultDisplay" text="+10" color="#FFFFFF" /> <!-- @@MARGIN_DISPLAY@@, @@RESULT_DISPLAY_COLOR@@-->
          <Panel id="rollControl_spacerRightC" class="rollControl_spacer" />
      </HorizontalLayout>

      <Panel id="rollControl_verticalSpacer" class="rollControl_verticalSpacer" />

      <HorizontalLayout class="rollControl_buttonContainer">



        <Button id="rollControl_btnRoll" class="rollControl_button rollControl_btnRoll" text="ROLL" />
        <Button id="rollControl_btnHalf" class="rollControl_button rollControl_btnHalf" text="TAKE HALF" active="false" />
        <Button id="rollControl_btnWP" class="rollControl_button rollControl_btnWP" text="SPEND WP"  active="false" />
        <Button id="rollControl_btnConfirm" class="rollControl_button rollControl_btnConfirm" text="CONFIRM" active="false" />
        <Button id="rollControl_btnOblivHunger_@@color@@" class="rollControl_button rollControl_btnOblivHunger" text="HUNGER" />
        <Button id="rollControl_btnOblivStain_@@color@@" class="rollControl_button rollControl_btnOblivStain" text="STAIN" />
        <Button id="rollControl_btnBrutalFail_@@color@@" class="rollControl_button rollControl_btnBrutalFail" text="FAILURE" />
        <Button id="rollControl_btnBrutalViolence_@@color@@" class="rollControl_button rollControl_btnBrutalViolence" text="VIOLENCE" />
        <Button id="rollControl_btnCancel" class="rollControl_button rollControl_btnCancel" text="CANCEL" />
      </HorizontalLayout>



    </VerticalLayout>
  </Panel>



  <Panel id="rollST_root" class="rollST_root">
    <VerticalLayout id="rollST_container" class="rollST_container">


    </VerticalLayout>
  </Panel>

</Panel>
