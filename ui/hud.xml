<!-- Main HUD - VTM5E Module -->
<!-- Root bundle file; no layout applied here. Include order matters for TTS defaults. -->
<!-- The TTS Tools extension bundles when using "Save and Play"; loaded via UI.setXml() -->

<!-- 1. Tag-based defaults (include first) -->
<Include src="ui/defaults_tags" />

<!-- 2. General shared classes -->
<Include src="ui/defaults_classes" />

<!-- 3. Storyteller HUD (Host|Black): Heritage admin panel + sidebar + camera -->
<Include src="ui/storyteller/hud_storyteller_defaults" />

<!-- 4. King's Dilemma HUD (reference templates) -->
<Include src="ui/kingsdilemma/hud_kd_defaults" />

<Panel id="HUD_PANEL" padding="10 10 10 10">
  <Include src="ui/storyteller/hud_storyteller" />

  <!-- 5. Player HUD (per-color panels) -->
  <Include src="ui/player/hud_player" />

  <!-- 5b. Player HUD Right Sidebar + Coteries reference grid -->
  <Include src="ui/player/panel_right_sidebar_entry.xml" />

  <!-- 6. Shared UI (dice results, scene transition overlay) -->
  <Include src="ui/shared/hud_shared" />

  <!-- 7. King's Dilemma HUD panels (Brown=turn, Red=splash, Pink=houseGrid, Orange=fetcher) -->
  <Include src="ui/kingsdilemma/hud_kd" />

</Panel>
